{
    "application": {
        "name": "RQA2025 Trading System",
        "version": "1.0.0",
        "environment": "production",
        "debug": false,
        "log_level": "INFO"
    },
    "database": {
        "host": "prod-db.internal.company.com",
        "port": 5432,
        "name": "rqa2025_prod",
        "connection_pool": {
            "min_connections": 10,
            "max_connections": 100,
            "connection_timeout": 30
        },
        "credentials": {
            "username": "${DB_USERNAME}",
            "password": "${DB_PASSWORD}"
        }
    },
    "redis": {
        "host": "prod-redis.internal.company.com",
        "port": 6379,
        "db": 0,
        "connection_pool": {
            "max_connections": 50
        },
        "password": "${REDIS_PASSWORD}"
    },
    "trading": {
        "max_positions": 1000,
        "risk_limits": {
            "max_loss_per_trade": 10000,
            "max_daily_loss": 50000,
            "max_position_size": 1000000
        },
        "execution": {
            "default_timeout": 30,
            "retry_attempts": 3,
            "circuit_breaker_threshold": 5
        }
    },
    "monitoring": {
        "enabled": true,
        "metrics_interval": 60,
        "health_check_interval": 30,
        "alerts": {
            "email_enabled": true,
            "sms_enabled": true,
            "webhook_url": "https://alerts.company.com/webhook"
        }
    },
    "security": {
        "encryption": {
            "algorithm": "AES256",
            "key_rotation_days": 90
        },
        "authentication": {
            "jwt_expiry_hours": 8,
            "refresh_token_expiry_days": 30
        },
        "audit": {
            "enabled": true,
            "log_retention_days": 365
        }
    },
    "features": {
        "high_frequency_trading": true,
        "algorithmic_trading": true,
        "risk_management": true,
        "portfolio_optimization": true,
        "market_data_feed": true,
        "real_time_analytics": true
    }
} 