{
  "database": {
    "host": "${DB_HOST}",
    "port": ${DB_PORT},
    "name": "${DB_NAME}",
    "user": "${DB_USER}",
    "password": "${DB_PASSWORD}",
    "ssl_mode": "${DB_SSL_MODE}",
    "connection_pool": {
      "min_size": ${DB_POOL_MIN_SIZE},
      "max_size": ${DB_POOL_MAX_SIZE},
      "max_idle_time": ${DB_POOL_MAX_IDLE_TIME}
    }
  }
}
