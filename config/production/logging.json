{
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "handlers": {
      "console": {
        "class": "logging.StreamHandler",
        "level": "INFO"
      },
      "file": {
        "class": "logging.FileHandler",
        "filename": "/var/log/rqa2025/application.log",
        "level": "INFO",
        "maxBytes": 10485760,
        "backupCount": 5
      },
      "syslog": {
        "class": "logging.handlers.SysLogHandler",
        "address": "/dev/log",
        "level": "ERROR"
      }
    },
    "loggers": {
      "src": {
        "level": "DEBUG",
        "handlers": [
          "console",
          "file"
        ],
        "propagate": false
      }
    }
  }
}