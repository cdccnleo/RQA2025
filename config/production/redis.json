{
  "redis": {
    "host": "${REDIS_HOST}",
    "port": ${REDIS_PORT},
    "password": "${REDIS_PASSWORD}",
    "db": ${REDIS_DB},
    "ssl": ${REDIS_SSL},
    "cluster": {
      "enabled": ${REDIS_CLUSTER_ENABLED},
      "nodes": [
        {
          "host": "redis-node-1",
          "port": 6379
        },
        {
          "host": "redis-node-2",
          "port": 6379
        },
        {
          "host": "redis-node-3",
          "port": 6379
        }
      ]
    },
    "connection_pool": {
      "max_connections": 50,
      "retry_on_timeout": true
    }
  }
}
