{
  "performance_optimization": {
    "cpu_optimization": {
      "enabled": true,
      "target_usage": 80,
      "profiling": true,
      "parallel_processing": true
    },
    "memory_optimization": {
      "enabled": true,
      "target_usage": 70,
      "gc_tuning": true,
      "caching_strategy": "lru"
    },
    "io_optimization": {
      "enabled": true,
      "async_io": true,
      "buffering": true,
      "compression": true
    },
    "gpu_acceleration": {
      "enabled": false,
      "target_devices": [
        "cuda:0"
      ],
      "memory_limit": "4GB"
    }
  }
}