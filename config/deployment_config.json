{
  "deployment": {
    "environment": "production",
    "version": "1.0.0",
    "backup_enabled": true,
    "monitoring_enabled": true,
    "alerting_enabled": true
  },
  "system": {
    "service_name": "dynamic-universe",
    "working_directory": "/opt/dynamic-universe",
    "log_directory": "/var/log/dynamic-universe",
    "data_directory": "/var/lib/dynamic-universe"
  },
  "components": {
    "dynamic_universe_manager": {
      "enabled": true,
      "config_file": "config/universe_manager_config.json"
    },
    "intelligent_updater": {
      "enabled": true,
      "config_file": "config/intelligent_updater_config.json"
    },
    "dynamic_weight_adjuster": {
      "enabled": true,
      "config_file": "config/weight_adjuster_config.json"
    }
  },
  "monitoring": {
    "performance_monitoring": {
      "enabled": true,
      "interval": 60,
      "metrics": ["cpu", "memory", "response_time", "throughput"]
    },
    "alerting": {
      "enabled": true,
      "email": "admin@example.com",
      "thresholds": {
        "cpu_usage": 80,
        "memory_usage": 85,
        "response_time": 5000,
        "error_rate": 5
      }
    },
    "logging": {
      "level": "INFO",
      "rotation": "daily",
      "retention": 30,
      "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
    }
  },
  "security": {
    "access_control": {
      "enabled": true,
      "admin_users": ["admin"],
      "read_only_users": ["monitor"]
    },
    "data_encryption": {
      "enabled": true,
      "algorithm": "AES-256"
    },
    "network_security": {
      "ssl_enabled": true,
      "firewall_rules": ["allow_local", "deny_external"]
    }
  },
  "backup": {
    "enabled": true,
    "schedule": "daily",
    "retention": 7,
    "location": "/backup/dynamic-universe",
    "components": [
      "config",
      "data",
      "logs"
    ]
  },
  "performance": {
    "max_workers": 4,
    "max_memory": "2GB",
    "timeout": 30,
    "cache_size": "1GB"
  },
  "integration": {
    "data_sources": {
      "market_data": {
        "type": "api",
        "endpoint": "https://api.marketdata.com/v1",
        "api_key": "your_api_key_here",
        "timeout": 10
      },
      "fundamental_data": {
        "type": "database",
        "connection_string": "postgresql://user:pass@localhost:5432/fundamental",
        "timeout": 15
      }
    },
    "external_services": {
      "risk_management": {
        "enabled": true,
        "endpoint": "http://localhost:8081/risk",
        "timeout": 5
      },
      "execution_engine": {
        "enabled": true,
        "endpoint": "http://localhost:8082/execution",
        "timeout": 10
      }
    }
  },
  "maintenance": {
    "auto_update": {
      "enabled": true,
      "schedule": "weekly",
      "backup_before_update": true
    },
    "health_check": {
      "enabled": true,
      "interval": 300,
      "endpoint": "/health"
    },
    "cleanup": {
      "enabled": true,
      "schedule": "daily",
      "retention_days": 30
    }
  }
}