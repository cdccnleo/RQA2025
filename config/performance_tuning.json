{
  "cache": {
    "memory_cache_size": "1GB",
    "redis_cache_size": "2GB",
    "cache_ttl": 3600,
    "max_connections": 100
  },
  "data_loading": {
    "batch_size": 1000,
    "max_workers": 4,
    "timeout": 30,
    "retry_count": 3
  },
  "database": {
    "connection_pool_size": 20,
    "max_connections": 50,
    "connection_timeout": 10
  },
  "optimization": {
    "enable_compression": true,
    "enable_caching": true,
    "enable_parallel_processing": true,
    "memory_limit": "4GB"
  }
}