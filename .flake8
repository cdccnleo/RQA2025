[flake8]
max-line-length = 100
max-complexity = 12
ignore =
    E203,
    E501,
    W503,
    F401,
    E265
extend-ignore =
    E203, W503
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    venv,
    env,
    build,
    dist,
    *.egg-info,
    .tox,
    .coverage,
    htmlcov,
    test_*,
    *_test.py,
    backup_*,
    temp*,
    logging_backup*,
    file_organization_backup*,
    config_backup*,
    interface_inheritance_backup*
per-file-ignores =
    __init__.py:F401