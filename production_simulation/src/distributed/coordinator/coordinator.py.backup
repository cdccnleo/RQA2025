        node_id="node_001",
        hostname="worker - 01",
        ip_address="192.168.1.101",
        cpu_cores=8,
        memory_gb=16.0,
        gpu_devices=[0]
    )

    coordinator.register_node(node1)

    # 提交示例任务
    task_id = coordinator.submit_task("ml_training", {"model": "resnet", "dataset": "imagenet"})
    logger.info(f"已提交任务: {task_id}")

    # 获取集群状态
    status = coordinator.get_cluster_status()
    logger.info(f"集群状态: {json.dumps(status, indent=2, default=str)}")
