# RQA2025 生产环境变量模板
# Production Environment Variables Template for RQA2025

# ===============================================
# 数据库配置
# ===============================================
# PostgreSQL数据库连接
DATABASE_URL=postgresql://rqa2025_admin:SecurePass123!@postgres:5432/rqa2025_prod
DB_USER=rqa2025_admin
DB_PASSWORD=SecurePass123!

# ===============================================
# Redis配置
# ===============================================
REDIS_PASSWORD=RedisSecure123!

# ===============================================
# 安全配置
# ===============================================
# JWT密钥（请使用强密码）
JWT_SECRET=your-super-secure-jwt-secret-key-here-change-this-in-production

# 备份加密密钥
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key-here-32-chars-min

# API加密密钥
ENCRYPTION_KEY=your-api-encryption-key-here-32-chars-min

# ===============================================
# 外部服务API密钥
# ===============================================
# AKShare数据源
AKSHARE_API_KEY=your-akshare-api-key-here

# Yahoo Finance
YAHOO_API_KEY=your-yahoo-api-key-here

# TuShare
TUSHARE_TOKEN=your-tushare-token-here

# ===============================================
# 监控和日志服务
# ===============================================
# Sentry错误监控
SENTRY_DSN=https://your-sentry-dsn-here

# Grafana API密钥
GRAFANA_API_KEY=your-grafana-api-key-here

# ===============================================
# 通知服务配置
# ===============================================
# 邮件通知
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-app-password

# Webhook通知
WEBHOOK_URL=https://your-webhook-url.com/api/notifications
WEBHOOK_TOKEN=your-webhook-bearer-token

# ===============================================
# 系统配置
# ===============================================
# 应用环境
ENVIRONMENT=production

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 调试模式（生产环境设为false）
DEBUG=false

# ===============================================
# 注意事项
# ===============================================
# 1. 请将此文件复制为 .env.production 并填入实际值
# 2. 生产环境使用强密码，不要使用默认值
# 3. API密钥请妥善保管，不要提交到版本控制系统
# 4. 定期轮换密钥和密码
# 5. 使用环境变量或密钥管理服务管理敏感信息