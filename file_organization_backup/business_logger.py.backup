import logging\n\n#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n引擎层业务日志记录器\n提供专门的业务事件日志记录和追踪功能\n"""\n\nimport time\nimport threading\nfrom typing import Dict, Any, Optional, List\nfrom dataclasses import dataclass, field\nfrom enum import Enum\n\nfrom .core_logger import EngineLogger, LogLevel, LogCategory\n\nclass BusinessEventType(Enum):\n\n    """业务事件类型"""\n    ORDER = "order"\n    TRADE = "trade"\n    RISK = "risk"\n    ACCOUNT = "account"\n    SYSTEM = "system"\n    USER = "user"\n\n@dataclass\n\nclass BusinessEvent:\n\n    """业务事件"""\n    event_type: BusinessEventType\n    event_id: str\n    user_id: str\n    session_id: str\n    timestamp: float\n    data: Dict[str, Any]\n    status: str\n    metadata: Dict[str, Any] = field(default_factory=dict)\n\nclass BusinessLogger:\n\n    """业务日志记录器"""\n\n    def __init__(self, logger: EngineLogger, config: Dict[str, Any] = None):\n\n        """初始化业务日志记录器\n\n        Args:\n            logger: 引擎日志记录器\n            config: 配置字典\n        """\n        self.logger = logger\n        self.config = config or {}\n\n        # 业务事件缓存\n        self._business_events = {}\n        self._events_lock = threading.RLock()\n\n        # 业务统计\n        self._business_stats = {\n            'total_events': 0,\n            'events_by_type': {},\n            'events_by_status': {},\n            'events_by_user': {}\n        }\n\n        # 关键业务类型\n        self._critical_business_types = self.config.get('critical_business_types', [\n            'order', 'trade', 'risk', 'account'\n        ])\n\n    def log_business_event(self, event_type: BusinessEventType, event_id: str,\n    """文档字符串"""\n\n                           user_id: str, session_id: str, data: Dict[str, Any],\n                           status: str = "success", **kwargs):\n        """记录业务事件"""\n        try:\n            # 创建业务事件\n            business_event = BusinessEvent(\n                event_type=event_type,\n                event_id=event_id,\n                user_id=user_id,\n                session_id=session_id,\n                timestamp=time.time(),\n                data=data,\n                status=status,\n                metadata=kwargs\n            )\n\n            # 记录业务日志\n            self.logger.business_log(\n                f"业务事件: {event_type.value} - {event_id} - {status}",\n                business_type=event_type.value,\n                event_id=event_id,\n                user_id=user_id,\n                session_id=session_id,\n                status=status,\n                data=data,\n                **kwargs\n            )\n\n            # 更新统计信息\n            self._update_business_stats(business_event)\n\n            # 缓存事件\n            self._cache_business_event(business_event)\n\n            # 检查关键业务事件\n            if event_type.value in self._critical_business_types:\n                self._handle_critical_business_event(business_event)\n\n        except Exception as e:\n            self.logger.error(f"记录业务事件失败: {e}", exception=e)\n\n    def log_order_event(self, order_id: str, user_id: str, session_id: str,\n    """文档字符串"""\n\n                        order_data: Dict[str, Any], status: str = "success", **kwargs):\n        """记录订单事件"""\n        self.log_business_event(\n            event_type=BusinessEventType.ORDER,\n            event_id=order_id,\n            user_id=user_id,\n            session_id=session_id,\n            data=order_data,\n            status=status,\n            **kwargs\n        )\n\n    def log_trade_event(self, trade_id: str, user_id: str, session_id: str,\n    """文档字符串"""\n\n                        trade_data: Dict[str, Any], status: str = "success", **kwargs):\n        """记录交易事件"""\n        self.log_business_event(\n            event_type=BusinessEventType.TRADE,\n            event_id=trade_id,\n            user_id=user_id,\n            session_id=session_id,\n            data=trade_data,\n            status=status,\n            **kwargs\n        )\n\n    def log_risk_event(self, risk_id: str, user_id: str, session_id: str,\n    """文档字符串"""\n\n                       risk_data: Dict[str, Any], status: str = "success", **kwargs):\n        """记录风控事件"""\n        self.log_business_event(\n            event_type=BusinessEventType.RISK,\n            event_id=risk_id,\n            user_id=user_id,\n            session_id=session_id,\n            data=risk_data,\n            status=status,\n            **kwargs\n        )\n\n    def log_account_event(self, account_id: str, user_id: str, session_id: str,\n    """文档字符串"""\n\n                          account_data: Dict[str, Any], status: str = "success", **kwargs):\n        """记录账户事件"""\n        self.log_business_event(\n            event_type=BusinessEventType.ACCOUNT,\n            event_id=account_id,\n            user_id=user_id,\n            session_id=session_id,\n            data=account_data,\n            status=status,\n            **kwargs\n        )\n\n    def log_system_event(self, event_id: str, system_data: Dict[str, Any],\n    """文档字符串"""\n\n                         status: str = "success", **kwargs):\n        """记录系统事件"""\n        self.log_business_event(\n            event_type=BusinessEventType.SYSTEM,\n            event_id=event_id,\n            user_id="system",\n            session_id="system",\n            data=system_data,\n            status=status,\n            **kwargs\n        )\n\n    def log_user_event(self, event_id: str, user_id: str, session_id: str,\n    """文档字符串"""\n\n                       user_data: Dict[str, Any], status: str = "success", **kwargs):\n        """记录用户事件"""\n        self.log_business_event(\n            event_type=BusinessEventType.USER,\n            event_id=event_id,\n            user_id=user_id,\n            session_id=session_id,\n            data=user_data,\n            status=status,\n            **kwargs\n        )\n\n    def _update_business_stats(self, business_event: BusinessEvent):\n    """文档字符串"""\n\n        """更新业务统计信息"""\n        with self._events_lock:\n            self._business_stats['total_events'] += 1\n\n            # 按类型统计\n            event_type = business_event.event_type.value\n            if event_type not in self._business_stats['events_by_type']:\n                self._business_stats['events_by_type'][event_type] = 0\n            self._business_stats['events_by_type'][event_type] += 1\n\n            # 按状态统计\n            status = business_event.status\n            if status not in self._business_stats['events_by_status']:\n                self._business_stats['events_by_status'][status] = 0\n            self._business_stats['events_by_status'][status] += 1\n\n            # 按用户统计\n            user_id = business_event.user_id\n            if user_id not in self._business_stats['events_by_user']:\n                self._business_stats['events_by_user'][user_id] = 0\n            self._business_stats['events_by_user'][user_id] += 1\n\n    def _cache_business_event(self, business_event: BusinessEvent):\n    """文档字符串"""\n\n        """缓存业务事件"""\n        with self._events_lock:\n            event_key = f"{business_event.event_type.value}_{business_event.event_id}"\n            self._business_events[event_key] = business_event\n\n            # 限制缓存大小\n            max_cache_size = self.config.get('max_business_events', 10000)\n        if len(self._business_events) > max_cache_size:\n            # 删除最旧的事件\n            oldest_key = min(self._business_events.keys(),\n                             key=lambda k: self._business_events[k].timestamp)\n            del self._business_events[oldest_key]\n\n    def _handle_critical_business_event(self, business_event: BusinessEvent):\n    """文档字符串"""\n\n        """处理关键业务事件"""\n        # 记录关键业务事件的详细信息\n        self.logger.info(\n            f"关键业务事件: {business_event.event_type.value} - {business_event.event_id}",\n            component="business_logger",\n            operation="critical_event_handling",\n            event_type=business_event.event_type.value,\n            event_id=business_event.event_id,\n            user_id=business_event.user_id,\n            status=business_event.status,\n            critical_event=True\n        )\n\n        # 检查失败状态\n        if business_event.status != "success":\n            self.logger.warning(\n                f"关键业务事件失败: {business_event.event_type.value} - {business_event.event_id}",\n                component="business_logger",\n                operation="critical_event_failure",\n                event_type=business_event.event_type.value,\n                event_id=business_event.event_id,\n                user_id=business_event.user_id,\n                status=business_event.status,\n                critical_failure=True\n            )\n\n    def get_business_event(self, event_type: BusinessEventType, event_id: str) -> Optional[BusinessEvent]:\n    """文档字符串"""\n\n        """获取业务事件"""\n        with self._events_lock:\n            event_key = f"{event_type.value}_{event_id}"\n            return self._business_events.get(event_key)\n\n    def get_business_events(self, event_type: BusinessEventType = None,\n    """文档字符串"""\n\n                            user_id: str = None, status: str = None,\n                            time_range: float = None) -> List[BusinessEvent]:\n        """获取业务事件列表"""\n        with self._events_lock:\n            events = list(self._business_events.values())\n\n            # 按类型过滤\n            if event_type:\n                events = [e for e in events if e.event_type == event_type]\n\n            # 按用户过滤\n            if user_id:\n                events = [e for e in events if e.user_id == user_id]\n\n            # 按状态过滤\n            if status:\n                events = [e for e in events if e.status == status]\n\n            # 按时间范围过滤\n            if time_range:\n                current_time = time.time()\n                events = [e for e in events if current_time - e.timestamp <= time_range]\n\n            return events\n\n    def get_business_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取业务统计信息"""\n        with self._events_lock:\n            return self._business_stats.copy()\n\n    def get_user_activity(self, user_id: str, time_range: float = None) -> List[BusinessEvent]:\n    """文档字符串"""\n\n        """获取用户活动"""\n        return self.get_business_events(user_id=user_id, time_range=time_range)\n\n    def get_event_summary(self, event_type: BusinessEventType = None,\n    """文档字符串"""\n\n                          time_range: float = None) -> Dict[str, Any]:\n        """获取事件摘要"""\n        events = self.get_business_events(event_type=event_type, time_range=time_range)\n\n        summary = {\n            'total_events': len(events),\n            'events_by_type': {},\n            'events_by_status': {},\n            'events_by_user': {},\n            'recent_events': []\n        }\n\n        for event in events:\n            # 按类型统计\n            event_type_str = event.event_type.value\n            if event_type_str not in summary['events_by_type']:\n                summary['events_by_type'][event_type_str] = 0\n            summary['events_by_type'][event_type_str] += 1\n\n            # 按状态统计\n            if event.status not in summary['events_by_status']:\n                summary['events_by_status'][event.status] = 0\n            summary['events_by_status'][event.status] += 1\n\n            # 按用户统计\n            if event.user_id not in summary['events_by_user']:\n                summary['events_by_user'][event.user_id] = 0\n            summary['events_by_user'][event.user_id] += 1\n\n        # 最近事件\n        recent_events = sorted(events, key=lambda e: e.timestamp, reverse=True)[:10]\n        summary['recent_events'] = [\n            {\n                'event_type': e.event_type.value,\n                'event_id': e.event_id,\n                'user_id': e.user_id,\n                'status': e.status,\n                'timestamp': e.timestamp\n            }\n            for e in recent_events\n        ]\n\n        return summary\n\n    def clear_business_events(self, time_range: float = None):\n    """文档字符串"""\n\n        """清理业务事件"""\n        with self._events_lock:\n            if time_range:\n                current_time = time.time()\n                keys_to_remove = [\n                    key for key, event in self._business_events.items()\n                    if current_time - event.timestamp > time_range\n                ]\n                for key in keys_to_remove:\n                    del self._business_events[key]\n            else:\n                self._business_events.clear()\n\n    def health_check(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """健康检查"""\n        try:\n            return {\n                'status': 'healthy',\n                'total_events': self._business_stats['total_events'],\n                'cached_events': len(self._business_events),\n                'critical_business_types': self._critical_business_types,\n                'business_stats': self.get_business_stats()\n            }\n        except Exception as e:\n            return {\n                'status': 'error',\n                'error': str(e)\n            }\n