"""\n同步冲突管理器\n负责检测和解决配置同步中的冲突\n"""\n\nfrom typing import Dict, List, Optional, Any\nimport hashlib\nimport time\n\nfrom dataclasses import dataclass\n\n@dataclass\n\nclass Conflict:\n\n    """冲突信息"""\n    key: str\n    local_value: Any\n    remote_value: Any\n    timestamp: float\n    resolved: bool = False\n    resolution: str = ""\n\nclass SyncConflictManager:\n\n    """同步冲突管理器"""\n\n    def __init__(self):\n\n        self.conflicts: Dict[str, Conflict] = {}\n\n    def detect_conflicts(self, local_config: Dict[str, Any], remote_config: Dict[str, Any]) -> List[Dict[str, Any]]:\n    """文档字符串"""\n\n        """检测配置冲突"""\n        conflicts = []\n\n        # 比较所有键\n        all_keys = set(local_config.keys()) | set(remote_config.keys())\n\n        for key in all_keys:\n            local_value = local_config.get(key)\n            remote_value = remote_config.get(key)\n\n            # 如果值不同，则认为是冲突\n            if local_value != remote_value:\n                conflict = Conflict(\n                    key=key,\n                    local_value=local_value,\n                    remote_value=remote_value,\n                    timestamp=time.time()\n                )\n                self.conflicts[key] = conflict\n\n                conflicts.append({\n                    "key": key,\n                    "local_value": local_value,\n                    "remote_value": remote_value,\n                    "conflict_type": "value_mismatch",\n                    "timestamp": conflict.timestamp\n                })\n\n        return conflicts\n\n    def resolve_conflicts(self, conflicts: List[Dict[str, Any]], strategy: str = "merge") -> Dict[str, Any]:\n    """文档字符串"""\n\n        """解决冲突"""\n        resolved_config = {}\n\n        for conflict_data in conflicts:\n            key = conflict_data["key"]\n            local_value = conflict_data["local_value"]\n            remote_value = conflict_data["remote_value"]\n\n            if strategy == "merge":\n                # 合并策略：优先使用本地值\n                resolved_value = local_value if local_value is not None else remote_value\n            elif strategy == "overwrite":\n                # 覆盖策略：使用远程值\n                resolved_value = remote_value\n            else:\n                # 默认使用本地值\n                resolved_value = local_value\n\n            resolved_config[key] = resolved_value\n\n            # 标记冲突为已解决\n            if key in self.conflicts:\n                self.conflicts[key].resolved = True\n                self.conflicts[key].resolution = strategy\n\n        return resolved_config\n\n    def get_conflicts(self) -> List[Dict[str, Any]]:\n    """文档字符串"""\n\n        """获取所有冲突"""\n        return [\n            {\n                "key": conflict.key,\n                "local_value": conflict.local_value,\n                "remote_value": conflict.remote_value,\n                "timestamp": conflict.timestamp,\n                "resolved": conflict.resolved,\n                "resolution": conflict.resolution\n            }\n            for conflict in self.conflicts.values()\n        ]\n\n    def clear_conflicts(self) -> int:\n    """文档字符串"""\n\n        """清空所有冲突"""\n        count = len(self.conflicts)\n        self.conflicts.clear()\n        return count\n\n    def get_conflict_count(self) -> int:\n    """文档字符串"""\n\n        """获取冲突数量"""\n        return len(self.conflicts)\n\n    def get_conflict_summary(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取冲突统计"""\n        resolved_count = len([c for c in self.conflicts.values() if c.resolved])\n        unresolved_count = len(self.conflicts) - resolved_count\n\n        return {\n            "total_conflicts": len(self.conflicts),\n            "resolved_conflicts": resolved_count,\n            "unresolved_conflicts": unresolved_count,\n            "conflict_keys": list(self.conflicts.keys())\n        }\n\n    def calculate_config_checksum(self, config: Dict[str, Any]) -> str:\n    """文档字符串"""\n\n        """计算配置校验和"""\n        # 序列化配置并计算MD5\n        config_str = str(sorted(config.items()))\n        return hashlib.md5(config_str.encode()).hexdigest()\n