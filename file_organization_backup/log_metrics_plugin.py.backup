import json\nimport logging\n\n"""\n基础设施层 - 日志系统组件\n\nlog_metrics_plugin 模块\n\n日志系统相关的文件\n提供日志系统相关的功能实现。\n"""\n\nimport time\nfrom typing import Dict, Any, Optional\nfrom collections import defaultdict\nfrom threading import Lock\nfrom prometheus_client import Counter, Gauge, Histogram\nfrom dataclasses import dataclass\nimport requests\n\n@dataclass\n\nclass LogMetricsConfig:\n\n    """日志监控配置"""\n    push_interval: int = 60  # 推送间隔(秒)\n    push_url: Optional[str] = None  # 监控数据推送URL\n    enable_prometheus: bool = True  # 是否启用Prometheus指标\n\nclass LogMetricsPlugin:\n\n    """日志监控指标收集器"""\n\n    _instance = None\n    _lock = Lock()\n\n    def __new__(cls, *args, **kwargs):\n\n        """单例模式"""\n        if cls._instance is None:\n            with cls._lock:\n                if cls._instance is None:\n                    cls._instance = super().__new__(cls)\n                    cls._instance._initialized = False\n        return cls._instance\n\n    def __init__(self, config: LogMetricsConfig = None):\n\n        """初始化指标收集器"""\n        if self._initialized:\n            return\n\n        self.config = config or LogMetricsConfig()\n        self._metrics = defaultdict(int)\n        self._lock = Lock()\n        self._last_push_time = 0\n\n        # Prometheus指标 - 使用类级别的注册表管理\n        if self.config.enable_prometheus:\n            try:\n                self._init_prometheus_metrics()\n            except Exception as e:\n                logging.warning(f"Failed to initialize Prometheus metrics: {e}")\n                # 禁用Prometheus以避免后续错误\n                self.config.enable_prometheus = False\n\n        self._initialized = True\n\n    def _init_prometheus_metrics(self):\n    """文档字符串"""\n\n        """初始化Prometheus指标"""\n        # 避免重复注册：检查是否已经注册过\n        if hasattr(self, '_prometheus_initialized') and self._prometheus_initialized:\n            return\n\n        try:\n            self.log_total = Counter(\n                'log_messages_total',\n                'Total log messages',\n                ['level', 'logger']\n            )\n\n            self.log_sampled = Counter(\n                'log_messages_sampled',\n                'Sampled log messages',\n                ['level', 'logger']\n            )\n\n            self.log_latency = Histogram(\n                'log_processing_latency_seconds',\n                'Log processing latency',\n                ['level']\n            )\n\n            self.log_buffer_size = Gauge(\n                'log_buffer_size',\n                'Current log buffer size'\n            )\n\n            self._prometheus_initialized = True\n\n        except ValueError as e:\n            # 如果指标已经注册，尝试获取已存在的指标\n            logging.warning(f"Prometheus metrics already registered: {e}")\n            try:\n                from prometheus_client import REGISTRY\n                # 尝试获取已存在的指标\n                if 'log_messages_total' in [m.name for m in REGISTRY._names_to_collectors]:\n                    self.log_total = Counter(\n                        'log_messages_total',\n                        'Total log messages',\n                        ['level', 'logger'],\n                        registry=REGISTRY\n                    )\n                if 'log_messages_sampled' in [m.name for m in REGISTRY._names_to_collectors]:\n                    self.log_sampled = Counter(\n                        'log_messages_sampled',\n                        'Sampled log messages',\n                        ['level', 'logger'],\n                        registry=REGISTRY\n                    )\n                if 'log_processing_latency_seconds' in [m.name for m in REGISTRY._names_to_collectors]:\n                    self.log_latency = Histogram(\n                        'log_processing_latency_seconds',\n                        'Log processing latency',\n                        ['level'],\n                        registry=REGISTRY\n                    )\n                if 'log_buffer_size' in [m.name for m in REGISTRY._names_to_collectors]:\n                    self.log_buffer_size = Gauge(\n                        'log_buffer_size',\n                        'Current log buffer size',\n                        registry=REGISTRY\n                    )\n            except Exception as inner_e:\n                logging.error(f"Failed to get existing Prometheus metrics: {inner_e}")\n                # 创建Mock指标以避免AttributeError\n                self._create_mock_metrics()\n\n            self._prometheus_initialized = True\n\n    def _create_mock_metrics(self):\n        """创建Mock指标对象以避免AttributeError"""\n        class MockMetric:\n            def labels(self, **kwargs):\n    """文档字符串"""\n                return self\n            def inc(self, value=1):\n    """文档字符串"""\n                pass\n            def observe(self, value):\n    """文档字符串"""\n                pass\n            def set(self, value):\n    """文档字符串"""\n                pass\n\n        self.log_total = MockMetric()\n        self.log_sampled = MockMetric()\n        self.log_latency = MockMetric()\n        self.log_buffer_size = MockMetric()\n\n    def record(self, level: str, logger: str, sampled: bool = False, latency: float = None):\n    """文档字符串"""\n\n        """记录日志指标"""\n        with self._lock:\n            self._metrics['total'] += 1\n            self._metrics[f'level_{level}'] += 1\n            self._metrics[f'logger_{logger}'] += 1\n\n            if sampled:\n                self._metrics['sampled'] += 1\n                self._metrics[f'sampled_level_{level}'] += 1\n\n            if latency is not None:\n                self._metrics['total_latency'] += latency\n                self._metrics['count_latency'] += 1\n\n            # Prometheus指标 - 确保属性存在\n            if self.config.enable_prometheus and hasattr(self, 'log_total') and self.log_total is not None:\n                try:\n                    self.log_total.labels(level=level, logger=logger).inc()\n                    if sampled and hasattr(self, 'log_sampled') and self.log_sampled is not None:\n                        self.log_sampled.labels(level=level, logger=logger).inc()\n                    if latency is not None and hasattr(self, 'log_latency') and self.log_latency is not None:\n                        self.log_latency.labels(level=level).observe(latency)\n                except Exception as e:\n                    logging.warning(f"Failed to update Prometheus metrics: {e}")\n\n    def record_log(self, level: str, logger: str, message: str = None, sampled: bool = False):\n    """文档字符串"""\n\n        """记录日志（兼容测试期望的接口）"""\n        self.record(level, logger, sampled)\n\n    def get_metrics(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取当前指标快照"""\n        with self._lock:\n            metrics = dict(self._metrics)\n\n            # 计算平均延迟\n            if metrics.get('count_latency', 0) > 0:\n                metrics['avg_latency'] = metrics['total_latency'] / metrics['count_latency']\n\n            return metrics\n\n    def push_metrics(self):\n    """文档字符串"""\n\n        """推送指标到监控系统"""\n        if not self.config.push_url:\n            return\n\n        current_time = time.time()\n        if current_time - self._last_push_time < self.config.push_interval:\n            return\n\n        try:\n            metrics = self.get_metrics()\n            response = requests.post(\n                self.config.push_url,\n                json=metrics,\n                timeout=5\n            )\n\n            response.raise_for_status()\n            self._last_push_time = current_time\n        except Exception as e:\n            pass  # 静默失败，避免影响主流程\n\n    def reset(self):\n    """文档字符串"""\n\n        """重置指标计数器"""\n        with self._lock:\n            self._metrics.clear()\n            # 重新初始化基本计数器\n            self._metrics.update({\n                'total': 0,\n                'sampled': 0,\n                'total_latency': 0.0,\n                'count_latency': 0\n            })\n\nclass LogMetricsSingleton:\n\n    _instance = None\n\n    def __new__(cls):\n\n        if cls._instance is None:\n            cls._instance = LogMetricsPlugin()\n        return cls._instance\n\n# 获取单例实例\n\ndef get_metrics_instance():\n    """文档字符串"""\n\n    """获取LogMetrics单例实例"""\n    return LogMetricsSingleton()\n\ndef record(level: str, logger: str, sampled: bool = False, latency: float = None):\n    """文档字符串"""\n\n    """快捷记录日志指标"\n\n    Args:\n        level: 日志级别(DEBUG / INFO / WARNING / ERROR)\n        logger: 记录器名称\n        sampled: 是否采样日志\n        latency: 处理延迟(秒)\n    """\n    get_metrics_instance().record(level, logger, sampled, latency)\n\ndef push_metrics():\n    """文档字符串"""\n\n    """快捷推送日志指标到监控系统"""\n    get_metrics_instance().push_metrics()\n