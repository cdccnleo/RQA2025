#!/usr/bin/env python3\n"""\n缓存预热和优化系统\n提供生产级别的缓存预热、故障转移和运维优化功能\n"""\n\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\nfrom datetime import datetime, timedelta\nfrom enum import Enum\nfrom typing import Dict, List, Any, Optional, Callable, Set\nimport json\nimport logging\nimport os\nimport threading\nimport time\n\nfrom dataclasses import dataclass, field\nimport psutil\n\nfrom .base_cache_manager import BaseCacheManager\nfrom .distributed_cache_manager import DistributedCacheManager\nfrom .smart_performance_monitor import SmartCacheMonitor\n\nlogger = logging.getLogger(__name__)\n\nclass WarmupStrategy(Enum):\n    """预热策略"""\n    FULL_LOAD = "full_load"          # 全量加载\n    HOT_KEYS = "hot_keys"            # 热点键加载\n    PREDICTIVE = "predictive"        # 预测性预热\n    HYBRID = "hybrid"               # 混合策略\n\nclass FailoverMode(Enum):\n    """故障转移模式"""\n    AUTOMATIC = "automatic"          # 自动切换\n    MANUAL = "manual"               # 手动切换\n    GRACEFUL_DEGRADATION = "graceful"  # 优雅降级\n\n@dataclass\nclass WarmupConfig:\n    """预热配置"""\n    strategy: WarmupStrategy = WarmupStrategy.HYBRID\n    max_concurrent_loads: int = 10\n    warmup_timeout: int = 300  # 5分钟超时\n    batch_size: int = 100\n    enable_progress_tracking: bool = True\n    retry_failed_keys: bool = True\n    max_retry_attempts: int = 3\n\n@dataclass\nclass FailoverConfig:\n    """故障转移配置"""\n    mode: FailoverMode = FailoverMode.AUTOMATIC\n    health_check_interval: int = 30\n    failover_timeout: int = 60\n    min_healthy_nodes: int = 1\n    enable_auto_recovery: bool = True\n    recovery_timeout: int = 300\n\n@dataclass\nclass ProductionConfig:\n    """生产配置"""\n    warmup_config: WarmupConfig = field(default_factory=WarmupConfig)\n    failover_config: FailoverConfig = field(default_factory=FailoverConfig)\n    enable_health_checks: bool = True\n    enable_performance_monitoring: bool = True\n    log_level: str = "INFO"\n    metrics_collection_interval: int = 60\n\n@dataclass\nclass WarmupTask:\n    """预热任务"""\n    task_id: str\n    keys: List[str]\n    priority: int = 1\n    status: str = "pending"\n    progress: float = 0.0\n    start_time: Optional[datetime] = None\n    end_time: Optional[datetime] = None\n    error_count: int = 0\n    loaded_count: int = 0\n\nclass CacheWarmupEngine:\n    """缓存预热引擎"""\n\n    def __init__(self, cache_manager: BaseCacheManager, config: WarmupConfig):\n        self.cache_manager = cache_manager\n        self.config = config\n        self.warmup_tasks: Dict[str, WarmupTask] = {}\n        self.hot_keys_detector = HotKeysDetector()\n        self.predictive_loader = PredictiveLoader()\n        self.is_warming_up = False\n        self.warmup_thread: Optional[threading.Thread] = None\n\n    def start_warmup(self, keys: Optional[List[str]] = None) -> str:\n        """启动预热"""\n        if self.is_warming_up:\n            logger.warning("预热已在进行中")\n            return ""\n\n        task_id = f"warmup_{int(time.time())}"\n        warmup_keys = self._select_keys_for_warmup(keys)\n\n        task = WarmupTask(\n            task_id=task_id,\n            keys=warmup_keys,\n            start_time=datetime.now()\n        )\n\n        self.warmup_tasks[task_id] = task\n        self.is_warming_up = True\n\n        self.warmup_thread = threading.Thread(\n            target=self._execute_warmup,\n            args=(task,),\n            daemon=True\n        )\n        self.warmup_thread.start()\n\n        logger.info(f"启动缓存预热任务: {task_id}, 键数量: {len(warmup_keys)}")\n        return task_id\n\n    def _select_keys_for_warmup(self, keys: Optional[List[str]]) -> List[str]:\n        """选择要预热的键"""\n        if keys:\n            return keys\n\n        if self.config.strategy == WarmupStrategy.FULL_LOAD:\n            return self._get_all_keys()\n        elif self.config.strategy == WarmupStrategy.HOT_KEYS:\n            return self.hot_keys_detector.get_hot_keys()\n        elif self.config.strategy == WarmupStrategy.PREDICTIVE:\n            return self.predictive_loader.predict_keys_to_warmup()\n        else:  # HYBRID\n            hot_keys = self.hot_keys_detector.get_hot_keys()\n            predicted_keys = self.predictive_loader.predict_keys_to_warmup()\n            return list(set(hot_keys + predicted_keys))\n\n    def _get_all_keys(self) -> List[str]:\n        """获取所有键（模拟）"""\n        # 在实际实现中，这里应该从数据源获取所有键\n        return [f"key_{i}" for i in range(1000)]  # 模拟1000个键\n\n    def _execute_warmup(self, task: WarmupTask):\n        """执行预热"""\n        try:\n            logger.info(f"开始执行预热任务: {task.task_id}")\n\n            # 分批处理\n            batches = self._create_batches(task.keys)\n\n            with ThreadPoolExecutor(max_workers=self.config.max_concurrent_loads) as executor:\n                futures = []\n\n                for batch in batches:\n                    future = executor.submit(self._load_batch, batch, task)\n                    futures.append(future)\n\n                # 等待所有批次完成\n                for future in as_completed(futures):\n                    try:\n                        batch_result = future.result(timeout=self.config.warmup_timeout)\n                        task.loaded_count += batch_result['loaded']\n                        task.error_count += batch_result['errors']\n                    except Exception as e:\n                        logger.error(f"批次加载失败: {e}")\n                        task.error_count += 1\n\n            # 更新任务状态\n            task.status = "completed"\n            task.end_time = datetime.now()\n            task.progress = 100.0\n\n            logger.info(f"预热任务完成: {task.task_id}, "\n                       f"加载: {task.loaded_count}, 错误: {task.error_count}")\n\n        except Exception as e:\n            logger.error(f"预热任务失败: {task.task_id}: {e}")\n            task.status = "failed"\n            task.end_time = datetime.now()\n        finally:\n            self.is_warming_up = False\n\n    def _create_batches(self, keys: List[str]) -> List[List[str]]:\n        """创建批次"""\n        return [keys[i:i + self.config.batch_size]\n                for i in range(0, len(keys), self.config.batch_size)]\n\n    def _load_batch(self, batch: List[str], task: WarmupTask) -> Dict[str, int]:\n        """加载批次数据"""\n        loaded = 0\n        errors = 0\n\n        for key in batch:\n            try:\n                # 模拟从数据源加载数据\n                value = self._load_key_data(key)\n                if value is not None:\n                    success = self.cache_manager.set(key, value)\n                    if success:\n                        loaded += 1\n                    else:\n                        errors += 1\n                else:\n                    errors += 1\n\n                # 更新进度\n                task.progress = (loaded + errors) / len(task.keys) * 100\n\n            except Exception as e:\n                logger.error(f"加载键失败: {key}: {e}")\n                errors += 1\n\n        return {'loaded': loaded, 'errors': errors}\n\n    def _load_key_data(self, key: str) -> Any:\n        """加载键数据（模拟）"""\n        # 在实际实现中，这里应该从数据库或外部数据源获取数据\n        return f"value_for_{key}"\n\n    def get_warmup_status(self, task_id: str) -> Optional[Dict[str, Any]]:\n        """获取预热状态"""\n        if task_id not in self.warmup_tasks:\n            return None\n\n        task = self.warmup_tasks[task_id]\n        return {\n            'task_id': task.task_id,\n            'status': task.status,\n            'progress': task.progress,\n            'total_keys': len(task.keys),\n            'loaded_count': task.loaded_count,\n            'error_count': task.error_count,\n            'start_time': task.start_time.isoformat() if task.start_time else None,\n            'end_time': task.end_time.isoformat() if task.end_time else None,\n            'duration': (task.end_time - task.start_time).total_seconds() if task.end_time and task.start_time else 0\n        }\n\nclass HotKeysDetector:\n    """热点键检测器"""\n\n    def __init__(self):\n        self.access_counts: Dict[str, int] = {}\n        self.last_reset = time.time()\n\n    def record_access(self, key: str):\n        """记录访问"""\n        self.access_counts[key] = self.access_counts.get(key, 0) + 1\n\n    def get_hot_keys(self, top_n: int = 100) -> List[str]:\n        """获取热点键"""\n        # 按访问次数排序\n        sorted_keys = sorted(self.access_counts.items(),\n                           key=lambda x: x[1], reverse=True)\n        return [key for key, _ in sorted_keys[:top_n]]\n\n    def reset_stats(self):\n        """重置统计"""\n        self.access_counts.clear()\n        self.last_reset = time.time()\n\nclass PredictiveLoader:\n    """预测性加载器"""\n\n    def __init__(self):\n        self.access_patterns: Dict[str, List[datetime]] = {}\n        self.prediction_model = {}\n\n    def record_access_pattern(self, key: str, timestamp: datetime):\n        """记录访问模式"""\n        if key not in self.access_patterns:\n            self.access_patterns[key] = []\n        self.access_patterns[key].append(timestamp)\n\n        # 保持最近100个访问记录\n        if len(self.access_patterns[key]) > 100:\n            self.access_patterns[key] = self.access_patterns[key][-100:]\n\n    def predict_keys_to_warmup(self) -> List[str]:\n        """预测需要预热的键"""\n        predicted_keys = []\n\n        for key, timestamps in self.access_patterns.items():\n            if len(timestamps) >= 5:  # 至少需要5个访问点\n                if self._is_access_pattern_predictable(key):\n                    predicted_keys.append(key)\n\n        return predicted_keys[:50]  # 最多返回50个预测键\n\n    def _is_access_pattern_predictable(self, key: str) -> bool:\n        """判断访问模式是否可预测"""\n        # 简化的预测逻辑：检查是否有规律的访问间隔\n        timestamps = self.access_patterns[key][-10:]  # 最近10个访问\n\n        if len(timestamps) < 3:\n            return False\n\n        # 计算访问间隔\n        intervals = []\n        for i in range(1, len(timestamps)):\n            interval = (timestamps[i] - timestamps[i-1]).total_seconds()\n            intervals.append(interval)\n\n        # 如果间隔相对稳定，认为可预测\n        if len(intervals) >= 2:\n            avg_interval = sum(intervals) / len(intervals)\n            variance = sum((x - avg_interval) ** 2 for x in intervals) / len(intervals)\n            std_dev = variance ** 0.5\n\n            # 如果标准差小于平均间隔的50%，认为稳定\n            return std_dev < avg_interval * 0.5\n\n        return False\n\nclass ProductionCacheManager:\n    """生产级缓存管理器 - P1级别完善实现"""\n\n    def __init__(self, cache_manager: BaseCacheManager, config: ProductionConfig):\n        self.cache_manager = cache_manager\n        self.config = config\n        self.warmup_engine = CacheWarmupEngine(cache_manager, config.warmup_config)\n        self.failover_manager = FailoverManager(cache_manager, config.failover_config)\n        self.smart_monitor = SmartCacheMonitor(cache_manager) if config.enable_performance_monitoring else None\n\n        # 健康检查\n        self.health_checker = HealthChecker()\n        self.last_health_check = 0\n        self.is_healthy = True\n        self._health_check_thread: Optional[threading.Thread] = None\n        self._shutdown_event = threading.Event()\n\n        # 性能监控\n        if self.smart_monitor:\n            self.smart_monitor.add_alert_callback(self._handle_performance_alert)\n\n        # 生产管理统计\n        self.production_stats = {\n            'start_time': None,\n            'total_requests': 0,\n            'successful_requests': 0,\n            'failed_requests': 0,\n            'cache_hits': 0,\n            'cache_misses': 0,\n            'warmup_tasks': 0,\n            'failover_events': 0,\n            'health_check_failures': 0\n        }\n\n        logger.info("生产级缓存管理器已初始化")\n\n    def start_production_mode(self):\n        """启动生产模式 - P1级别完善实现"""\n        logger.info("启动生产模式...")\n        \n        try:\n            # 记录启动时间\n            self.production_stats['start_time'] = time.time()\n            \n            # 启动性能监控\n            if self.smart_monitor:\n                self.smart_monitor.start_monitoring()\n                logger.info("智能性能监控已启动")\n\n            # 启动健康检查\n            if self.config.enable_health_checks:\n                self._start_health_monitoring()\n                logger.info("健康检查已启动")\n\n            # 执行初始预热\n            if self.config.warmup_config.strategy != WarmupStrategy.FULL_LOAD:\n                warmup_task_id = self.warmup_cache()\n                if warmup_task_id:\n                    logger.info(f"初始缓存预热已启动: {warmup_task_id}")\n                    self.production_stats['warmup_tasks'] += 1\n\n            # 初始健康检查\n            self._perform_health_check()\n            \n            logger.info("生产模式启动完成")\n            \n        except Exception as e:\n            logger.error(f"启动生产模式失败: {e}")\n            raise\n\n    def stop_production_mode(self):\n        """停止生产模式 - 优雅关闭"""\n        logger.info("停止生产模式...")\n        \n        try:\n            # 设置关闭信号\n            self._shutdown_event.set()\n            \n            # 停止性能监控\n            if self.smart_monitor:\n                self.smart_monitor.stop_monitoring()\n                logger.info("性能监控已停止")\n\n            # 停止健康检查\n            if self._health_check_thread and self._health_check_thread.is_alive():\n                self._health_check_thread.join(timeout=5)\n                logger.info("健康检查已停止")\n\n            # 生成最终报告\n            final_report = self.get_production_report()\n            logger.info(f"生产模式运行统计: {final_report}")\n            \n            logger.info("生产模式已停止")\n            \n        except Exception as e:\n            logger.error(f"停止生产模式失败: {e}")\n\n    def warmup_cache(self, keys: Optional[List[str]] = None) -> Optional[str]:\n        """缓存预热 - 增强版本"""\n        try:\n            task_id = self.warmup_engine.start_warmup(keys)\n            if task_id:\n                self.production_stats['warmup_tasks'] += 1\n                logger.info(f"缓存预热任务已启动: {task_id}")\n                \n                # 异步监控预热进度\n                threading.Thread(\n                    target=self._monitor_warmup_progress,\n                    args=(task_id,),\n                    daemon=True\n                ).start()\n                \n            return task_id\n        except Exception as e:\n            logger.error(f"缓存预热失败: {e}")\n            return None\n\n    def get_warmup_status(self, task_id: str) -> Optional[Dict[str, Any]]:\n        """获取预热状态"""\n        return self.warmup_engine.get_warmup_status(task_id)\n\n    def get_health_status(self) -> Dict[str, Any]:\n        """获取健康状态"""\n        try:\n            cache_health = self._check_cache_health()\n            system_health = self._check_system_health() \n            performance_health = self._check_performance_health()\n            \n            overall_health = cache_health and system_health and performance_health\n            \n            return {\n                'overall_healthy': overall_health,\n                'cache_healthy': cache_health,\n                'system_healthy': system_health,\n                'performance_healthy': performance_health,\n                'last_check_time': time.time(),\n                'uptime_seconds': time.time() - (self.production_stats['start_time'] or time.time()),\n                'health_check_failures': self.production_stats['health_check_failures']\n            }\n        except Exception as e:\n            logger.error(f"健康检查失败: {e}")\n            return {\n                'overall_healthy': False,\n                'error': str(e),\n                'last_check_time': time.time()\n            }\n\n    def get_performance_report(self) -> Dict[str, Any]:\n        """获取性能报告"""\n        try:\n            if self.smart_monitor:\n                return self.smart_monitor.get_performance_report()\n            else:\n                return {\n                    'error': '性能监控未启用',\n                    'monitoring_enabled': False\n                }\n        except Exception as e:\n            logger.error(f"获取性能报告失败: {e}")\n            return {\n                'error': str(e),\n                'timestamp': time.time()\n            }\n\n    def get_production_report(self) -> Dict[str, Any]:\n        """获取生产运行报告"""\n        try:\n            current_time = time.time()\n            start_time = self.production_stats['start_time'] or current_time\n            uptime = current_time - start_time\n            \n            # 计算成功率\n            total_requests = self.production_stats['total_requests']\n            success_rate = (self.production_stats['successful_requests'] / max(1, total_requests)) * 100\n            \n            # 计算命中率\n            total_cache_ops = self.production_stats['cache_hits'] + self.production_stats['cache_misses']\n            hit_rate = (self.production_stats['cache_hits'] / max(1, total_cache_ops)) * 100\n            \n            return {\n                'uptime_seconds': uptime,\n                'uptime_formatted': f"{int(uptime // 3600)}h {int((uptime % 3600) // 60)}m {int(uptime % 60)}s",\n                'total_requests': total_requests,\n                'success_rate': success_rate,\n                'cache_hit_rate': hit_rate,\n                'warmup_tasks_completed': self.production_stats['warmup_tasks'],\n                'failover_events': self.production_stats['failover_events'],\n                'health_check_failures': self.production_stats['health_check_failures'],\n                'current_health': self.is_healthy,\n                'performance_monitoring': self.smart_monitor is not None\n            }\n        except Exception as e:\n            logger.error(f"获取生产报告失败: {e}")\n            return {\n                'error': str(e),\n                'timestamp': time.time()\n            }\n\n    def _start_health_monitoring(self):\n        """启动健康监控线程"""\n        def health_monitor_loop():\n    """文档字符串"""\n            while not self._shutdown_event.is_set():\n                try:\n                    self._perform_health_check()\n                    time.sleep(self.config.failover_config.health_check_interval)\n                except Exception as e:\n                    logger.error(f"健康检查循环异常: {e}")\n                    time.sleep(5)  # 短暂等待后重试\n        \n        self._health_check_thread = threading.Thread(target=health_monitor_loop, daemon=True)\n        self._health_check_thread.start()\n\n    def _perform_health_check(self):\n        """执行健康检查"""\n        try:\n            was_healthy = self.is_healthy\n            \n            # 检查缓存健康\n            cache_health = self._check_cache_health()\n            system_health = self._check_system_health()\n            performance_health = self._check_performance_health()\n            \n            self.is_healthy = cache_health and system_health and performance_health\n            self.last_health_check = time.time()\n            \n            # 如果健康状态发生变化\n            if was_healthy != self.is_healthy:\n                if self.is_healthy:\n                    logger.info("系统健康状态恢复")\n                else:\n                    logger.warning("系统健康状态异常")\n                    self.production_stats['health_check_failures'] += 1\n                    \n                    # 触发故障转移\n                    if self._should_trigger_failover():\n                        self._trigger_failover()\n            \n        except Exception as e:\n            logger.error(f"健康检查失败: {e}")\n            self.is_healthy = False\n            self.production_stats['health_check_failures'] += 1\n\n    def _check_cache_health(self) -> bool:\n        """检查缓存健康"""\n        try:\n            # 测试缓存基本操作\n            test_key = "__health_check_key__"\n            test_value = f"health_check_{time.time()}"\n            \n            # 设置和获取测试\n            set_success = self.cache_manager.set(test_key, test_value)\n            if not set_success:\n                return False\n                \n            retrieved_value = self.cache_manager.get(test_key)\n            if retrieved_value != test_value:\n                return False\n                \n            # 清理测试数据\n            self.cache_manager.delete(test_key)\n            \n            return True\n            \n        except Exception as e:\n            logger.error(f"缓存健康检查失败: {e}")\n            return False\n\n    def _check_system_health(self) -> bool:\n        """检查系统健康"""\n        try:\n            import psutil\n            \n            # 检查CPU使用率\n            cpu_percent = psutil.cpu_percent(interval=1)\n            if cpu_percent > 90:  # CPU使用率过高\n                logger.warning(f"CPU使用率过高: {cpu_percent}%")\n                return False\n                \n            # 检查内存使用率\n            memory = psutil.virtual_memory()\n            if memory.percent > 90:  # 内存使用率过高\n                logger.warning(f"内存使用率过高: {memory.percent}%")\n                return False\n                \n            return True\n            \n        except ImportError:\n            # 如果没有psutil，跳过系统检查\n            return True\n        except Exception as e:\n            logger.error(f"系统健康检查失败: {e}")\n            return False\n\n    def _check_performance_health(self) -> bool:\n        """检查性能健康"""\n        try:\n            if not self.smart_monitor:\n                return True  # 如果没有监控，认为健康\n                \n            report = self.smart_monitor.get_performance_report()\n            \n            # 检查命中率\n            current_hit_rate = report.get('current_hit_rate', 1.0)\n            if current_hit_rate < 0.5:  # 命中率低于50%\n                logger.warning(f"缓存命中率过低: {current_hit_rate:.2%}")\n                return False\n                \n            # 检查响应时间\n            current_response_time = report.get('current_response_time', 0)\n            if current_response_time > 1000:  # 响应时间超过1秒\n                logger.warning(f"缓存响应时间过高: {current_response_time}ms")\n                return False\n                \n            return True\n            \n        except Exception as e:\n            logger.error(f"性能健康检查失败: {e}")\n            return True  # 如果检查失败，不影响整体健康\n\n    def _should_trigger_failover(self) -> bool:\n        """判断是否应该触发故障转移"""\n        # 简化的故障转移逻辑\n        return (self.production_stats['health_check_failures'] >= 3 and \n                not self.is_healthy)\n\n    def _trigger_failover(self):\n        """触发故障转移"""\n        try:\n            logger.warning("触发故障转移...")\n            self.production_stats['failover_events'] += 1\n            \n            # 这里应该实现具体的故障转移逻辑\n            # 例如切换到备用缓存实例\n            \n            logger.info("故障转移完成")\n            \n        except Exception as e:\n            logger.error(f"故障转移失败: {e}")\n\n    def _monitor_warmup_progress(self, task_id: str):\n        """监控预热进度"""\n        while True:\n            try:\n                status = self.get_warmup_status(task_id)\n                if not status:\n                    break\n                    \n                if status['status'] in ['completed', 'failed']:\n                    logger.info(f"预热任务{status['status']}: {task_id}, "\n                               f"进度: {status['progress']:.1f}%, "\n                               f"成功: {status['loaded_count']}, "\n                               f"错误: {status['error_count']}")\n                    break\n                    \n                time.sleep(10)  # 每10秒检查一次\n                \n            except Exception as e:\n                logger.error(f"监控预热进度失败: {e}")\n                break\n\n    def _handle_performance_alert(self, alert: Dict[str, Any]):\n        """处理性能告警"""\n        try:\n            severity = alert.get('severity', 'info')\n            message = alert.get('message', '未知告警')\n            \n            logger.warning(f"性能告警 [{severity}]: {message}")\n            \n            # 根据告警类型执行相应动作\n            alert_type = alert.get('type')\n            if alert_type == 'hit_rate_low':\n                # 命中率低，可以触发预热\n                self.warmup_cache()\n            elif alert_type == 'response_time_high':\n                # 响应时间高，检查系统负载\n                self._perform_health_check()\n            elif alert_type == 'memory_usage_high':\n                # 内存使用高，可以清理缓存\n                self._trigger_cache_cleanup()\n                \n        except Exception as e:\n            logger.error(f"处理性能告警失败: {e}")\n\n    def _trigger_cache_cleanup(self):\n        """触发缓存清理"""\n        try:\n            logger.info("触发缓存清理...")\n            \n            # 这里应该实现具体的清理逻辑\n            # 例如清理过期数据或低优先级数据\n            \n            # 如果缓存管理器支持清理方法，则调用\n            cleanup_method = getattr(self.cache_manager, 'cleanup', None)\n            if cleanup_method and callable(cleanup_method):\n                cleanup_method()\n            else:\n                # 使用基本的清理策略\n                logger.info("使用基本清理策略")\n                \n            logger.info("缓存清理完成")\n            \n        except Exception as e:\n            logger.error(f"缓存清理失败: {e}")\n\nclass FailoverManager:\n    """故障转移管理器"""\n\n    def __init__(self, cache_manager: BaseCacheManager, config: FailoverConfig):\n        self.cache_manager = cache_manager\n        self.config = config\n        self.backup_managers: List[BaseCacheManager] = []\n        self.current_primary = cache_manager\n        self.is_monitoring = False\n        self.monitoring_thread: Optional[threading.Thread] = None\n        self.failover_history: List[Dict[str, Any]] = []\n\n    def add_backup_manager(self, backup_manager: BaseCacheManager):\n        """添加备用缓存管理器"""\n        self.backup_managers.append(backup_manager)\n\n    def start_monitoring(self):\n        """启动故障转移监控"""\n        if self.is_monitoring:\n            return\n\n        self.is_monitoring = True\n        self.monitoring_thread = threading.Thread(target=self._monitor_failover, daemon=True)\n        self.monitoring_thread.start()\n        logger.info("故障转移监控已启动")\n\n    def stop_monitoring(self):\n        """停止故障转移监控"""\n        self.is_monitoring = False\n        if self.monitoring_thread:\n            self.monitoring_thread.join(timeout=5)\n\n    def _monitor_failover(self):\n        """监控故障转移"""\n        while self.is_monitoring:\n            try:\n                if self.config.mode == FailoverMode.AUTOMATIC:\n                    self.check_failover_needed()\n                time.sleep(self.config.health_check_interval)\n            except Exception as e:\n                logger.error(f"故障转移监控异常: {e}")\n\n    def check_failover_needed(self) -> bool:\n        """检查是否需要故障转移"""\n        # 检查当前主缓存的健康状态\n        if not self._is_cache_healthy(self.current_primary):\n            if self.backup_managers:\n                return self._perform_failover()\n        return False\n\n    def _is_cache_healthy(self, cache_manager: BaseCacheManager) -> bool:\n        """检查缓存健康状态"""\n        try:\n            # 基本的健康检查\n            test_key = f"health_check_{int(time.time())}"\n            success = cache_manager.set(test_key, "test_value", ttl=10)\n            if success:\n                value = cache_manager.get(test_key)\n                cache_manager.delete(test_key)\n                return value == "test_value"\n        except Exception:\n            pass\n        return False\n\n    def _perform_failover(self) -> bool:\n        """执行故障转移"""\n        logger.warning("检测到主缓存故障，开始故障转移")\n\n        for backup in self.backup_managers:\n            if self._is_cache_healthy(backup):\n                old_primary = self.current_primary\n                self.current_primary = backup\n\n                # 记录故障转移历史\n                failover_record = {\n                    'timestamp': datetime.now().isoformat(),\n                    'from_manager': str(type(old_primary).__name__),\n                    'to_manager': str(type(backup).__name__),\n                    'reason': 'primary_cache_failure'\n                }\n                self.failover_history.append(failover_record)\n\n                logger.info(f"故障转移成功: {old_primary} -> {backup}")\n                return True\n\n        logger.error("故障转移失败：没有可用的备用缓存")\n        return False\n\n    def get_status(self) -> Dict[str, Any]:\n        """获取故障转移状态"""\n        return {\n            'current_primary': str(type(self.current_primary).__name__),\n            'backup_count': len(self.backup_managers),\n            'monitoring_active': self.is_monitoring,\n            'total_failovers': len(self.failover_history),\n            'recent_failovers': self.failover_history[-5:] if self.failover_history else []\n        }\n\nclass HealthChecker:\n    """健康检查器"""\n\n    def __init__(self):\n        self.check_functions: List[Callable[[BaseCacheManager], bool]] = [\n            self._check_basic_operations,\n            self._check_performance,\n            self._check_memory_usage\n        ]\n\n    def check_health(self, cache_manager: BaseCacheManager) -> bool:\n        """检查缓存健康状态"""\n        for check_func in self.check_functions:\n            try:\n                if not check_func(cache_manager):\n                    return False\n            except Exception as e:\n                logger.error(f"健康检查失败: {check_func.__name__}: {e}")\n                return False\n        return True\n\n    def _check_basic_operations(self, cache_manager: BaseCacheManager) -> bool:\n        """检查基本操作"""\n        try:\n            test_key = f"health_test_{int(time.time())}"\n            # 测试设置\n            success = cache_manager.set(test_key, "health_check")\n            if not success:\n                return False\n\n            # 测试获取\n            value = cache_manager.get(test_key)\n            if value != "health_check":\n                return False\n\n            # 测试删除\n            success = cache_manager.delete(test_key)\n            return success\n        except Exception:\n            return False\n\n    def _check_performance(self, cache_manager: BaseCacheManager) -> bool:\n        """检查性能"""\n        try:\n            import time\n            start_time = time.time()\n\n            # 执行一些操作来测试性能\n            for i in range(10):\n                test_key = f"perf_test_{i}"\n                cache_manager.set(test_key, f"value_{i}")\n                cache_manager.get(test_key)\n                cache_manager.delete(test_key)\n\n            elapsed = time.time() - start_time\n            # 如果操作时间超过1秒，认为性能不佳\n            return elapsed < 1.0\n        except Exception:\n            return False\n\n    def _check_memory_usage(self, cache_manager: BaseCacheManager) -> bool:\n        """检查内存使用"""\n        try:\n            memory = psutil.virtual_memory()\n            # 如果内存使用超过90%，认为不健康\n            return memory.percent < 90.0\n        except Exception:\n            return True  # 如果无法检查内存，默认认为健康\n