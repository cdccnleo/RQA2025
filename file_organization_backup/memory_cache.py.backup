"""\n内存缓存实现\n提供LRU缓存策略和内存缓存管理\n"""\n\nfrom collections import OrderedDict\nfrom typing import Any, Optional, Dict, Tuple\nimport threading\nimport time\n\nclass LRUCache:\n\n    """\n    memory_cache - 缓存系统\n\n    职责说明：\n    负责数据缓存、内存管理、缓存策略和性能优化\n\n    核心职责：\n    - 内存缓存管理\n    - Redis缓存操作\n    - 缓存策略实现\n    - 缓存性能监控\n    - 缓存数据同步\n    - 缓存失效处理\n\n    相关接口：\n    - ICacheComponent\n    - ICacheManager\n    - ICacheStrategy\n    """ """LRU缓存实现"""\n\n    def set(self, key, value, ttl=None):\n        """设置缓存项"""\n        if ttl:\n            expiration_time = time.time() + ttl\n        else:\n            expiration_time = None\n\n        with self._lock:\n            # 检查容量限制\n            if len(self.cache) >= self.capacity and key not in self.cache:\n                # 移除最少使用的项\n                oldest_key, _ = self.cache.popitem(last=False)\n                self.timestamps.pop(oldest_key, None)\n\n            # 设置新值\n            self.cache[key] = value\n            self.timestamps[key] = expiration_time\n\n        return True\n\n    def __init__(self, capacity: int = 1000, ttl: int = 3600):\n\n        """\n        初始化LRU缓存\n\n        Args:\n            capacity: 缓存容量\n            ttl: 缓存过期时间（秒）\n        """\n        self.capacity = capacity\n        self.ttl = ttl\n        self.cache = OrderedDict()\n        self.timestamps = {}\n        self._lock = threading.RLock()  # 使用可重入锁\n\n    def get(self, key: str) -> Optional[Any]:\n    """文档字符串"""\n\n        """\n        获取缓存值\n\n        Args:\n            key: 缓存键\n\n        Returns:\n            缓存值，如果不存在或已过期则返回None\n        """\n        with self._lock:\n            if key not in self.cache:\n                return None\n\n            # 检查是否过期\n            if self._is_expired(key):\n                self.delete(key)\n                return None\n\n            # 移动到末尾（最近使用）\n            self.cache.move_to_end(key)\n            return self.cache[key]\n\n    def put(self, key: str, value: Any) -> None:\n    """文档字符串"""\n\n        """\n        设置缓存值\n\n        Args:\n            key: 缓存键\n            value: 缓存值\n        """\n        with self._lock:\n            if key in self.cache:\n                # 更新现有值\n                self.cache.move_to_end(key)\n            else:\n                # 检查容量\n                if len(self.cache) >= self.capacity:\n                    # 移除最久未使用的项\n                    oldest_key = next(iter(self.cache))\n                    self.delete(oldest_key)\n\n            self.cache[key] = value\n            self.timestamps[key] = time.time()\n\n    def delete(self, key: str) -> bool:\n    """文档字符串"""\n\n        """\n        删除缓存项\n\n        Args:\n            key: 缓存键\n\n        Returns:\n            是否成功删除\n        """\n        with self._lock:\n            if key in self.cache:\n                del self.cache[key]\n                del self.timestamps[key]\n                return True\n            return False\n\n    def clear(self) -> None:\n    """文档字符串"""\n\n        """清空缓存"""\n        with self._lock:\n            self.cache.clear()\n            self.timestamps.clear()\n\n    def size(self) -> int:\n    """文档字符串"""\n\n        """获取缓存大小"""\n        with self._lock:\n            return len(self.cache)\n\n    def is_full(self) -> bool:\n    """文档字符串"""\n\n        """检查缓存是否已满"""\n        with self._lock:\n            return len(self.cache) >= self.capacity\n\n    def _is_expired(self, key: str) -> bool:\n    """文档字符串"""\n\n        """检查缓存项是否过期"""\n        if key not in self.timestamps:\n            return True\n        timestamp = self.timestamps[key]\n        if timestamp is None:\n            return False  # 永不过期\n        return time.time() - timestamp > self.ttl\n\n    def get_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取缓存统计信息"""\n        with self._lock:\n            return {\n                'size': self.size(),\n                'capacity': self.capacity,\n                'is_full': self.is_full(),\n                'ttl': self.ttl\n            }\n\nclass MemoryCacheManager:\n\n    """内存缓存管理器"""\n\n    def __init__(self):\n\n        """初始化内存缓存管理器"""\n        self.caches: Dict[str, LRUCache] = {}\n        self._lock = threading.RLock()  # 使用可重入锁\n\n    def create_cache(self, name: str, capacity: int = 1000, ttl: int = 3600) -> LRUCache:\n    """文档字符串"""\n\n        """\n        创建缓存\n\n        Args:\n            name: 缓存名称\n            capacity: 缓存容量\n            ttl: 缓存过期时间\n\n        Returns:\n            LRU缓存实例\n        """\n        with self._lock:\n            cache = LRUCache(capacity=capacity, ttl=ttl)\n            self.caches[name] = cache\n            return cache\n\n    def get_cache(self, name: str) -> Optional[LRUCache]:\n    """文档字符串"""\n\n        """\n        获取缓存\n\n        Args:\n            name: 缓存名称\n\n        Returns:\n            缓存实例，如果不存在则返回None\n        """\n        with self._lock:\n            return self.caches.get(name)\n\n    def delete_cache(self, name: str) -> bool:\n    """文档字符串"""\n\n        """\n        删除缓存\n\n        Args:\n            name: 缓存名称\n\n        Returns:\n            是否成功删除\n        """\n        with self._lock:\n            if name in self.caches:\n                del self.caches[name]\n                return True\n            return False\n\n    def get_all_stats(self) -> Dict[str, Dict[str, Any]]:\n    """文档字符串"""\n\n        """获取所有缓存的统计信息"""\n        with self._lock:\n            return {name: cache.get_stats() for name, cache in self.caches.items()}\n\n    def clear_all(self) -> None:\n    """文档字符串"""\n\n        """清空所有缓存"""\n        with self._lock:\n            for cache in self.caches.values():\n                cache.clear()\n\n    def _monitor_memory_usage(self):\n        """监控内存使用情况"""\n        process = psutil.Process(os.getpid())\n        memory_usage = process.memory_info().rss / 1024 / 1024  # MB\n\n        # 如果内存使用超过阈值，触发清理\n        if memory_usage > 500:  # 500MB阈值\n            self._cleanup_expired_entries()\n            self._reduce_cache_size()\n\n        return memory_usage\n\n    def _cleanup_expired_entries(self):\n        """清理过期条目"""\n        current_time = time.time()\n        expired_keys = []\n\n        for key, (_, _, expiry) in self.cache.items():\n            if expiry and current_time > expiry:\n                expired_keys.append(key)\n\n        for key in expired_keys:\n            del self.cache[key]\n\n        if expired_keys:\n            print(f"🧹 清理了 {len(expired_keys)} 个过期缓存条目")\n\n    def _reduce_cache_size(self):\n        """减少缓存大小"""\n        if len(self.cache) > self.capacity * 0.8:  # 超过80%容量\n            # 删除最旧的20%条目\n            remove_count = int(len(self.cache) * 0.2)\n            keys_to_remove = list(self.cache.keys())[:remove_count]\n\n            for key in keys_to_remove:\n                del self.cache[key]\n\n            print(f"🗑️ 减少缓存大小，删除了 {remove_count} 个条目")\n\n    def get_cache_stats(self):\n        """获取缓存统计信息"""\n        total_entries = len(self.cache)\n        expired_entries = sum(1 for _, _, expiry in self.cache.values()\n                            if expiry and time.time() > expiry)\n        memory_usage = self._monitor_memory_usage()\n\n        return {\n            'total_entries': total_entries,\n            'expired_entries': expired_entries,\n            'memory_usage_mb': memory_usage,\n            'hit_ratio': getattr(self, '_hits', 0) / max(getattr(self, '_accesses', 1), 1)\n        }\n