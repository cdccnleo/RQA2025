#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n引擎层统一日志记录器\n提供结构化日志记录、性能监控和业务关联功能\n"""\n\nfrom enum import Enum\nfrom pathlib import Path\nfrom typing import Dict, Any, Optional, List\nimport json\nimport logging\nimport threading\nimport time\nimport uuid\n\nfrom dataclasses import dataclass, field\nimport traceback\n\nfrom ..exceptions import EngineException, create_error_context\nfrom .unified_context import UnifiedLogContext\n\nclass LogLevel(Enum):\n\n    """日志级别"""\n    DEBUG = "DEBUG"\n    INFO = "INFO"\n    WARNING = "WARNING"\n    ERROR = "ERROR"\n    CRITICAL = "CRITICAL"\n\nclass LogCategory(Enum):\n\n    """日志分类"""\n    SYSTEM = "system"\n    BUSINESS = "business"\n    PERFORMANCE = "performance"\n    SECURITY = "security"\n    DEBUG = "debug"\n\n# 使用统一的日志上下文\n# @dataclass\n# class LogContext:\n#     """日志上下文"""\n#     correlation_id: str = ""\n    #     user_id: str = ""\n    #     session_id: str = ""\n    #     component: str = ""\n    #     operation: str = ""\n    #     metadata: Dict[str, Any] = field(default_factory=dict)\n    #     timestamp: float = field(default_factory=time.time)\n\nclass EngineLogger:\n\n    """引擎层统一日志记录器"""\n\n    def __init__(self, name: str, config: Dict[str, Any] = None):\n\n        """初始化日志记录器\n\n        Args:\n            name: 日志记录器名称\n            config: 配置字典\n        """\n        self.name = name\n        self.config = config or {}\n        self.logger = logging.getLogger(name)\n\n        # 性能监控\n        self.performance_metrics = {\n            'log_count': 0,\n            'error_count': 0,\n            'avg_log_time': 0.0,\n            'total_log_time': 0.0\n        }\n\n        # 线程锁\n        self._lock = threading.RLock()\n\n        # 关联追踪\n        self._correlation_stack = []\n        self._context_stack = []\n\n        # 初始化配置\n        self._setup_logger()\n\n    def _setup_logger(self):\n    """文档字符串"""\n\n        """设置日志记录器"""\n        # 设置日志级别\n        level = self.config.get('level', 'INFO')\n        self.logger.setLevel(getattr(logging, level.upper()))\n\n        # 清除现有处理器\n        self.logger.handlers.clear()\n\n        # 添加处理器\n        self._add_handlers()\n\n    def _add_handlers(self):\n    """文档字符串"""\n\n        """添加日志处理器"""\n        # 控制台处理器\n        console_handler = logging.StreamHandler()\n        console_handler.setLevel(logging.INFO)\n        console_formatter = logging.Formatter(\n            '%(asctime)s - %(name)s - %(levelname)s - %(message)s'\n        )\n        console_handler.setFormatter(console_formatter)\n        self.logger.addHandler(console_handler)\n\n        # 文件处理器\n        log_dir = Path(self.config.get('log_dir', 'logs'))\n        log_dir.mkdir(parents=True, exist_ok=True)\n\n        # 结构化日志文件\n        structured_handler = logging.FileHandler(\n            log_dir / f'{self.name}_structured.log',\n            encoding='utf - 8'\n        )\n        structured_handler.setLevel(logging.INFO)\n        structured_formatter = logging.Formatter(\n            '%(message)s'  # 结构化日志只输出消息部分\n        )\n        structured_handler.setFormatter(structured_formatter)\n        self.logger.addHandler(structured_handler)\n\n        # 错误日志文件\n        error_handler = logging.FileHandler(\n            log_dir / f'{self.name}_error.log',\n            encoding='utf - 8'\n        )\n        error_handler.setLevel(logging.ERROR)\n        error_formatter = logging.Formatter(\n            '%(asctime)s - %(name)s - %(levelname)s - %(message)s\n'\n            'Exception: %(exc_info)s\n'\n            'Location: %(pathname)s:%(lineno)d\n'\n        )\n        error_handler.setFormatter(error_formatter)\n        self.logger.addHandler(error_handler)\n\n    def _create_log_entry(self, level: LogLevel, message: str,\n    """文档字符串"""\n\n                          category: LogCategory = LogCategory.SYSTEM,\n                          context: Optional[UnifiedLogContext] = None,\n                          **kwargs) -> Dict[str, Any]:\n        """创建日志条目"""\n        # 获取当前上下文\n        current_context = context or self._get_current_context()\n\n        # 创建结构化日志条目\n        log_entry = {\n            'timestamp': time.time(),\n            'level': level.value,\n            'category': category.value,\n            'message': message,\n            'logger': self.name,\n            'correlation_id': current_context.correlation_id,\n            'user_id': current_context.user_id,\n            'session_id': current_context.session_id,\n            'component': current_context.component,\n            'operation': current_context.operation,\n            'metadata': {**current_context.metadata, **kwargs}\n        }\n\n        return log_entry\n\n    def _get_current_context(self) -> UnifiedLogContext:\n    """文档字符串"""\n\n        """获取当前上下文"""\n        if self._context_stack:\n            return self._context_stack[-1]\n        return UnifiedLogContext()\n\n    def _log_structured(self, log_entry: Dict[str, Any]):\n    """文档字符串"""\n\n        """记录结构化日志"""\n        try:\n            # 转换为JSON格式\n            json_message = json.dumps(log_entry, ensure_ascii=False, default=str)\n            self.logger.info(json_message)\n        except Exception as e:\n            # 如果结构化日志失败，回退到普通日志\n            self.logger.error(f"结构化日志记录失败: {e}")\n            self.logger.info(log_entry.get('message', ''))\n\n    def _update_performance_metrics(self, start_time: float, level: LogLevel):\n    """文档字符串"""\n\n        """更新性能指标"""\n        with self._lock:\n            log_time = time.time() - start_time\n            self.performance_metrics['log_count'] += 1\n            self.performance_metrics['total_log_time'] += log_time\n            self.performance_metrics['avg_log_time'] = (\n                self.performance_metrics['total_log_time']\n                / self.performance_metrics['log_count']\n            )\n\n        if level in [LogLevel.ERROR, LogLevel.CRITICAL]:\n            self.performance_metrics['error_count'] += 1\n\n    def log(self, level: LogLevel, message: str,\n    """文档字符串"""\n\n            category: LogCategory = LogCategory.SYSTEM,\n            context: Optional[UnifiedLogContext] = None,\n            **kwargs):\n        """记录日志"""\n        start_time = time.time()\n\n        try:\n            # 创建日志条目\n            log_entry = self._create_log_entry(level, message, category, context, **kwargs)\n\n            # 记录结构化日志\n            self._log_structured(log_entry)\n\n            # 更新性能指标\n            self._update_performance_metrics(start_time, level)\n\n        except Exception as e:\n            # 记录日志失败时的错误处理\n            error_context = create_error_context(\n                module="engine_logger",\n                function="log",\n                line_number=1\n            )\n            raise EngineException(\n                f"日志记录失败: {e}",\n                context=error_context\n            )\n\n    def debug(self, message: str, **kwargs):\n    """文档字符串"""\n\n        """记录调试日志"""\n        self.log(LogLevel.DEBUG, message, LogCategory.DEBUG, **kwargs)\n\n    def info(self, message: str, **kwargs):\n    """文档字符串"""\n\n        """记录信息日志"""\n        self.log(LogLevel.INFO, message, LogCategory.SYSTEM, **kwargs)\n\n    def warning(self, message: str, **kwargs):\n    """文档字符串"""\n\n        """记录警告日志"""\n        self.log(LogLevel.WARNING, message, LogCategory.SYSTEM, **kwargs)\n\n    def error(self, message: str, exception: Optional[Exception] = None, **kwargs):\n    """文档字符串"""\n\n        """记录错误日志"""\n        if exception:\n            kwargs['exception'] = {\n                'type': type(exception).__name__,\n                'message': str(exception),\n                'traceback': traceback.format_exc()\n            }\n        self.log(LogLevel.ERROR, message, LogCategory.SYSTEM, **kwargs)\n\n    def critical(self, message: str, exception: Optional[Exception] = None, **kwargs):\n    """文档字符串"""\n\n        """记录严重错误日志"""\n        if exception:\n            kwargs['exception'] = {\n                'type': type(exception).__name__,\n                'message': str(exception),\n                'traceback': traceback.format_exc()\n            }\n        self.log(LogLevel.CRITICAL, message, LogCategory.SYSTEM, **kwargs)\n\n    def business_log(self, message: str, business_type: str, **kwargs):\n    """文档字符串"""\n\n        """记录业务日志"""\n        kwargs['business_type'] = business_type\n        self.log(LogLevel.INFO, message, LogCategory.BUSINESS, **kwargs)\n\n    def performance_log(self, message: str, metrics: Dict[str, Any], **kwargs):\n    """文档字符串"""\n\n        """记录性能日志"""\n        kwargs['performance_metrics'] = metrics\n        self.log(LogLevel.INFO, message, LogCategory.PERFORMANCE, **kwargs)\n\n    def security_log(self, message: str, security_event: str, **kwargs):\n    """文档字符串"""\n\n        """记录安全日志"""\n        kwargs['security_event'] = security_event\n        self.log(LogLevel.WARNING, message, LogCategory.SECURITY, **kwargs)\n\n    def push_context(self, context: UnifiedLogContext):\n    """文档字符串"""\n\n        """推入上下文"""\n        self._context_stack.append(context)\n\n    def pop_context(self) -> Optional[UnifiedLogContext]:\n    """文档字符串"""\n\n        """弹出上下文"""\n        if self._context_stack:\n            return self._context_stack.pop()\n        return None\n\n    def set_correlation_id(self, correlation_id: str):\n    """文档字符串"""\n\n        """设置关联ID"""\n        if self._context_stack:\n            self._context_stack[-1].correlation_id = correlation_id\n        else:\n            context = UnifiedLogContext(component=self.name, operation="set_correlation", correlation_id=correlation_id)\n            self.push_context(context)\n\n    def get_correlation_id(self) -> str:\n    """文档字符串"""\n\n        """获取关联ID"""\n        context = self._get_current_context()\n        return context.correlation_id\n\n    def get_performance_metrics(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取性能指标"""\n        with self._lock:\n            return self.performance_metrics.copy()\n\n    def health_check(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """健康检查"""\n        try:\n            return {\n                'status': 'healthy',\n                'logger_name': self.name,\n                'log_level': self.logger.level,\n                'handler_count': len(self.logger.handlers),\n                'performance_metrics': self.get_performance_metrics(),\n                'context_stack_size': len(self._context_stack)\n            }\n        except Exception as e:\n            return {\n                'status': 'error',\n                'error': str(e)\n            }\n\n# 全局日志记录器实例\n_global_engine_logger = None\n\ndef get_engine_logger(name: str = "engine") -> EngineLogger:\n    """文档字符串"""\n\n    """获取全局引擎日志记录器实例"""\n    global _global_engine_logger\n    if _global_engine_logger is None:\n        _global_engine_logger = EngineLogger(name)\n    elif name != "engine" and _global_engine_logger.name != name:\n        # 如果请求的名称不同，创建新的日志记录器\n        return EngineLogger(name)\n    return _global_engine_logger\n\ndef configure_engine_logging(config: Dict[str, Any]) -> None:\n    """文档字符串"""\n\n    """配置引擎日志系统"""\n    global _global_engine_logger\n    if _global_engine_logger:\n        _global_engine_logger.config.update(config)\n        _global_engine_logger._setup_logger()\n    else:\n        _global_engine_logger = EngineLogger("engine", config)\n