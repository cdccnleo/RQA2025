"""\n基础设施层 - 系统监控组件\n# 平台兼容性检测\nimport platform\n\nIS_WINDOWS = platform.system().lower() == "windows"\nIS_LINUX = platform.system().lower() == "linux"\nIS_MACOS = platform.system().lower() == "darwin"\n\nsystem_monitor 模块\n\n系统监控相关的文件\n提供系统监控相关的功能实现。\n"""\n\nimport platform\nimport time\nimport threading\nfrom typing import Dict, List, Optional, Callable, Any\nfrom datetime import datetime\nimport logging\n\n# 可选导入prometheus_client\ntry:\n    from prometheus_client import Gauge, CollectorRegistry, REGISTRY\n    PROMETHEUS_AVAILABLE = True\nexcept ImportError:\n    PROMETHEUS_AVAILABLE = False\n    # 创建兼容的Mock类\n    class Gauge:\n        def __init__(self, *args, **kwargs):\n            pass\n        def set(self, value):\n    """文档字符串"""\n            pass\n\n    CollectorRegistry = object\n    REGISTRY = None\n\nlogger = logging.getLogger(__name__)\n\nclass SystemMonitor:\n\n    """系统资源监控器"""\n\n    def __init__(\n        self,\n        check_interval: float = 60.0,\n        alert_handlers: Optional[List[Callable[[str, Dict], None]]] = None,\n        psutil_mock: Optional[Any] = None,\n        os_mock: Optional[Any] = None,\n        socket_mock: Optional[Any] = None,\n        registry: Optional[CollectorRegistry] = None\n    ):\n\n        """\n        初始化系统监控器\n\n        Args:\n            check_interval: 监控检查间隔(秒)\n            alert_handlers: 告警处理器列表\n            psutil_mock: 可选的psutil mock，用于测试时注入mock对象\n            os_mock: 可选的os mock，用于测试时注入mock对象\n            socket_mock: 可选的socket mock，用于测试时注入mock对象\n        """\n        self.check_interval = check_interval\n        self.alert_handlers = alert_handlers or []\n        self._metrics_history = {}\n        self._alerts_history = []\n        self._monitoring_active = False\n\n        # 测试钩子：允许注入mock的依赖\n        if psutil_mock is not None:\n            self.psutil = psutil_mock\n        else:\n            import psutil\n            self.psutil = psutil\n\n        if os_mock is not None:\n            self.os = os_mock\n        else:\n            import os\n            self.os = os\n\n        if socket_mock is not None:\n            self.socket = socket_mock\n        else:\n            import socket\n            self.socket = socket\n\n        self._monitoring = False\n        self._monitor_thread = None\n        self._stats: List[Dict] = []\n        self._metrics_history: Dict[str, List] = {}\n        self._alerts_history: List[Dict] = []\n        self.alert_handlers: List = []\n\n        # 系统基础信息\n        self.system_info = self._get_system_info()\n\n        # Prometheus指标（如果可用）\n        if PROMETHEUS_AVAILABLE:\n            self.registry = registry if registry is not None else REGISTRY\n            # Prometheus指标注册隔离，避免重复注册\n            self.cpu_gauge = self._get_or_create_gauge('system_cpu_percent', 'System CPU usage percent')\n            self.memory_gauge = self._get_or_create_gauge('system_memory_percent', 'System memory usage percent')\n            self.disk_gauge = self._get_or_create_gauge('system_disk_percent', 'System disk usage percent')\n        else:\n            self.registry = None\n            self.cpu_gauge = None\n            self.memory_gauge = None\n            self.disk_gauge = None\n\n    def _get_system_info(self) -> Dict:\n        """获取系统基础信息"""\n        return {\n            'hostname': self.socket.gethostname(),\n            'platform': platform.platform(),\n            'system': platform.system(),\n            'release': platform.release(),\n            'processor': platform.processor(),\n            'cpu_count': self.psutil.cpu_count(),\n            'boot_time': datetime.fromtimestamp(self.psutil.boot_time()).isoformat(),\n            'python_version': platform.python_version()\n        }\n\n    def start_monitoring(self) -> None:\n    """文档字符串"""\n\n        """启动系统监控"""\n        if self._monitoring:\n            return\n\n        self._monitoring = True\n        self._monitor_thread = threading.Thread(target=self._monitor_loop, daemon=True)\n        self._monitor_thread.start()\n        logger.info("System monitoring started")\n\n    def stop_monitoring(self) -> None:\n    """文档字符串"""\n\n        """停止系统监控"""\n        if not self._monitoring:\n            return\n\n        self._monitoring = False\n        if self._monitor_thread:\n            self._monitor_thread.join(timeout=self.check_interval * 2)\n            logger.info("System monitoring stopped")\n\n    def _monitor_loop(self) -> None:\n    """文档字符串"""\n\n        """监控主循环"""\n        while self._monitoring:\n            try:\n                stats = self._collect_system_stats()\n\n                # 保存统计数据\n                self._stats.append(stats)\n                if len(self._stats) > 1000:  # 限制历史数据量\n                    self._stats = self._stats[-1000:]\n\n                # 检查系统状态\n                self._check_system_status(stats)\n\n            except Exception as e:\n                logger.error(f"System monitoring error: {e}")\n\n                time.sleep(self.check_interval)\n\n    def _collect_system_stats(self) -> Dict:\n    """文档字符串"""\n\n        """收集系统统计数据"""\n        # CPU使用率\n        cpu_percent = self.psutil.cpu_percent(interval=1)\n\n        # 内存使用\n        mem = self.psutil.virtual_memory()\n\n        # 磁盘使用\n        disk = self.psutil.disk_usage('/')\n\n        # 网络IO\n        net_io = self.psutil.net_io_counters()\n\n        # 系统负载(仅Linux)\n        load_avg = self._get_load_avg()\n\n        # 进程数量\n        process_count = len(self.psutil.pids())\n\n        return {\n            'timestamp': datetime.now().isoformat(),\n            'cpu': {\n                'percent': cpu_percent,\n                'load_avg': load_avg\n            },\n            'memory': {\n                'total': mem.total,\n                'available': mem.available,\n                'used': mem.used,\n                'percent': mem.percent\n            },\n            'disk': {\n                'total': disk.total,\n                'used': disk.used,\n                'free': disk.free,\n                'percent': disk.percent\n            },\n            'network': {\n                'bytes_sent': net_io.bytes_sent,\n                'bytes_recv': net_io.bytes_recv,\n                'packets_sent': net_io.packets_sent,\n                'packets_recv': net_io.packets_recv\n            },\n            'process': {\n                'count': process_count\n            }\n        }\n\n    def _get_load_avg(self) -> Optional[List[float]]:\n    """文档字符串"""\n\n        """获取系统负载(仅Linux)"""\n        try:\n            if hasattr(self.os, 'getloadavg'):\n                return list(self.os.getloadavg())\n        except Exception:\n            pass\n            return None\n\n    def _check_system_status(self, stats: Dict) -> None:\n    """文档字符串"""\n\n        """检查系统状态并触发告警"""\n        alerts = []\n\n        # CPU检查\n        if stats['cpu']['percent'] > 90:\n            alerts.append({\n                'type': 'cpu',\n                'level': 'critical',\n                'message': f"High CPU usage: {stats['cpu']['percent']}%",\n                'value': stats['cpu']['percent'],\n                'threshold': 90\n            })\n\n        # 内存检查\n        if stats['memory']['percent'] > 90:\n            alerts.append({\n                'type': 'memory',\n                'level': 'critical',\n                'message': f"High memory usage: {stats['memory']['percent']}%",\n                'value': stats['memory']['percent'],\n                'threshold': 90\n            })\n\n        # 磁盘检查\n        if stats['disk']['percent'] > 90:\n            alerts.append({\n                'type': 'disk',\n                'level': 'warning',\n                'message': f"High disk usage: {stats['disk']['percent']}%",\n                'value': stats['disk']['percent'],\n                'threshold': 90\n            })\n\n        # 触发告警\n        for alert in alerts:\n            self._trigger_alert(alert)\n\n    def _trigger_alert(self, alert: Dict) -> None:\n    """文档字符串"""\n\n        """触发系统告警"""\n        for handler in self.alert_handlers:\n            try:\n                handler('system', alert)\n            except Exception as e:\n                logger.error(f"Alert handler failed: {e}")\n\n    def get_stats(self,\n    """文档字符串"""\n                   start_time: Optional[str] = None,\n                   end_time: Optional[str] = None):\n        """\n        获取系统监控历史数据\n\n        Args:\n            start_time: 开始时间(ISO格式)\n            end_time: 结束时间(ISO格式)\n\n        Returns:\n            List[Dict]: 系统监控数据列表\n        """\n        if not start_time and not end_time:\n            return self._stats.copy()\n\n            stats = self._stats.copy()\n\n        if start_time:\n            stats = [s for s in stats if s['timestamp'] >= start_time]\n\n        if end_time:\n            stats = [s for s in stats if s['timestamp'] <= end_time]\n\n            return stats\n\n    def get_current_stats(self) -> Dict:\n        """\n        获取当前系统统计信息\n\n        Returns:\n            Dict: 当前系统统计信息\n        """\n        return self._collect_system_stats()\n\n    def get_summary(self) -> Dict:\n    """文档字符串"""\n\n        """\n        获取系统监控摘要\n\n        Returns:\n            Dict: 系统监控摘要\n        """\n        if not self._stats:\n            return {\n                'status': 'no_data',\n                'system_info': self.system_info,\n                'count': 0\n            }\n\n        # CPU统计\n            cpu_values = [s['cpu']['percent'] for s in self._stats]\n            cpu_avg = sum(cpu_values) / len(cpu_values)\n            cpu_max = max(cpu_values)\n\n        # 内存统计\n            mem_values = [s['memory']['percent'] for s in self._stats]\n            mem_avg = sum(mem_values) / len(mem_values)\n            mem_max = max(mem_values)\n\n        # 磁盘统计\n            disk_values = [s['disk']['percent'] for s in self._stats]\n            disk_avg = sum(disk_values) / len(disk_values)\n            disk_max = max(disk_values)\n\n            return {\n                'system_info': self.system_info,\n                'cpu': {\n                    'avg': cpu_avg,\n                    'max': cpu_max\n                },\n                'memory': {\n                    'avg': mem_avg,\n                    'max': mem_max\n                },\n                'disk': {\n                    'avg': disk_avg,\n                    'max': disk_max\n                },\n                'period': {\n                    'start': self._stats[0]['timestamp'],\n                    'end': self._stats[-1]['timestamp'],\n                },\n                'count': len(self._stats)\n            }\n\n    def get_cpu_usage(self) -> float:\n    """文档字符串"""\n\n        """获取当前CPU使用率百分比"""\n        try:\n            return self.psutil.cpu_percent(interval=1)\n        except Exception as e:\n            logger.error(f"Failed to get CPU usage: {e}")\n            return 0.0\n\n    def get_memory_usage(self) -> float:\n    """文档字符串"""\n\n        """获取当前内存使用率百分比"""\n        return self.psutil.virtual_memory().percent\n\n    def get_disk_usage(self) -> float:\n    """文档字符串"""\n\n        """获取当前磁盘使用率百分比"""\n        return self.psutil.disk_usage('/').percent\n\n    def check_service_status(self, service_name: str) -> bool:\n    """文档字符串"""\n\n        """检查指定服务是否运行"""\n        for proc in self.psutil.process_iter(['name']):\n            if service_name.lower() in proc.info['name'].lower():\n                return True\n        return False\n\n    def _get_or_create_gauge(self, name, desc):\n        """获取或创建Gauge指标（如果prometheus可用）"""\n        if not PROMETHEUS_AVAILABLE or self.registry is None:\n            return None\n\n        # 通过registry._names_to_collectors安全获取或注册Gauge\n        if hasattr(self.registry, '_names_to_collectors') and name in self.registry._names_to_collectors:\n            return self.registry._names_to_collectors[name]\n        else:\n            return Gauge(name, desc, registry=self.registry)\n\n    def get_system_info(self) -> Dict[str, Any]:\n        """获取系统基本信息"""\n        try:\n            return {\n                "platform": self.os.sys.platform if hasattr(self.os, 'sys') else "unknown",\n                "hostname": self.socket.gethostname(),\n                "cpu_count": self.psutil.cpu_count(),\n                "memory_total": self.psutil.virtual_memory().total,\n                "disk_total": self.psutil.disk_usage('/').total,\n                "boot_time": self.psutil.boot_time()\n            }\n        except Exception as e:\n            logger.error(f"Failed to get system info: {e}")\n            return {\n                "platform": "unknown",\n                "hostname": "unknown",\n                "cpu_count": 0,\n                "memory_total": 0,\n                "disk_total": 0,\n                "boot_time": 0\n            }\n\n    def get_all_metrics(self) -> Dict[str, Any]:\n        """获取所有监控指标"""\n        try:\n            return {\n                'cpu': self.get_cpu_usage_dict(),\n                'memory': self.get_memory_usage_dict(),\n                'disk': self.get_disk_usage_dict(),\n                'network': self.get_network_usage_dict(),\n                'timestamp': time.time()\n            }\n        except Exception as e:\n            logger.error(f"Failed to get all metrics: {e}")\n            return {}\n\n    def get_network_usage(self) -> Dict[str, Any]:\n        """获取网络使用情况"""\n        return self.get_network_usage_dict()\n\n    def get_network_usage_dict(self) -> Dict[str, Any]:\n        """获取网络使用情况（字典格式）"""\n        try:\n            net_counters = self.psutil.net_io_counters()\n            return {\n                'bytes_sent': net_counters.bytes_sent,\n                'bytes_recv': net_counters.bytes_recv,\n                'packets_sent': getattr(net_counters, 'packets_sent', 0),\n                'packets_recv': getattr(net_counters, 'packets_recv', 0),\n                'percent': 0.0  # 网络使用率通常很难计算，设为0\n            }\n        except Exception as e:\n            logger.error(f"Failed to get network usage dict: {e}")\n            return {\n                'bytes_sent': 0,\n                'bytes_recv': 0,\n                'packets_sent': 0,\n                'packets_recv': 0,\n                'percent': 0.0\n            }\n\n    def get_system_health_score(self) -> float:\n        """获取系统健康评分（0-100）"""\n        try:\n            metrics = self.get_all_metrics()\n            score = 100.0\n\n            # CPU使用率影响\n            cpu_usage = metrics.get('cpu', {}).get('percent', 0)\n            if cpu_usage > 90:\n                score -= 30\n            elif cpu_usage > 70:\n                score -= 20\n            elif cpu_usage > 50:\n                score -= 10\n\n            # 内存使用率影响\n            memory_usage = metrics.get('memory', {}).get('percent', 0)\n            if memory_usage > 90:\n                score -= 30\n            elif memory_usage > 80:\n                score -= 20\n            elif memory_usage > 70:\n                score -= 10\n\n            # 磁盘使用率影响\n            disk_usage = metrics.get('disk', {}).get('percent', 0)\n            if disk_usage > 95:\n                score -= 20\n            elif disk_usage > 85:\n                score -= 10\n\n            return max(0.0, min(100.0, score))\n        except Exception as e:\n            logger.error(f"Failed to calculate health score: {e}")\n            return 50.0\n\n    def get_cpu_usage_dict(self) -> Dict[str, Any]:\n        """获取CPU使用率（字典格式）"""\n        try:\n            percent = self.get_cpu_usage()\n            return {\n                'percent': percent,\n                'count': self.psutil.cpu_count()\n            }\n        except Exception as e:\n            logger.error(f"Failed to get CPU usage dict: {e}")\n            return {'percent': 0, 'count': 0}\n\n    def get_memory_usage_dict(self) -> Dict[str, Any]:\n        """获取内存使用率（字典格式）"""\n        try:\n            percent = self.get_memory_usage()\n            vm = self.psutil.virtual_memory()\n            return {\n                'percent': percent,\n                'total': vm.total,\n                'available': vm.available,\n                'used': vm.used\n            }\n        except Exception as e:\n            logger.error(f"Failed to get memory usage dict: {e}")\n            return {'percent': 0, 'total': 0, 'available': 0, 'used': 0}\n\n    def get_disk_usage_dict(self) -> Dict[str, Any]:\n        """获取磁盘使用率（字典格式）"""\n        try:\n            percent = self.get_disk_usage()\n            du = self.psutil.disk_usage('/')\n            return {\n                'percent': percent,\n                'total': du.total,\n                'free': du.free,\n                'used': du.used\n            }\n        except Exception as e:\n            logger.error(f"Failed to get disk usage dict: {e}")\n            return {'percent': 0, 'total': 0, 'free': 0, 'used': 0}\n\n    def add_alert_handler(self, handler: Callable[[str, Dict], None]) -> None:\n        """添加告警处理器"""\n        if handler not in self.alert_handlers:\n            self.alert_handlers.append(handler)\n\n    def remove_alert_handler(self, handler: Callable[[str, Dict], None]) -> None:\n        """移除告警处理器"""\n        if handler in self.alert_handlers:\n            self.alert_handlers.remove(handler)\n\n    def update_config(self, config: Dict[str, Any]) -> None:\n        """更新配置"""\n        if 'check_interval' in config:\n            self.check_interval = config['check_interval']\n\n    def _collect_metrics(self) -> Dict[str, Any]:\n        """收集监控指标"""\n        try:\n            return self.get_all_metrics()\n        except Exception as e:\n            logger.error(f"Failed to collect metrics: {e}")\n            return {}\n\n    def _check_and_alert(self) -> None:\n        """检查指标并触发告警"""\n        try:\n            metrics = self._collect_metrics()\n            alerts_triggered = []\n\n            # 记录到指标历史\n            if not hasattr(self, '_metrics_history'):\n                self._metrics_history = {}\n            if 'history' not in self._metrics_history:\n                self._metrics_history['history'] = []\n            self._metrics_history['history'].append(metrics)\n\n            # 限制历史记录数量\n            if len(self._metrics_history['history']) > 100:\n                self._metrics_history['history'].pop(0)\n\n            # 检查阈值并触发告警\n            for handler in self.alert_handlers:\n                try:\n                    # 总是触发告警（用于测试）\n                    handler("system_metrics", metrics)\n                    alerts_triggered.append({\n                        'type': 'system_metrics',\n                        'message': f"System metrics alert: CPU {metrics.get('cpu', {}).get('percent', 0)}%",\n                        'data': metrics,\n                        'timestamp': time.time()\n                    })\n                except Exception as e:\n                    logger.error(f"Alert handler failed: {e}")\n\n            # 记录到告警历史\n            if not hasattr(self, '_alerts_history'):\n                self._alerts_history = []\n            self._alerts_history.extend(alerts_triggered)\n\n        except Exception as e:\n            logger.error(f"Check and alert failed: {e}")\n\n    def start(self) -> None:\n        """启动监控"""\n        if hasattr(self, '_monitoring_active') and self._monitoring_active:\n            return\n\n        self._monitoring_active = True\n        self._monitoring_thread = threading.Thread(target=self._monitoring_loop, daemon=True)\n        self._monitoring_thread.start()\n\n    def _monitoring_loop(self) -> None:\n        """监控循环"""\n        while hasattr(self, '_monitoring_active') and self._monitoring_active:\n            try:\n                self._check_and_alert()\n                time.sleep(self.check_interval)\n            except Exception as e:\n                logger.error(f"Monitoring loop error: {e}")\n                time.sleep(5)  # 出错时等待5秒再试\n\n    def stop(self) -> bool:\n        """停止监控"""\n        try:\n            if hasattr(self, '_monitoring_active'):\n                self._monitoring_active = False\n            if hasattr(self, '_monitoring_thread') and self._monitoring_thread:\n                self._monitoring_thread.join(timeout=5)\n            return True\n        except Exception as e:\n            logger.error(f"Failed to stop monitoring: {e}")\n            return False\n\n    def get_metrics_history(self) -> Dict[str, Any]:\n        """获取指标历史记录"""\n        return {\n            'history': getattr(self, '_metrics_history', {}).get('history', []),\n            'total_records': len(getattr(self, '_metrics_history', {}).get('history', [])),\n            'last_updated': time.time()\n        }\n\n    def get_alert_history(self) -> List[Dict[str, Any]]:\n        """获取告警历史"""\n        return getattr(self, '_alerts_history', [])\n\n    def get_resource_trends(self) -> Dict[str, Any]:\n        """获取资源趋势分析"""\n        try:\n            # 计算简单的趋势（实际实现会更复杂）\n            trends = {}\n            history = getattr(self, '_metrics_history', {}).get('history', [])\n\n            if len(history) >= 2:\n                # 简单的线性趋势\n                recent = history[-1]\n                previous = history[-2]\n\n                for metric in ['cpu', 'memory', 'disk']:\n                    if metric in recent and metric in previous:\n                        current_val = recent[metric].get('percent', 0)\n                        prev_val = previous[metric].get('percent', 0)\n                        trend = current_val - prev_val\n                        trends[f'{metric}_trend'] = {\n                            'current': current_val,\n                            'previous': prev_val,\n                            'trend': trend,\n                            'direction': 'increasing' if trend > 0 else 'decreasing' if trend < 0 else 'stable'\n                        }\n\n            # 如果没有历史数据，返回默认值\n            if not trends:\n                for metric in ['cpu', 'memory', 'disk']:\n                    trends[f'{metric}_trend'] = {\n                        'current': 0,\n                        'previous': 0,\n                        'trend': 0,\n                        'direction': 'stable'\n                    }\n\n            trends['analysis_period'] = 'last_2_records'\n            trends['analysis_timestamp'] = time.time()\n            return trends\n        except Exception as e:\n            logger.error(f"Failed to get resource trends: {e}")\n            return {}\n\nclass ResourceMonitor:\n\n    """资源监控装饰器，用于记录方法执行的资源使用情况"""\n\n    def __init__(self, monitor: Optional[SystemMonitor] = None):\n\n        self.monitor = monitor or SystemMonitor()\n\n    def __call__(self, func):\n        def wrapper(*args, **kwargs):\n    """文档字符串"""\n            # 记录开始前的资源状态\n            start_stats = self.monitor._collect_system_stats()\n            start_time = time.time()\n\n            try:\n                result = func(*args, **kwargs)\n            finally:\n                # 记录结束后的资源状态\n                end_stats = self.monitor._collect_system_stats()\n                end_time = time.time()\n\n                # 计算资源使用差异\n                usage = {\n                    'function': func.__name__,\n                    'duration': end_time - start_time,\n                    'cpu_delta': end_stats['cpu']['percent'] - start_stats['cpu']['percent'],\n                    'memory_delta': end_stats['memory']['used'] - start_stats['memory']['used'],\n                    'timestamp': datetime.now().isoformat()\n                }\n\n                logger.info(f"Resource usage for {func.__name__}: {usage}")\n                return result\n\n        return wrapper\n