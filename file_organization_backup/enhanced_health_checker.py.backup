#!/usr/bin/env python3\n"""\n增强健康检查器实现\n提供高级的健康检查功能，包括性能监控、智能诊断、预测性检查等\n"""\n\nfrom collections import defaultdict, deque\nfrom datetime import datetime, timedelta\nfrom typing import Dict, Any, Optional, Callable, List\nimport json\nimport logging\nimport threading\nimport time\n\nimport psutil\n\nfrom .interfaces import IHealthChecker\nfrom .health_status import HealthStatus\nfrom .health_result import HealthCheckResult, ServiceHealthProfile, CheckType\n\nlogger = logging.getLogger(__name__)\n\nclass EnhancedHealthChecker(IHealthChecker):\n\n    """增强健康检查器"""\n\n    def __init__(self, config: Optional[Dict[str, Any]] = None):\n\n        """\n        初始化增强健康检查器\n\n        Args:\n            config: 配置字典\n        """\n        self.config = config or {}\n        self._services: Dict[str, ServiceHealthProfile] = {}\n        self._checkers: Dict[str, Callable] = {}\n        self._monitoring = False\n\n        # 配置验证和默认值设置\n        self._check_interval = self._validate_config_value('check_interval', 30, min_value=1, max_value=3600)\n        self._timeout = self._validate_config_value('timeout', 10, min_value=1, max_value=300)\n\n        # 增强功能配置\n        self._enable_performance_monitoring = self.config.get('performance_monitoring', True)\n        self._enable_predictive_checks = self.config.get('predictive_checks', True)\n        self._enable_auto_recovery = self.config.get('auto_recovery', False)\n\n        # 性能监控数据\n        self._performance_history = deque(maxlen=1000)\n        self._health_trends = defaultdict(list)\n        self._alert_thresholds = self.config.get('alert_thresholds', {})\n\n        # 线程安全\n        self._lock = threading.RLock()\n        self._monitor_thread: Optional[threading.Thread] = None\n\n        # 默认检查器\n        self._register_default_checkers()\n\n        logger.info("增强健康检查器已初始化")\n\n    def _validate_config_value(self, key: str, default_value: Any, min_value: Optional[Any] = None, max_value: Optional[Any] = None) -> Any:\n        """\n        验证配置值并返回有效值\n\n        Args:\n            key: 配置键\n            default_value: 默认值\n            min_value: 最小值（可选）\n            max_value: 最大值（可选）\n\n        Returns:\n            Any: 验证后的配置值\n        """\n        value = self.config.get(key, default_value)\n\n        # 类型检查\n        if not isinstance(value, type(default_value)):\n            logger.warning(f"配置 {key} 类型无效，使用默认值 {default_value}")\n            return default_value\n\n        # 范围检查\n        if min_value is not None and value < min_value:\n            logger.warning(f"配置 {key} 值 {value} 小于最小值 {min_value}，使用默认值 {default_value}")\n            return default_value\n\n        if max_value is not None and value > max_value:\n            logger.warning(f"配置 {key} 值 {value} 大于最大值 {max_value}，使用默认值 {default_value}")\n            return default_value\n\n        return value\n\n    def _register_default_checkers(self):\n    """文档字符串"""\n\n        """注册默认检查器"""\n        # 系统资源检查器\n        self.register_checker('system_resources', self._check_system_resources)\n\n        # 内存使用检查器\n        self.register_checker('memory_usage', self._check_memory_usage)\n\n        # 磁盘空间检查器\n        self.register_checker('disk_space', self._check_disk_space)\n\n        # 网络连接检查器\n        self.register_checker('network_connectivity', self._check_network_connectivity)\n\n        # 服务依赖检查器\n        self.register_checker('service_dependencies', self._check_service_dependencies)\n\n    def register_service(self, service_name: str, check_function: Callable,\n    """文档字符串"""\n\n                         config: Optional[Dict[str, Any]] = None) -> bool:\n        """\n        注册服务进行健康检查\n\n        Args:\n            service_name: 服务名称\n            check_function: 检查函数或URL字符串\n            config: 服务配置\n\n        Returns:\n            bool: 注册是否成功\n        """\n        try:\n            with self._lock:\n                # 如果传入的是字符串，当作URL处理\n                if isinstance(check_function, str):\n                    url = check_function\n                    # 创建一个检查URL的函数\n                    def url_check():\n    """文档字符串"""\n                        return self._check_url(url)\n                    actual_check_function = url_check\n                else:\n                    actual_check_function = check_function\n                    url = None\n\n                profile = ServiceHealthProfile(\n                    service_name=service_name,\n                    current_status=HealthStatus.UNKNOWN,\n                    last_check=datetime.now(),\n                    check_function=actual_check_function\n                )\n                # 为测试兼容性添加url属性\n                if url:\n                    profile.url = url\n                self._services[service_name] = profile\n                logger.info(f"服务 {service_name} 已注册健康检查")\n                return True\n        except Exception as e:\n            logger.error(f"注册服务 {service_name} 失败: {e}")\n            return False\n\n    def unregister_service(self, service_name: str) -> bool:\n    """文档字符串"""\n\n        """\n        取消注册服务\n\n        Args:\n            service_name: 服务名称\n\n        Returns:\n            bool: 取消注册是否成功\n        """\n        try:\n            with self._lock:\n                if service_name in self._services:\n                    del self._services[service_name]\n                    logger.info(f"服务 {service_name} 已取消注册")\n                    return True\n                return False\n        except Exception as e:\n            logger.error(f"取消注册服务 {service_name} 失败: {e}")\n            return False\n\n    def register_checker(self, checker_name: str, checker_function: Callable) -> bool:\n    """文档字符串"""\n\n        """\n        注册自定义检查器\n\n        Args:\n            checker_name: 检查器名称\n            checker_function: 检查器函数\n\n        Returns:\n            bool: 注册是否成功\n        """\n        try:\n            with self._lock:\n                self._checkers[checker_name] = checker_function\n                logger.info(f"检查器 {checker_name} 已注册")\n                return True\n        except Exception as e:\n            logger.error(f"注册检查器 {checker_name} 失败: {e}")\n            return False\n\n    def check_health(self) -> Dict[str, Any]:\n        """\n        执行健康检查（兼容测试接口）\n\n        Returns:\n            Dict[str, Any]: 健康检查结果，包含服务检查和注册检查器结果\n        """\n        results = {}\n\n        try:\n            with self._lock:\n                # 执行注册的检查器\n                for checker_name, checker_func in self._checkers.items():\n                    try:\n                        result = checker_func()\n                        results[checker_name] = result\n                    except Exception as e:\n                        logger.error(f"检查器 {checker_name} 执行失败: {e}")\n                        results[checker_name] = {\n                            'status': 'unhealthy',\n                            'error': str(e),\n                            'response_time': 0.0,\n                            'timestamp': time.time()\n                        }\n\n                # 执行服务检查\n                for service_name, service_profile in self._services.items():\n                    try:\n                        result = self.perform_health_check(service_name)\n                        results[service_name] = result\n                    except Exception as e:\n                        logger.error(f"服务 {service_name} 检查失败: {e}")\n                        # 创建一个失败的HealthCheckResult\n                        results[service_name] = HealthCheckResult(\n                            service_name=service_name,\n                            check_type=CheckType.AVAILABILITY,\n                            status=HealthStatus.DOWN,\n                            timestamp=datetime.now(),\n                            response_time=0.0,\n                            error_message=str(e)\n                        )\n\n        except Exception as e:\n            logger.error(f"健康检查执行失败: {e}")\n            results = {\n                'error': str(e)\n            }\n\n        # 添加整体状态信息\n        overall_status = 'healthy'\n        if any(isinstance(result, dict) and result.get('status') == 'unhealthy' for result in results.values()):\n            overall_status = 'unhealthy'\n        elif any(isinstance(result, HealthCheckResult) and result.status == HealthStatus.DOWN for result in results.values()):\n            overall_status = 'unhealthy'\n\n        results['status'] = overall_status\n        results['timestamp'] = time.time()\n        results['component'] = 'enhanced_health_checker'\n\n        return results\n\n    def perform_health_check(self, service_name: str, check_type: CheckType = CheckType.AVAILABILITY) -> HealthCheckResult:\n    """文档字符串"""\n\n        """\n        执行健康检查\n\n        Args:\n            service_name: 服务名称\n            check_type: 检查类型\n\n        Returns:\n            HealthCheckResult: 健康检查结果\n        """\n        start_time = time.time()\n\n        try:\n            with self._lock:\n                if service_name not in self._services:\n                    return HealthCheckResult(\n                        service_name=service_name,\n                        check_type=check_type,\n                        status=HealthStatus.UNKNOWN,\n                        timestamp=datetime.now(),\n                        response_time=time.time() - start_time,\n                        error_message=f"服务 {service_name} 未注册"\n                    )\n\n                service = self._services[service_name]\n                service.last_check = datetime.now()\n\n                # 执行检查\n                if check_type == CheckType.AVAILABILITY:\n                    result = self._perform_basic_check(service)\n                elif check_type == CheckType.DETAILED:\n                    result = self._perform_detailed_check(service)\n                elif check_type == CheckType.PERFORMANCE:\n                    result = self._perform_performance_check(service)\n                else:\n                    result = HealthCheckResult(\n                        service_name=service_name,\n                        status=HealthStatus.UNKNOWN,\n                        message=f"不支持的检查类型: {check_type}",\n                        response_time=time.time() - start_time,\n                        timestamp=datetime.now()\n                    )\n\n                # 更新服务状态\n                service.current_status = result.status\n                if result.status != HealthStatus.UP:\n                    service.consecutive_failures += 1\n                else:\n                    service.consecutive_failures = 0\n\n                # 记录性能数据\n                if self._enable_performance_monitoring:\n                    self._record_performance_data(service_name, result)\n\n                return result\n\n        except Exception as e:\n            response_time = time.time() - start_time\n            logger.error(f"健康检查 {service_name} 异常: {e}")\n            return HealthCheckResult(\n                service_name=service_name,\n                check_type=check_type,\n                status=HealthStatus.DOWN,\n                timestamp=datetime.now(),\n                response_time=response_time,\n                error_message=f"检查异常: {str(e)}"\n            )\n\n    def _perform_basic_check(self, service: ServiceHealthProfile) -> HealthCheckResult:\n    """文档字符串"""\n\n        """执行基本检查"""\n        try:\n            result = service.check_function()\n            if isinstance(result, dict):\n                status_str = result.get('status', 'unknown')\n                if isinstance(status_str, str):\n                    if status_str.lower() in ['healthy', 'up', 'ok']:\n                        status = HealthStatus.UP\n                    elif status_str.lower() in ['unhealthy', 'down', 'fail']:\n                        status = HealthStatus.DOWN\n                    else:\n                        status = HealthStatus.UNKNOWN\n                else:\n                    status = status_str\n                message = result.get('message', '检查完成')\n                details = result.get('details', {})\n            else:\n                status = HealthStatus.UP if result else HealthStatus.DOWN\n                message = '检查通过' if result else '检查失败'\n                details = {}\n\n            return HealthCheckResult(\n                service_name=service.service_name,\n                check_type=CheckType.AVAILABILITY,\n                status=status,\n                timestamp=datetime.now(),\n                response_time=0.0,  # 会在外层设置\n                details=details\n            )\n        except Exception as e:\n            return HealthCheckResult(\n                service_name=service.service_name,\n                check_type=CheckType.AVAILABILITY,\n                status=HealthStatus.DOWN,\n                timestamp=datetime.now(),\n                response_time=0.0,\n                error_message=f"基本检查异常: {str(e)}"\n            )\n\n    def _perform_detailed_check(self, service: ServiceHealthProfile) -> HealthCheckResult:\n    """文档字符串"""\n\n        """执行详细检查"""\n        result = self._perform_basic_check(service)\n\n        # 添加系统资源信息\n        if result.status == HealthStatus.UP:\n            system_info = self._get_system_info()\n            result.details.update({\n                'system_info': system_info,\n                'check_type': 'detailed'\n            })\n\n        return result\n\n    def _perform_performance_check(self, service: ServiceHealthProfile) -> HealthCheckResult:\n    """文档字符串"""\n\n        """执行性能检查"""\n        start_time = time.time()\n        result = self._perform_basic_check(service)\n        response_time = time.time() - start_time\n\n        # 添加性能指标\n        result.details.update({\n            'performance_metrics': {\n                'execution_time': response_time,\n                'memory_usage': psutil.virtual_memory().percent,\n                'cpu_usage': psutil.cpu_percent(interval=0.1)\n            },\n            'check_type': 'performance'\n        })\n\n        return result\n\n    def get_service_status(self, service_name: str) -> Optional[HealthCheckResult]:\n    """文档字符串"""\n\n        """\n        获取服务状态\n\n        Args:\n            service_name: 服务名称\n\n        Returns:\n            Optional[HealthStatus]: 服务状态\n        """\n        with self._lock:\n            service = self._services.get(service_name)\n            if service:\n                # 返回最后一次检查结果\n                if service.check_history:\n                    return service.check_history[-1]\n                else:\n                    # 如果没有检查历史，返回默认结果\n                    return HealthCheckResult(\n                        service_name=service_name,\n                        check_type=CheckType.AVAILABILITY,\n                        status=service.current_status,\n                        timestamp=datetime.now(),\n                        response_time=0.0\n                    )\n            return None\n\n    def get_all_service_status(self) -> Dict[str, HealthStatus]:\n    """文档字符串"""\n\n        """\n        获取所有服务状态\n\n        Returns:\n            Dict[str, HealthStatus]: 服务状态字典\n        """\n        with self._lock:\n            return {name: service.current_status for name, service in self._services.items()}\n\n    def start_monitoring(self) -> bool:\n    """文档字符串"""\n\n        """\n        启动监控\n\n        Returns:\n            bool: 启动是否成功\n        """\n        try:\n            with self._lock:\n                if self._monitoring:\n                    return True\n\n                self._monitoring = True\n                self._monitor_thread = threading.Thread(target=self._monitoring_loop, daemon=True)\n                self._monitor_thread.start()\n\n                logger.info("健康检查监控已启动")\n                return True\n        except Exception as e:\n            logger.error(f"启动监控失败: {e}")\n            return False\n\n    def stop_monitoring(self) -> bool:\n    """文档字符串"""\n\n        """\n        停止监控\n\n        Returns:\n            bool: 停止是否成功\n        """\n        try:\n            with self._lock:\n                if not self._monitoring:\n                    return True\n\n                self._monitoring = False\n                if self._monitor_thread and self._monitor_thread.is_alive():\n                    self._monitor_thread.join(timeout=5)\n\n                logger.info("健康检查监控已停止")\n                return True\n        except Exception as e:\n            logger.error(f"停止监控失败: {e}")\n            return False\n\n    def _monitoring_loop(self):\n    """文档字符串"""\n\n        """监控循环"""\n        while self._monitoring:\n            try:\n                # 执行所有服务的健康检查\n                for service_name in list(self._services.keys()):\n                    self.perform_health_check(service_name)\n\n                    # 检查告警阈值\n                    if self._enable_predictive_checks:\n                        self._check_alert_thresholds(service_name)\n\n                # 等待下一个检查周期\n                time.sleep(self._check_interval)\n\n            except Exception as e:\n                logger.error(f"监控循环异常: {e}")\n                time.sleep(5)  # 异常情况下等待5秒后重试\n\n    def _check_system_resources(self) -> HealthCheckResult:\n    """文档字符串"""\n\n        """检查系统资源"""\n        try:\n            cpu_percent = psutil.cpu_percent(interval=1)\n            memory = psutil.virtual_memory()\n            disk = psutil.disk_usage('/')\n\n            # 检查阈值\n            if cpu_percent > 90 or memory.percent > 90 or disk.percent > 95:\n                status = HealthStatus.DOWN\n                message = '系统资源使用率过高'\n            else:\n                status = HealthStatus.UP\n                message = '系统资源正常'\n\n            return HealthCheckResult(\n                service_name='system_resources',\n                check_type=CheckType.SYSTEM,\n                status=status,\n                response_time=0.1,\n                timestamp=datetime.now(),\n                details={\n                    'cpu_usage': cpu_percent,\n                    'memory_usage': memory.percent,\n                    'disk_usage': disk.percent,\n                    'memory_total': memory.total,\n                    'memory_used': memory.used,\n                    'memory_free': memory.available,\n                    'disk_total': disk.total,\n                    'disk_used': disk.used,\n                    'disk_free': disk.free\n                },\n                error_message=message if status == HealthStatus.DOWN else None\n            )\n        except Exception as e:\n            return HealthCheckResult(\n                service_name='system_resources',\n                check_type=CheckType.SYSTEM,\n                status=HealthStatus.DOWN,\n                response_time=0.1,\n                timestamp=datetime.now(),\n                details={},\n                error_message=f'系统资源检查失败: {str(e)}'\n            )\n\n    def _check_memory_usage(self) -> HealthCheckResult:\n    """文档字符串"""\n\n        """检查内存使用"""\n        try:\n            memory = psutil.virtual_memory()\n            status = HealthStatus.UP if memory.percent < 90 else HealthStatus.DOWN\n\n            return HealthCheckResult(\n                service_name="system_memory",\n                check_type=CheckType.SYSTEM,\n                status=status,\n                timestamp=datetime.now(),\n                response_time=0.0,\n                details={\n                    'memory_total': memory.total,\n                    'memory_used': memory.used,\n                    'memory_free': memory.free,\n                    'memory_percent': memory.percent\n                }\n            )\n        except Exception as e:\n            return HealthCheckResult(\n                service_name="system_memory",\n                check_type=CheckType.SYSTEM,\n                status=HealthStatus.DOWN,\n                timestamp=datetime.now(),\n                response_time=0.0,\n                error_message=f'内存检查失败: {str(e)}',\n                details={}\n            )\n\n    def _check_disk_space(self) -> HealthCheckResult:\n    """文档字符串"""\n\n        """检查磁盘空间"""\n        try:\n            disk = psutil.disk_usage('/')\n            status = HealthStatus.UP if disk.percent < 90 else HealthStatus.DOWN\n            details = {\n                'disk_total': disk.total,\n                'disk_used': disk.used,\n                'disk_free': disk.free,\n                'disk_usage': disk.percent,  # 百分比作为usage\n                'free_space': disk.free      # 可用空间\n            }\n\n            return HealthCheckResult(\n                service_name='disk_space',\n                check_type=CheckType.SYSTEM,  # 系统检查\n                status=status,\n                timestamp=datetime.now(),\n                response_time=0.0,\n                details=details\n            )\n        except Exception as e:\n            return HealthCheckResult(\n                service_name='disk_space',\n                check_type=CheckType.SYSTEM,  # 系统检查\n                status=HealthStatus.DOWN,\n                timestamp=datetime.now(),\n                response_time=0.0,\n                error_message=f'磁盘检查失败: {str(e)}'\n            )\n\n    def _check_url(self, url: str) -> HealthCheckResult:\n        """\n        检查URL是否可访问\n\n        Args:\n            url: 要检查的URL\n\n        Returns:\n            HealthCheckResult: 检查结果\n        """\n        import requests\n        import time\n\n        start_time = time.time()\n        try:\n            response = requests.get(url, timeout=self._timeout)\n            response_time = time.time() - start_time\n\n            if response.status_code == 200:\n                return HealthCheckResult(\n                    service_name=url,\n                    check_type=CheckType.AVAILABILITY,\n                    status=HealthStatus.UP,\n                    timestamp=datetime.now(),\n                    response_time=response_time,\n                    details={'status_code': response.status_code}\n                )\n            else:\n                return HealthCheckResult(\n                    service_name=url,\n                    check_type=CheckType.AVAILABILITY,\n                    status=HealthStatus.DOWN,\n                    timestamp=datetime.now(),\n                    response_time=response_time,\n                    error_message=f'HTTP {response.status_code}'\n                )\n        except Exception as e:\n            response_time = time.time() - start_time\n            return HealthCheckResult(\n                service_name=url,\n                check_type=CheckType.AVAILABILITY,\n                status=HealthStatus.DOWN,\n                timestamp=datetime.now(),\n                response_time=response_time,\n                error_message=str(e)\n            )\n\n    def _check_network_connectivity(self) -> HealthCheckResult:\n    """文档字符串"""\n\n        """检查网络连接"""\n        try:\n            # 简单的网络连接检查\n            import socket\n            socket.create_connection(("8.8.8.8", 53), timeout=5)\n            return HealthCheckResult(\n                service_name="network_connectivity",\n                check_type=CheckType.AVAILABILITY,\n                status=HealthStatus.UP,\n                timestamp=datetime.now(),\n                response_time=0.0,\n                details={'network_status': 'connected'}\n            )\n        except Exception as e:\n            return HealthCheckResult(\n                service_name="network_connectivity",\n                check_type=CheckType.AVAILABILITY,\n                status=HealthStatus.DOWN,\n                timestamp=datetime.now(),\n                response_time=0.0,\n                error_message=f'网络连接检查失败: {str(e)}',\n                details={'network_status': 'disconnected'}\n            )\n\n    def _check_service_dependencies(self) -> HealthCheckResult:\n    """文档字符串"""\n\n        """检查服务依赖"""\n        # 这里可以实现具体的服务依赖检查逻辑\n        return HealthCheckResult(\n            service_name="service_dependencies",\n            check_type=CheckType.AVAILABILITY,\n            status=HealthStatus.UP,\n            timestamp=datetime.now(),\n            response_time=0.0,\n            details={'dependencies_status': 'ok'}\n        )\n\n    def _record_performance_data(self, service_name: str, result: HealthCheckResult):\n    """文档字符串"""\n\n        """记录性能数据"""\n        if not self._enable_performance_monitoring:\n            return\n\n        data = {\n            'service_name': service_name,\n            'timestamp': datetime.now(),\n            'execution_time': result.response_time,\n            'status': result.status.value,\n            'memory_usage': psutil.virtual_memory().percent,\n            'cpu_usage': psutil.cpu_percent(interval=0.1)\n        }\n\n        self._performance_history.append(data)\n\n        # 更新趋势数据\n        self._health_trends[service_name].append({\n            'timestamp': datetime.now(),\n            'status': result.status.value,\n            'execution_time': result.response_time\n        })\n\n        # 保持趋势数据在合理范围内\n        if len(self._health_trends[service_name]) > 100:\n            self._health_trends[service_name].pop(0)\n\n    def _check_alert_thresholds(self, service_name: str):\n    """文档字符串"""\n\n        """检查告警阈值"""\n        if service_name not in self._health_trends:\n            return\n\n        trends = self._health_trends[service_name]\n        if len(trends) < 5:  # 需要足够的样本\n            return\n\n        # 检查连续失败次数\n        recent_failures = sum(1 for t in trends[-5:] if t['status'] != 'healthy')\n        if recent_failures >= 3:\n            logger.warning(f"服务 {service_name} 连续失败次数过多: {recent_failures}")\n\n        # 检查性能下降趋势\n        recent_times = [t['response_time'] if 'response_time' in t else t['execution_time'] for t in trends[-10:]]\n        if len(recent_times) >= 5:\n            avg_recent = sum(recent_times[-3:]) / 3\n            avg_older = sum(recent_times[:-3]) / (len(recent_times) - 3)\n\n        if avg_recent > avg_older * 2:  # 性能下降超过2倍\n            logger.warning(f"服务 {service_name} 性能明显下降")\n\n    def _get_system_info(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取系统信息"""\n        try:\n            return {\n                'cpu_count': psutil.cpu_count(),\n                'cpu_percent': psutil.cpu_percent(interval=0.1),\n                'memory': dict(psutil.virtual_memory()._asdict()),\n                'disk': dict(psutil.disk_usage('/')._asdict()),\n                'boot_time': psutil.boot_time()\n            }\n        except Exception as e:\n            return {'error': str(e)}\n\n    def get_performance_metrics(self, service_name: Optional[str] = None) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取性能指标\n\n        Args:\n            service_name: 服务名称，为None时返回所有服务\n\n        Returns:\n            Dict[str, Any]: 性能指标\n        """\n        # 计算聚合指标\n        total_checks = len(self._performance_history)\n        avg_response_time = 0.0\n        healthy_services = 0\n\n        if self._performance_history:\n            response_times = [m.get('response_time', 0) for m in self._performance_history if 'response_time' in m]\n            if response_times:\n                avg_response_time = sum(response_times) / len(response_times)\n\n            # 计算健康服务数量\n            healthy_services = sum(1 for m in self._performance_history\n                                 if m.get('status') == HealthStatus.UP)\n\n        metrics = {\n            'total_checks': total_checks,\n            'avg_response_time': avg_response_time,\n            'healthy_services': healthy_services,\n            'total_services': len(self._services),\n            'all_services': list(self._performance_history),\n            'trends': dict(self._health_trends)\n        }\n\n        if service_name:\n            service_metrics = [m for m in self._performance_history if m.get('service_name') == service_name]\n            metrics.update({\n                'service_name': service_name,\n                'service_metrics': service_metrics\n            })\n\n        return metrics\n\n    def get_health_summary(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取健康摘要\n\n        Returns:\n            Dict[str, Any]: 健康摘要\n        """\n        with self._lock:\n            total_services = len(self._services)\n            healthy_services = sum(1 for s in self._services.values() if s.current_status == HealthStatus.UP)\n            unhealthy_services = sum(1 for s in self._services.values() if s.current_status == HealthStatus.DOWN)\n\n            return {\n                'total_services': total_services,\n                'healthy_services': healthy_services,\n                'unhealthy_services': unhealthy_services,\n                'unknown_services': total_services - healthy_services - unhealthy_services,\n                'overall_status': HealthStatus.UP if unhealthy_services == 0 else HealthStatus.DOWN,\n                'last_check': datetime.now(),\n                'monitoring_active': self._monitoring\n            }\n\n    def get_health_trends(self) -> Dict[str, Any]:\n        """\n        获取健康趋势分析\n\n        Returns:\n            Dict[str, Any]: 健康趋势数据\n        """\n        with self._lock:\n            trends = {}\n            for service_name in self._services:\n                # 计算服务健康趋势\n                recent_checks = [s for s in self._performance_history if s['service_name'] == service_name]\n                if len(recent_checks) >= 2:\n                    recent_statuses = [check.get('status') for check in recent_checks[-10:]]\n                    healthy_count = sum(1 for status in recent_statuses if status == HealthStatus.UP.value)\n\n                    # 趋势分析\n                    if len(recent_statuses) >= 5:\n                        recent_healthy_ratio = healthy_count / len(recent_statuses)\n                        older_statuses = recent_statuses[:-5]\n                        if len(older_statuses) > 0:\n                            older_healthy_ratio = sum(1 for status in older_statuses if status == HealthStatus.UP.value) / len(older_statuses)\n                        else:\n                            older_healthy_ratio = recent_healthy_ratio\n\n                        if recent_healthy_ratio > older_healthy_ratio + 0.2:\n                            trend = "improving"\n                        elif recent_healthy_ratio < older_healthy_ratio - 0.2:\n                            trend = "degrading"\n                        else:\n                            trend = "stable"\n                    else:\n                        trend = "insufficient_data"\n\n                    trends[service_name] = {\n                        'trend': trend,\n                        'healthy_ratio': healthy_count / len(recent_statuses) if recent_statuses else 0,\n                        'total_checks': len(recent_checks),\n                        'recent_checks': len(recent_statuses)\n                    }\n                else:\n                    trends[service_name] = {\n                        'trend': 'insufficient_data',\n                        'healthy_ratio': 0,\n                        'total_checks': len(recent_checks),\n                        'recent_checks': 0\n                    }\n\n            return trends\n\n    def get_predictive_insights(self) -> Dict[str, Any]:\n        """\n        获取预测性洞察\n\n        Returns:\n            Dict[str, Any]: 预测性洞察数据\n        """\n        with self._lock:\n            insights = {\n                'predictions': {},\n                'risk_assessments': {},\n                'recommendations': []\n            }\n\n            for service_name in self._services:\n                # 基于历史数据进行预测\n                recent_checks = [s for s in self._performance_history if s['service_name'] == service_name]\n\n                if len(recent_checks) >= 5:\n                    # 计算健康率趋势\n                    healthy_counts = []\n                    for i in range(len(recent_checks) - 4):\n                        window = recent_checks[i:i+5]\n                        healthy_count = sum(1 for check in window if check.get('status') == HealthStatus.UP.value)\n                        healthy_counts.append(healthy_count / 5)\n\n                    # 简单趋势预测\n                    if len(healthy_counts) >= 3:\n                        recent_trend = sum(healthy_counts[-3:]) / 3\n                        overall_trend = sum(healthy_counts) / len(healthy_counts)\n\n                        if recent_trend < 0.7 and recent_trend < overall_trend - 0.1:\n                            insights['predictions'][service_name] = {\n                                'risk_level': 'high',\n                                'predicted_status': 'degrading',\n                                'confidence': 0.8\n                            }\n                            insights['recommendations'].append(f"考虑增加服务 {service_name} 的监控频率")\n                        elif recent_trend > 0.9:\n                            insights['predictions'][service_name] = {\n                                'risk_level': 'low',\n                                'predicted_status': 'stable',\n                                'confidence': 0.9\n                            }\n                        else:\n                            insights['predictions'][service_name] = {\n                                'risk_level': 'medium',\n                                'predicted_status': 'stable',\n                                'confidence': 0.6\n                            }\n                    else:\n                        insights['predictions'][service_name] = {\n                            'risk_level': 'unknown',\n                            'predicted_status': 'unknown',\n                            'confidence': 0.0\n                        }\n\n                    insights['risk_assessments'][service_name] = {\n                        'failure_probability': 1 - (healthy_counts[-1] if healthy_counts else 0),\n                        'data_points': len(healthy_counts),\n                        'last_updated': datetime.now()\n                    }\n                else:\n                    insights['predictions'][service_name] = {\n                        'risk_level': 'insufficient_data',\n                        'predicted_status': 'unknown',\n                        'confidence': 0.0\n                    }\n                    insights['risk_assessments'][service_name] = {\n                        'failure_probability': 0.5,\n                        'data_points': len(recent_checks),\n                        'last_updated': datetime.now()\n                    }\n\n            return insights\n\n    def check_database_health(self) -> Dict[str, Any]:\n        """\n        检查数据库健康状态\n\n        Returns:\n            Dict[str, Any]: 数据库健康检查结果\n        """\n        try:\n            # 模拟数据库连接检查\n            import time\n            start_time = time.time()\n            # 这里可以添加实际的数据库连接检查逻辑\n            response_time = time.time() - start_time\n\n            return {\n                'status': 'healthy',\n                'response_time': response_time,\n                'connection_count': 10,\n                'active_connections': 5,\n                'timestamp': time.time()\n            }\n        except Exception as e:\n            return {\n                'status': 'unhealthy',\n                'error': str(e),\n                'response_time': 0.0,\n                'timestamp': time.time()\n            }\n\n    def check_external_service(self, service_name: str) -> Dict[str, Any]:\n        """\n        检查外部服务健康状态\n\n        Args:\n            service_name: 外部服务名称\n\n        Returns:\n            Dict[str, Any]: 外部服务健康检查结果\n        """\n        try:\n            import time\n            start_time = time.time()\n            # 这里可以添加实际的外部服务检查逻辑\n            response_time = time.time() - start_time\n\n            return {\n                'status': 'healthy',\n                'service_name': service_name,\n                'response_time': response_time,\n                'endpoint': f'http://{service_name}.example.com',\n                'timestamp': time.time()\n            }\n        except Exception as e:\n            return {\n                'status': 'unhealthy',\n                'service_name': service_name,\n                'error': str(e),\n                'response_time': 0.0,\n                'timestamp': time.time()\n            }\n\n    def check_resource_health(self) -> Dict[str, Any]:\n        """\n        检查系统资源健康状态\n\n        Returns:\n            Dict[str, Any]: 系统资源健康检查结果\n        """\n        try:\n            import psutil\n            import time\n\n            cpu_usage = psutil.cpu_percent(interval=0.1)\n            memory = psutil.virtual_memory()\n            disk = psutil.disk_usage('/')\n\n            return {\n                'cpu_usage': cpu_usage,\n                'memory_usage': memory.percent,\n                'disk_usage': disk.percent,\n                'memory_available': memory.available,\n                'disk_free': disk.free,\n                'status': 'healthy' if cpu_usage < 80 and memory.percent < 85 and disk.percent < 90 else 'warning',\n                'timestamp': time.time()\n            }\n        except Exception as e:\n            return {\n                'cpu_usage': 0.0,\n                'memory_usage': 0.0,\n                'disk_usage': 0.0,\n                'status': 'unhealthy',\n                'error': str(e),\n                'timestamp': time.time()\n            }\n