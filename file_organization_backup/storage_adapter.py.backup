import time\n\n"""\n基础设施层 - 缓存系统组件\n\nstorage_adapter 模块\n\n缓存系统相关的文件\n提供缓存系统相关的功能实现。\n"""\n\nfrom typing import Any, Optional\nfrom .data_version_manager import DataVersionManager\nfrom threading import RLock\n\nclass VersionedStorageAdapter:\n\n    """带版本控制的存储适配器"""\n\n    def __init__(self, base_storage: Any):\n\n        """\n        初始化适配器\n        :param base_storage: 基础存储对象\n        """\n        self._storage = base_storage\n        self._version_manager = DataVersionManager()\n        self._lock = RLock()\n\n    def get(self, key: str, version: Optional[float] = None) -> Any:\n    """文档字符串"""\n\n        """\n        获取数据(可选指定版本)\n        :param key: 数据键\n        :param version: 可选版本时间戳\n        :return: 数据值\n        """\n        with self._lock:\n            if version is not None:\n                # 获取历史版本\n                snapshot = self._version_manager.get_version(version)\n                if snapshot is None:\n                    raise KeyError(f"Version {version} not found")\n                return snapshot.get(key)\n            return self._storage.get(key)\n\n    def set(self, key: str, value: Any) -> float:\n    """文档字符串"""\n\n        """\n        设置数据并创建快照\n        :param key: 数据键\n        :param value: 数据值\n        :return: 快照时间戳\n        """\n        with self._lock:\n            # 更新基础存储\n            self._storage.set(key, value)\n            # 获取更新后的完整状态\n            current_state = self._storage.get_all()\n\n        # 在锁外调用版本管理器方法，避免死锁\n        self._version_manager.record_change(\n            operation="set",\n            key=key,\n            value=value\n        )\n\n        # 创建快照\n        return self._version_manager.take_snapshot(current_state)\n\n    def delete(self, key: str) -> float:\n    """文档字符串"""\n\n        """\n        删除数据并创建快照\n        :param key: 数据键\n        :return: 快照时间戳\n        """\n        with self._lock:\n            current_state = self._storage.get_all()\n            self._storage.delete(key)\n\n        # 在锁外调用版本管理器方法，避免死锁\n        self._version_manager.record_change(\n            operation="delete",\n            key=key\n        )\n\n        return self._version_manager.take_snapshot(current_state)\n\n    def get_history(self, key: str, since: float = 0) -> list:\n    """文档字符串"""\n\n        """\n        获取键的变更历史\n        :param key: 数据键\n        :param since: 起始时间戳\n        :return: 变更记录列表\n        """\n        with self._lock:\n            return [\n                log for log in self._version_manager.get_changelog(since)\n                if log['params'].get('key') == key\n            ]\n\n    def get_version_history(self, key: str) -> list:\n    """文档字符串"""\n\n        """\n        获取键的版本历史\n        :param key: 数据键\n        :return: 版本历史列表\n        """\n        with self._lock:\n            history = []\n            changelog = self._version_manager.get_changelog()\n\n        for log in changelog:\n            if log['params'].get('key') == key:\n                history.append({\n                    'timestamp': log['timestamp'],\n                    'operation': log['operation'],\n                    'value': log['params'].get('value')\n                })\n\n        return history\n\n    def get_latest_version(self, key: str) -> float:\n    """文档字符串"""\n\n        """\n        获取键的最新版本时间戳\n        :param key: 数据键\n        :return: 最新版本时间戳\n        """\n        with self._lock:\n            history = self.get_version_history(key)\n            if not history:\n                raise KeyError(f"Key '{key}' not found")\n            return max(log['timestamp'] for log in history)\n\n    def rollback(self, key: str, version: float) -> bool:\n    """文档字符串"""\n\n        """\n        回滚指定键到指定版本\n        :param key: 数据键\n        :param version: 目标版本时间戳\n        :return: 是否回滚成功\n        """\n        with self._lock:\n            snapshot = self._version_manager.get_version(version)\n            if not snapshot:\n                raise KeyError(f"Version {version} not found")\n\n            if key not in snapshot:\n                raise KeyError(f"Key '{key}' not found in version {version}")\n\n            # 恢复指定键的值\n            self._storage.set(key, snapshot[key])\n\n        # 在锁外调用版本管理器方法，避免死锁\n        self._version_manager.record_change(\n            operation="rollback",\n            key=key,\n            target_version=version\n        )\n\n        return True\n\n    def rollback_global(self, version: float) -> bool:\n    """文档字符串"""\n\n        """\n        全局回滚到指定版本\n        :param version: 目标版本时间戳\n        :return: 是否回滚成功\n        """\n        with self._lock:\n            snapshot = self._version_manager.get_version(version)\n            if not snapshot:\n                return False\n\n            # 先清除当前所有键\n            current_keys = list(self._storage.get_all().keys())\n            for key in current_keys:\n                self._storage.delete(key)\n            # 恢复快照中的所有键值\n            for key, value in snapshot.items():\n                self._storage.set(key, value)\n\n        # 在锁外调用版本管理器方法，避免死锁\n        self._version_manager.record_change(\n            operation="rollback_global",\n            target_version=version\n        )\n\n        return True\n