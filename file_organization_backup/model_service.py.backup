"""\n模型服务实现\n\n提供模型加载、预测、A / B测试等功能，支持多种模型格式。\n"""\n\nfrom typing import Dict, Any, Optional, List, Union\nimport logging\nimport os\nimport pickle\n\nfrom fastapi import FastAPI, HTTPException\nfrom pydantic import BaseModel\nimport joblib\nimport numpy as np\n\nfrom .base_service import BaseService\n\nlogger = logging.getLogger(__name__)\n\nclass PredictionRequest(BaseModel):\n\n    """\nmodel_service - 日志系统\n\n职责说明：\n负责系统日志记录、日志格式化、日志存储和日志分析\n\n核心职责：\n- 日志记录和格式化\n- 日志级别管理\n- 日志存储和轮转\n- 日志分析和监控\n- 日志搜索和过滤\n- 日志性能优化\n\n相关接口：\n- ILoggingComponent\n- ILogger\n- ILogHandler\n""" """预测请求模型"""\n    model_id: str\n    features: Dict[str, Any]\n    request_id: Optional[str] = None\n\nclass PredictionResponse(BaseModel):\n\n    """预测响应模型"""\n    request_id: Optional[str]\n    prediction: float\n    probabilities: Optional[List[float]] = None\n    confidence: Optional[float] = None\n\nclass ModelWrapper:\n\n    """模型包装器"""\n\n    def __init__(self, model_path: str, version: str = "1.0", model_type: str = "sklearn"):\n\n        """\n        初始化模型包装器\n\n        Args:\n            model_path: 模型文件路径\n            version: 模型版本\n            model_type: 模型类型 (sklearn, pytorch, tensorflow等)\n        """\n        self.model_path = model_path\n        self.version = version\n        self.model_type = model_type\n        self.model = None\n        self.feature_names = []\n        self.metadata = {}\n\n        # 加载模型\n        self._load_model()\n\n    def _load_model(self):\n    """文档字符串"""\n\n        """加载模型"""\n        try:\n            if not os.path.exists(self.model_path):\n                raise FileNotFoundError(f"模型文件不存在: {self.model_path}")\n\n            # 根据文件扩展名判断模型类型\n            if self.model_path.endswith('.pkl') or self.model_path.endswith('.joblib'):\n                self.model = joblib.load(self.model_path)\n            elif self.model_path.endswith('.pickle'):\n                with open(self.model_path, 'rb') as f:\n                    self.model = pickle.load(f)\n            else:\n                raise ValueError(f"不支持的模型文件格式: {self.model_path}")\n\n            # 获取特征名称\n            if hasattr(self.model, 'feature_names_in_'):\n                self.feature_names = list(self.model.feature_names_in_)\n            elif hasattr(self.model, 'feature_names'):\n                self.feature_names = self.model.feature_names\n            else:\n                # 如果没有特征名称，使用默认的\n                self.feature_names = [f"feature_{i}" for i in range(10)]\n\n            # 获取模型元数据\n            self.metadata = {\n                "model_type": self.model_type,\n                "version": self.version,\n                "feature_count": len(self.feature_names),\n                "feature_names": self.feature_names\n            }\n\n            logger.info(f"模型加载成功: {self.model_path}")\n\n        except Exception as e:\n            logger.error(f"模型加载失败: {self.model_path}, 错误: {e}")\n            raise\n\n    def predict(self, features: Dict[str, Any]) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        执行预测\n\n        Args:\n            features: 特征字典\n\n        Returns:\n            Dict[str, Any]: 预测结果\n        """\n        try:\n            # 验证特征\n            if not features:\n                raise ValueError("特征不能为空")\n\n            # 构建特征向量\n            feature_vector = []\n            for feature_name in self.feature_names:\n                if feature_name in features:\n                    feature_vector.append(features[feature_name])\n                else:\n                    # 如果缺少特征，使用默认值0\n                    feature_vector.append(0.0)\n\n            # 转换为numpy数组\n            X = np.array([feature_vector])\n\n            # 执行预测\n            prediction = self.model.predict(X)[0]\n\n            # 获取概率（如果模型支持）\n            probabilities = None\n            if hasattr(self.model, 'predict_proba'):\n                proba = self.model.predict_proba(X)[0]\n                probabilities = proba.tolist() if hasattr(proba, 'tolist') else list(proba)\n\n            # 计算置信度\n            confidence = None\n            if probabilities:\n                confidence = max(probabilities)\n\n            return {\n                "prediction": float(prediction),\n                "probabilities": probabilities,\n                "confidence": confidence,\n                "feature_names": self.feature_names\n            }\n\n        except Exception as e:\n            logger.error(f"预测失败: {e}")\n            raise\n\n    def get_info(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取模型信息"""\n        return {\n            "version": self.version,\n            "model_type": self.model_type,\n            "feature_names": self.feature_names,\n            "feature_count": len(self.feature_names),\n            "metadata": self.metadata\n        }\n\nclass ModelService(BaseService):\n\n    """模型服务 - 重构版本"""\n\n    def __init__(self, name: Optional[str] = None):\n\n        """\n        初始化模型服务\n\n        Args:\n            name: 服务名称\n        """\n        super().__init__(name)\n        self.models = {}\n        self.model_configs = {}\n        self.app = FastAPI(title="Model Service API", version="1.0.0")\n        self._register_routes()\n\n    def _start(self) -> bool:\n    """文档字符串"""\n\n        """启动模型服务"""\n        try:\n            logger.info("模型服务启动中...")\n            # 这里可以添加启动逻辑，比如加载默认模型等\n            return True\n        except Exception as e:\n            logger.error(f"模型服务启动失败: {e}")\n            return False\n\n    def _stop(self) -> bool:\n    """文档字符串"""\n\n        """停止模型服务"""\n        try:\n            logger.info("模型服务停止中...")\n            # 清理资源\n            self.models.clear()\n            return True\n        except Exception as e:\n            logger.error(f"模型服务停止失败: {e}")\n            return False\n\n    def _health_check(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """模型服务健康检查"""\n        return {\n            "model_count": len(self.models),\n            "available_models": list(self.models.keys()),\n            "service_type": "model_service"\n        }\n\n    def load_model(self, model_id: str, model_path: str, config: Optional[Dict] = None) -> bool:\n    """文档字符串"""\n\n        """\n        加载模型\n\n        Args:\n            model_id: 模型ID\n            model_path: 模型文件路径\n            config: 模型配置\n\n        Returns:\n            bool: 加载是否成功\n        """\n        try:\n            logger.info(f"正在加载模型: {model_id} -> {model_path}")\n\n            # 创建模型包装器\n            model_wrapper = ModelWrapper(model_path, config.get("version", "1.0") if config else "1.0")\n\n            # 存储模型\n            self.models[model_id] = model_wrapper\n            self.model_configs[model_id] = config or {}\n\n            logger.info(f"模型加载成功: {model_id}")\n            return True\n\n        except Exception as e:\n            logger.error(f"模型加载失败: {model_id}, 错误: {e}")\n            return False\n\n    def unload_model(self, model_id: str) -> bool:\n    """文档字符串"""\n\n        """\n        卸载模型\n\n        Args:\n            model_id: 模型ID\n\n        Returns:\n            bool: 卸载是否成功\n        """\n        try:\n            if model_id in self.models:\n                del self.models[model_id]\n            if model_id in self.model_configs:\n                del self.model_configs[model_id]\n            logger.info(f"模型卸载成功: {model_id}")\n            return True\n        except Exception as e:\n            logger.error(f"模型卸载失败: {model_id}, 错误: {e}")\n            return False\n\n    def predict(self, model_id: str, features: Dict[str, Any]) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        执行预测\n\n        Args:\n            model_id: 模型ID\n            features: 特征字典\n\n        Returns:\n            Dict[str, Any]: 预测结果\n        """\n        if model_id not in self.models:\n            raise ValueError(f"模型不存在: {model_id}")\n\n        model = self.models[model_id]\n        return model.predict(features)\n\n    def get_model_info(self, model_id: str) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取模型信息\n\n        Args:\n            model_id: 模型ID\n\n        Returns:\n            Dict[str, Any]: 模型信息\n        """\n        if model_id not in self.models:\n            raise ValueError(f"模型不存在: {model_id}")\n\n        model = self.models[model_id]\n        return model.get_info()\n\n    def list_models(self) -> List[str]:\n    """文档字符串"""\n\n        """\n        列出所有模型\n\n        Returns:\n            List[str]: 模型ID列表\n        """\n        return list(self.models.keys())\n\n    def _register_routes(self):\n    """文档字符串"""\n\n        """注册API路由"""\n\n        @self.app.post("/predict", response_model=PredictionResponse)\n\n        def predict(request: PredictionRequest):\n    """文档字符串"""\n\n            """预测接口"""\n            try:\n                result = self.predict(request.model_id, request.features)\n                return PredictionResponse(\n                    request_id=request.request_id,\n                    prediction=result["prediction"],\n                    probabilities=result.get("probabilities"),\n                    confidence=result.get("confidence")\n                )\n            except ValueError as e:\n                raise HTTPException(status_code=404, detail=str(e))\n            except Exception as e:\n                raise HTTPException(status_code=500, detail=str(e))\n\n        @self.app.get("/models")\n\n        def list_models():\n    """文档字符串"""\n\n            """列出所有模型"""\n            return {"models": self.list_models()}\n\n        @self.app.get("/model/{model_id}")\n\n        def model_info(model_id: str):\n    """文档字符串"""\n\n            """获取模型信息"""\n            try:\n                return self.get_model_info(model_id)\n            except ValueError as e:\n                raise HTTPException(status_code=404, detail=str(e))\n\n        @self.app.post("/model/{model_id}/load")\n\n        def load_model_endpoint(model_id: str, model_path: str):\n    """文档字符串"""\n\n            """加载模型接口"""\n            success = self.load_model(model_id, model_path)\n            if success:\n                return {"message": f"模型加载成功: {model_id}"}\n            else:\n                raise HTTPException(status_code=500, detail=f"模型加载失败: {model_id}")\n\n        @self.app.delete("/model/{model_id}")\n\n        def unload_model_endpoint(model_id: str):\n    """文档字符串"""\n\n            """卸载模型接口"""\n            success = self.unload_model(model_id)\n            if success:\n                return {"message": f"模型卸载成功: {model_id}"}\n            else:\n                raise HTTPException(status_code=404, detail=f"模型卸载失败: {model_id}")\n\nclass ABTestManager:\n\n    """A / B测试管理器"""\n\n    def __init__(self, model_service: ModelService):\n\n        """\n        初始化A / B测试管理器\n\n        Args:\n            model_service: 模型服务实例\n        """\n        self.model_service = model_service\n        self.experiments = {}\n\n    def create_experiment(self, exp_id: str, model_weights: Dict[str, float]):\n    """文档字符串"""\n\n        """\n        创建A / B测试实验\n\n        Args:\n            exp_id: 实验ID\n            model_weights: 模型权重字典 {model_id: weight}\n        """\n        self.experiments[exp_id] = {\n            "weights": model_weights,\n            "stats": {mid: {"requests": 0, "success": 0, "errors": 0} for mid in model_weights}\n        }\n\n        logger.info(f"A / B测试实验创建成功: {exp_id}")\n\n    def predict(self, exp_id: str, features: Dict[str, Any]) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        执行A / B测试预测\n\n        Args:\n            exp_id: 实验ID\n            features: 特征字典\n\n        Returns:\n            Dict[str, Any]: 预测结果\n        """\n        if exp_id not in self.experiments:\n            raise ValueError(f"实验不存在: {exp_id}")\n\n        # 根据权重选择模型\n        model_ids = list(self.experiments[exp_id]["weights"].keys())\n        weights = list(self.experiments[exp_id]["weights"].values())\n\n        # 归一化权重\n        total_weight = sum(weights)\n        normalized_weights = [w / total_weight for w in weights]\n\n        # 随机选择模型\n        model_id = np.random.choice(model_ids, p=normalized_weights)\n\n        # 更新统计信息\n        self.experiments[exp_id]["stats"][model_id]["requests"] += 1\n\n        try:\n            # 执行预测\n            result = self.model_service.predict(model_id, features)\n            self.experiments[exp_id]["stats"][model_id]["success"] += 1\n\n            return {\n                "experiment_id": exp_id,\n                "model_id": model_id,\n                **result\n            }\n\n        except Exception as e:\n            self.experiments[exp_id]["stats"][model_id]["errors"] += 1\n            logger.error(f"A / B测试预测失败: {e}")\n            raise\n\n    def get_experiment_stats(self, exp_id: str) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取实验统计信息\n\n        Args:\n            exp_id: 实验ID\n\n        Returns:\n            Dict[str, Any]: 统计信息\n        """\n        if exp_id not in self.experiments:\n            raise ValueError(f"实验不存在: {exp_id}")\n\n        return self.experiments[exp_id]\n\n# 为了向后兼容，保留ModelServing别名\nModelServing = ModelService\n