"""\n基础设施层 - 配置管理组件\n\nhandler 模块\n\n配置管理相关的文件\n提供配置管理相关的功能实现。\n"""\n\n#!/usr/bin/env python3\nfrom .interfaces import IErrorHandler\nfrom datetime import datetime, timedelta\nfrom enum import Enum\nfrom threading import Lock\nfrom typing import Any, Dict, List, Optional, Callable, Type, Union\nimport threading\nimport time\n\n# -*- coding: utf-8 -*-\n"""\n统一错误处理器实现\n"""\n\n# 跨层级导入：infrastructure层组件\n\n# 默认错误处理器实例\n_default_error_handler = None\n_error_handler_lock = threading.Lock()\n\ndef get_default_error_handler() -> 'UnifiedErrorHandler':\n    """获取默认错误处理器实例"""\n    global _default_error_handler\n    if _default_error_handler is None:\n        with _error_handler_lock:\n            if _default_error_handler is None:\n                _default_error_handler = UnifiedErrorHandler()\n    return _default_error_handler\n\nclass ErrorLevel(Enum):\n\n    """错误级别"""\n    DEBUG = "DEBUG"\n    INFO = "INFO"\n    WARNING = "WARNING"\n    ERROR = "ERROR"\n    CRITICAL = "CRITICAL"\n\nclass ErrorType(Enum):\n\n    """错误类型"""\n    NETWORK = "NETWORK"\n    DATABASE = "DATABASE"\n    CONFIGURATION = "CONFIGURATION"\n    VALIDATION = "VALIDATION"\n    TIMEOUT = "TIMEOUT"\n    PERMISSION = "PERMISSION"\n    RESOURCE = "RESOURCE"\n    UNKNOWN = "UNKNOWN"\n\nclass CircuitBreakerState(Enum):\n\n    """熔断器状态"""\n    CLOSED = "CLOSED"      # 正常状态\n    OPEN = "OPEN"          # 熔断状态\n    HALF_OPEN = "HALF_OPEN"  # 半开状态\n\nclass ErrorInfo:\n\n    """错误信息"""\n\n    def __init__(self, error: Exception, context: Optional[Dict[str, Any]] = None):\n\n        self.error = error\n        self.error_type = type(error).__name__\n        self.message = str(error)\n        self.context = context or {}\n        self.timestamp = datetime.now()\n        self.level = self._determine_level(error)\n        self.category = self._determine_category(error)\n\n    def _determine_level(self, error: Exception) -> ErrorLevel:\n    """文档字符串"""\n\n        """确定错误级别"""\n        error_name = type(error).__name__.lower()\n\n        if any(keyword in error_name for keyword in ['critical', 'fatal']):\n            return ErrorLevel.CRITICAL\n        elif any(keyword in error_name for keyword in ['timeout', 'connection']):\n            return ErrorLevel.ERROR\n        elif any(keyword in error_name for keyword in ['validation', 'config']):\n            return ErrorLevel.WARNING\n        else:\n            return ErrorLevel.ERROR\n\n    def _determine_category(self, error: Exception) -> ErrorType:\n    """文档字符串"""\n\n        """确定错误类别"""\n        error_name = type(error).__name__.lower()\n\n        if any(keyword in error_name for keyword in ['connection', 'timeout', 'network']):\n            return ErrorType.NETWORK\n        elif any(keyword in error_name for keyword in ['database', 'sql', 'db']):\n            return ErrorType.DATABASE\n        elif any(keyword in error_name for keyword in ['config', 'setting']):\n            return ErrorType.CONFIGURATION\n        elif any(keyword in error_name for keyword in ['validation', 'invalid']):\n            return ErrorType.VALIDATION\n        elif any(keyword in error_name for keyword in ['permission', 'access']):\n            return ErrorType.PERMISSION\n        elif any(keyword in error_name for keyword in ['resource', 'memory', 'disk']):\n            return ErrorType.RESOURCE\n        else:\n            return ErrorType.UNKNOWN\n\n    def to_dict(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """转换为字典"""\n        return {\n            'error_type': self.error_type,\n            'message': self.message,\n            'level': self.level.value,\n            'category': self.category.value,\n            'timestamp': self.timestamp.isoformat(),\n            'context': self.context\n        }\n\nclass CircuitBreaker:\n\n    """熔断器"""\n\n    def __init__(self, service_name: str, failure_threshold: int = 5, recovery_timeout: int = 60):\n\n        self.service_name = service_name\n        self.failure_threshold = failure_threshold\n        self.recovery_timeout = recovery_timeout\n        self.state = CircuitBreakerState.CLOSED\n        self.failure_count = 0\n        self.last_failure_time = None\n        self._lock = Lock()\n\n    def call(self, func: Callable, *args, **kwargs) -> Any:\n    """文档字符串"""\n\n        """执行函数调用"""\n        if not self._can_execute():\n            raise Exception(f"熔断器已打开: {self.service_name}")\n\n        try:\n            result = func(*args, **kwargs)\n            self._on_success()\n            return result\n        except Exception as e:\n            self._on_failure()\n            raise e\n\n    def _can_execute(self) -> bool:\n    """文档字符串"""\n\n        """检查是否可以执行"""\n        with self._lock:\n            if self.state == CircuitBreakerState.CLOSED:\n                return True\n            elif self.state == CircuitBreakerState.OPEN:\n                if time.time() - self.last_failure_time > self.recovery_timeout:\n                    self.state = CircuitBreakerState.HALF_OPEN\n                    return True\n                return False\n            else:  # HALF_OPEN\n                return True\n\n    def _on_success(self) -> None:\n    """文档字符串"""\n\n        """成功时的处理"""\n        with self._lock:\n            self.failure_count = 0\n            self.state = CircuitBreakerState.CLOSED\n\n    def _on_failure(self) -> None:\n    """文档字符串"""\n\n        """失败时的处理"""\n        with self._lock:\n            self.failure_count += 1\n            self.last_failure_time = time.time()\n\n            if self.failure_count >= self.failure_threshold:\n                self.state = CircuitBreakerState.OPEN\n\n    def get_status(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取状态"""\n        with self._lock:\n            return {\n                'service_name': self.service_name,\n                'state': self.state.value,\n                'failure_count': self.failure_count,\n                'failure_threshold': self.failure_threshold,\n                'last_failure_time': self.last_failure_time.isoformat() if self.last_failure_time else None\n            }\n\nclass UnifiedErrorHandler(IErrorHandler):\n\n    """统一错误处理器"""\n\n    def __init__(self, config: Optional[Dict[str, Any]] = None):\n\n        self.config = config or {}\n        self._errors = []\n        self._handlers = {}\n        self._circuit_breakers = {}\n        self._lock = Lock()\n\n        # 错误处理配置\n        self._enabled = self.config.get('enabled', True)\n        self._max_errors = self.config.get('max_errors', 1000)\n        self._retry_delays = self.config.get('retry_delays', [1, 2, 4])\n\n    def handle(self, error: Exception, context: Optional[Dict[str, Any]] = None) -> None:\n    """文档字符串"""\n\n        """处理错误"""\n        if not self._enabled:\n            return\n\n        error_info = ErrorInfo(error, context)\n\n        with self._lock:\n            # 添加到错误列表\n            self._errors.append(error_info)\n\n            # 限制错误数量\n            if len(self._errors) > self._max_errors:\n                self._errors = self._errors[-self._max_errors:]\n\n            # 调用对应的错误处理器\n            self._call_error_handlers(error_info)\n\n    def retry(self, func: Callable, max_retries: int = 3, delay: float = 1.0) -> Any:\n    """文档字符串"""\n\n        """重试机制"""\n        last_error = None\n\n        for attempt in range(max_retries + 1):\n            try:\n                return func()\n            except Exception as e:\n                last_error = e\n                if attempt < max_retries:\n                    time.sleep(delay * (2 ** attempt))  # 指数退避\n                else:\n                    break\n\n        # 所有重试都失败了\n        self.handle(last_error, {'function': func.__name__, 'retries': max_retries})\n        raise last_error\n\n    def circuit_breaker(self, service_name: str, failure_threshold: int = 5) -> bool:\n    """文档字符串"""\n\n        """熔断器机制"""\n        if service_name not in self._circuit_breakers:\n            self._circuit_breakers[service_name] = CircuitBreaker(service_name, failure_threshold)\n\n        circuit_breaker = self._circuit_breakers[service_name]\n        return circuit_breaker.state == CircuitBreakerState.CLOSED\n\n    def add_error_handler(self, error_type: Type[Exception], handler: Callable) -> None:\n    """文档字符串"""\n\n        """添加错误处理器"""\n        with self._lock:\n            self._handlers[error_type] = handler\n\n    def add_circuit_breaker(self, service_name: str, failure_threshold: int = 5) -> CircuitBreaker:\n    """文档字符串"""\n\n        """添加熔断器"""\n        with self._lock:\n            circuit_breaker = CircuitBreaker(service_name, failure_threshold)\n            self._circuit_breakers[service_name] = circuit_breaker\n            return circuit_breaker\n\n    def get_errors(self, level: Optional[ErrorLevel] = None,\n    """文档字符串"""\n\n                   category: Optional[ErrorType] = None,\n                   limit: Optional[int] = None):\n        """获取错误列表"""\n        with self._lock:\n            errors = self._errors.copy()\n\n            if level:\n                errors = [e for e in errors if e.level == level]\n\n            if category:\n                errors = [e for e in errors if e.category == category]\n\n            if limit:\n                errors = errors[-limit:]\n\n            return errors\n\n    def get_error_summary(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取错误摘要"""\n        with self._lock:\n            if not self._errors:\n                return {\n                    'total_errors': 0,\n                    'enabled': self._enabled,\n                    'circuit_breakers': len(self._circuit_breakers)\n                }\n\n            # 按级别统计\n            level_stats = {}\n            for level in ErrorLevel:\n                level_stats[level.value] = len([e for e in self._errors if e.level == level])\n\n            # 按类别统计\n            category_stats = {}\n            for category in ErrorType:\n                category_stats[category.value] = len([e for e in self._errors if e.category == category])\n\n            # 最近的错误\n            recent_errors = [e.to_dict() for e in self._errors[-10:]]\n\n            return {\n                'total_errors': len(self._errors),\n                'enabled': self._enabled,\n                'level_stats': level_stats,\n                'category_stats': category_stats,\n                'recent_errors': recent_errors,\n                'circuit_breakers': len(self._circuit_breakers)\n            }\n\n    def clear_errors(self) -> None:\n    """文档字符串"""\n\n        """清除错误记录"""\n        with self._lock:\n            self._errors.clear()\n\n    def _call_error_handlers(self, error_info: ErrorInfo) -> None:\n    """文档字符串"""\n\n        """调用错误处理器"""\n        error_type = type(error_info.error)\n\n        # 查找匹配的处理器\n        for handler_type, handler in self._handlers.items():\n            if isinstance(error_info.error, handler_type):\n                try:\n                    handler(error_info)\n                except Exception as e:\n                    print(f"错误处理器执行失败: {e}")\n\nclass NetworkErrorHandler:\n\n    """网络错误处理器"""\n\n    def __init__(self, max_retries: int = 3):\n\n        self.max_retries = max_retries\n\n    def handle(self, error_info: ErrorInfo) -> None:\n    """文档字符串"""\n\n        """处理网络错误"""\n        print(f"网络错误处理: {error_info.message}")\n        # 这里可以实现具体的网络错误处理逻辑\n\nclass DatabaseErrorHandler:\n\n    """数据库错误处理器"""\n\n    def __init__(self, connection_pool):\n\n        self.connection_pool = connection_pool\n\n    def handle(self, error_info: ErrorInfo) -> None:\n    """文档字符串"""\n\n        """处理数据库错误"""\n        print(f"数据库错误处理: {error_info.message}")\n        # 这里可以实现具体的数据库错误处理逻辑\n\n# 便捷函数\n\ndef get_error_handler() -> UnifiedErrorHandler:\n    """文档字符串"""\n\n    """获取错误处理器的便捷函数"""\n# 跨层级导入：层组件\n    return get_default_error_handler()\n\ndef handle_error(error: Exception, context: Optional[Dict[str, Any]] = None) -> None:\n    """文档字符串"""\n\n    """处理错误的便捷函数"""\n    get_error_handler().handle(error, context)\n\ndef retry_function(func: Callable, max_retries: int = 3, delay: float = 1.0) -> Any:\n    """文档字符串"""\n\n    """重试函数的便捷函数"""\n    return get_error_handler().retry(func, max_retries, delay)\n\ndef get_error_summary() -> Dict[str, Any]:\n    """文档字符串"""\n\n    """获取错误摘要的便捷函数"""\n    return get_error_handler().get_error_summary()\n