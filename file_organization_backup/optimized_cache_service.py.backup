"""\n优化缓存服务模块\n提供高性能的配置缓存功能\n"""\n\nfrom collections import OrderedDict\nfrom typing import Any, Optional, Dict, List, Callable\nimport hashlib\nimport json\nimport threading\nimport time\nimport weakref\n\nclass OptimizedCacheService:\n\n    """\n    optimized_cache_service - 缓存系统\n\n    职责说明：\n    负责数据缓存、内存管理、缓存策略和性能优化\n\n    核心职责：\n    - 内存缓存管理\n    - Redis缓存操作\n    - 缓存策略实现\n    - 缓存性能监控\n    - 缓存数据同步\n    - 缓存失效处理\n\n    相关接口：\n    - ICacheComponent\n    - ICacheManager\n    - ICacheStrategy\n    优化缓存服务\n    """\n\n    def __init__(self, max_size: int = 10000, ttl: int = 3600,\n\n        cleanup_interval: int = 300):\n\n        self.max_size = max_size\n        self.ttl = ttl\n        self.cleanup_interval = cleanup_interval\n\n        # 缓存存储\n        self._cache: OrderedDict = OrderedDict()\n        self._timestamps: Dict[str, float] = {}\n        self._access_counts: Dict[str, int] = {}\n\n        # 线程安全\n        self._lock = threading.RLock()\n\n        # 清理线程\n        self._cleanup_thread = None\n        self._stop_cleanup = threading.Event()\n        self._start_cleanup_thread()\n\n    def _start_cleanup_thread(self) -> None:\n    """文档字符串"""\n\n        """启动清理线程"""\n\n        def cleanup_worker():\n    """文档字符串"""\n\n            while not self._stop_cleanup.wait(self.cleanup_interval):\n                try:\n                    self.cleanup_expired()\n                except Exception as e:\n                    print(f"缓存清理错误: {e}")\n\n        self._cleanup_thread = threading.Thread(target=cleanup_worker, daemon=True)\n        self._cleanup_thread.start()\n\n    def get(self, key: str) -> Optional[Any]:\n    """文档字符串"""\n\n        """\n        获取缓存值\n\n        Args:\n            key: 缓存键\n\n        Returns:\n            缓存值，如果不存在或已过期则返回None\n        """\n        with self._lock:\n            if key not in self._cache:\n                return None\n\n            # 检查是否过期\n            if self._is_expired(key):\n                self._remove(key)\n                return None\n\n            # 更新访问计数\n            self._access_counts[key] = self._access_counts.get(key, 0) + 1\n\n            # 移动到末尾（LRU）\n            self._cache.move_to_end(key)\n            return self._cache[key]\n\n    def set(self, key: str, value: Any) -> None:\n    """文档字符串"""\n\n        """\n        设置缓存值\n\n        Args:\n            key: 缓存键\n            value: 缓存值\n        """\n        with self._lock:\n            # 如果键已存在，先移除\n            if key in self._cache:\n                self._remove(key)\n\n            # 检查容量\n            if len(self._cache) >= self.max_size:\n                self._evict_least_used()\n\n            # 添加新项\n            self._cache[key] = value\n            self._timestamps[key] = time.time()\n            self._access_counts[key] = 0\n\n    def delete(self, key: str) -> bool:\n    """文档字符串"""\n\n        """\n        删除缓存项\n\n        Args:\n            key: 缓存键\n\n        Returns:\n            是否成功删除\n        """\n        with self._lock:\n            return self._remove(key)\n\n    def clear(self) -> None:\n    """文档字符串"""\n\n        """清空所有缓存"""\n        with self._lock:\n            self._cache.clear()\n            self._timestamps.clear()\n            self._access_counts.clear()\n\n    def has(self, key: str) -> bool:\n    """文档字符串"""\n\n        """\n        检查键是否存在且未过期\n\n        Args:\n            key: 缓存键\n\n        Returns:\n            是否存在\n        """\n        with self._lock:\n            if key not in self._cache:\n                return False\n            return not self._is_expired(key)\n\n    def size(self) -> int:\n    """文档字符串"""\n\n        """获取缓存大小"""\n        with self._lock:\n            return len(self._cache)\n\n    def keys(self) -> list:\n    """文档字符串"""\n\n        """获取所有键"""\n        with self._lock:\n            return list(self._cache.keys())\n\n    def _is_expired(self, key: str) -> bool:\n    """文档字符串"""\n\n        """检查是否过期"""\n        if key not in self._timestamps:\n            return True\n        return time.time() - self._timestamps[key] > self.ttl\n\n    def _remove(self, key: str) -> bool:\n    """文档字符串"""\n\n        """移除缓存项"""\n        if key in self._cache:\n            del self._cache[key]\n            del self._timestamps[key]\n        if key in self._access_counts:\n            del self._access_counts[key]\n            return True\n        return False\n\n    def _evict_least_used(self) -> None:\n    """文档字符串"""\n\n        """驱逐最少使用的项"""\n        if not self._cache:\n            return\n\n        # 找到最少使用的项\n        least_used_key = min(self._access_counts.keys(),\n                           key=lambda k: self._access_counts.get(k, 0))\n\n        self._remove(least_used_key)\n\n    def cleanup_expired(self) -> int:\n    """文档字符串"""\n\n        """\n        清理过期项\n\n        Returns:\n            清理的项数\n        """\n        with self._lock:\n            expired_keys = [key for key in self._cache.keys() if self._is_expired(key)]\n            for key in expired_keys:\n                self._remove(key)\n            return len(expired_keys)\n\n    def get_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取缓存统计信息"""\n        with self._lock:\n            expired_count = len([k for k in self._cache.keys() if self._is_expired(k)])\n            total_access = sum(self._access_counts.values())\n            avg_access = total_access / len(self._access_counts) if self._access_counts else 0\n\n            return {\n                "size": len(self._cache),\n                "max_size": self.max_size,\n                "ttl": self.ttl,\n                "expired_count": expired_count,\n                "utilization": len(self._cache) / self.max_size if self.max_size > 0 else 0,\n                "total_access": total_access,\n                "avg_access": avg_access,\n                "cleanup_interval": self.cleanup_interval\n            }\n\n    def shutdown(self) -> None:\n    """文档字符串"""\n\n        """关闭缓存服务"""\n        self._stop_cleanup.set()\n        if self._cleanup_thread:\n            self._cleanup_thread.join(timeout=5)\n\nclass ConfigCache:\n\n    """配置专用缓存"""\n\n    def __init__(self, max_size: int = 5000, ttl: int = 1800):\n\n        self.cache_service = OptimizedCacheService(max_size, ttl)\n        self._config_hash_cache = {}\n\n    def get_config(self, config_id: str) -> Optional[Dict[str, Any]]:\n    """文档字符串"""\n\n        """\n        获取配置\n\n        Args:\n            config_id: 配置ID\n\n        Returns:\n            配置数据\n        """\n        return self.cache_service.get(f"config:{config_id}")\n\n    def set_config(self, config_id: str, config: Dict[str, Any]) -> None:\n    """文档字符串"""\n\n        """\n        # 设置配置\n\n        Args:\n            config_id: Configuration ID\n            config: Configuration data\n        """\n        self.cache_service.set(f"config:{config_id}", config)\n\n        # 缓存配置哈希\n        config_str = json.dumps(config, sort_keys=True)\n        config_hash = hashlib.md5(config_str.encode()).hexdigest()\n        self._config_hash_cache[config_id] = config_hash\n\n    def get_config_hash(self, config_id: str) -> Optional[str]:\n    """文档字符串"""\n\n        """\n        获取配置哈希\n\n        Args:\n            config_id: Configuration ID\n\n        Returns:\n            Configuration hash\n        """\n        return self._config_hash_cache.get(config_id)\n\n    def has_config_changed(self, config_id: str, new_config: Dict[str, Any]) -> bool:\n    """文档字符串"""\n\n        """\n        检查配置是否发生变化\n\n        Args:\n            config_id: Configuration ID\n            new_config: New configuration\n\n        Returns:\n            Whether configuration has changed\n        """\n        old_hash = self._config_hash_cache.get(config_id)\n        if not old_hash:\n            return True\n\n            new_config_str = json.dumps(new_config, sort_keys=True)\n            new_hash = hashlib.md5(new_config_str.encode()).hexdigest()\n\n            return old_hash != new_hash\n\n    def invalidate_config(self, config_id: str) -> None:\n    """文档字符串"""\n\n        """\n        使配置失效\n\n        Args:\n            config_id: 配置ID\n        """\n        self.cache_service.delete(f"config:{config_id}")\n        if config_id in self._config_hash_cache:\n            del self._config_hash_cache[config_id]\n\n    def get_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取统计信息"""\n        stats = self.cache_service.get_stats()\n        stats["config_hash_cache_size"] = len(self._config_hash_cache)\n        return stats\n\n    # 通用缓存方法（向后兼容性）\n\n    def set(self, key: str, value: Any, ttl: Optional[float] = None) -> None:\n    """文档字符串"""\n\n        """设置缓存值（通用接口）"""\n        self.cache_service.set(key, value, ttl)\n\n    def get(self, key: str) -> Optional[Any]:\n    """文档字符串"""\n\n        """获取缓存值（通用接口）"""\n        return self.cache_service.get(key)\n\n    def clear(self) -> None:\n    """文档字符串"""\n\n        """清空缓存（通用接口）"""\n        self.cache_service.clear()\n        self._config_hash_cache.clear()\n\n    def delete(self, key: str) -> bool:\n    """文档字符串"""\n\n        """删除缓存条目（通用接口）"""\n        return self.cache_service.delete(key)\n\n    def has(self, key: str) -> bool:\n    """文档字符串"""\n\n        """检查缓存是否存在（通用接口）"""\n        return self.cache_service.has(key)\n\n    def size(self) -> int:\n    """文档字符串"""\n\n        """获取缓存大小（通用接口）"""\n        return self.cache_service.size()\n\nclass OptimizedCacheManager:\n\n    """优化缓存管理器"""\n\n    def __init__(self):\n\n        self._caches: Dict[str, OptimizedCacheService] = {}\n        self._default_cache = OptimizedCacheService()\n\n    def get_cache(self, name: str = "default") -> OptimizedCacheService:\n    """文档字符串"""\n\n        """\n        获取指定名称的缓存\n\n        Args:\n            name: 缓存名称\n\n        Returns:\n            优化缓存服务实例\n        """\n        return self._caches.get(name, self._default_cache)\n\n    def create_cache(self, name: str, max_size: int = 1000, ttl: int = 3600) -> OptimizedCacheService:\n    """文档字符串"""\n\n        """\n        创建新的优化缓存\n\n        Args:\n            name: 缓存名称\n            max_size: 最大大小\n            ttl: 生存时间\n\n        Returns:\n            新创建的优化缓存服务\n        """\n        cache = OptimizedCacheService(max_size, ttl)\n        self._caches[name] = cache\n        return cache\n\n    def delete_cache(self, name: str) -> bool:\n    """文档字符串"""\n\n        """\n        删除缓存\n\n        Args:\n            name: 缓存名称\n\n        Returns:\n            是否成功删除\n        """\n        if name in self._caches:\n            del self._caches[name]\n            return True\n        return False\n\n    def list_caches(self) -> list:\n    """文档字符串"""\n\n        """\n        列出所有缓存名称\n\n        Returns:\n            缓存名称列表\n        """\n        return list(self._caches.keys())\n\n    def get_default_cache(self) -> OptimizedCacheService:\n    """文档字符串"""\n\n        """\n        获取默认缓存\n\n        Returns:\n            默认优化缓存服务\n        """\n        return self._default_cache\n\n    def cleanup_all(self) -> Dict[str, int]:\n    """文档字符串"""\n\n        """\n        清理所有缓存\n\n        Returns:\n            各缓存清理的项数量\n        """\n        results = {}\n        for name, cache in self._caches.items():\n            results[name] = cache.cleanup_expired()\n        results['default'] = self._default_cache.cleanup_expired()\n        return results\n\n    def get_all_stats(self) -> Dict[str, Dict[str, Any]]:\n    """文档字符串"""\n\n        """\n        获取所有缓存的统计信息\n\n        Returns:\n            统计信息字典\n        """\n        stats = {}\n        for name, cache in self._caches.items():\n            stats[name] = cache.get_stats()\n        stats['default'] = self._default_cache.get_stats()\n        return stats\n\n    def get_cache_service(name: str = "default") -> OptimizedCacheService:\n    """文档字符串"""\n\n        """获取缓存服务实例"""\n        return OptimizedCacheManager().get_cache(name)\n\n    def get_config_cache_service(name: str = "default") -> ConfigCache:\n    """文档字符串"""\n\n        """获取配置缓存服务实例"""\n        return ConfigCache()\n