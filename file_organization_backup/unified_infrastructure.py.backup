"""\n基础设施层 - 缓存系统组件\n\nunified_infrastructure 模块\n\n缓存系统相关的文件\n提供缓存系统相关的功能实现。\n"""\n\n#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n基础设施层统一入口模块\n\n整合所有工厂和容器，提供统一的访问接口：\n- 配置管理工厂\n- 监控系统工厂\n- 缓存系统工厂\n- 依赖注入容器\n"""\n\n# 显式导入以提高代码可维护性\nfrom .core.factories.cache_factory import (\n    CacheManagerFactory, get_cache_factory, get_cache_manager\n)\nfrom .di.unified_dependency_container import (\n    UnifiedDependencyContainer, ServiceLifecycle, get_container,\n    register_service, get_service, has_service, unregister_service\n)\nfrom .core.monitoring.monitor_factory import MonitorType\nfrom .core.factories.monitor_factory import (\n    MonitorFactory, get_monitor_factory, get_monitor\n)\nfrom .core.config.config_factory import ConfigManagerType\nfrom .core.factories.config_factory import (\n    ConfigManagerFactory, get_config_factory, get_config_manager\n)\nfrom enum import Enum\n\nfrom .core.factories.config_factory import (\n    ConfigManagerFactory,\n    get_config_manager as get_config_manager_from_factory,\n    get_config_factory\n)\n\nfrom .core.factories.monitor_factory import (\n    MonitorFactory,\n    get_monitor as get_monitor_from_factory,\n    get_monitor_factory\n)\n\nfrom .core.factories.cache_factory import (\n    CacheManagerFactory,\n    get_cache_manager as get_cache_manager_from_factory,\n    get_cache_factory\n)\n\nfrom .di.unified_dependency_container import (\n    UnifiedDependencyContainer,\n    ServiceLifecycle,\n    get_container,\n    register_service,\n    get_service\n)\n\n# 定义缓存类型枚举（因为缓存工厂中没有定义）\n\nclass CacheType(Enum):\n\n    """缓存类型"""\n    SMART = "smart"\n    MEMORY = "memory"\n    REDIS = "redis"\n    DISK = "disk"\n    HYBRID = "hybrid"\n\nclass InfrastructureManager:\n\n    """基础设施管理器 - 统一管理所有基础设施组件"""\n\n    def __init__(self):\n\n        self.config_factory = get_config_factory()\n        self.monitor_factory = get_monitor_factory()\n        self.cache_factory = get_cache_factory()\n        self.di_container = get_container()\n\n    def get_config_manager(self, manager_type: str = "unified", **kwargs):\n    """文档字符串"""\n\n        """获取配置管理器"""\n        return self.config_factory.create_manager(manager_type, **kwargs)\n\n    def get_monitor(self, monitor_type: str = "unified", **kwargs):\n    """文档字符串"""\n\n        """获取监控器"""\n        return self.monitor_factory.create_monitor(monitor_type, **kwargs)\n\n    def get_cache_manager(self, cache_type: str = "smart", **kwargs):\n    """文档字符串"""\n\n        """获取缓存管理器"""\n        return self.cache_factory.create_manager(cache_type, **kwargs)\n\n    def get_cache(self, cache_type: str = "smart", **kwargs):\n    """文档字符串"""\n\n        """获取缓存管理器（别名方法）"""\n        return self.get_cache_manager(cache_type, **kwargs)\n\n    def register_service(self, name: str, service, lifecycle: ServiceLifecycle = ServiceLifecycle.SINGLETON):\n    """文档字符串"""\n\n        """注册服务"""\n        register_service(name, service, lifecycle)\n\n    def get_service(self, name: str):\n    """文档字符串"""\n\n        """获取服务"""\n        return get_service(name)\n\n    def get_available_config_managers(self):\n    """文档字符串"""\n\n        """获取可用的配置管理器类型"""\n        return self.config_factory.get_available_managers()\n\n    def get_available_monitors(self):\n    """文档字符串"""\n\n        """获取可用的监控器类型"""\n        return self.monitor_factory.get_available_monitors()\n\n    def get_available_cache_managers(self):\n    """文档字符串"""\n\n        """获取可用的缓存管理器类型"""\n        return self.cache_factory.get_available_managers()\n\n# 全局基础设施管理器\n_infrastructure_manager = InfrastructureManager()\n\n# 便捷函数\n\ndef get_infrastructure_manager() -> InfrastructureManager:\n    """文档字符串"""\n\n    """获取全局基础设施管理器"""\n    return _infrastructure_manager\n\ndef get_config_manager(manager_type: str = "unified", **kwargs):\n    """文档字符串"""\n\n    """获取配置管理器"""\n    return _infrastructure_manager.get_config_manager(manager_type, **kwargs)\n\ndef get_monitor(monitor_type: str = "unified", **kwargs):\n    """文档字符串"""\n\n    """获取监控器"""\n    return _infrastructure_manager.get_monitor(monitor_type, **kwargs)\n\ndef get_cache_manager(cache_type: str = "smart", **kwargs):\n    """文档字符串"""\n\n    """获取缓存管理器"""\n    return _infrastructure_manager.get_cache_manager(cache_type, **kwargs)\n\ndef register_infrastructure_service(name: str, service, lifecycle: ServiceLifecycle = ServiceLifecycle.SINGLETON):\n    """文档字符串"""\n\n    """注册基础设施服务"""\n    _infrastructure_manager.register_service(name, service, lifecycle)\n\ndef get_infrastructure_service(name: str):\n    """文档字符串"""\n\n    """获取基础设施服务"""\n    return _infrastructure_manager.get_service(name)\n\n# 导出主要类型和常量\n__all__ = []\n# 配置管理\n'ConfigManagerFactory',\n'ConfigManagerType',\n'get_config_manager',\n'get_config_manager_from_factory',\n\n# 监控系统\n'MonitorFactory',\n'MonitorType',\n'get_monitor',\n'get_monitor_from_factory',\n\n# 缓存系统\n'CacheManagerFactory',\n'CacheType',\n'get_cache_manager',\n'get_cache_manager_from_factory',\n\n# 依赖注入\n'UnifiedDependencyContainer',\n'ServiceLifecycle',\n'get_container',\n'register_service',\n'get_service',\n\n# 基础设施管理器\n'InfrastructureManager',\n'get_infrastructure_manager',\n'get_config_manager',\n'get_monitor',\n'get_cache_manager',\n'register_infrastructure_service',\n'get_infrastructure_service',\n