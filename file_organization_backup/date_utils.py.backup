import time\n\n"""\n日期处理工具 - 提供与A股交易日历相关的功能\n"""\n\nfrom datetime import datetime, timedelta\nimport pandas as pd\nfrom typing import Optional, List\n\n# 导入基础设施层的时区转换功能\n# 跨层级导入：infrastructure层组件\n# from src.infrastructure.core.utils.date_utils import convert_timezone as _convert_timezone\n\n# 简单的时区转换实现\ndef _convert_timezone(dt, from_tz, to_tz):\n    """简单的时区转换实现"""\n    # 这里应该实现实际的时区转换逻辑\n    # 暂时返回原时间\n    return dt\n\n# A股交易日历缓存\n_trading_days_cache: Optional[List[datetime]] = None\n\ndef _load_trading_calendar():\n    """文档字符串"""\n\n    """\n    date_utils - 工具组件\n\n    职责说明：\n    提供通用工具函数、辅助类和基础组件\n\n    核心职责：\n    - 通用工具函数\n    - 数据格式转换\n    - 文件操作工具\n    - 网络工具函数\n    - 日期时间处理\n    - 数学计算工具\n\n    相关接口：\n    - IUtilityComponent\n    - IConverter\n    - IHelper\n    """\n\ndef _load_trading_calendar():\n    """加载交易日历"""\n    global _trading_days_cache\n    if _trading_days_cache is not None:\n        return\n\n    # 生成工作日范围（周一到周五）\n    trading_range = pd.bdate_range(\n        start='2020-01-01',\n        end='2025-12-31',\n        freq='B'\n    )\n\n    _trading_days_cache = []\n    for ts in trading_range:\n        if pd.notna(ts):  # 过滤掉NaT值\n            _trading_days_cache.append(ts.to_pydatetime())\n\ndef is_trading_day(date: datetime) -> bool:\n    """文档字符串"""\n\n    """判断是否为交易日"\n\n    Args:\n        date: 要检查的日期\n\n    Returns:\n        bool: 是否为交易日\n    """\n    if _trading_days_cache is None:\n        _load_trading_calendar()\n    # 只比较日期部分\n    return any(day.date() == date.date() for day in _trading_days_cache)  # type: ignore\n\ndef get_business_date(date: Optional[datetime] = None) -> datetime:\n    """文档字符串"""\n\n    """获取最近的交易日"\n\n    Args:\n        date: 参考日期(默认当前日期)\n\n    Returns:\n        最近的交易日\n    """\n    if date is None:\n        date = datetime.now()\n\n    if _trading_days_cache is None:\n        _load_trading_calendar()\n\n    # 只比较日期部分\n    while not any(day.date() == date.date() for day in _trading_days_cache):  # type: ignore\n        date -= timedelta(days=1)\n    return date\n\ndef convert_timezone(dt: datetime, from_tz: str, to_tz: str) -> datetime:\n    """文档字符串"""\n\n    """转换时区 - 重定向到基础设施层实现"\n\n    Args:\n        dt: 原始时间\n        from_tz: 原始时区\n        to_tz: 目标时区\n\n    Returns:\n        转换后的时间\n    """\n    return _convert_timezone(dt, from_tz, to_tz)\n\ndef next_trading_day(date: datetime) -> datetime:\n    """文档字符串"""\n\n    """获取下一个交易日"""\n    current = date + timedelta(days=1)\n    while not is_trading_day(current):\n        current += timedelta(days=1)\n    return current\n\ndef prev_trading_day(date: datetime) -> datetime:\n    """文档字符串"""\n\n    """获取上一个交易日"""\n    current = date - timedelta(days=1)\n    while not is_trading_day(current):\n        current -= timedelta(days=1)\n    return current\n\ndef get_trading_days(start: datetime, end: datetime) -> List[datetime]:\n    """文档字符串"""\n\n    """获取指定日期范围内的交易日列表"""\n    if _trading_days_cache is None:\n        _load_trading_calendar()\n    # 只比较日期部分\n    return [day for day in _trading_days_cache if start.date() <= day.date() <= end.date()]  # type: ignore\n\ndef is_trading_time(dt: datetime) -> bool:\n    """文档字符串"""\n\n    """判断是否为交易时间 (A股: 9:30 - 11:30, 13:00 - 15:00)"""\n    if not is_trading_day(dt):\n        return False\n    time = dt.time()\n    return (\n        (time >= datetime.strptime("09:30:00", "%H:%M:%S").time())\n        and time <= datetime.strptime("11:30:00", "%H:%M:%S").time()\n        or (time >= datetime.strptime("13:00:00", "%H:%M:%S").time())\n        and time <= datetime.strptime("15:00:00", "%H:%M:%S").time()\n    )\n