"""\n分布式测试执行框架\n支持多机分布式测试执行，提高大规模测试的执行效率\n"""\n\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\nfrom enum import Enum\nfrom typing import Dict, Any, List, Optional, Callable, Tuple, Queue\nimport json\nimport logging\nimport multiprocessing as mp\nimport os\nimport pickle\nimport socket\nimport threading\nimport time\n\nfrom dataclasses import dataclass, asdict\n\nfrom .automated_test_runner import (\n    AutomatedTestRunner,\n    TestSuiteConfig,\n    TestExecutionStatus,\n    TestResult,\n    TestMode\n)\n\nlogger = logging.getLogger(__name__)\n\nclass NodeRole(Enum):\n\n    """节点角色"""\n    MASTER = "master"\n    WORKER = "worker"\n\nclass NodeStatus(Enum):\n\n    """节点状态"""\n    ONLINE = "online"\n    OFFLINE = "offline"\n    BUSY = "busy"\n    IDLE = "idle"\n\n@dataclass\n\nclass NodeInfo:\n\n    """节点信息"""\n    node_id: str\n    host: str\n    port: int\n    role: NodeRole\n    status: NodeStatus\n    capabilities: Dict[str, Any]\n    load: float = 0.0\n    last_heartbeat: float = 0.0\n\n@dataclass\n\nclass DistributedTestConfig:\n\n    """分布式测试配置"""\n    master_host: str = "localhost"\n    master_port: int = 5000\n    worker_timeout: int = 30\n    heartbeat_interval: int = 5\n    max_workers_per_node: int = 4\n    test_distribution_strategy: str = "round_robin"  # round_robin, load_balanced, random\n    enable_fault_tolerance: bool = True\n    retry_failed_tests: bool = True\n    max_retries: int = 3\n\nclass DistributedTestRunner:\n\n    """分布式测试执行器"""\n\n    def __init__(self, config: DistributedTestConfig):\n\n        self.config = config\n        self.master_node = None\n        self.worker_nodes: Dict[str, NodeInfo] = {}\n        self.test_queue: Queue = None\n        self.result_queue: Queue = None\n        self.node_manager = None\n        self._running = False\n        self._lock = threading.Lock()\n\n        # 测试结果管理\n        self.test_results: List[TestResult] = []\n        self.completed_tests: int = 0\n        self.failed_tests: int = 0\n\n        # 性能统计\n        self.start_time: float = 0.0\n        self.total_execution_time: float = 0.0\n\n    def start_master(self) -> None:\n    """文档字符串"""\n\n        """启动主节点"""\n        if self._running:\n            logger.warning("分布式测试运行器已在运行")\n            return\n\n        logger.info("启动分布式测试主节点...")\n\n        # 创建进程管理器\n        self.node_manager = mp.Manager()\n        self.test_queue = self.node_manager.Queue()\n        self.result_queue = self.node_manager.Queue()\n\n        # 启动主节点进程\n        self.master_node = mp.Process(\n            target=self._run_master_node,\n            args=(self.config, self.test_queue, self.result_queue)\n        )\n        self.master_node.start()\n\n        self._running = True\n        logger.info("分布式测试主节点启动完成")\n\n    def stop_master(self) -> None:\n    """文档字符串"""\n\n        """停止主节点"""\n        if not self._running:\n            return\n\n        logger.info("停止分布式测试主节点...")\n\n        if self.master_node and self.master_node.is_alive():\n            self.master_node.terminate()\n            self.master_node.join(timeout=5)\n\n        self._running = False\n        logger.info("分布式测试主节点已停止")\n\n    def add_worker_node(self, node_id: str, host: str, port: int, capabilities: Dict[str, Any]) -> None:\n    """文档字符串"""\n\n        """添加工作节点"""\n        with self._lock:\n            worker_node = NodeInfo(\n                node_id=node_id,\n                host=host,\n                port=port,\n                role=NodeRole.WORKER,\n                status=NodeStatus.OFFLINE,\n                capabilities=capabilities\n            )\n            self.worker_nodes[node_id] = worker_node\n            logger.info(f"工作节点已添加: {node_id} ({host}:{port})")\n\n    def remove_worker_node(self, node_id: str) -> None:\n    """文档字符串"""\n\n        """移除工作节点"""\n        with self._lock:\n            if node_id in self.worker_nodes:\n                del self.worker_nodes[node_id]\n                logger.info(f"工作节点已移除: {node_id}")\n\n    def distribute_tests(self, test_suite: List[Tuple[str, Callable, Dict[str, Any]]]) -> None:\n    """文档字符串"""\n\n        """分发测试到工作节点"""\n        if not self._running:\n            raise RuntimeError("分布式测试运行器未启动")\n\n        logger.info(f"开始分发 {len(test_suite)} 个测试...")\n\n        # 根据策略分发测试\n        if self.config.test_distribution_strategy == "round_robin":\n            self._distribute_round_robin(test_suite)\n        elif self.config.test_distribution_strategy == "load_balanced":\n            self._distribute_load_balanced(test_suite)\n        elif self.config.test_distribution_strategy == "random":\n            self._distribute_random(test_suite)\n        else:\n            self._distribute_round_robin(test_suite)\n\n        logger.info("测试分发完成")\n\n    def collect_results(self, timeout: int = 300) -> List[TestResult]:\n    """文档字符串"""\n\n        """收集测试结果"""\n        if not self._running:\n            raise RuntimeError("分布式测试运行器未启动")\n\n        logger.info("开始收集测试结果...")\n\n        start_time = time.time()\n        collected_results = []\n\n        while len(collected_results) < len(self.test_results):\n            try:\n                # 从结果队列获取结果\n                result_data = self.result_queue.get(timeout=1)\n                if result_data:\n                    test_result = pickle.loads(result_data)\n                    collected_results.append(test_result)\n\n                    # 更新统计信息\n                    if test_result.status == TestExecutionStatus.PASSED:\n                        self.completed_tests += 1\n                    else:\n                        self.failed_tests += 1\n\n                    logger.info(f"收集结果: {test_result.test_name} - {test_result.status.value}")\n\n            except Exception as e:\n                if time.time() - start_time > timeout:\n                    logger.warning(f"收集结果超时: {e}")\n                    break\n                continue\n\n        self.total_execution_time = time.time() - self.start_time\n        logger.info(f"结果收集完成: {len(collected_results)}/{len(self.test_results)}")\n\n        return collected_results\n\n    def get_cluster_status(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取集群状态"""\n        with self._lock:\n            online_workers = len([n for n in self.worker_nodes.values() if n.status == NodeStatus.ONLINE])\n            busy_workers = len([n for n in self.worker_nodes.values() if n.status == NodeStatus.BUSY])\n            idle_workers = len([n for n in self.worker_nodes.values() if n.status == NodeStatus.IDLE])\n\n            return {\n                'master_status': 'running' if self._running else 'stopped',\n                'total_workers': len(self.worker_nodes),\n                'online_workers': online_workers,\n                'busy_workers': busy_workers,\n                'idle_workers': idle_workers,\n                'test_progress': {\n                    'total': len(self.test_results),\n                    'completed': self.completed_tests,\n                    'failed': self.failed_tests,\n                    'pending': len(self.test_results) - self.completed_tests - self.failed_tests\n                },\n                'execution_time': self.total_execution_time\n            }\n\n    def _distribute_round_robin(self, test_suite: List[Tuple[str, Callable, Dict[str, Any]]]) -> None:\n    """文档字符串"""\n\n        """轮询分发测试"""\n        online_workers = [n for n in self.worker_nodes.values() if n.status == NodeStatus.ONLINE]\n        if not online_workers:\n            raise RuntimeError("没有可用的工作节点")\n\n        worker_index = 0\n        for test_name, test_func, test_kwargs in test_suite:\n            worker = online_workers[worker_index % len(online_workers)]\n\n            # 创建测试任务\n            test_task = {\n                'test_name': test_name,\n                'test_func': test_func,\n                'test_kwargs': test_kwargs,\n                'assigned_worker': worker.node_id,\n                'timestamp': time.time()\n            }\n\n            # 发送到测试队列\n            self.test_queue.put(pickle.dumps(test_task))\n\n            # 更新工作节点状态\n            worker.status = NodeStatus.BUSY\n            worker.load += 1.0\n\n            worker_index += 1\n\n    def _distribute_load_balanced(self, test_suite: List[Tuple[str, Callable, Dict[str, Any]]]) -> None:\n    """文档字符串"""\n\n        """负载均衡分发测试"""\n        online_workers = [n for n in self.worker_nodes.values() if n.status == NodeStatus.ONLINE]\n        if not online_workers:\n            raise RuntimeError("没有可用的工作节点")\n\n        for test_name, test_func, test_kwargs in test_suite:\n            # 选择负载最低的工作节点\n            worker = min(online_workers, key=lambda w: w.load)\n\n            # 创建测试任务\n            test_task = {\n                'test_name': test_name,\n                'test_func': test_func,\n                'test_kwargs': test_kwargs,\n                'assigned_worker': worker.node_id,\n                'timestamp': time.time()\n            }\n\n            # 发送到测试队列\n            self.test_queue.put(pickle.dumps(test_task))\n\n            # 更新工作节点状态\n            worker.status = NodeStatus.BUSY\n            worker.load += 1.0\n\n    def _distribute_random(self, test_suite: List[Tuple[str, Callable, Dict[str, Any]]]) -> None:\n    """文档字符串"""\n\n        """随机分发测试"""\n        import random\n\n        online_workers = [n for n in self.worker_nodes.values() if n.status == NodeStatus.ONLINE]\n        if not online_workers:\n            raise RuntimeError("没有可用的工作节点")\n\n        for test_name, test_func, test_kwargs in test_suite:\n            # 随机选择工作节点\n            worker = random.choice(online_workers)\n\n            # 创建测试任务\n            test_task = {\n                'test_name': test_name,\n                'test_func': test_func,\n                'test_kwargs': test_kwargs,\n                'assigned_worker': worker.node_id,\n                'timestamp': time.time()\n            }\n\n            # 发送到测试队列\n            self.test_queue.put(pickle.dumps(test_task))\n\n            # 更新工作节点状态\n            worker.status = NodeStatus.BUSY\n            worker.load += 1.0\n\n    def _run_master_node(self, config: DistributedTestConfig, test_queue: Queue, result_queue: Queue) -> None:\n    """文档字符串"""\n\n        """运行主节点"""\n        logger.info("主节点进程启动")\n\n        try:\n            # 主节点主循环\n            while True:\n                # 处理测试任务分发\n                # 处理结果收集\n                # 处理节点心跳\n                time.sleep(1)\n\n        except KeyboardInterrupt:\n            logger.info("主节点进程收到中断信号")\n        except Exception as e:\n            logger.error(f"主节点进程异常: {e}")\n        finally:\n            logger.info("主节点进程退出")\n\nclass WorkerNode:\n\n    """工作节点"""\n\n    def __init__(self, node_id: str, master_host: str, master_port: int, capabilities: Dict[str, Any]):\n\n        self.node_id = node_id\n        self.master_host = master_host\n        self.master_port = master_port\n        self.capabilities = capabilities\n        self.status = NodeStatus.OFFLINE\n        self.test_runner = None\n        self._running = False\n        self._lock = threading.Lock()\n\n        # 测试执行器\n        self.test_executor = ThreadPoolExecutor(max_workers=capabilities.get('max_workers', 4))\n\n    def start(self) -> None:\n    """文档字符串"""\n\n        """启动工作节点"""\n        if self._running:\n            logger.warning(f"工作节点 {self.node_id} 已在运行")\n            return\n\n        logger.info(f"启动工作节点 {self.node_id}...")\n\n        # 创建测试运行器\n        config = TestSuiteConfig(\n            name=f"工作节点 {self.node_id}",\n            test_mode=TestMode.INTEGRATION,\n            max_workers=self.capabilities.get('max_workers', 4),\n            timeout=300,\n            parallel_execution=True\n        )\n        self.test_runner = AutomatedTestRunner(config)\n\n        # 启动心跳线程\n        heartbeat_thread = threading.Thread(target=self._heartbeat_loop, daemon=True)\n        heartbeat_thread.start()\n\n        # 启动测试执行线程\n        test_thread = threading.Thread(target=self._test_execution_loop, daemon=True)\n        test_thread.start()\n\n        self._running = True\n        self.status = NodeStatus.ONLINE\n        logger.info(f"工作节点 {self.node_id} 启动完成")\n\n    def stop(self) -> None:\n    """文档字符串"""\n\n        """停止工作节点"""\n        if not self._running:\n            return\n\n        logger.info(f"停止工作节点 {self.node_id}...")\n\n        self._running = False\n        self.status = NodeStatus.OFFLINE\n\n        if self.test_executor:\n            self.test_executor.shutdown(wait=True)\n\n        logger.info(f"工作节点 {self.node_id} 已停止")\n\n    def _heartbeat_loop(self) -> None:\n    """文档字符串"""\n\n        """心跳循环"""\n        while self._running:\n            try:\n                # 发送心跳到主节点\n                self._send_heartbeat()\n                time.sleep(5)  # 每5秒发送一次心跳\n            except Exception as e:\n                logger.error(f"心跳发送失败: {e}")\n                time.sleep(5)\n\n    def _test_execution_loop(self) -> None:\n    """文档字符串"""\n\n        """测试执行循环"""\n        while self._running:\n            try:\n                # 从主节点获取测试任务\n                test_task = self._get_test_task()\n                if test_task:\n                    # 执行测试\n                    self._execute_test(test_task)\n\n            except Exception as e:\n                logger.error(f"测试执行循环异常: {e}")\n                time.sleep(1)\n\n    def _send_heartbeat(self) -> None:\n    """文档字符串"""\n\n        """发送心跳"""\n        try:\n            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:\n                s.connect((self.master_host, self.master_port))\n\n                heartbeat_data = {\n                    'node_id': self.node_id,\n                    'status': self.status.value,\n                    'load': self.capabilities.get('max_workers', 4),\n                    'timestamp': time.time()\n                }\n\n                s.send(json.dumps(heartbeat_data).encode())\n\n        except Exception as e:\n            logger.error(f"心跳发送失败: {e}")\n\n    def _get_test_task(self) -> Optional[Dict[str, Any]]:\n    """文档字符串"""\n\n        """获取测试任务"""\n        # 这里应该实现从主节点获取测试任务的逻辑\n        # 暂时返回None，实际实现需要与主节点通信\n        return None\n\n    def _execute_test(self, test_task: Dict[str, Any]) -> None:\n    """文档字符串"""\n\n        """执行测试"""\n        try:\n            test_name = test_task['test_name']\n            test_func = test_task['test_func']\n            test_kwargs = test_task.get('test_kwargs', {})\n\n            logger.info(f"执行测试: {test_name}")\n\n            # 更新状态\n            with self._lock:\n                self.status = NodeStatus.BUSY\n\n            # 执行测试\n            start_time = time.time()\n            try:\n                result = test_func(**test_kwargs)\n                test_result = TestResult(\n                    test_name=test_name,\n                    test_mode=TestMode.INTEGRATION,\n                    status=TestExecutionStatus.PASSED,\n                    execution_time=time.time() - start_time,\n                    start_time=start_time,\n                    end_time=time.time(),\n                    metadata={'worker_node': self.node_id}\n                )\n            except Exception as e:\n                test_result = TestResult(\n                    test_name=test_name,\n                    test_mode=TestMode.INTEGRATION,\n                    status=TestExecutionStatus.FAILED,\n                    execution_time=time.time() - start_time,\n                    start_time=start_time,\n                    end_time=time.time(),\n                    error_message=str(e),\n                    metadata={'worker_node': self.node_id}\n                )\n\n            # 发送结果到主节点\n            self._send_test_result(test_result)\n\n            # 更新状态\n            with self._lock:\n                self.status = NodeStatus.IDLE\n\n        except Exception as e:\n            logger.error(f"测试执行异常: {e}")\n            with self._lock:\n                self.status = NodeStatus.IDLE\n\n    def _send_test_result(self, test_result: TestResult) -> None:\n    """文档字符串"""\n\n        """发送测试结果"""\n        try:\n            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:\n                s.connect((self.master_host, self.master_port))\n\n                result_data = {\n                    'node_id': self.node_id,\n                    'test_result': asdict(test_result),\n                    'timestamp': time.time()\n                }\n\n                s.send(json.dumps(result_data).encode())\n\n        except Exception as e:\n            logger.error(f"结果发送失败: {e}")\n\n# 便捷函数\n\ndef create_distributed_test_runner(config: DistributedTestConfig) -> DistributedTestRunner:\n    """文档字符串"""\n\n    """创建分布式测试运行器"""\n    return DistributedTestRunner(config)\n\ndef create_worker_node(node_id: str, master_host: str, master_port: int, capabilities: Dict[str, Any]) -> WorkerNode:\n    """文档字符串"""\n\n    """创建工作节点"""\n    return WorkerNode(node_id, master_host, master_port, capabilities)\n\ndef run_distributed_tests(\n    """文档字符串"""\n\n        test_suite: List[Tuple[str, Callable, Dict[str, Any]]],\n        worker_nodes: List[Dict[str, Any]],\n        config: DistributedTestConfig):\n    """运行分布式测试"""\n    # 创建分布式测试运行器\n    runner = create_distributed_test_runner(config)\n\n    # 添加工作节点\n    for worker_info in worker_nodes:\n        runner.add_worker_node(\n            worker_info['node_id'],\n            worker_info['host'],\n            worker_info['port'],\n            worker_info['capabilities']\n        )\n\n    try:\n        # 启动主节点\n        runner.start_master()\n\n        # 分发测试\n        runner.distribute_tests(test_suite)\n\n        # 收集结果\n        results = runner.collect_results()\n\n        return results\n\n    finally:\n        # 停止主节点\n        runner.stop_master()\n