#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n基础设施层 - 数据库异常处理机制\n处理数据库连接、查询、事务等方面的异常\n"""\n\nfrom enum import Enum\nfrom typing import Dict, Any, Optional, Callable, List, Union\nimport logging\nimport sqlite3\nimport threading\nimport time\n\nfrom dataclasses import dataclass, field\nimport psycopg2\nimport redis\nimport traceback\n\nlogger = logging.getLogger(__name__)\n\nclass DatabaseExceptionType(Enum):\n    """数据库异常类型"""\n    CONNECTION_LOST = "connection_lost"\n    CONNECTION_TIMEOUT = "connection_timeout"\n    QUERY_TIMEOUT = "query_timeout"\n    SYNTAX_ERROR = "syntax_error"\n    CONSTRAINT_VIOLATION = "constraint_violation"\n    DEADLOCK = "deadlock"\n    LOCK_TIMEOUT = "lock_timeout"\n    INSUFFICIENT_PRIVILEGES = "insufficient_privileges"\n    OUT_OF_MEMORY = "out_of_memory"\n    DISK_FULL = "disk_full"\n    CONNECTION_POOL_EXHAUSTED = "connection_pool_exhausted"\n\n@dataclass\nclass DatabaseExceptionContext:\n    """数据库异常上下文"""\n    exception: Exception\n    exception_type: DatabaseExceptionType\n    database_type: str = ""\n    operation: str = ""\n    query: str = ""\n    table: str = ""\n    connection_id: str = ""\n    timestamp: float = None\n    duration: float = 0.0\n    metadata: Dict[str, Any] = field(default_factory=dict)\n\n    def __post_init__(self):\n        if self.timestamp is None:\n            self.timestamp = time.time()\n\n@dataclass\nclass DatabaseRecoveryResult:\n    """数据库恢复结果"""\n    recovered: bool\n    retry_count: int = 0\n    new_connection: Any = None\n    recovery_time: float = 0.0\n    message: str = ""\n    should_reconnect: bool = False\n\nclass DatabaseExceptionHandler:\n    """数据库异常处理器"""\n\n    def __init__(self):\n        self.exception_handlers = {}\n        self.recovery_strategies = {}\n        self.connection_pool = {}\n        self.exception_stats = {}\n        self._lock = threading.RLock()\n\n        # 初始化处理器\n        self._initialize_handlers()\n\n    def _initialize_handlers(self):\n        """初始化异常处理器"""\n        self.register_handler(DatabaseExceptionType.CONNECTION_LOST, self._handle_connection_lost)\n        self.register_handler(DatabaseExceptionType.CONNECTION_TIMEOUT, self._handle_connection_timeout)\n        self.register_handler(DatabaseExceptionType.QUERY_TIMEOUT, self._handle_query_timeout)\n        self.register_handler(DatabaseExceptionType.SYNTAX_ERROR, self._handle_syntax_error)\n        self.register_handler(DatabaseExceptionType.CONSTRAINT_VIOLATION, self._handle_constraint_violation)\n        self.register_handler(DatabaseExceptionType.DEADLOCK, self._handle_deadlock)\n        self.register_handler(DatabaseExceptionType.LOCK_TIMEOUT, self._handle_lock_timeout)\n        self.register_handler(DatabaseExceptionType.INSUFFICIENT_PRIVILEGES, self._handle_insufficient_privileges)\n        self.register_handler(DatabaseExceptionType.OUT_OF_MEMORY, self._handle_out_of_memory)\n        self.register_handler(DatabaseExceptionType.DISK_FULL, self._handle_disk_full)\n        self.register_handler(DatabaseExceptionType.CONNECTION_POOL_EXHAUSTED, self._handle_connection_pool_exhausted)\n\n    def register_handler(self, exception_type: DatabaseExceptionType, handler: Callable):\n        """注册异常处理器"""\n        self.exception_handlers[exception_type] = handler\n\n    def register_recovery_strategy(self, exception_type: DatabaseExceptionType, strategy: Callable):\n        """注册恢复策略"""\n        self.recovery_strategies[exception_type] = strategy\n\n    def handle_database_exception(self, exception: Exception,\n    """文档字符串"""\n                                context: Dict[str, Any] = None) -> DatabaseRecoveryResult:\n        """处理数据库异常"""\n        context = context or {}\n\n        # 确定异常类型\n        exception_type = self._classify_database_exception(exception, context)\n\n        # 创建异常上下文\n        exc_context = DatabaseExceptionContext(\n            exception=exception,\n            exception_type=exception_type,\n            database_type=context.get('database_type', ''),\n            operation=context.get('operation', ''),\n            query=context.get('query', ''),\n            table=context.get('table', ''),\n            connection_id=context.get('connection_id', ''),\n            duration=context.get('duration', 0.0),\n            metadata=context\n        )\n\n        # 更新统计信息\n        self._update_exception_stats(exception_type)\n\n        # 获取处理器\n        handler = self.exception_handlers.get(exception_type)\n        if handler:\n            try:\n                return handler(exc_context)\n            except Exception as e:\n                logger.error(f"数据库异常处理器执行失败: {e}")\n                return DatabaseRecoveryResult(\n                    recovered=False,\n                    message=f"处理器执行失败: {e}"\n                )\n\n        # 默认处理\n        return self._default_database_exception_handling(exc_context)\n\n    def _classify_database_exception(self, exception: Exception,\n    """文档字符串"""\n                                   context: Dict[str, Any]) -> DatabaseExceptionType:\n        """分类数据库异常"""\n        exc_type = type(exception).__name__\n        exc_message = str(exception).lower()\n\n        # PostgreSQL异常\n        if exc_type == 'OperationalError':\n            if 'connection' in exc_message and 'lost' in exc_message:\n                return DatabaseExceptionType.CONNECTION_LOST\n            elif 'timeout' in exc_message:\n                return DatabaseExceptionType.CONNECTION_TIMEOUT\n            elif 'syntax' in exc_message:\n                return DatabaseExceptionType.SYNTAX_ERROR\n            elif 'constraint' in exc_message:\n                return DatabaseExceptionType.CONSTRAINT_VIOLATION\n            elif 'deadlock' in exc_message:\n                return DatabaseExceptionType.DEADLOCK\n            elif 'lock' in exc_message and 'timeout' in exc_message:\n                return DatabaseExceptionType.LOCK_TIMEOUT\n            elif 'privilege' in exc_message:\n                return DatabaseExceptionType.INSUFFICIENT_PRIVILEGES\n\n        # SQLite异常\n        elif exc_type == 'OperationalError' and 'sqlite' in exc_message:\n            if 'disk' in exc_message and 'full' in exc_message:\n                return DatabaseExceptionType.DISK_FULL\n            elif 'memory' in exc_message:\n                return DatabaseExceptionType.OUT_OF_MEMORY\n\n        # Redis异常\n        elif hasattr(exception, 'args') and len(exception.args) > 0:\n            if 'ConnectionError' in exc_type or 'connection' in exc_message:\n                return DatabaseExceptionType.CONNECTION_LOST\n            elif 'TimeoutError' in exc_type or 'timeout' in exc_message:\n                return DatabaseExceptionType.QUERY_TIMEOUT\n\n        # 通用异常分类\n        if 'timeout' in exc_message:\n            return DatabaseExceptionType.QUERY_TIMEOUT\n        elif 'connection' in exc_message:\n            return DatabaseExceptionType.CONNECTION_LOST\n        elif 'syntax' in exc_message:\n            return DatabaseExceptionType.SYNTAX_ERROR\n        elif 'constraint' in exc_message or 'violation' in exc_message:\n            return DatabaseExceptionType.CONSTRAINT_VIOLATION\n        elif 'deadlock' in exc_message:\n            return DatabaseExceptionType.DEADLOCK\n        elif 'privilege' in exc_message or 'permission' in exc_message:\n            return DatabaseExceptionType.INSUFFICIENT_PRIVILEGES\n\n        # 默认归类为连接问题\n        return DatabaseExceptionType.CONNECTION_LOST\n\n    def _update_exception_stats(self, exception_type: DatabaseExceptionType):\n        """更新异常统计"""\n        key = f"db_{exception_type.value}"\n        self.exception_stats[key] = self.exception_stats.get(key, 0) + 1\n\n    def _handle_connection_lost(self, context: DatabaseExceptionContext) -> DatabaseRecoveryResult:\n        """处理连接丢失异常"""\n        logger.warning(f"数据库连接丢失: {context.database_type} - {context.connection_id}")\n\n        return DatabaseRecoveryResult(\n            recovered=True,\n            retry_count=3,\n            should_reconnect=True,\n            message="连接已丢失，正在重新连接"\n        )\n\n    def _handle_connection_timeout(self, context: DatabaseExceptionContext) -> DatabaseRecoveryResult:\n        """处理连接超时异常"""\n        logger.warning(f"数据库连接超时: {context.database_type} - {context.operation}")\n\n        return DatabaseRecoveryResult(\n            recovered=True,\n            retry_count=2,\n            should_reconnect=True,\n            message="连接超时，增加超时时间后重试"\n        )\n\n    def _handle_query_timeout(self, context: DatabaseExceptionContext) -> DatabaseRecoveryResult:\n        """处理查询超时异常"""\n        logger.warning(f"数据库查询超时: {context.table} - {context.operation}")\n\n        return DatabaseRecoveryResult(\n            recovered=True,\n            retry_count=1,\n            message="查询超时，优化查询后重试"\n        )\n\n    def _handle_syntax_error(self, context: DatabaseExceptionContext) -> DatabaseRecoveryResult:\n        """处理语法错误异常"""\n        logger.error(f"数据库语法错误: {context.query}")\n\n        return DatabaseRecoveryResult(\n            recovered=False,\n            message="SQL语法错误，请检查查询语句"\n        )\n\n    def _handle_constraint_violation(self, context: DatabaseExceptionContext) -> DatabaseRecoveryResult:\n        """处理约束违反异常"""\n        logger.warning(f"数据库约束违反: {context.table}")\n\n        return DatabaseRecoveryResult(\n            recovered=False,\n            message="数据约束违反，请检查输入数据"\n        )\n\n    def _handle_deadlock(self, context: DatabaseExceptionContext) -> DatabaseRecoveryResult:\n        """处理死锁异常"""\n        logger.warning(f"数据库死锁: {context.table}")\n\n        return DatabaseRecoveryResult(\n            recovered=True,\n            retry_count=3,\n            message="检测到死锁，正在重试事务"\n        )\n\n    def _handle_lock_timeout(self, context: DatabaseExceptionContext) -> DatabaseRecoveryResult:\n        """处理锁超时异常"""\n        logger.warning(f"数据库锁超时: {context.table} - {context.operation}")\n\n        return DatabaseRecoveryResult(\n            recovered=True,\n            retry_count=2,\n            message="锁超时，增加等待时间后重试"\n        )\n\n    def _handle_insufficient_privileges(self, context: DatabaseExceptionContext) -> DatabaseRecoveryResult:\n        """处理权限不足异常"""\n        logger.error(f"数据库权限不足: {context.operation} - {context.table}")\n\n        return DatabaseRecoveryResult(\n            recovered=False,\n            message="数据库权限不足，请检查用户权限"\n        )\n\n    def _handle_out_of_memory(self, context: DatabaseExceptionContext) -> DatabaseRecoveryResult:\n        """处理内存不足异常"""\n        logger.error(f"数据库内存不足: {context.database_type}")\n\n        return DatabaseRecoveryResult(\n            recovered=False,\n            message="数据库内存不足，建议优化查询或增加内存"\n        )\n\n    def _handle_disk_full(self, context: DatabaseExceptionContext) -> DatabaseRecoveryResult:\n        """处理磁盘满异常"""\n        logger.error(f"数据库磁盘已满: {context.database_type}")\n\n        return DatabaseRecoveryResult(\n            recovered=False,\n            message="数据库磁盘已满，请清理磁盘空间"\n        )\n\n    def _handle_connection_pool_exhausted(self, context: DatabaseExceptionContext) -> DatabaseRecoveryResult:\n        """处理连接池耗尽异常"""\n        logger.warning(f"数据库连接池耗尽: {context.database_type}")\n\n        return DatabaseRecoveryResult(\n            recovered=True,\n            retry_count=5,\n            should_reconnect=True,\n            message="连接池耗尽，等待连接释放后重试"\n        )\n\n    def _default_database_exception_handling(self, context: DatabaseExceptionContext) -> DatabaseRecoveryResult:\n        """默认数据库异常处理"""\n        logger.error(f"未处理的数据库异常: {context.exception_type.value} - {context.exception}")\n\n        return DatabaseRecoveryResult(\n            recovered=False,\n            message=f"数据库异常: {type(context.exception).__name__}"\n        )\n\n    def get_exception_stats(self) -> Dict[str, int]:\n        """获取异常统计信息"""\n        with self._lock:\n            return self.exception_stats.copy()\n\nclass DatabaseConnectionManager:\n    """数据库连接管理器"""\n\n    def __init__(self, exception_handler: Optional[DatabaseExceptionHandler] = None):\n        self.exception_handler = exception_handler or DatabaseExceptionHandler()\n        self.connections = {}\n        self.connection_configs = {}\n\n    def register_connection(self, name: str, config: Dict[str, Any]):\n        """注册数据库连接配置"""\n        self.connection_configs[name] = config\n\n    def get_connection(self, name: str, auto_reconnect: bool = True) -> Any:\n        """获取数据库连接"""\n        if name not in self.connection_configs:\n            raise ValueError(f"未注册的数据库连接: {name}")\n\n        # 检查现有连接\n        if name in self.connections:\n            connection = self.connections[name]\n            if self._is_connection_valid(connection, name):\n                return connection\n\n        # 创建新连接\n        return self._create_connection(name, auto_reconnect)\n\n    def _create_connection(self, name: str, auto_reconnect: bool = True) -> Any:\n        """创建数据库连接"""\n        config = self.connection_configs[name]\n        db_type = config.get('type', 'postgresql')\n\n        try:\n            if db_type == 'postgresql':\n                connection = psycopg2.connect(**config.get('params', {}))\n            elif db_type == 'sqlite':\n                connection = sqlite3.connect(config.get('database', ':memory:'))\n            elif db_type == 'redis':\n                connection = redis.Redis(**config.get('params', {}))\n            else:\n                raise ValueError(f"不支持的数据库类型: {db_type}")\n\n            self.connections[name] = connection\n            return connection\n\n        except Exception as e:\n            if auto_reconnect:\n                # 尝试恢复连接\n                result = self.exception_handler.handle_database_exception(\n                    e,\n                    {\n                        'database_type': db_type,\n                        'connection_id': name,\n                        'operation': 'connect'\n                    }\n                )\n\n                if result.should_reconnect and result.retry_count > 0:\n                    logger.info(f"尝试重新连接数据库: {name}")\n                    time.sleep(1)\n                    return self._create_connection(name, False)\n\n            raise e\n\n    def _is_connection_valid(self, connection: Any, name: str) -> bool:\n        """检查连接是否有效"""\n        try:\n            if hasattr(connection, 'ping'):\n                connection.ping()\n            elif hasattr(connection, 'cursor'):\n                cursor = connection.cursor()\n                cursor.execute("SELECT 1")\n                cursor.close()\n            elif hasattr(connection, 'exists'):\n                # Redis连接检查\n                connection.exists('test_key')\n            return True\n        except Exception as e:\n            logger.warning(f"数据库连接无效: {name} - {e}")\n            return False\n\n    def close_connection(self, name: str):\n        """关闭数据库连接"""\n        if name in self.connections:\n            try:\n                self.connections[name].close()\n            except Exception as e:\n                logger.error(f"关闭数据库连接失败: {name} - {e}")\n            finally:\n                del self.connections[name]\n\n    def close_all_connections(self):\n        """关闭所有数据库连接"""\n        for name in list(self.connections.keys()):\n            self.close_connection(name)\n\n# 装饰器\ndef database_exception_handler(operation: str = "", table: str = ""):\n    """数据库异常处理装饰器"""\n    def decorator(func):\n    """文档字符串"""\n        def wrapper(*args, **kwargs):\n            handler = DatabaseExceptionHandler()\n            start_time = time.time()\n\n            try:\n                return func(*args, **kwargs)\n            except Exception as e:\n                duration = time.time() - start_time\n\n                result = handler.handle_database_exception(\n                    e,\n                    {\n                        'operation': operation or func.__name__,\n                        'table': table,\n                        'duration': duration,\n                        'function': func.__name__,\n                        'args': str(args)[:100],  # 限制长度\n                        'kwargs': str(kwargs)[:100]\n                    }\n                )\n\n                if result.recovered and result.retry_count > 0:\n                    # 重试逻辑\n                    for i in range(result.retry_count):\n                        try:\n                            time.sleep(0.1 * (i + 1))\n                            return func(*args, **kwargs)\n                        except Exception:\n                            continue\n\n                raise e\n\n        return wrapper\n    return decorator\n