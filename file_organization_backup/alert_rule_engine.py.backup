"""\n基础设施层 - 日志系统组件\n\nalert_rule_engine 模块\n\n日志系统相关的文件\n提供日志系统相关的功能实现。\n"""\n\n#!/usr/bin/env python3\nfrom datetime import datetime, timedelta\nfrom enum import Enum\nfrom typing import Dict, Any, List, Optional, Callable\nimport asyncio\nimport json\nimport logging\nimport re\nimport threading\nimport time\n\nfrom dataclasses import dataclass, field\n\n# -*- coding: utf-8 -*-\n\n"""\nalert_rule_engine - 日志系统\n\n职责说明：\n负责系统日志记录、日志格式化、日志存储和日志分析\n\n核心职责：\n- 日志记录和格式化\n- 日志级别管理\n- 日志存储和轮转\n- 日志分析和监控\n- 日志搜索和过滤\n- 日志性能优化\n\n相关接口：\n- ILoggingComponent\n- ILogger\n- ILogHandler\n""" """\n智能告警规则引擎\n支持动态规则配置、自动阈值调整和智能告警抑制\n"""\n\nlogger = logging.getLogger(__name__)\n\nclass AlertSeverity(Enum):\n\n    """告警严重程度"""\n    INFO = "info"\n    WARNING = "warning"\n    CRITICAL = "critical"\n    EMERGENCY = "emergency"\n\nclass AlertStatus(Enum):\n\n    """告警状态"""\n    ACTIVE = "active"\n    ACKNOWLEDGED = "acknowledged"\n    RESOLVED = "resolved"\n    SUPPRESSED = "suppressed"\n\n@dataclass\nclass AlertRule:\n\n    """告警规则定义"""\n    name: str\n    description: str\n    query: str  # Prometheus查询表达式\n    severity: AlertSeverity\n    threshold: float\n    duration: str  # 持续时间，如 "5m"\n    labels: Dict[str, str] = field(default_factory=dict)\n    annotations: Dict[str, str] = field(default_factory=dict)\n    enabled: bool = True\n    auto_threshold: bool = False  # 是否启用自动阈值调整\n\n    # 告警抑制配置\n    suppress_duration: str = "0s"  # 抑制持续时间\n    suppress_conditions: List[str] = field(default_factory=list)  # 抑制条件\n\n    # 自动阈值调整配置\n    learning_window: str = "24h"  # 学习窗口\n    adjustment_factor: float = 0.1  # 调整因子\n\n@dataclass\nclass AlertInstance:\n\n    """告警实例"""\n    rule_name: str\n    severity: AlertSeverity\n    status: AlertStatus\n    value: float\n    threshold: float\n    labels: Dict[str, str]\n    annotations: Dict[str, str]\n    start_time: datetime\n    last_update: datetime\n    acknowledged_by: Optional[str] = None\n    acknowledged_at: Optional[datetime] = None\n    resolved_at: Optional[datetime] = None\n\nclass AlertRuleEngine:\n\n    """智能告警规则引擎"""\n\n    def __init__(self, prometheus_exporter=None, alert_manager=None):\n\n        """\n        初始化告警规则引擎\n\n        Args:\n            prometheus_exporter: Prometheus导出器实例\n            alert_manager: 告警管理器实例\n        """\n        self.prometheus_exporter = prometheus_exporter\n        self.alert_manager = alert_manager\n\n        # 告警规则存储\n        self.rules: Dict[str, AlertRule] = {}\n\n        # 活跃告警实例\n        self.active_alerts: Dict[str, AlertInstance] = {}\n\n        # 告警历史记录\n        self.alert_history: List[AlertInstance] = []\n\n        # 规则评估线程\n        self._evaluation_thread = None\n        self._stop_evaluation = False\n\n        # 性能指标历史（用于自动阈值调整）\n        self.metrics_history: Dict[str, List[float]] = {}\n\n        # 告警抑制状态\n        self.suppression_state: Dict[str, Dict[str, Any]] = {}\n\n        # 启动规则评估\n        self._start_rule_evaluation()\n\n        logger.info("Alert rule engine initialized")\n\n    def add_rule(self, rule: AlertRule) -> bool:\n    """文档字符串"""\n\n        """\n        添加告警规则\n\n        Args:\n            rule: 告警规则\n\n        Returns:\n            是否添加成功\n        """\n        try:\n            # 验证规则\n            if not self._validate_rule(rule):\n                return False\n\n            self.rules[rule.name] = rule\n            logger.info(f"Alert rule added: {rule.name}")\n            return True\n\n        except Exception as e:\n            logger.error(f"Failed to add alert rule: {e}")\n            return False\n\n    def remove_rule(self, rule_name: str) -> bool:\n    """文档字符串"""\n\n        """\n        删除告警规则\n\n        Args:\n            rule_name: 规则名称\n\n        Returns:\n            是否删除成功\n        """\n        if rule_name in self.rules:\n            del self.rules[rule_name]\n            logger.info(f"Alert rule removed: {rule_name}")\n            return True\n        return False\n\n    def update_rule(self, rule_name: str, updates: Dict[str, Any]) -> bool:\n    """文档字符串"""\n\n        """\n        更新告警规则\n\n        Args:\n            rule_name: 规则名称\n            updates: 更新内容\n\n        Returns:\n            是否更新成功\n        """\n        if rule_name not in self.rules:\n            return False\n\n        try:\n            rule = self.rules[rule_name]\n            for key, value in updates.items():\n                if hasattr(rule, key):\n                    setattr(rule, key, value)\n\n            logger.info(f"Alert rule updated: {rule_name}")\n            return True\n\n        except Exception as e:\n            logger.error(f"Failed to update alert rule: {e}")\n            return False\n\n    def evaluate_rules(self, metrics: Optional[Dict[str, Any]] = None) -> List[AlertInstance]:\n    """文档字符串"""\n\n        """\n        评估所有告警规则\n\n        Args:\n            metrics: 可选的指标数据，用于规则评估\n\n        Returns:\n            触发的告警列表\n        """\n        triggered_alerts = []\n\n        for rule_name, rule in self.rules.items():\n            if not rule.enabled:\n                continue\n\n            try:\n                # 检查是否被抑制\n                if self._is_suppressed(rule):\n                    continue\n\n                # 评估规则，使用传入的metrics\n                alert_instance = self._evaluate_rule(rule, metrics)\n                if alert_instance:\n                    triggered_alerts.append(alert_instance)\n\n                    # 更新活跃告警\n                    self.active_alerts[rule_name] = alert_instance\n\n                    # 发送告警\n                    if self.alert_manager:\n                        try:\n                            # 使用AlertManager的check_alert_condition方法\n                            # 创建标签字典\n                            labels = {\n                                "component": "alert_rule_engine",\n                                "rule_name": alert_instance.rule_name,\n                                "severity": alert_instance.severity.value\n                            }\n\n                            # 调用AlertManager的check_alert_condition方法\n                            triggered_alerts = self.alert_manager.check_alert_condition(\n                                metric_name=alert_instance.rule_name,\n                                metric_value=alert_instance.value,\n                                labels=labels\n                            )\n\n                            if triggered_alerts:\n                                logger.info(f"Alert sent via AlertManager: {alert_instance.rule_name}")\n                            else:\n                                logger.warning(f"Alert not triggered by AlertManager: {alert_instance.rule_name}")\n\n                        except Exception as e:\n                            logger.error(f"Failed to send alert via AlertManager: {e}")\n                            # 如果AlertManager发送失败，记录到本地日志\n                            logger.warning(f"Alert triggered: {alert_instance.rule_name} - {alert_instance.value} {alert_instance.threshold}")\n\n            except Exception as e:\n                logger.error(f"Error evaluating rule {rule_name}: {e}")\n\n        return triggered_alerts\n\n    def _evaluate_rule(self, rule: AlertRule, metrics: Optional[Dict[str, Any]] = None) -> Optional[AlertInstance]:\n    """文档字符串"""\n\n        """\n        评估单个告警规则\n\n        Args:\n            rule: 告警规则\n            metrics: 可选的指标数据\n\n        Returns:\n            告警实例或None\n        """\n        try:\n            # 优先使用传入的metrics数据\n            current_value = None\n            if metrics:\n                # 从metrics中提取相关值\n                if 'cpu_usage' in rule.query and 'cpu_usage' in metrics:\n                    current_value = metrics['cpu_usage']\n                elif 'memory_usage' in rule.query and 'memory_usage' in metrics:\n                    current_value = metrics['memory_usage']\n                elif 'disk_usage' in rule.query and 'disk_usage' in metrics:\n                    current_value = metrics['disk_usage']\n\n            # 如果没有找到匹配的metrics，使用模拟查询\n            if current_value is None:\n                current_value = self._simulate_prometheus_query(rule.query)\n\n            if current_value is None:\n                return None\n\n            # 检查阈值\n            if self._check_threshold(current_value, rule.threshold, rule.query):\n                # 创建告警实例\n                alert_instance = AlertInstance(\n                    rule_name=rule.name,\n                    severity=rule.severity,\n                    status=AlertStatus.ACTIVE,\n                    value=current_value,\n                    threshold=rule.threshold,\n                    labels=rule.labels.copy(),\n                    annotations=rule.annotations.copy(),\n                    start_time=datetime.now(),\n                    last_update=datetime.now()\n                )\n\n                # 记录指标历史（用于自动阈值调整）\n                self._record_metric_history(rule.query, current_value)\n\n                # 如果启用自动阈值调整，尝试调整阈值\n                if rule.auto_threshold:\n                    self._adjust_threshold(rule)\n\n                return alert_instance\n\n            return None\n\n        except Exception as e:\n            logger.error(f"Error evaluating rule {rule.name}: {e}")\n            return None\n\n    def _check_threshold(self, value: float, threshold: float, query: str) -> bool:\n    """文档字符串"""\n\n        """检查是否超过阈值"""\n        # 根据查询类型判断阈值检查逻辑\n        if '>' in query:\n            return value > threshold\n        elif '<' in query:\n            return value < threshold\n        elif '>=' in query:\n            return value >= threshold\n        elif '<=' in query:\n            return value <= threshold\n        else:\n            return value != threshold\n\n    def _is_suppressed(self, rule: AlertRule) -> bool:\n    """文档字符串"""\n\n        """检查告警是否被抑制"""\n        rule_key = f"{rule.name}_{rule.severity.value}"\n\n        if rule_key not in self.suppression_state:\n            return False\n\n        suppression = self.suppression_state[rule_key]\n\n        # 检查时间抑制\n        if suppression.get('until'):\n            if datetime.now() < suppression['until']:\n                return True\n\n        # 检查条件抑制\n        for condition in rule.suppress_conditions:\n            if self._evaluate_suppression_condition(condition):\n                return True\n\n        return False\n\n    def _evaluate_suppression_condition(self, condition: str) -> bool:\n    """文档字符串"""\n\n        """评估抑制条件"""\n        try:\n            # 简单的条件评估，实际应用中可能需要更复杂的表达式解析\n            if 'time' in condition:\n                # 时间条件，如 "time: 23:00 - 06:00"\n                return self._evaluate_time_condition(condition)\n            elif 'day' in condition:\n                # 日期条件，如 "day: weekend"\n                return self._evaluate_day_condition(condition)\n            else:\n                return False\n        except Exception as e:\n            logger.warning(f"Failed to evaluate suppression condition: {e}")\n            return False\n\n    def _evaluate_time_condition(self, condition: str) -> bool:\n    """文档字符串"""\n\n        """评估时间条件"""\n        try:\n            # 解析时间范围，如 "23:00 - 06:00"\n            time_range = condition.split(':')[1].strip()\n            start_time, end_time = time_range.split('-')\n\n            current_time = datetime.now().time()\n            start_time = datetime.strptime(start_time, '%H:%M').time()\n            end_time = datetime.strptime(end_time, '%H:%M').time()\n\n            if start_time <= end_time:\n                return start_time <= current_time <= end_time\n            else:\n                # 跨午夜的情况\n                return current_time >= start_time or current_time <= end_time\n\n        except Exception as e:\n            logger.warning(f"Failed to parse time condition: {e}")\n            return False\n\n    def _evaluate_day_condition(self, condition: str) -> bool:\n    """文档字符串"""\n\n        """评估日期条件"""\n        try:\n            day_type = condition.split(':')[1].strip()\n            current_weekday = datetime.now().weekday()\n\n            if day_type == 'weekend':\n                return current_weekday >= 5  # 周六、周日\n            elif day_type == 'weekday':\n                return current_weekday < 5   # 周一至周五\n            else:\n                return False\n\n        except Exception as e:\n            logger.warning(f"Failed to parse day condition: {e}")\n            return False\n\n    def _record_metric_history(self, query: str, value: float) -> None:\n    """文档字符串"""\n\n        """记录指标历史"""\n        if query not in self.metrics_history:\n            self.metrics_history[query] = []\n\n        self.metrics_history[query].append(value)\n\n        # 保持历史记录在合理范围内\n        if len(self.metrics_history[query]) > 1000:\n            self.metrics_history[query] = self.metrics_history[query][-500:]\n\n    def _adjust_threshold(self, rule: AlertRule) -> None:\n    """文档字符串"""\n\n        """自动调整阈值"""\n        try:\n            if rule.query not in self.metrics_history:\n                return\n\n            values = self.metrics_history[rule.query]\n            if len(values) < 10:  # 需要足够的数据点\n                return\n\n            # 计算统计信息\n            mean_value = sum(values) / len(values)\n            std_dev = (sum((x - mean_value) ** 2 for x in values) / len(values)) ** 0.5\n\n            # 根据当前值和统计信息调整阈值\n            current_threshold = rule.threshold\n            new_threshold = current_threshold\n\n            if rule.query.find('>') != -1 or rule.query.find('>=') != -1:\n                # 大于阈值的情况\n                if mean_value > current_threshold:\n                    new_threshold = mean_value + std_dev * rule.adjustment_factor\n            elif rule.query.find('<') != -1 or rule.query.find('<=') != -1:\n                # 小于阈值的情况\n                if mean_value < current_threshold:\n                    new_threshold = mean_value - std_dev * rule.adjustment_factor\n\n            # 应用调整\n            if abs(new_threshold - current_threshold) > std_dev * 0.1:\n                rule.threshold = new_threshold\n                logger.info(f"Threshold adjusted for rule {rule.name}: {current_threshold:.2f} -> {new_threshold:.2f}")\n\n        except Exception as e:\n            logger.warning(f"Failed to adjust threshold for rule {rule.name}: {e}")\n\n    def _simulate_prometheus_query(self, query: str) -> Optional[float]:\n    """文档字符串"""\n\n        """模拟Prometheus查询（用于测试）"""\n        # 在实际应用中，这里应该执行真正的Prometheus查询\n        # 现在我们返回一个模拟值\n        import random\n        return random.uniform(0, 100)\n\n    def _validate_rule(self, rule: AlertRule) -> bool:\n    """文档字符串"""\n\n        """验证告警规则"""\n        if not rule.name or not rule.query:\n            return False\n\n        if rule.threshold <= 0:\n            return False\n\n        # 验证持续时间格式\n        if not self._is_valid_duration(rule.duration):\n            return False\n\n        return True\n\n    def _is_valid_duration(self, duration: str) -> bool:\n    """文档字符串"""\n\n        """验证持续时间格式"""\n        # 简单的持续时间格式验证\n        pattern = r'^\d+[smhdwy]$'\n        return bool(re.match(pattern, duration))\n\n    def _start_rule_evaluation(self) -> None:\n    """文档字符串"""\n\n        """启动规则评估线程"""\n        # 检查是否在测试环境中\n        import os\n        if os.environ.get('PYTEST_CURRENT_TEST') is not None:\n            logger.info("测试环境检测到，跳过后台规则评估启动")\n            return\n\n        def evaluation_worker():\n    """文档字符串"""\n\n            while not self._stop_evaluation:\n                try:\n                    # 评估所有规则\n                    triggered_alerts = self.evaluate_rules()\n\n                    if triggered_alerts:\n                        try:\n                            logger.info(f"Rule evaluation triggered {len(triggered_alerts)} alerts")\n                        except (ValueError, OSError):\n                            # 如果日志记录失败，使用print作为后备\n                            print(f"Rule evaluation triggered {len(triggered_alerts)} alerts")\n\n                        # 清理已解决的告警\n                        self._cleanup_resolved_alerts()\n\n                        # 等待下次评估\n                        time.sleep(30)  # 每30秒评估一次\n\n                except Exception as e:\n                    try:\n                        logger.error(f"Rule evaluation error: {e}")\n                    except (ValueError, OSError):\n                        # 如果日志记录失败，使用print作为后备\n                        print(f"Rule evaluation error: {e}")\n                        time.sleep(30)\n\n        self._evaluation_thread = threading.Thread(target=evaluation_worker, daemon=True)\n        self._evaluation_thread.start()\n\n    def _cleanup_resolved_alerts(self) -> None:\n    """文档字符串"""\n\n        """清理已解决的告警"""\n        current_time = datetime.now()\n        resolved_alerts = []\n\n        for alert_id, alert in self.active_alerts.items():\n            # 检查告警是否应该自动解决\n            if alert.status == AlertStatus.ACTIVE:\n                # 这里可以添加自动解决逻辑\n                pass\n\n            # 将已解决的告警移到历史记录\n            if alert.status == AlertStatus.RESOLVED:\n                resolved_alerts.append(alert_id)\n                self.alert_history.append(alert)\n\n        # 从活跃告警中移除已解决的告警\n        for alert_id in resolved_alerts:\n            del self.active_alerts[alert_id]\n\n    def acknowledge_alert(self, rule_name: str, user: str) -> bool:\n    """文档字符串"""\n\n        """确认告警"""\n        if rule_name in self.active_alerts:\n            alert = self.active_alerts[rule_name]\n            alert.status = AlertStatus.ACKNOWLEDGED\n            alert.acknowledged_by = user\n            alert.acknowledged_at = datetime.now()\n            alert.last_update = datetime.now()\n            return True\n        return False\n\n    def resolve_alert(self, rule_name: str) -> bool:\n    """文档字符串"""\n\n        """解决告警"""\n        if rule_name in self.active_alerts:\n            alert = self.active_alerts[rule_name]\n            alert.status = AlertStatus.RESOLVED\n            alert.resolved_at = datetime.now()\n            alert.last_update = datetime.now()\n            return True\n        return False\n\n    def suppress_alert(self, rule_name: str, duration: str, reason: str) -> bool:\n    """文档字符串"""\n\n        """抑制告警"""\n        if rule_name in self.rules:\n            rule = self.rules[rule_name]\n            rule_key = f"{rule_name}_{rule.severity.value}"\n\n            # 计算抑制结束时间\n            suppress_until = self._parse_duration(duration)\n\n            self.suppression_state[rule_key] = {\n                'until': suppress_until,\n                'reason': reason,\n                'created_at': datetime.now()\n            }\n\n            try:\n                logger.info(f"Alert {rule_name} suppressed until {suppress_until}")\n            except (ValueError, OSError):\n                # 如果日志记录失败，使用print作为后备\n                print(f"Alert {rule_name} suppressed until {suppress_until}")\n            return True\n\n        return False\n\n    def _parse_duration(self, duration: str) -> datetime:\n    """文档字符串"""\n\n        """解析持续时间"""\n        current_time = datetime.now()\n\n        if duration.endswith('s'):\n            seconds = int(duration[:-1])\n            return current_time + timedelta(seconds=seconds)\n        elif duration.endswith('m'):\n            minutes = int(duration[:-1])\n            return current_time + timedelta(minutes=minutes)\n        elif duration.endswith('h'):\n            hours = int(duration[:-1])\n            return current_time + timedelta(hours=hours)\n        elif duration.endswith('d'):\n            days = int(duration[:-1])\n            return current_time + timedelta(days=days)\n        else:\n            return current_time + timedelta(hours=1)  # 默认1小时\n\n    def get_active_alerts(self) -> List[AlertInstance]:\n    """文档字符串"""\n\n        """获取活跃告警列表"""\n        return list(self.active_alerts.values())\n\n    def get_alert_history(self, limit: int = 100) -> List[AlertInstance]:\n    """文档字符串"""\n\n        """获取告警历史"""\n        return self.alert_history[-limit:]\n\n    def get_rule_statistics(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取规则统计信息"""\n        total_rules = len(self.rules)\n        enabled_rules = sum(1 for rule in self.rules.values() if rule.enabled)\n        active_alerts = len(self.active_alerts)\n\n        return {\n            'total_rules': total_rules,\n            'enabled_rules': enabled_rules,\n            'disabled_rules': total_rules - enabled_rules,\n            'active_alerts': active_alerts,\n            'alert_history_count': len(self.alert_history)\n        }\n\n    def stop(self) -> None:\n    """文档字符串"""\n\n        """停止规则引擎"""\n        self._stop_evaluation = True\n        if self._evaluation_thread:\n            self._evaluation_thread.join(timeout=5)\n\ndef get_alert_rule_engine(**kwargs) -> AlertRuleEngine:\n    """文档字符串"""\n\n    """获取告警规则引擎实例"""\n    return AlertRuleEngine(**kwargs)\n