"""\n统一热重载服务\n整合热重载服务和统一热重载功能\n"""\n\nfrom enum import Enum\nfrom pathlib import Path\nfrom typing import Callable, Dict, Any, Optional, List, Set\nimport json\nimport logging\nimport os\nimport threading\nimport time\n\nfrom dataclasses import dataclass\nimport yaml\n\ntry:\n    from watchdog.observers import Observer\n    WATCHDOG_AVAILABLE = True\nexcept ImportError:\n    WATCHDOG_AVAILABLE = False\n    # Fallback classes when watchdog is not available\n\n    class Observer:\n\n        def __init__(self):\n\n            self.handlers = []\n            self.running = False\n\n        def schedule(self, handler, path, recursive=False):\n    """文档字符串"""\n\n            pass\n\n        def start(self):\n    """文档字符串"""\n\n            pass\n\n        def stop(self):\n    """文档字符串"""\n\n            pass\n\n        def join(self, timeout=None):\n    """文档字符串"""\n\n            pass\n\n        def is_alive(self):\n    """文档字符串"""\n\n            return False\n\n    class FileSystemEventHandler:\n\n        def on_modified(self, event):\n    """文档字符串"""\n\n            pass\n\nlogger = logging.getLogger(__name__)\n\nclass HotReloadStatus(Enum):\n\n    """\n    热重载状态\n    """\n\n    # Status values\n    STOPPED = "stopped"\n    STARTING = "starting"\n    RUNNING = "running"\n    STOPPING = "stopping"\n    ERROR = "error"\n\n@dataclass\n\nclass HotReloadConfig:\n\n    """热重载配置"""\n    enable_hot_reload: bool = True\n    debounce_time: float = 1.0  # 防抖时间（秒）\n    delay_time: float = 0.5  # 延迟处理时间（秒）\n    max_watched_files: int = 100  # 最大监听文件数\n    auto_restart: bool = True  # 自动重启\n    log_level: str = "INFO"\n\nclass ConfigFileHandler(FileSystemEventHandler):\n\n    """配置文件变更处理器"""\n\n    def __init__(self, callback: Callable[[str, Dict[str, Any]], None], config: HotReloadConfig):\n\n        self.callback = callback\n        self.config = config\n        self.last_modified = {}\n\n    def on_modified(self, event):\n    """文档字符串"""\n\n        """文件修改事件"""\n        if event.is_directory:\n            return\n\n        file_path = event.src_path\n        current_time = time.time()\n\n        # 防抖处理\n        if file_path in self.last_modified:\n            if current_time - self.last_modified[file_path] < self.config.debounce_time:\n                return\n\n        self.last_modified[file_path] = current_time\n\n        # 延迟处理，确保文件写入完成\n        threading.Timer(self.config.delay_time, self._process_file_change, args=[file_path]).start()\n\n    def _process_file_change(self, file_path: str):\n    """文档字符串"""\n\n        """处理文件变更"""\n        try:\n            # 检查文件是否存在\n            if not os.path.exists(file_path):\n                logger.warning(f"配置文件不存在: {file_path}")\n                return\n\n            # 读取配置文件\n            config = self._load_config_file(file_path)\n            if config is not None:\n                logger.info(f"配置文件已更新: {file_path}")\n                self.callback(file_path, config)\n\n        except Exception as e:\n            logger.error(f"处理配置文件变更失败: {file_path}, 错误: {e}")\n\n    def _load_config_file(self, file_path: str) -> Optional[Dict[str, Any]]:\n    """文档字符串"""\n\n        """加载配置文件"""\n        try:\n            file_ext = Path(file_path).suffix.lower()\n\n            if file_ext == '.json':\n                with open(file_path, 'r', encoding='utf - 8') as f:\n                    return json.load(f)\n\n            elif file_ext in ['.yml', '.yaml']:\n                with open(file_path, 'r', encoding='utf - 8') as f:\n                    return yaml.safe_load(f)\n\n            elif file_ext == '.ini':\n                import configparser\n                config = configparser.ConfigParser()\n                config.read(file_path, encoding='utf - 8')\n\n                # 转换为字典格式\n                result = {}\n                for section in config.sections():\n                    result[section] = dict(config[section])\n                return result\n\n            else:\n                logger.warning(f"不支持的文件格式: {file_ext}")\n                return None\n\n        except Exception as e:\n            logger.error(f"加载配置文件失败: {file_path}, 错误: {e}")\n            return None\n\nclass UnifiedHotReloadService:\n\n    """统一热重载服务"""\n\n    def __init__(self, config: Optional[HotReloadConfig] = None):\n\n        """\n        初始化统一热重载服务\n\n        Args:\n            config: 热重载配置\n        """\n        self.config = config or HotReloadConfig()\n        self._lock = threading.RLock()\n        self._status = HotReloadStatus.STOPPED\n\n        # 观察者\n        self.observer = Observer()\n        self.handlers = {}\n        self.callbacks = {}\n        self.watched_files: Set[str] = set()\n\n        # 服务状态\n        self._running = False\n        self._restart_thread = None\n        self._stop_event = threading.Event()\n\n    def watch_file(self, file_path: str, callback: Optional[Callable[[str, Dict[str, Any]], None]] = None) -> bool:\n    """文档字符串"""\n\n        """\n        监听配置文件\n\n        Args:\n            file_path: 文件路径\n            callback: 回调函数，None表示使用默认回调\n\n        Returns:\n            是否监听成功\n        """\n        if not self.config.enable_hot_reload:\n            logger.warning("热重载功能未启用")\n            return False\n\n        try:\n            file_path = os.path.abspath(file_path)\n\n            with self._lock:\n                if file_path in self.watched_files:\n                    logger.warning(f"文件已在监听中: {file_path}")\n                    return False\n\n                # 检查文件数量限制\n                if len(self.watched_files) >= self.config.max_watched_files:\n                    logger.error(f"达到最大监听文件数限制: {self.config.max_watched_files}")\n                    return False\n\n                # 检查文件是否存在\n                if not os.path.exists(file_path):\n                    logger.error(f"配置文件不存在: {file_path}")\n                    return False\n\n                # 设置默认回调\n                if callback is None:\n\n                    def default_callback(changed_file: str, new_config: Dict[str, Any]):\n    """文档字符串"""\n\n                        logger.info(f"配置文件变更: {changed_file}")\n                        # 这里可以添加默认的处理逻辑\n                        pass\n                    callback = default_callback\n\n                # 创建处理器\n                handler = ConfigFileHandler(callback, self.config)\n                self.handlers[file_path] = handler\n                self.callbacks[file_path] = callback\n                self.watched_files.add(file_path)\n\n                # 添加到观察者\n                directory = os.path.dirname(file_path)\n                self.observer.schedule(handler, directory, recursive=False)\n\n                logger.info(f"开始监听配置文件: {file_path}")\n                return True\n\n        except Exception as e:\n            logger.error(f"监听配置文件失败: {file_path}, 错误: {e}")\n            return False\n\n    def unwatch_file(self, file_path: str) -> bool:\n    """文档字符串"""\n\n        """\n        取消监听配置文件\n\n        Args:\n            file_path: 文件路径\n\n        Returns:\n            是否取消成功\n        """\n        try:\n            file_path = os.path.abspath(file_path)\n\n            with self._lock:\n                if file_path not in self.watched_files:\n                    logger.warning(f"文件未在监听中: {file_path}")\n                    return False\n\n                # 从观察者中移除\n                if file_path in self.handlers:\n                    handler = self.handlers[file_path]\n                    try:\n                        self.observer.unschedule(handler)\n                    except Exception as e:\n                        logger.warning(f"取消调度处理器时出现警告: {e}")\n                    finally:\n                        del self.handlers[file_path]\n\n                # 清理记录\n                self.watched_files.discard(file_path)\n                self.callbacks.pop(file_path, None)\n\n                logger.info(f"停止监听配置文件: {file_path}")\n                return True\n\n        except Exception as e:\n            logger.error(f"取消监听配置文件失败: {file_path}, 错误: {e}")\n            return False\n\n    def watch_directory(self, directory: str, pattern: str = "*.json",\n    """文档字符串"""\n\n                        callback: Optional[Callable[[str, Dict[str, Any]], None]] = None):\n        """\n        监听目录下的配置文件\n\n        Args:\n            directory: 目录路径\n            pattern: 文件模式\n            callback: 回调函数\n\n        Returns:\n            是否监听成功\n        """\n        try:\n            directory = os.path.abspath(directory)\n\n            if not os.path.exists(directory):\n                logger.error(f"目录不存在: {directory}")\n                return False\n\n            # 查找匹配的文件\n            import glob\n            pattern_path = os.path.join(directory, pattern)\n            matching_files = glob.glob(pattern_path)\n\n            success_count = 0\n            for file_path in matching_files:\n                if self.watch_file(file_path, callback):\n                    success_count += 1\n\n            logger.info(f"监听目录 {directory} 中的 {success_count} 个配置文件")\n            return success_count > 0\n\n        except Exception as e:\n            logger.error(f"监听目录失败: {directory}, 错误: {e}")\n            return False\n\n    def start_service(self) -> bool:\n    """文档字符串"""\n\n        """\n        启动热重载服务\n\n        Returns:\n            是否启动成功\n        """\n        try:\n            with self._lock:\n                if self._running:\n                    logger.warning("热重载服务已在运行")\n                    return False\n\n                self._status = HotReloadStatus.STARTING\n\n                # 启动观察者\n                self.observer.start()\n                self._running = True\n                self._status = HotReloadStatus.RUNNING\n\n                # 启动自动重启线程\n                if self.config.auto_restart:\n                    self._start_restart_thread()\n\n                logger.info("统一热重载服务启动成功")\n                return True\n\n        except Exception as e:\n            logger.error(f"启动热重载服务失败: {e}")\n            self._status = HotReloadStatus.ERROR\n            return False\n\n    def stop_service(self) -> bool:\n    """文档字符串"""\n\n        """\n        停止热重载服务\n\n        Returns:\n            是否停止成功\n        """\n        try:\n            with self._lock:\n                if not self._running:\n                    logger.warning("热重载服务未在运行")\n                    return False\n\n                self._status = HotReloadStatus.STOPPING\n\n                # 停止观察者\n                self.observer.stop()\n                self.observer.join()\n\n                # 停止自动重启线程\n                if self._restart_thread:\n                    self._stop_event.set()\n                    self._restart_thread.join(timeout=5)\n\n                self._running = False\n                self._status = HotReloadStatus.STOPPED\n\n                # 清理所有监听\n                self.watched_files.clear()\n                self.handlers.clear()\n                self.callbacks.clear()\n\n                logger.info("统一热重载服务停止成功")\n                return True\n\n        except Exception as e:\n            logger.error(f"停止热重载服务失败: {e}")\n            self._status = HotReloadStatus.ERROR\n            return False\n\n    def is_running(self) -> bool:\n    """文档字符串"""\n\n        """检查服务是否运行"""\n        return self._running\n\n    def get_watched_files(self) -> List[str]:\n    """文档字符串"""\n\n        """获取正在监听的文件列表"""\n        with self._lock:\n            return list(self.watched_files)\n\n    def reload_all(self) -> Dict[str, bool]:\n    """文档字符串"""\n\n        """\n        重新加载所有监听的配置文件\n\n        Returns:\n            重载结果字典\n        """\n        results = {}\n\n        with self._lock:\n            for file_path in self.watched_files:\n                try:\n                    if os.path.exists(file_path):\n                        # 手动触发文件变更处理\n                        handler = self.handlers.get(file_path)\n                        if handler:\n                            handler._process_file_change(file_path)\n                            results[file_path] = True\n                        else:\n                            results[file_path] = False\n                    else:\n                        results[file_path] = False\n                        logger.warning(f"配置文件不存在: {file_path}")\n\n                except Exception as e:\n                    results[file_path] = False\n                    logger.error(f"重新加载配置文件失败: {file_path}, 错误: {e}")\n\n        return results\n\n    def get_service_status(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取服务状态\n\n        Returns:\n            服务状态信息\n        """\n        with self._lock:\n            return {\n                "status": self._status.value,\n                "running": self._running,\n                "watched_files_count": len(self.watched_files),\n                "handlers_count": len(self.handlers),\n                "callbacks_count": len(self.callbacks),\n                "enable_hot_reload": self.config.enable_hot_reload,\n                "auto_restart": self.config.auto_restart,\n                "max_watched_files": self.config.max_watched_files\n            }\n\n    def get_service_info(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取服务信息\n\n        Returns:\n            服务详细信息\n        """\n        status = self.get_service_status()\n\n        return {\n            **status,\n            "watched_files": list(self.watched_files),\n            "config": {\n                "enable_hot_reload": self.config.enable_hot_reload,\n                "debounce_time": self.config.debounce_time,\n                "delay_time": self.config.delay_time,\n                "max_watched_files": self.config.max_watched_files,\n                "auto_restart": self.config.auto_restart,\n                "log_level": self.config.log_level\n            }\n        }\n\n    def _start_restart_thread(self):\n    """文档字符串"""\n\n        """启动自动重启线程"""\n\n        def restart_worker():\n    """文档字符串"""\n\n            while not self._stop_event.wait(30):  # 每30秒检查一次\n                try:\n                    # 检查观察者是否还在运行\n                    if not self.observer.is_alive():\n                        logger.warning("观察者线程已停止，尝试重启")\n                        self.observer.stop()\n                        self.observer.join(timeout=5)\n                        self.observer.start()\n                        logger.info("观察者线程重启成功")\n                except Exception as e:\n                    logger.error(f"自动重启检查失败: {e}")\n\n        self._restart_thread = threading.Thread(target=restart_worker, daemon=True)\n        self._restart_thread.start()\n\n# 全局统一热重载服务实例\n_unified_hot_reload_service = None\n_hot_reload_lock = threading.Lock()\n\ndef get_unified_hot_reload_service() -> UnifiedHotReloadService:\n    """文档字符串"""\n\n    """获取统一热重载服务实例"""\n    global _unified_hot_reload_service\n    with _hot_reload_lock:\n        if _unified_hot_reload_service is None:\n            _unified_hot_reload_service = UnifiedHotReloadService()\n        return _unified_hot_reload_service\n\ndef start_unified_hot_reload() -> bool:\n    """文档字符串"""\n\n    """启动统一热重载服务"""\n    service = get_unified_hot_reload_service()\n    return service.start_service()\n\ndef stop_unified_hot_reload() -> bool:\n    """文档字符串"""\n\n    """停止统一热重载服务"""\n    global _unified_hot_reload_service\n    if _unified_hot_reload_service:\n        result = _unified_hot_reload_service.stop_service()\n        if result:\n            _unified_hot_reload_service = None\n        return result\n    return False\n\ndef watch_config_file(file_path: str, callback: Optional[Callable[[str, Dict[str, Any]], None]] = None) -> bool:\n    """文档字符串"""\n\n    """监听配置文件"""\n    service = get_unified_hot_reload_service()\n    return service.watch_file(file_path, callback)\n\ndef unwatch_config_file(file_path: str) -> bool:\n    """文档字符串"""\n\n    """取消监听配置文件"""\n    service = get_unified_hot_reload_service()\n    return service.unwatch_file(file_path)\n\ndef watch_config_directory(directory: str, pattern: str = "*.json",\n    """文档字符串"""\n\n                           callback: Optional[Callable[[str, Dict[str, Any]], None]] = None):\n    """监听目录下的配置文件"""\n    service = get_unified_hot_reload_service()\n    return service.watch_directory(directory, pattern, callback)\n