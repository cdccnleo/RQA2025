#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\n"""\n基础设施层 - 监控接口定义\n\n统一监控相关的接口定义，消除重复和不一致性\n"""\n\nfrom abc import ABC, abstractmethod\nfrom datetime import datetime, timedelta\nfrom enum import Enum\nfrom typing import Any, Dict, List, Optional, Union, Protocol, Callable\n\nclass MonitorType(Enum):\n    """监控类型枚举"""\n\n    SYSTEM = "system"\n    APPLICATION = "application"\n    BUSINESS = "business"\n    PERFORMANCE = "performance"\n    HEALTH = "health"\n    RESOURCE = "resource"\n    SECURITY = "security"\n\nclass MonitorStatus(Enum):\n    """监控状态枚举"""\n\n    HEALTHY = "healthy"\n    WARNING = "warning"\n    CRITICAL = "critical"\n    UNKNOWN = "unknown"\n    DISABLED = "disabled"\n\nclass AlertLevel(Enum):\n    """告警级别枚举"""\n\n    INFO = "info"\n    WARNING = "warning"\n    ERROR = "error"\n    CRITICAL = "critical"\n\nclass IMonitorComponent(ABC):\n    """监控组件基础接口"""\n\n    @abstractmethod\n    def start_monitoring(self) -> bool:\n        """启动监控"""\n        pass\n\n    @abstractmethod\n    def stop_monitoring(self) -> bool:\n        """停止监控"""\n        pass\n\n    @abstractmethod\n    def get_status(self) -> MonitorStatus:\n        """获取监控状态"""\n        pass\n\n    @abstractmethod\n    def get_metrics(self) -> Dict[str, Any]:\n        """获取监控指标"""\n        pass\n\n    @abstractmethod\n    def reset_metrics(self) -> bool:\n        """重置监控指标"""\n        pass\n\nclass IMonitor(ABC):\n    """监控器接口"""\n\n    @abstractmethod\n    def collect_metrics(self) -> Dict[str, Any]:\n        """收集指标数据"""\n        pass\n\n    @abstractmethod\n    def check_health(self) -> MonitorStatus:\n        """检查健康状态"""\n        pass\n\n    @abstractmethod\n    def get_alerts(self) -> List[Dict[str, Any]]:\n        """获取告警信息"""\n        pass\n\n    @abstractmethod\n    def set_thresholds(self, thresholds: Dict[str, Any]) -> bool:\n        """设置监控阈值"""\n        pass\n\n    @abstractmethod\n    def get_thresholds(self) -> Dict[str, Any]:\n        """获取监控阈值"""\n        pass\n\nclass ISystemMonitor(IMonitor):\n    """系统监控器接口"""\n\n    @abstractmethod\n    def get_cpu_usage(self) -> Dict[str, float]:\n        """获取CPU使用率"""\n        pass\n\n    @abstractmethod\n    def get_memory_usage(self) -> Dict[str, float]:\n        """获取内存使用率"""\n        pass\n\n    @abstractmethod\n    def get_disk_usage(self) -> Dict[str, float]:\n        """获取磁盘使用率"""\n        pass\n\n    @abstractmethod\n    def get_network_stats(self) -> Dict[str, Any]:\n        """获取网络统计"""\n        pass\n\nclass IApplicationMonitor(IMonitor):\n    """应用监控器接口"""\n\n    @abstractmethod\n    def get_response_time(self) -> Dict[str, float]:\n        """获取响应时间"""\n        pass\n\n    @abstractmethod\n    def get_error_rate(self) -> Dict[str, float]:\n        """获取错误率"""\n        pass\n\n    @abstractmethod\n    def get_throughput(self) -> Dict[str, float]:\n        """获取吞吐量"""\n        pass\n\n    @abstractmethod\n    def get_active_connections(self) -> int:\n        """获取活跃连接数"""\n        pass\n\nclass IPerformanceMonitor(IMonitor):\n    """性能监控器接口"""\n\n    @abstractmethod\n    def get_execution_time(self) -> Dict[str, float]:\n        """获取执行时间"""\n        pass\n\n    @abstractmethod\n    def get_resource_utilization(self) -> Dict[str, float]:\n        """获取资源利用率"""\n        pass\n\n    @abstractmethod\n    def get_bottlenecks(self) -> List[Dict[str, Any]]:\n        """获取性能瓶颈"""\n        pass\n\n    @abstractmethod\n    def profile_function(self, func: Callable,\n    """文档字符串"""\n                        *args, **kwargs) -> Dict[str, Any]:\n        """性能分析函数"""\n        pass\n\nclass IBusinessMetricsMonitor(IMonitor):\n    """业务指标监控器接口"""\n\n    @abstractmethod\n    def get_user_activity(self) -> Dict[str, Any]:\n        """获取用户活动指标"""\n        pass\n\n    @abstractmethod\n    def get_transaction_metrics(self) -> Dict[str, Any]:\n        """获取交易指标"""\n        pass\n\n    @abstractmethod\n    def get_conversion_rates(self) -> Dict[str, Any]:\n        """获取转化率"""\n        pass\n\n    @abstractmethod\n    def get_revenue_metrics(self) -> Dict[str, Any]:\n        """获取收入指标"""\n        pass\n\nclass IHealthMonitor(IMonitor):\n    """健康监控器接口"""\n\n    @abstractmethod\n    def check_service_health(self, service_name: str) -> MonitorStatus:\n        """检查服务健康状态"""\n        pass\n\n    @abstractmethod\n    def get_service_status(self) -> Dict[str, MonitorStatus]:\n        """获取所有服务状态"""\n        pass\n\n    @abstractmethod\n    def get_health_report(self) -> Dict[str, Any]:\n        """获取健康报告"""\n        pass\n\nclass IResourceMonitor(IMonitor):\n    """资源监控器接口"""\n\n    @abstractmethod\n    def get_resource_usage(self, resource_type: str) -> Dict[str, Any]:\n        """获取资源使用情况"""\n        pass\n\n    @abstractmethod\n    def predict_resource_usage(self, time_window: timedelta) -> Dict[str, Any]:\n        """预测资源使用情况"""\n        pass\n\n    @abstractmethod\n    def get_resource_limits(self) -> Dict[str, Any]:\n        """获取资源限制"""\n        pass\n\nclass IAlertManager(ABC):\n    """告警管理器接口"""\n\n    @abstractmethod\n    def create_alert(self, alert_data: Dict[str, Any]) -> bool:\n        """创建告警"""\n        pass\n\n    @abstractmethod\n    def resolve_alert(self, alert_id: str) -> bool:\n        """解决告警"""\n        pass\n\n    @abstractmethod\n    def get_active_alerts(self) -> List[Dict[str, Any]]:\n        """获取活跃告警"""\n        pass\n\n    @abstractmethod\n    def get_alert_history(self, time_range: timedelta) -> List[Dict[str, Any]]:\n        """获取告警历史"""\n        pass\n\nclass IMonitorFactory(ABC):\n    """监控工厂接口"""\n\n    @abstractmethod\n    def create_monitor(self, monitor_type: MonitorType,\n    """文档字符串"""\n                      config: Dict[str, Any]) -> IMonitor:\n        """创建监控器"""\n        pass\n\n    @abstractmethod\n    def create_alert_manager(self, config: Dict[str, Any]) -> IAlertManager:\n        """创建告警管理器"""\n        pass\n\n    @abstractmethod\n    def get_supported_types(self) -> List[MonitorType]:\n        """获取支持的监控类型"""\n        pass\n\nclass MonitorConfig:\n    """监控配置类"""\n\n    def __init__(self,\n                 monitor_type: MonitorType = MonitorType.SYSTEM,\n                 collection_interval: int = 60,\n                 enable_alerts: bool = True,\n                 alert_thresholds: Optional[Dict[str, Any]] = None,\n                 retention_period: int = 7,\n                 **kwargs):\n        self.monitor_type = monitor_type\n        self.collection_interval = collection_interval\n        self.enable_alerts = enable_alerts\n        self.alert_thresholds = alert_thresholds or {}\n        self.retention_period = retention_period\n        self.extra_config = kwargs\n\n# 向后兼容的别名\nMonitor = IMonitor\nSystemMonitor = ISystemMonitor\nApplicationMonitor = IApplicationMonitor\nPerformanceMonitor = IPerformanceMonitor\nHealthMonitor = IHealthMonitor\nAlertManager = IAlertManager\nMonitorFactory = IMonitorFactory\n