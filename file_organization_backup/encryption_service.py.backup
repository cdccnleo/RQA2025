"""\n基础设施层 - 日志系统组件\n\nencryption_service 模块\n\n日志系统相关的文件\n提供日志系统相关的功能实现。\n"""\n\nfrom typing import Dict, Any, Optional\nimport base64\nimport hashlib\nimport logging\n\nfrom cryptography.fernet import Fernet\nfrom cryptography.hazmat.primitives import hashes\nfrom cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC\n\nfrom .interfaces import IEncryptionService\n\nlogger = logging.getLogger(__name__)\n\nclass EncryptionService(IEncryptionService):\n\n    """加密服务实现"""\n\n    def __init__(self, master_key: Optional[str] = None):\n\n        self._keys: Dict[str, bytes] = {}\n        self._fernets: Dict[str, Fernet] = {}\n        self._encrypted_prefix = "encrypted:"\n\n        # 初始化主密钥\n        if master_key:\n            self._init_master_key(master_key)\n        else:\n            self._init_default_key()\n\n    def _init_master_key(self, master_key: str):\n    """文档字符串"""\n\n        """初始化主密钥"""\n        salt = b'config_salt_2025'\n        kdf = PBKDF2HMAC(\n            algorithm=hashes.SHA256(),\n            length=32,\n            salt=salt,\n            iterations=100000,\n        )\n\n        key = base64.urlsafe_b64encode(kdf.derive(master_key.encode()))\n        self._keys["master"] = key\n        self._fernets["master"] = Fernet(key)\n        logger.info("主密钥已初始化")\n\n    def _init_default_key(self):\n    """文档字符串"""\n\n        """初始化默认密钥"""\n        key = Fernet.generate_key()\n        self._keys["default"] = key\n        self._fernets["default"] = Fernet(key)\n        logger.info("默认密钥已生成")\n\n    def generate_key(self, key_id: str) -> bool:\n    """文档字符串"""\n\n        """生成新密钥"""\n        try:\n            key = Fernet.generate_key()\n            self._keys[key_id] = key\n            self._fernets[key_id] = Fernet(key)\n            logger.info(f"密钥 {key_id} 已生成")\n            return True\n        except Exception as e:\n            logger.error(f"生成密钥 {key_id} 失败: {e}")\n            return False\n\n    def encrypt_value(self, value: str, key_id: Optional[str] = None) -> str:\n    """文档字符串"""\n\n        """加密值"""\n        if not value:\n            return value\n\n        key_id = key_id or "default"\n        if key_id not in self._fernets:\n            logger.error(f"密钥 {key_id} 不存在")\n            raise ValueError(f"密钥 {key_id} 不存在")\n\n        try:\n            encrypted = self._fernets[key_id].encrypt(value.encode())\n            encrypted_str = base64.urlsafe_b64encode(encrypted).decode()\n            return f"{self._encrypted_prefix}{key_id}:{encrypted_str}"\n        except Exception as e:\n            logger.error(f"加密失败: {e}")\n            raise ValueError(f"加密失败: {e}")\n\n    def decrypt_value(self, encrypted_value: str, key_id: Optional[str] = None) -> str:\n    """文档字符串"""\n\n        """解密值"""\n        if not encrypted_value or not encrypted_value.startswith(self._encrypted_prefix):\n            return encrypted_value\n\n        try:\n            # 解析加密格式: encrypted:key_id:encrypted_data\n            parts = encrypted_value[len(self._encrypted_prefix):].split(":", 1)\n            if len(parts) != 2:\n                raise ValueError("无效的加密格式")\n\n            actual_key_id, encrypted_data = parts\n            if key_id and key_id != actual_key_id:\n                logger.warning(f"密钥ID不匹配: 期望 {key_id}, 实际 {actual_key_id}")\n\n            if actual_key_id not in self._fernets:\n                logger.error(f"密钥 {actual_key_id} 不存在")\n                raise ValueError(f"密钥 {actual_key_id} 不存在")\n\n            encrypted_bytes = base64.urlsafe_b64decode(encrypted_data)\n            decrypted = self._fernets[actual_key_id].decrypt(encrypted_bytes)\n            return decrypted.decode()\n        except Exception as e:\n            logger.error(f"解密失败: {e}")\n            raise ValueError(f"解密失败: {e}")\n\n    def is_encrypted(self, value: str) -> bool:\n    """文档字符串"""\n\n        """检查是否已加密"""\n        return value.startswith(self._encrypted_prefix)\n\n    def rotate_key(self, old_key_id: str, new_key_id: str) -> bool:\n    """文档字符串"""\n\n        """轮换密钥"""\n        if old_key_id not in self._fernets:\n            logger.error(f"旧密钥 {old_key_id} 不存在")\n            return False\n\n        if new_key_id not in self._fernets:\n            logger.error(f"新密钥 {new_key_id} 不存在")\n            return False\n\n        try:\n            # 这里应该实现密钥轮换逻辑\n            # 在实际应用中，需要重新加密所有使用旧密钥的数据\n            logger.info(f"密钥轮换: {old_key_id} -> {new_key_id}")\n            return True\n        except Exception as e:\n            logger.error(f"密钥轮换失败: {e}")\n            return False\n\n    def encrypt_config_section(self, config: Dict[str, Any], sensitive_keys: list, key_id: Optional[str] = None) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """加密配置节"""\n        encrypted_config = config.copy()\n\n        def encrypt_nested_dict(data: Dict[str, Any]) -> Dict[str, Any]:\n    """文档字符串"""\n\n            """递归加密嵌套字典"""\n            result = {}\n            for k, v in data.items():\n                if isinstance(v, dict):\n                    result[k] = encrypt_nested_dict(v)\n                elif isinstance(v, str) and k in sensitive_keys and not self.is_encrypted(v):\n                    result[k] = self.encrypt_value(v, key_id)\n                else:\n                    result[k] = v\n            return result\n\n        return encrypt_nested_dict(encrypted_config)\n\n    def decrypt_config_section(self, config: Dict[str, Any], key_id: Optional[str] = None) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """解密配置节"""\n\n        def decrypt_nested_dict(data: Dict[str, Any]) -> Dict[str, Any]:\n    """文档字符串"""\n\n            """递归解密嵌套字典"""\n            result = {}\n            for k, v in data.items():\n                if isinstance(v, dict):\n                    result[k] = decrypt_nested_dict(v)\n                elif isinstance(v, str) and self.is_encrypted(v):\n                    try:\n                        result[k] = self.decrypt_value(v, key_id)\n                    except Exception as e:\n                        logger.warning(f"解密配置项 {k} 失败: {e}")\n                        result[k] = v  # 保持原值，避免数据丢失\n                else:\n                    result[k] = v\n            return result\n\n        return decrypt_nested_dict(config.copy())\n