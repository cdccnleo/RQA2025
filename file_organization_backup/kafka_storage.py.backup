"""\n基础设施层 - 缓存系统组件\n\nkafka_storage 模块\n\n缓存系统相关的文件\n提供缓存系统相关的功能实现。\n"""\n\nimport json\n\nfrom kafka.errors import KafkaError\nimport kafka\n\nclass KafkaStorage:\n\n    def __init__(self, *args, **kwargs):\n\n        self.bootstrap_servers = kwargs.get('bootstrap_servers', ['localhost:9092'])\n        self.topic = kwargs.get('topic', 'test_topic')\n        self.group_id = kwargs.get('group_id', 'test_group')\n        self.producer = kafka.KafkaProducer(bootstrap_servers=self.bootstrap_servers)\n        self.consumer = kafka.KafkaConsumer(self.topic, bootstrap_servers=self.bootstrap_servers, group_id=self.group_id)\n\n    def send_message(self, message):\n    """文档字符串"""\n\n        try:\n            self.producer.send(self.topic, value=message)\n            self.producer.flush()\n            return True\n        except Exception as e:\n            raise KafkaError(str(e))\n\n    def consume_messages(self, max_messages=1):\n    """文档字符串"""\n\n        try:\n            count = 0\n            for msg in self.consumer:\n                val = msg.value() if callable(msg.value) else msg.value\n                if isinstance(val, bytes):\n                    try:\n                        val = json.loads(val.decode('utf - 8'))\n                    except Exception:\n                        pass\n                yield val\n                count += 1\n                if count >= max_messages:\n                    break\n            self.consumer.commit()\n        except Exception:\n            return iter([])\n\n    def close(self):\n    """文档字符串"""\n\n        if self.producer:\n            self.producer.close()\n        if self.consumer:\n            self.consumer.close()\n