import time\n\n"""\n基础设施层 - 日志系统组件\n\nintegrity_checker 模块\n\n日志系统相关的文件\n提供日志系统相关的功能实现。\n"""\n\nimport hashlib\nimport hmac\nimport json\nimport logging\nfrom typing import Dict, Any, Optional\nfrom datetime import datetime\nfrom .interfaces import IIntegrityChecker\n\nlogger = logging.getLogger(__name__)\n\nclass IntegrityChecker(IIntegrityChecker):\n\n    """完整性检查器实现"""\n\n    def __init__(self, secret_key: Optional[str] = None):\n\n        self._secret_key = secret_key or "default_integrity_key_2025"\n        self._hash_algorithm = "sha256"\n\n    def _normalize_config(self, config_data: Dict[str, Any]) -> str:\n    """文档字符串"""\n\n        """标准化配置数据用于哈希计算"""\n        # 深度排序，确保相同配置产生相同哈希\n\n        def sort_dict(d):\n    """文档字符串"""\n\n            if isinstance(d, dict):\n                return {k: sort_dict(v) for k, v in sorted(d.items())}  # type: ignore\n            elif isinstance(d, list):\n                return [sort_dict(item) for item in d]  # type: ignore\n            else:\n                return d\n\n        normalized = sort_dict(config_data)\n        return json.dumps(normalized, sort_keys=True, separators=(',', ':'))\n\n    def calculate_hash(self, config_data: Dict[str, Any]) -> str:\n    """文档字符串"""\n\n        """计算配置哈希"""\n        try:\n            normalized = self._normalize_config(config_data)\n            hash_obj = hashlib.new(self._hash_algorithm)\n            hash_obj.update(normalized.encode('utf - 8'))\n            return hash_obj.hexdigest()\n        except Exception as e:\n            logger.error(f"计算配置哈希失败: {e}")\n            raise ValueError(f"计算配置哈希失败: {e}")\n\n    def verify_integrity(self, config_data: Dict[str, Any], expected_hash: str) -> bool:\n    """文档字符串"""\n\n        """验证完整性"""\n        try:\n            actual_hash = self.calculate_hash(config_data)\n            is_valid = hmac.compare_digest(actual_hash, expected_hash)\n\n            if not is_valid:\n                logger.warning("配置完整性验证失败")\n\n            return is_valid\n        except Exception as e:\n            logger.error(f"验证配置完整性失败: {e}")\n            return False\n\n    def sign_config(self, config_data: Dict[str, Any]) -> str:\n    """文档字符串"""\n\n        """签名配置"""\n        try:\n            normalized = self._normalize_config(config_data)\n            signature = hmac.new(\n                self._secret_key.encode('utf - 8'),\n                normalized.encode('utf - 8'),\n                hashlib.sha256\n            ).hexdigest()\n\n            # 包含时间戳的签名\n            timestamp = datetime.now().isoformat()\n            signed_data = {\n                "signature": signature,\n                "timestamp": timestamp,\n                "algorithm": "hmac - sha256"\n            }\n\n            return json.dumps(signed_data)\n        except Exception as e:\n            logger.error(f"签名配置失败: {e}")\n            raise ValueError(f"签名配置失败: {e}")\n\n    def verify_signature(self, config_data: Dict[str, Any], signature_data: str) -> bool:\n    """文档字符串"""\n\n        """验证签名"""\n        try:\n            signed_info = json.loads(signature_data)\n            expected_signature = signed_info.get("signature")\n            timestamp = signed_info.get("timestamp")\n\n            if not expected_signature or not timestamp:\n                logger.warning("签名数据格式无效")\n                return False\n\n            # 验证时间戳（可选：检查签名是否过期）\n            try:\n                signed_time = datetime.fromisoformat(timestamp)\n                current_time = datetime.now()\n                if (current_time - signed_time).days > 365:  # 签名超过1年\n                    logger.warning("签名已过期")\n                    return False\n            except Exception:\n                logger.warning("签名时间戳格式无效")\n                return False\n\n            # 重新计算签名\n            normalized = self._normalize_config(config_data)\n            actual_signature = hmac.new(\n                self._secret_key.encode('utf - 8'),\n                normalized.encode('utf - 8'),\n                hashlib.sha256\n            ).hexdigest()\n\n            is_valid = hmac.compare_digest(actual_signature, expected_signature)\n\n            if not is_valid:\n                logger.warning("配置签名验证失败")\n\n            return is_valid\n        except Exception as e:\n            logger.error(f"验证配置签名失败: {e}")\n            return False\n\n    def create_integrity_metadata(self, config_data: Dict[str, Any]) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """创建完整性元数据"""\n        try:\n            hash_value = self.calculate_hash(config_data)\n            signature_data = self.sign_config(config_data)\n\n            metadata = {\n                "hash": hash_value,\n                "hash_algorithm": self._hash_algorithm,\n                "signature": signature_data,\n                "created_at": datetime.now().isoformat(),\n                "version": "1.0"\n            }\n\n            return metadata\n        except Exception as e:\n            logger.error(f"创建完整性元数据失败: {e}")\n            raise ValueError(f"创建完整性元数据失败: {e}")\n\n    def verify_config_with_metadata(self, config_data: Dict[str, Any], metadata: Dict[str, Any]) -> bool:\n    """文档字符串"""\n\n        """使用元数据验证配置"""\n        try:\n            # 验证哈希\n            expected_hash = metadata.get("hash")\n            if not expected_hash:\n                logger.warning("元数据中缺少哈希值")\n                return False\n\n            if not self.verify_integrity(config_data, expected_hash):\n                return False\n\n            # 验证签名\n            signature_data = metadata.get("signature")\n            if not signature_data:\n                logger.warning("元数据中缺少签名")\n                return False\n\n            if not self.verify_signature(config_data, signature_data):\n                return False\n\n            logger.info("配置完整性验证通过")\n            return True\n        except Exception as e:\n            logger.error(f"使用元数据验证配置失败: {e}")\n            return False\n