"""\n基础设施层 - 健康检查组件\n\nhealth_status 模块\n\n健康检查相关的文件\n提供健康检查相关的功能实现。\n"""\n\n#!/usr/bin/env python3\nfrom enum import Enum\n\n# -*- coding: utf-8 -*-\n"""\n统一健康状态枚举\n\n与基础设施层ServiceStatus枚举保持一致，确保接口统一。\n"""\n\nclass HealthStatus(Enum):\n\n    """统一健康状态枚举"""\n    UP = "UP"           # 服务正常\n    DOWN = "DOWN"       # 服务不可用\n    DEGRADED = "DEGRADED"  # 服务降级\n    UNKNOWN = "UNKNOWN"    # 状态未知\n    UNHEALTHY = "UNHEALTHY"  # 不健康状态\n\n    @classmethod\n\n    def from_string(cls, status_str: str) -> 'HealthStatus':\n    """文档字符串"""\n\n        """从字符串转换为枚举值"""\n        try:\n            return cls(status_str.upper())\n        except ValueError:\n            return cls.UNKNOWN\n\n    def to_string(self) -> str:\n    """文档字符串"""\n\n        """转换为字符串"""\n        return self.value\n\n    def is_healthy(self) -> bool:\n    """文档字符串"""\n\n        """检查是否为健康状态"""\n        return self in [self.UP, self.DEGRADED]\n\n    def is_critical(self) -> bool:\n    """文档字符串"""\n\n        """检查是否为严重状态"""\n        return self == self.DOWN\n