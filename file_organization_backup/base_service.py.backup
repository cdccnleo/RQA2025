"""\n服务基类模块\n\n提供统一的服务接口和生命周期管理，所有服务都应该继承此基类。\n"""\n\nfrom abc import ABC, abstractmethod\nfrom enum import Enum\nfrom typing import Dict, Any, Optional\nimport logging\nimport time\n\nclass ServiceStatus(Enum):\n\n    """服务状态枚举"""\n    INITIALIZED = "initialized"\n    STARTING = "starting"\n    RUNNING = "running"\n    STOPPING = "stopping"\n    STOPPED = "stopped"\n    ERROR = "error"\n\nclass BaseServiceComponent(ABC):\n\n    """\n    服务基类\n\n    提供统一的服务接口和生命周期管理,包括:\n    - 服务启动 / 停止\n    - 健康检查\n    - 状态管理\n    - 错误处理\n    """\n\n    def __init__(self, name: Optional[str] = None):\n\n        """\n        初始化服务基类\n\n        Args:\n            name: 服务名称,默认为类名\n        """\n        self.name = name or self.__class__.__name__\n        self.status = ServiceStatus.INITIALIZED\n        self.logger = logging.getLogger(f"{__name__}.{self.name}")\n        self.start_time = None\n        self.error_count = 0\n        self.last_error = None\n\n    def start(self) -> bool:\n    """文档字符串"""\n\n        """\n        启动服务\n\n        Returns:\n            bool: 启动是否成功\n        """\n        try:\n            self.logger.info(f"正在启动服务: {self.name}")\n            self.status = ServiceStatus.STARTING\n\n            # 调用子类的启动逻辑\n            if self._start():\n                self.status = ServiceStatus.RUNNING\n                self.start_time = time.time()\n                self.logger.info(f"服务启动成功: {self.name}")\n                return True\n            else:\n                self.status = ServiceStatus.ERROR\n                self.logger.error(f"服务启动失败: {self.name}")\n                return False\n\n        except Exception as e:\n            self.status = ServiceStatus.ERROR\n            self.last_error = str(e)\n            self.error_count += 1\n            self.logger.error(f"服务启动异常: {self.name}, 错误: {e}")\n            return False\n\n    def stop(self) -> bool:\n    """文档字符串"""\n\n        """\n        停止服务\n\n        Returns:\n            bool: 停止是否成功\n        """\n        try:\n            self.logger.info(f"正在停止服务: {self.name}")\n            self.status = ServiceStatus.STOPPING\n\n            # 调用子类的停止逻辑\n            if self._stop():\n                self.status = ServiceStatus.STOPPED\n                self.logger.info(f"服务停止成功: {self.name}")\n                return True\n            else:\n                self.status = ServiceStatus.ERROR\n                self.logger.error(f"服务停止失败: {self.name}")\n                return False\n\n        except Exception as e:\n            self.status = ServiceStatus.ERROR\n            self.last_error = str(e)\n            self.error_count += 1\n            self.logger.error(f"服务停止异常: {self.name}, 错误: {e}")\n            return False\n\n    def health_check(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        健康检查\n\n        Returns:\n            Dict[str, Any]: 健康状态信息\n        """\n        uptime = 0.0\n        if self.start_time:\n            uptime = time.time() - self.start_time\n            # 确保uptime不为负数\n            uptime = max(0.0, uptime)\n\n        health_info = {\n            "name": self.name,\n            "status": self.status.value,\n            "uptime": uptime,\n            "error_count": self.error_count,\n            "last_error": self.last_error,\n            "timestamp": time.time()\n        }\n\n        # 调用子类的健康检查\n        try:\n            service_health = self._health_check()\n            health_info.update(service_health)\n        except Exception as e:\n            self.logger.error(f"健康检查异常: {e}")\n            health_info["health_check_error"] = str(e)\n\n        return health_info\n\n    def is_running(self) -> bool:\n    """文档字符串"""\n\n        """\n        检查服务是否正在运行\n\n        Returns:\n            bool: 是否正在运行\n        """\n        return self.status == ServiceStatus.RUNNING\n\n    def get_status(self) -> ServiceStatus:\n    """文档字符串"""\n\n        """\n        获取服务状态\n\n        Returns:\n            ServiceStatus: 服务状态\n        """\n        return self.status\n\n    def reset_errors(self):\n    """文档字符串"""\n\n        """重置错误计数"""\n        self.error_count = 0\n        self.last_error = None\n\n    @abstractmethod\n\n    def _start(self) -> bool:\n    """文档字符串"""\n\n        """\n        子类实现的启动逻辑\n\n        Returns:\n            bool: 启动是否成功\n        """\n        pass\n\n    @abstractmethod\n\n    def _stop(self) -> bool:\n    """文档字符串"""\n\n        """\n        子类实现的停止逻辑\n\n        Returns:\n            bool: 停止是否成功\n        """\n        pass\n\n    def _health_check(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        子类实现的健康检查逻辑\n\n        Returns:\n            Dict[str, Any]: 服务特定的健康信息\n        """\n        return {}\n\n    def __str__(self) -> str:\n\n        return f"{self.name}({self.status.value})"\n\n    def __repr__(self) -> str:\n\n        return f"<{self.__class__.__name__} name='{self.name}' status='{self.status.value}'>"\n