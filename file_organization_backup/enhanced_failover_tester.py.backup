#!/usr/bin/env python3\n"""\n故障转移自动化测试和验证系统 - P1级别改进\n提供全面的故障转移场景测试和自动化验证\n"""\n\nfrom concurrent.futures import ThreadPoolExecutor\nfrom datetime import datetime, timedelta\nfrom enum import Enum\nfrom typing import Dict, List, Any, Optional, Callable\nimport logging\nimport random\nimport threading\nimport time\nimport uuid\n\nfrom dataclasses import dataclass, field\n\nfrom .base_cache_manager import BaseCacheManager\nfrom .cache_warmup_optimizer import FailoverManager, FailoverConfig, FailoverMode\n\nlogger = logging.getLogger(__name__)\n\nclass FailoverTestType(Enum):\n    """故障转移测试类型"""\n    PRIMARY_FAILURE = "primary_failure"              # 主节点故障\n    NETWORK_PARTITION = "network_partition"          # 网络分区\n    PERFORMANCE_DEGRADATION = "performance_degradation"  # 性能降级\n    GRADUAL_FAILURE = "gradual_failure"              # 渐进式故障\n    CASCADE_FAILURE = "cascade_failure"              # 级联故障\n    SPLIT_BRAIN = "split_brain"                      # 脑裂情况\n\nclass FailoverTestResult(Enum):\n    """故障转移测试结果"""\n    SUCCESS = "success"                               # 成功\n    FAILURE = "failure"                               # 失败\n    PARTIAL_SUCCESS = "partial_success"               # 部分成功\n    TIMEOUT = "timeout"                               # 超时\n    UNEXPECTED_ERROR = "unexpected_error"             # 意外错误\n\n@dataclass\nclass FailoverTestScenario:\n    """故障转移测试场景"""\n    test_id: str\n    test_type: FailoverTestType\n    description: str\n    primary_failure_delay: float = 0.0               # 主节点故障延迟\n    recovery_delay: float = 10.0                     # 恢复延迟\n    expected_failover_time: float = 5.0              # 预期故障转移时间\n    load_pattern: str = "steady"                     # 负载模式\n    data_consistency_check: bool = True              # 数据一致性检查\n    performance_baseline: Dict[str, float] = field(default_factory=dict)\n\n@dataclass\nclass FailoverTestReport:\n    """故障转移测试报告"""\n    test_id: str\n    scenario: FailoverTestScenario\n    result: FailoverTestResult\n    start_time: datetime\n    end_time: Optional[datetime] = None\n    failover_detected_time: Optional[datetime] = None\n    recovery_time: Optional[datetime] = None\n    data_loss_count: int = 0\n    performance_impact: Dict[str, float] = field(default_factory=dict)\n    error_messages: List[str] = field(default_factory=list)\n    detailed_metrics: Dict[str, Any] = field(default_factory=dict)\n\nclass MockFailureCacheManager(BaseCacheManager):\n    """可模拟故障的缓存管理器"""\n    \n    def __init__(self, name: str = "MockCache"):\n        super().__init__()\n        self.name = name\n        self.data = {}\n        self.is_healthy = True\n        self.response_delay = 0.0  # 响应延迟（模拟性能问题）\n        self.failure_probability = 0.0  # 故障概率\n        self.operations_count = 0\n        self.failure_count = 0\n        \n    def simulate_failure(self):\n        """模拟故障"""\n        self.is_healthy = False\n        logger.info(f"{self.name} 模拟故障状态")\n        \n    def simulate_recovery(self):\n        """模拟恢复"""\n        self.is_healthy = True\n        self.response_delay = 0.0\n        self.failure_probability = 0.0\n        logger.info(f"{self.name} 模拟恢复状态")\n        \n    def simulate_performance_degradation(self, delay: float, failure_prob: float = 0.1):\n        """模拟性能降级"""\n        self.response_delay = delay\n        self.failure_probability = failure_prob\n        logger.info(f"{self.name} 模拟性能降级: 延迟={delay}s, 故障率={failure_prob}")\n        \n    def _check_health_and_delay(self):\n        """检查健康状态和应用延迟"""\n        if not self.is_healthy:\n            raise Exception(f"{self.name} 处于故障状态")\n        \n        if self.response_delay > 0:\n            time.sleep(self.response_delay)\n        \n        if random.random() < self.failure_probability:\n            self.failure_count += 1\n            raise Exception(f"{self.name} 随机故障")\n        \n        self.operations_count += 1\n        \n    def get(self, key: str) -> Any:\n    """文档字符串"""\n        self._check_health_and_delay()\n        return self.data.get(key)\n        \n    def set(self, key: str, value: Any, ttl: Optional[int] = None) -> bool:\n    """文档字符串"""\n        self._check_health_and_delay()\n        self.data[key] = value\n        return True\n        \n    def delete(self, key: str) -> bool:\n    """文档字符串"""\n        self._check_health_and_delay()\n        if key in self.data:\n            del self.data[key]\n            return True\n        return False\n        \n    def exists(self, key: str) -> bool:\n    """文档字符串"""\n        self._check_health_and_delay()\n        return key in self.data\n        \n    def clear(self) -> bool:\n    """文档字符串"""\n        self._check_health_and_delay()\n        self.data.clear()\n        return True\n        \n    def size(self) -> int:\n    """文档字符串"""\n        return len(self.data)\n        \n    def keys(self) -> list:\n    """文档字符串"""\n        return list(self.data.keys())\n\nclass LoadGenerator:\n    """负载生成器"""\n    \n    def __init__(self, cache_manager: BaseCacheManager):\n        self.cache_manager = cache_manager\n        self.is_running = False\n        self.thread: Optional[threading.Thread] = None\n        self.operations_count = 0\n        self.error_count = 0\n        self.success_count = 0\n        self.response_times = []\n        \n    def start_load(self, duration: float = 60.0, operations_per_second: int = 10):\n        """启动负载生成"""\n        if self.is_running:\n            return\n        \n        self.is_running = True\n        self.thread = threading.Thread(\n            target=self._generate_load,\n            args=(duration, operations_per_second),\n            daemon=True\n        )\n        self.thread.start()\n        logger.info(f"启动负载生成: {operations_per_second} ops/sec, 持续 {duration}s")\n        \n    def stop_load(self):\n        """停止负载生成"""\n        self.is_running = False\n        if self.thread:\n            self.thread.join(timeout=5)\n        logger.info("负载生成已停止")\n        \n    def _generate_load(self, duration: float, ops_per_second: int):\n        """生成负载"""\n        start_time = time.time()\n        interval = 1.0 / ops_per_second\n        \n        while self.is_running and (time.time() - start_time) < duration:\n            op_start = time.time()\n            try:\n                \n                # 随机选择操作类型\n                operation = random.choice(['get', 'set', 'delete'])\n                key = f"load_key_{random.randint(1, 100)}"\n                \n                if operation == 'get':\n                    self.cache_manager.get(key)\n                elif operation == 'set':\n                    self.cache_manager.set(key, f"value_{time.time()}")\n                elif operation == 'delete':\n                    self.cache_manager.delete(key)\n                \n                op_time = time.time() - op_start\n                self.response_times.append(op_time)\n                self.success_count += 1\n                \n            except Exception as e:\n                self.error_count += 1\n                logger.debug(f"负载操作失败: {e}")\n            \n            self.operations_count += 1\n            \n            # 控制操作频率\n            elapsed = time.time() - op_start\n            time.sleep(max(0, interval - elapsed))\n    \n    def get_metrics(self) -> Dict[str, Any]:\n        """获取负载指标"""\n        avg_response_time = sum(self.response_times) / max(1, len(self.response_times))\n        max_response_time = max(self.response_times) if self.response_times else 0\n        \n        return {\n            'total_operations': self.operations_count,\n            'successful_operations': self.success_count,\n            'failed_operations': self.error_count,\n            'error_rate': self.error_count / max(1, self.operations_count),\n            'avg_response_time': avg_response_time,\n            'max_response_time': max_response_time,\n            'total_response_samples': len(self.response_times)\n        }\n\nclass EnhancedFailoverTester:\n    """增强故障转移测试器 - P1级别改进"""\n    \n    def __init__(self):\n        self.test_scenarios: Dict[str, FailoverTestScenario] = {}\n        self.test_reports: Dict[str, FailoverTestReport] = {}\n        self.load_generators: List[LoadGenerator] = []\n        self.monitoring_active = False\n        self.monitoring_thread: Optional[threading.Thread] = None\n        \n        # 预定义测试场景\n        self._initialize_test_scenarios()\n        \n    def _initialize_test_scenarios(self):\n        """初始化测试场景"""\n        scenarios = [\n            FailoverTestScenario(\n                test_id="primary_failure_basic",\n                test_type=FailoverTestType.PRIMARY_FAILURE,\n                description="基本主节点故障测试",\n                expected_failover_time=3.0\n            ),\n            FailoverTestScenario(\n                test_id="performance_degradation",\n                test_type=FailoverTestType.PERFORMANCE_DEGRADATION,\n                description="性能降级故障转移测试",\n                expected_failover_time=10.0,\n                performance_baseline={'response_time': 0.1, 'error_rate': 0.01}\n            ),\n            FailoverTestScenario(\n                test_id="gradual_failure",\n                test_type=FailoverTestType.GRADUAL_FAILURE,\n                description="渐进式故障测试",\n                primary_failure_delay=5.0,\n                expected_failover_time=8.0\n            ),\n            FailoverTestScenario(\n                test_id="network_partition",\n                test_type=FailoverTestType.NETWORK_PARTITION,\n                description="网络分区故障测试",\n                expected_failover_time=5.0\n            )\n        ]\n        \n        for scenario in scenarios:\n            self.test_scenarios[scenario.test_id] = scenario\n    \n    def register_custom_scenario(self, scenario: FailoverTestScenario):\n        """注册自定义测试场景"""\n        self.test_scenarios[scenario.test_id] = scenario\n        logger.info(f"注册自定义测试场景: {scenario.test_id}")\n    \n    def run_failover_test(self, \n    """文档字符串"""\n                         test_id: str, \n                         primary_cache: MockFailureCacheManager,\n                         backup_caches: List[MockFailureCacheManager],\n                         failover_config: FailoverConfig) -> FailoverTestReport:\n        """运行故障转移测试"""\n        if test_id not in self.test_scenarios:\n            raise ValueError(f"未知测试场景: {test_id}")\n        \n        scenario = self.test_scenarios[test_id]\n        report = FailoverTestReport(\n            test_id=test_id,\n            scenario=scenario,\n            result=FailoverTestResult.FAILURE,\n            start_time=datetime.now()\n        )\n        \n        logger.info(f"开始故障转移测试: {test_id} - {scenario.description}")\n        \n        try:\n            # 创建故障转移管理器\n            failover_manager = FailoverManager(primary_cache, failover_config)\n            for backup in backup_caches:\n                failover_manager.add_backup_manager(backup)\n            \n            # 启动监控\n            failover_manager.start_monitoring()\n            \n            # 创建负载生成器\n            load_generator = LoadGenerator(failover_manager.current_primary)\n            self.load_generators.append(load_generator)\n            \n            # 启动负载\n            load_generator.start_load(duration=30.0, operations_per_second=20)\n            \n            # 等待系统稳定\n            time.sleep(2)\n            \n            # 执行故障场景\n            self._execute_failure_scenario(scenario, primary_cache, backup_caches, report)\n            \n            # 监控故障转移过程\n            failover_detected = self._monitor_failover_process(\n                failover_manager, scenario, report\n            )\n            \n            if failover_detected:\n                # 验证故障转移结果\n                self._verify_failover_result(\n                    failover_manager, load_generator, scenario, report\n                )\n            \n            # 测试恢复过程\n            if scenario.recovery_delay > 0:\n                self._test_recovery_process(\n                    primary_cache, failover_manager, scenario, report\n                )\n            \n            # 停止负载和监控\n            load_generator.stop_load()\n            failover_manager.stop_monitoring()\n            \n            # 生成最终报告\n            report.end_time = datetime.now()\n            report.detailed_metrics['load_metrics'] = load_generator.get_metrics()\n            report.detailed_metrics['failover_status'] = failover_manager.get_status()\n            \n            # 判断测试结果\n            if report.failover_detected_time and report.data_loss_count == 0:\n                report.result = FailoverTestResult.SUCCESS\n            elif report.failover_detected_time and report.data_loss_count > 0:\n                report.result = FailoverTestResult.PARTIAL_SUCCESS\n            else:\n                report.result = FailoverTestResult.FAILURE\n            \n            logger.info(f"故障转移测试完成: {test_id} - {report.result.value}")\n            \n        except Exception as e:\n            report.result = FailoverTestResult.UNEXPECTED_ERROR\n            report.error_messages.append(str(e))\n            report.end_time = datetime.now()\n            logger.error(f"故障转移测试异常: {test_id}: {e}")\n        \n        self.test_reports[test_id] = report\n        return report\n    \n    def _execute_failure_scenario(self, \n    """文档字符串"""\n                                 scenario: FailoverTestScenario,\n                                 primary_cache: MockFailureCacheManager,\n                                 backup_caches: List[MockFailureCacheManager],\n                                 report: FailoverTestReport):\n        """执行故障场景"""\n        logger.info(f"执行故障场景: {scenario.test_type.value}")\n        \n        if scenario.primary_failure_delay > 0:\n            time.sleep(scenario.primary_failure_delay)\n        \n        if scenario.test_type == FailoverTestType.PRIMARY_FAILURE:\n            primary_cache.simulate_failure()\n        \n        elif scenario.test_type == FailoverTestType.PERFORMANCE_DEGRADATION:\n            primary_cache.simulate_performance_degradation(delay=0.5, failure_prob=0.3)\n        \n        elif scenario.test_type == FailoverTestType.GRADUAL_FAILURE:\n            # 渐进式增加故障率\n            for i in range(5):\n                primary_cache.simulate_performance_degradation(\n                    delay=0.1 * (i + 1), \n                    failure_prob=0.1 * (i + 1)\n                )\n                time.sleep(1)\n            primary_cache.simulate_failure()\n        \n        elif scenario.test_type == FailoverTestType.NETWORK_PARTITION:\n            # 模拟网络分区（主节点无法响应）\n            primary_cache.simulate_failure()\n    \n    def _monitor_failover_process(self,\n    """文档字符串"""\n                                 failover_manager: FailoverManager,\n                                 scenario: FailoverTestScenario,\n                                 report: FailoverTestReport) -> bool:\n        """监控故障转移过程"""\n        start_time = time.time()\n        timeout = scenario.expected_failover_time * 3  # 3倍超时时间\n        \n        original_primary = failover_manager.current_primary\n        \n        while time.time() - start_time < timeout:\n            current_status = failover_manager.get_status()\n            \n            # 检查是否发生了故障转移\n            if failover_manager.current_primary != original_primary:\n                report.failover_detected_time = datetime.now()\n                failover_duration = time.time() - start_time\n                report.performance_impact['failover_duration'] = failover_duration\n                \n                logger.info(f"检测到故障转移: {failover_duration:.2f}s")\n                return True\n            \n            time.sleep(0.1)  # 100ms检查间隔\n        \n        logger.warning(f"故障转移超时: {timeout}s")\n        return False\n    \n    def _verify_failover_result(self,\n    """文档字符串"""\n                               failover_manager: FailoverManager,\n                               load_generator: LoadGenerator,\n                               scenario: FailoverTestScenario,\n                               report: FailoverTestReport):\n        """验证故障转移结果"""\n        logger.info("验证故障转移结果...")\n        \n        # 验证新的主节点是否正常工作\n        try:\n            test_key = f"failover_test_{time.time()}"\n            success = failover_manager.current_primary.set(test_key, "test_value")\n            if not success:\n                report.error_messages.append("故障转移后写操作失败")\n            \n            value = failover_manager.current_primary.get(test_key)\n            if value != "test_value":\n                report.error_messages.append("故障转移后读操作失败")\n                report.data_loss_count += 1\n            \n            failover_manager.current_primary.delete(test_key)\n            \n        except Exception as e:\n            report.error_messages.append(f"故障转移验证失败: {e}")\n        \n        # 分析负载指标\n        load_metrics = load_generator.get_metrics()\n        report.performance_impact.update({\n            'error_rate_during_failover': load_metrics['error_rate'],\n            'avg_response_time': load_metrics['avg_response_time'],\n            'max_response_time': load_metrics['max_response_time']\n        })\n        \n        # 检查数据一致性\n        if scenario.data_consistency_check:\n            self._check_data_consistency(failover_manager, report)\n    \n    def _check_data_consistency(self,\n    """文档字符串"""\n                               failover_manager: FailoverManager,\n                               report: FailoverTestReport):\n        """检查数据一致性"""\n        logger.info("检查数据一致性...")\n        \n        # 这里可以实现更复杂的数据一致性检查\n        # 简化版本：检查当前缓存的基本操作\n        test_keys = [f"consistency_test_{i}" for i in range(10)]\n        \n        try:\n            # 写入测试数据\n            for key in test_keys:\n                failover_manager.current_primary.set(key, f"value_{key}")\n            \n            # 验证数据\n            for key in test_keys:\n                value = failover_manager.current_primary.get(key)\n                if value != f"value_{key}":\n                    report.data_loss_count += 1\n            \n            # 清理测试数据\n            for key in test_keys:\n                failover_manager.current_primary.delete(key)\n                \n        except Exception as e:\n            report.error_messages.append(f"数据一致性检查失败: {e}")\n    \n    def _test_recovery_process(self,\n    """文档字符串"""\n                              primary_cache: MockFailureCacheManager,\n                              failover_manager: FailoverManager,\n                              scenario: FailoverTestScenario,\n                              report: FailoverTestReport):\n        """测试恢复过程"""\n        logger.info("测试故障恢复过程...")\n        \n        time.sleep(scenario.recovery_delay)\n        \n        # 恢复原主节点\n        primary_cache.simulate_recovery()\n        \n        # 监控是否切回原主节点（如果配置了自动恢复）\n        start_time = time.time()\n        while time.time() - start_time < 10:  # 10秒超时\n            if failover_manager.current_primary == primary_cache:\n                report.recovery_time = datetime.now()\n                logger.info("检测到故障恢复")\n                break\n            time.sleep(0.5)\n    \n    def run_comprehensive_test_suite(self,\n    """文档字符串"""\n                                   primary_cache: MockFailureCacheManager,\n                                   backup_caches: List[MockFailureCacheManager],\n                                   failover_config: FailoverConfig) -> Dict[str, FailoverTestReport]:\n        """运行综合测试套件"""\n        logger.info("开始运行故障转移综合测试套件...")\n        \n        results = {}\n        \n        for test_id in self.test_scenarios.keys():\n            logger.info(f"运行测试: {test_id}")\n            \n            # 重置缓存状态\n            primary_cache.simulate_recovery()\n            for backup in backup_caches:\n                backup.simulate_recovery()\n            \n            # 运行测试\n            report = self.run_failover_test(test_id, primary_cache, backup_caches, failover_config)\n            results[test_id] = report\n            \n            # 短暂等待，避免测试间相互影响\n            time.sleep(2)\n        \n        return results\n    \n    def generate_test_summary(self, reports: Dict[str, FailoverTestReport]) -> Dict[str, Any]:\n        """生成测试摘要"""\n        total_tests = len(reports)\n        successful_tests = sum(1 for r in reports.values() if r.result == FailoverTestResult.SUCCESS)\n        partial_success_tests = sum(1 for r in reports.values() if r.result == FailoverTestResult.PARTIAL_SUCCESS)\n        failed_tests = sum(1 for r in reports.values() if r.result == FailoverTestResult.FAILURE)\n        \n        avg_failover_time = 0\n        failover_times = []\n        \n        for report in reports.values():\n            if report.performance_impact.get('failover_duration'):\n                failover_times.append(report.performance_impact['failover_duration'])\n        \n        if failover_times:\n            avg_failover_time = sum(failover_times) / len(failover_times)\n        \n        return {\n            'total_tests': total_tests,\n            'successful_tests': successful_tests,\n            'partial_success_tests': partial_success_tests,\n            'failed_tests': failed_tests,\n            'success_rate': (successful_tests / max(1, total_tests)) * 100,\n            'average_failover_time': avg_failover_time,\n            'max_failover_time': max(failover_times) if failover_times else 0,\n            'min_failover_time': min(failover_times) if failover_times else 0,\n            'test_execution_time': datetime.now().isoformat()\n        }\n    \n    def cleanup(self):\n        """清理资源"""\n        for load_gen in self.load_generators:\n            load_gen.stop_load()\n        self.load_generators.clear()\n        logger.info("故障转移测试器已清理")