"""
audit_logger 模块

提供 audit_logger 相关功能
"""


from ..utils.interfaces import QueryResult, WriteResult\nfrom datetime import datetime\nfrom enum import Enum\nfrom threading import Lock\nfrom typing import Dict, Any, Optional, List\nimport hashlib\nimport json\nimport logging\nimport time\nimport uuid\n\nfrom dataclasses import dataclass, asdict\n\n"""\n基础设施层 - 配置管理组件\n\naudit_logger 模块\n\n配置管理相关的文件\n提供配置管理相关的功能实现。\n"""\n\n#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\n"""\n审计日志管理器\n实现数据库操作的审计日志记录、操作追踪和安全审计功能\n"""\n\nclass OperationType(Enum):\n\n    """操作类型枚举"""\n    QUERY = "query"\n    WRITE = "write"\n    TRANSACTION = "transaction"\n    CONNECTION = "connection"\n    CONFIGURATION = "configuration"\n\nclass SecurityLevel(Enum):\n\n    """安全级别枚举"""\n    LOW = "low"\n    MEDIUM = "medium"\n    HIGH = "high"\n    CRITICAL = "critical"\n\n@dataclass\n\nclass AuditRecord:\n\n    """审计记录"""\n    id: str\n    timestamp: datetime\n    operation_type: OperationType\n    user_id: Optional[str]\n    session_id: Optional[str]\n    sql: str\n    params: Optional[Dict[str, Any]]\n    result: Dict[str, Any]\n    execution_time: float\n    security_level: SecurityLevel\n    ip_address: Optional[str] = None\n    user_agent: Optional[str] = None\n    additional_info: Optional[Dict[str, Any]] = None\n\nclass DatabaseAuditLogger:\n\n    """数据库审计日志器"""\n\n    def __init__(self,\n\n                 log_file: str = "logs/database_audit.log",\n                 max_records: int = 10000,\n                 enable_encryption: bool = False,\n                 retention_days: int = 365):\n        """\n        初始化数据库审计日志器\n\n        Args:\n            log_file: 日志文件路径\n            max_records: 最大记录数\n            enable_encryption: 是否启用加密\n            retention_days: 保留天数\n        """\n        self._log_file = log_file\n        self._max_records = max_records\n        self._enable_encryption = enable_encryption\n        self._retention_days = retention_days\n\n        self._records: List[AuditRecord] = []\n        self._lock = Lock()\n        self._logger = logging.getLogger('database_audit_logger')\n\n        # 设置日志\n        self._setup_logging()\n\n    def log_database_operation(self, operation_type: str, sql: str,\n    """文档字符串"""\n\n                               params: Optional[Dict[str, Any]],\n                               result: Dict[str, Any], execution_time: float,\n                               user_id: Optional[str] = None,\n                               session_id: Optional[str] = None,\n                               ip_address: Optional[str] = None,\n                               user_agent: Optional[str] = None):\n        """\n        记录数据库操作\n\n        Args:\n            operation_type: 操作类型\n            sql: SQL语句\n            params: 查询参数\n            result: 操作结果\n            execution_time: 执行时间\n            user_id: 用户ID\n            session_id: 会话ID\n            ip_address: IP地址\n            user_agent: 用户代理\n\n        Returns:\n            审计记录ID\n        """\n        try:\n            record_id = str(uuid.uuid4())\n            timestamp = datetime.now()\n\n            # 确定安全级别\n            security_level = self._determine_security_level(operation_type, sql, params)\n\n            # 创建审计记录\n            record = AuditRecord(\n                id=record_id,\n                timestamp=timestamp,\n                operation_type=OperationType(operation_type),\n                user_id=user_id,\n                session_id=session_id,\n                sql=sql,\n                params=params,\n                result=result,\n                execution_time=execution_time,\n                security_level=security_level,\n                ip_address=ip_address,\n                user_agent=user_agent\n            )\n\n            # 写入日志\n            with self._lock:\n                self._records.append(record)\n                self._write_log_entry(record)\n\n                # 限制记录数量\n                if len(self._records) > self._max_records:\n                    self._records = self._records[-self._max_records:]\n\n                self._logger.info(f"Database operation logged: {record_id}")\n                return record_id\n\n        except Exception as e:\n            self._logger.error(f"Failed to log database operation: {e}")\n            return ""\n\n    def get_audit_records(self,\n    """文档字符串"""\n\n                          operation_type: Optional[str] = None,\n                          user_id: Optional[str] = None,\n                          start_time: Optional[datetime] = None,\n                          end_time: Optional[datetime] = None,\n                          limit: Optional[int] = None):\n        """\n        获取审计记录\n\n        Args:\n            operation_type: 操作类型过滤\n            user_id: 用户ID过滤\n            start_time: 开始时间\n            end_time: 结束时间\n            limit: 限制数量\n\n        Returns:\n            审计记录列表\n        """\n        with self._lock:\n            filtered_records = self._records.copy()\n\n        # 应用过滤条件\n        if operation_type:\n            filtered_records = [r for r in filtered_records\n                                if r.operation_type.value == operation_type]\n        if user_id:\n            filtered_records = [r for r in filtered_records\n                                if r.user_id == user_id]\n        if start_time:\n            filtered_records = [r for r in filtered_records\n                                if r.timestamp >= start_time]\n        if end_time:\n            filtered_records = [r for r in filtered_records\n                                if r.timestamp <= end_time]\n        # 限制数量\n        if limit:\n            filtered_records = filtered_records[-limit:]\n\n        # 转换为字典\n        return [asdict(record) for record in filtered_records]\n\n    def get_audit_summary(self, start_time: Optional[datetime] = None,\n    """文档字符串"""\n\n                          end_time: Optional[datetime] = None):\n        """\n        获取审计摘要\n\n        Args:\n            start_time: 开始时间\n            end_time: 结束时间\n\n        Returns:\n            审计摘要\n        """\n        records = self.get_audit_records(start_time=start_time, end_time=end_time)\n\n        if not records:\n            return {\n                "total_operations": 0,\n                "operation_types": {},\n                "security_levels": {},\n                "average_execution_time": 0.0,\n                "users": set()\n            }\n\n        # 统计信息\n        operation_types = {}\n        security_levels = {}\n        total_execution_time = 0.0\n        users = set()\n\n        for record in records:\n            # 操作类型统计\n            op_type = record["operation_type"].value\n            operation_types[op_type] = operation_types.get(op_type, 0) + 1\n\n            # 安全级别统计\n            sec_level = record["security_level"].value\n            security_levels[sec_level] = security_levels.get(sec_level, 0) + 1\n\n            # 执行时间统计\n            total_execution_time += record["execution_time"]\n\n            # 用户统计\n            if record["user_id"]:\n                users.add(record["user_id"])\n\n        return {\n            "total_operations": len(records),\n            "operation_types": operation_types,\n            "security_levels": security_levels,\n            "average_execution_time": total_execution_time / len(records),\n            "users": list(users)\n        }\n\n    def export_audit_log(self, file_path: str,\n    """文档字符串"""\n\n                         start_time: Optional[datetime] = None,\n                         end_time: Optional[datetime] = None):\n        """\n        导出审计日志\n\n        Args:\n            file_path: 导出文件路径\n            start_time: 开始时间\n            end_time: 结束时间\n\n        Returns:\n            是否成功\n        """\n        try:\n            records = self.get_audit_records(start_time=start_time, end_time=end_time)\n\n            with open(file_path, 'w', encoding='utf - 8') as f:\n                json.dump(records, f, indent=2, default=str)\n\n            self._logger.info(f"Audit log exported to: {file_path}")\n            return True\n\n        except Exception as e:\n            self._logger.error(f"Failed to export audit log: {e}")\n            return False\n\n    def _determine_security_level(self, operation_type: str,\n    """文档字符串"""\n\n                                  sql: str, params: Optional[Dict[str, Any]]):\n        """确定安全级别"""\n        sql_lower = sql.lower()\n\n        # 高风险操作\n        if any(keyword in sql_lower for keyword in ['drop', 'delete', 'truncate', 'alter']):\n            return SecurityLevel.CRITICAL\n\n        # 中等风险操作\n        if any(keyword in sql_lower for keyword in ['update', 'insert', 'create']):\n            return SecurityLevel.HIGH\n\n        # 低风险操作\n        if any(keyword in sql_lower for keyword in ['select', 'show', 'describe']):\n            return SecurityLevel.LOW\n\n        return SecurityLevel.MEDIUM\n\n    def _write_log_entry(self, record: AuditRecord) -> None:\n    """文档字符串"""\n\n        """写入日志条目"""\n        try:\n            log_entry = {\n                "timestamp": record.timestamp.isoformat(),\n                "operation_type": record.operation_type.value,\n                "user_id": record.user_id,\n                "session_id": record.session_id,\n                "sql": record.sql,\n                "execution_time": record.execution_time,\n                "security_level": record.security_level.value,\n                "ip_address": record.ip_address,\n                "user_agent": record.user_agent\n            }\n\n            self._logger.info(f"Database audit: {json.dumps(log_entry, ensure_ascii=False)}")\n\n        except Exception as e:\n            self._logger.error(f"Failed to write log entry: {e}")\n\n    def _setup_logging(self) -> None:\n    """文档字符串"""\n\n        """设置日志"""\n        handler = logging.FileHandler(self._log_file, encoding='utf - 8')\n        formatter = logging.Formatter(\n            '%(asctime)s - %(name)s - %(levelname)s - %(message)s'\n        )\n\n        handler.setFormatter(formatter)\n        self._logger.addHandler(handler)\n        self._logger.setLevel(logging.INFO)\n\nclass AuditLogger:\n\n    """审计日志管理器"""\n\n    def __init__(self,\n\n                 log_file: str = "logs/audit.log",\n                 max_records: int = 10000,\n                 enable_encryption: bool = False,\n                 retention_days: int = 365):\n        """\n        初始化审计日志管理器\n\n        Args:\n            log_file: 日志文件路径\n            max_records: 最大记录数\n            enable_encryption: 是否启用加密\n            retention_days: 保留天数\n        """\n        self._log_file = log_file\n        self._max_records = max_records\n        self._enable_encryption = enable_encryption\n        self._retention_days = retention_days\n\n        self._records: List[AuditRecord] = []\n        self._lock = Lock()\n        self._logger = logging.getLogger('audit_logger')\n\n        # 设置日志\n        self._setup_logging()\n\n    def get_logger(self, name: str) -> logging.Logger:\n        """获取日志器实例（兼容性方法）"""\n        if name != 'audit_logger':\n            return logging.getLogger(name)\n        return self._logger\n\n    def log_query(self, sql: str, params: Optional[Dict[str, Any]],\n    """文档字符串"""\n\n                  result: QueryResult, execution_time: float,\n                  user_id: Optional[str] = None, session_id: Optional[str] = None,\n                  ip_address: Optional[str] = None, user_agent: Optional[str] = None):\n        """\n        记录查询操作\n\n        Args:\n            sql: SQL语句\n            params: 查询参数\n            result: 查询结果\n            execution_time: 执行时间\n            user_id: 用户ID\n            session_id: 会话ID\n            ip_address: IP地址\n            user_agent: 用户代理\n\n        Returns:\n            审计记录ID\n        """\n        return self._log_operation(\n            OperationType.QUERY, sql, params, result.to_dict(), execution_time,\n            user_id, session_id, ip_address, user_agent\n        )\n\n    def log_write(self, sql: str, params: Optional[Dict[str, Any]],\n    """文档字符串"""\n\n                  result: WriteResult, execution_time: float,\n                  user_id: Optional[str] = None, session_id: Optional[str] = None,\n                  ip_address: Optional[str] = None, user_agent: Optional[str] = None):\n        """\n        记录写入操作\n\n        Args:\n            sql: SQL语句\n            params: 写入参数\n            result: 写入结果\n            execution_time: 执行时间\n            user_id: 用户ID\n            session_id: 会话ID\n            ip_address: IP地址\n            user_agent: 用户代理\n\n        Returns:\n            审计记录ID\n        """\n        return self._log_operation(\n            OperationType.WRITE, sql, params, result.to_dict(), execution_time,\n            user_id, session_id, ip_address, user_agent\n        )\n\n    def log_transaction(self, operations: List[Dict[str, Any]],\n    """文档字符串"""\n\n                        success: bool, execution_time: float,\n                        user_id: Optional[str] = None, session_id: Optional[str] = None,\n                        ip_address: Optional[str] = None, user_agent: Optional[str] = None):\n        """\n        记录事务操作\n\n        Args:\n            operations: 操作列表\n            success: 是否成功\n            execution_time: 执行时间\n            user_id: 用户ID\n            session_id: 会话ID\n            ip_address: IP地址\n            user_agent: 用户代理\n\n        Returns:\n            审计记录ID\n        """\n        result = {\n            "success": success,\n            "operations_count": len(operations),\n            "operations": operations\n        }\n\n        return self._log_operation(\n            OperationType.TRANSACTION, "TRANSACTION", None, result, execution_time,\n            user_id, session_id, ip_address, user_agent\n        )\n\n    def log_connection(self, action: str, success: bool,\n    """文档字符串"""\n\n                       database_type: str, connection_info: Dict[str, Any],\n                       user_id: Optional[str] = None, session_id: Optional[str] = None,\n                       ip_address: Optional[str] = None, user_agent: Optional[str] = None):\n        """\n        记录连接操作\n\n        Args:\n            action: 连接动作\n            success: 是否成功\n            database_type: 数据库类型\n            connection_info: 连接信息\n            user_id: 用户ID\n            session_id: 会话ID\n            ip_address: IP地址\n            user_agent: 用户代理\n\n        Returns:\n            审计记录ID\n        """\n        result = {\n            "action": action,\n            "success": success,\n            "database_type": database_type,\n            "connection_info": connection_info\n        }\n\n        return self._log_operation(\n            OperationType.CONNECTION, f"CONNECTION_{action}", None, result, 0.0,\n            user_id, session_id, ip_address, user_agent\n        )\n\n    def log_configuration(self, action: str, config: Dict[str, Any],\n    """文档字符串"""\n\n                          success: bool, user_id: Optional[str] = None,\n                          session_id: Optional[str] = None, ip_address: Optional[str] = None,\n                          user_agent: Optional[str] = None):\n        """\n        记录配置操作\n\n        Args:\n            action: 配置动作\n            config: 配置信息\n            success: 是否成功\n            user_id: 用户ID\n            session_id: 会话ID\n            ip_address: IP地址\n            user_agent: 用户代理\n\n        Returns:\n            审计记录ID\n        """\n        result = {\n            "action": action,\n            "success": success,\n            "config": config\n        }\n\n        return self._log_operation(\n            OperationType.CONFIGURATION, f"CONFIG_{action}", None, result, 0.0,\n            user_id, session_id, ip_address, user_agent\n        )\n\n    def get_audit_records(self,\n    """文档字符串"""\n\n                          operation_type: Optional[OperationType] = None,\n                          user_id: Optional[str] = None,\n                          start_time: Optional[datetime] = None,\n                          end_time: Optional[datetime] = None,\n                          limit: Optional[int] = None):\n        """\n        获取审计记录\n\n        Args:\n            operation_type: 操作类型过滤\n            user_id: 用户ID过滤\n            start_time: 开始时间\n            end_time: 结束时间\n            limit: 限制数量\n\n        Returns:\n            审计记录列表\n        """\n        with self._lock:\n            filtered_records = self._records.copy()\n\n        # 应用过滤条件\n        if operation_type:\n            filtered_records = [r for r in filtered_records\n                                if r.operation_type == operation_type]\n        if user_id:\n            filtered_records = [r for r in filtered_records\n                                if r.user_id == user_id]\n        if start_time:\n            filtered_records = [r for r in filtered_records\n                                if r.timestamp >= start_time]\n        if end_time:\n            filtered_records = [r for r in filtered_records\n                                if r.timestamp <= end_time]\n        # 限制数量\n        if limit:\n            filtered_records = filtered_records[-limit:]\n\n        # 转换为字典\n        return [asdict(record) for record in filtered_records]\n\n    def get_audit_summary(self, start_time: Optional[datetime] = None,\n    """文档字符串"""\n\n                          end_time: Optional[datetime] = None):\n        """\n        获取审计摘要\n\n        Args:\n            start_time: 开始时间\n            end_time: 结束时间\n\n        Returns:\n            审计摘要\n        """\n        records = self.get_audit_records(start_time=start_time, end_time=end_time)\n\n        if not records:\n            return {\n                "total_operations": 0,\n                "operation_types": {},\n                "security_levels": {},\n                "average_execution_time": 0.0,\n                "users": set()\n            }\n\n        # 统计信息\n        operation_types = {}\n        security_levels = {}\n        total_execution_time = 0.0\n        users = set()\n\n        for record in records:\n            # 操作类型统计\n            op_type = record["operation_type"].value\n            operation_types[op_type] = operation_types.get(op_type, 0) + 1\n\n            # 安全级别统计\n            sec_level = record["security_level"].value\n            security_levels[sec_level] = security_levels.get(sec_level, 0) + 1\n\n            # 执行时间统计\n            total_execution_time += record["execution_time"]\n\n            # 用户统计\n            if record["user_id"]:\n                users.add(record["user_id"])\n\n        return {\n            "total_operations": len(records),\n            "operation_types": operation_types,\n            "security_levels": security_levels,\n            "average_execution_time": total_execution_time / len(records),\n            "users": list(users)\n        }\n\n    def export_audit_log(self, file_path: str,\n    """文档字符串"""\n\n                         start_time: Optional[datetime] = None,\n                         end_time: Optional[datetime] = None):\n        """\n        导出审计日志\n\n        Args:\n            file_path: 导出文件路径\n            start_time: 开始时间\n            end_time: 结束时间\n\n        Returns:\n            是否成功\n        """\n        try:\n            records = self.get_audit_records(start_time=start_time, end_time=end_time)\n\n            with open(file_path, 'w', encoding='utf - 8') as f:\n                json.dump(records, f, indent=2, default=str)\n\n            self._logger.info(f"Audit log exported to: {file_path}")\n            return True\n\n        except Exception as e:\n            self._logger.error(f"Failed to export audit log: {e}")\n            return False\n\n    def _log_operation(self, operation_type: OperationType, sql: str,\n    """文档字符串"""\n\n                       params: Optional[Dict[str, Any]], result: Dict[str, Any],\n                       execution_time: float, user_id: Optional[str] = None,\n                       session_id: Optional[str] = None, ip_address: Optional[str] = None,\n                       user_agent: Optional[str] = None):\n        """\n        记录操作\n\n        Args:\n            operation_type: 操作类型\n            sql: SQL语句\n            params: 参数\n            result: 结果\n            execution_time: 执行时间\n            user_id: 用户ID\n            session_id: 会话ID\n            ip_address: IP地址\n            user_agent: 用户代理\n\n        Returns:\n            审计记录ID\n        """\n        try:\n            record_id = str(uuid.uuid4())\n            timestamp = datetime.now()\n\n            # 确定安全级别\n            security_level = self._determine_security_level(operation_type, sql, params)\n\n            # 创建审计记录\n            record = AuditRecord(\n                id=record_id,\n                timestamp=timestamp,\n                operation_type=operation_type,\n                user_id=user_id,\n                session_id=session_id,\n                sql=sql,\n                params=params,\n                result=result,\n                execution_time=execution_time,\n                security_level=security_level,\n                ip_address=ip_address,\n                user_agent=user_agent\n            )\n\n            # 写入日志\n            with self._lock:\n                self._records.append(record)\n                self._write_log_entry(record)\n\n                # 限制记录数量\n                if len(self._records) > self._max_records:\n                    self._records = self._records[-self._max_records:]\n\n                self._logger.info(f"Operation logged: {record_id}")\n                return record_id\n\n        except Exception as e:\n            self._logger.error(f"Failed to log operation: {e}")\n            return ""\n\n    def _determine_security_level(self, operation_type: OperationType,\n    """文档字符串"""\n\n                                  sql: str, params: Optional[Dict[str, Any]]):\n        """确定安全级别"""\n        sql_lower = sql.lower()\n\n        # 高风险操作\n        if any(keyword in sql_lower for keyword in ['drop', 'delete', 'truncate', 'alter']):\n            return SecurityLevel.CRITICAL\n\n        # 中等风险操作\n        if any(keyword in sql_lower for keyword in ['update', 'insert', 'create']):\n            return SecurityLevel.HIGH\n\n        # 低风险操作\n        if any(keyword in sql_lower for keyword in ['select', 'show', 'describe']):\n            return SecurityLevel.LOW\n\n        return SecurityLevel.MEDIUM\n\n    def _get_data_preview(self, data: List[Dict[str, Any]], max_rows: int = 5) -> List[Dict[str, Any]]:\n    """文档字符串"""\n\n        """获取数据预览"""\n        if not data:\n            return []\n\n        preview = data[:max_rows]\n\n        # 限制每个字段的长度\n        for row in preview:\n            for key, value in row.items():\n                if isinstance(value, str) and len(value) > 100:\n                    row[key] = value[:100] + "..."\n\n        return preview\n\n    def _write_log_entry(self, record: AuditRecord) -> None:\n    """文档字符串"""\n\n        """写入日志条目"""\n        try:\n            log_entry = {\n                "timestamp": record.timestamp.isoformat(),\n                "operation_type": record.operation_type.value,\n                "user_id": record.user_id,\n                "session_id": record.session_id,\n                "sql": record.sql,\n                "execution_time": record.execution_time,\n                "security_level": record.security_level.value,\n                "ip_address": record.ip_address,\n                "user_agent": record.user_agent\n            }\n\n            self._logger.info(f"Audit: {json.dumps(log_entry, ensure_ascii=False)}")\n\n        except Exception as e:\n            self._logger.error(f"Failed to write log entry: {e}")\n\n    def _setup_logging(self) -> None:\n    """文档字符串"""\n\n        """设置日志"""\n        handler = logging.FileHandler(self._log_file, encoding='utf - 8')\n        formatter = logging.Formatter(\n            '%(asctime)s - %(name)s - %(levelname)s - %(message)s'\n        )\n\n        handler.setFormatter(formatter)\n        self._logger.addHandler(handler)\n        self._logger.setLevel(logging.INFO)\n