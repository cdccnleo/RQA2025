"""\n统一错误处理器\n"""\n\nfrom enum import Enum\nfrom typing import Dict, Any, Optional, List, Callable, Type\nimport logging\nimport threading\nimport time\n\nfrom dataclasses import dataclass\nimport traceback\n\nclass ErrorSeverity(Enum):\n\n    """错误严重程度枚举"""\n    LOW = "low"\n    MEDIUM = "medium"\n    HIGH = "high"\n    CRITICAL = "critical"\n\n@dataclass\n\nclass ErrorInfo:\n\n    """错误信息"""\n    error_type: str\n    message: str\n    severity: ErrorSeverity\n    timestamp: float\n    context: Optional[Dict[str, Any]] = None\n    stack_trace: Optional[str] = None\n    handled: bool = False\n\nclass UnifiedErrorHandler:\n\n    """统一错误处理器"""\n\n    def __init__(self, max_history: int = 1000):\n\n        """初始化错误处理器"""\n        self._handlers: Dict[Type[Exception], Callable] = {}\n        self._error_history: List[ErrorInfo] = []\n        self._max_history = max_history\n        self._lock = threading.Lock()\n        self._fallback_handler: Optional[Callable] = None\n\n        self._register_default_handlers()\n\n    @property\n    def handlers(self) -> Dict[Type[Exception], Callable]:\n        """获取处理器字典（兼容测试接口）"""\n        return self._handlers\n\n    def get_error_stats(self) -> Dict[str, Any]:\n        """获取错误统计信息"""\n        with self._lock:\n            total_errors = len(self._error_history)\n            handled_errors = sum(1 for e in self._error_history if e.handled)\n            unhandled_errors = total_errors - handled_errors\n\n            # 统计错误类型\n            error_types = {}\n            for error in self._error_history:\n                error_type = error.error_type\n                error_types[error_type] = error_types.get(error_type, 0) + 1\n\n            severity_counts = {}\n            for error in self._error_history:\n                severity = error.severity.value\n                severity_counts[severity] = severity_counts.get(severity, 0) + 1\n\n            return {\n                'total_errors': total_errors,\n                'handled_errors': handled_errors,\n                'unhandled_errors': unhandled_errors,\n                'error_types': error_types,\n                'severity_counts': severity_counts,\n                'handler_count': len(self._handlers)\n            }\n\n    def register_handler(self, error_type: Type[Exception], handler: Callable) -> None:\n    """文档字符串"""\n\n        """注册错误处理器"""\n        if handler is None:\n            raise TypeError("Handler cannot be None")\n\n        if not callable(handler):\n            raise TypeError("Handler must be callable")\n\n        with self._lock:\n            self._handlers[error_type] = handler\n\n    def unregister_handler(self, error_type: Type[Exception]) -> None:\n    """文档字符串"""\n\n        """注销错误处理器"""\n        with self._lock:\n            self._handlers.pop(error_type, None)\n\n    def set_fallback_handler(self, handler: Callable) -> None:\n    """文档字符串"""\n\n        """设置后备错误处理器"""\n        with self._lock:\n            self._fallback_handler = handler\n\n    def handle_error(self, error: Exception, context: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """处理错误"""\n        error_info = ErrorInfo(\n            error_type=type(error).__name__,\n            message=str(error),\n            severity=self._determine_severity(error),\n            timestamp=time.time(),\n            context=context,\n            stack_trace=traceback.format_exc()\n        )\n\n        with self._lock:\n            # 添加到历史记录\n            self._error_history.append(error_info)\n            if len(self._error_history) > self._max_history:\n                self._error_history.pop(0)\n\n        # 查找合适的处理器\n        handler = self._find_handler(error)\n\n        if handler:\n            try:\n                result = handler(error, error_info)\n                error_info.handled = True\n                error_dict = self._error_info_to_dict(error_info)\n                # 将result中的字段合并到顶级\n                response = {\n                    'handled': True,\n                    'result': result,\n                    'error_type': error_dict['error_type'],\n                    'message': error_dict['message'],\n                    'severity': error_dict['severity'],\n                    'timestamp': error_dict['timestamp'],\n                    'context': error_dict['context'],\n                    'stack_trace': error_dict['stack_trace']\n                }\n                # 如果result是字典，将其字段合并到顶级\n                if isinstance(result, dict):\n                    response.update(result)\n                return response\n            except Exception as handler_error:\n                logging.error(f"Error handler failed: {handler_error}")\n\n        # 使用后备处理器\n        if self._fallback_handler:\n            try:\n                result = self._fallback_handler(error, error_info)\n                error_info.handled = True\n                error_dict = self._error_info_to_dict(error_info)\n                return {\n                    'handled': True,\n                    'result': result,\n                    'error_type': error_dict['error_type'],\n                    'message': error_dict['message'],\n                    'severity': error_dict['severity'],\n                    'timestamp': error_dict['timestamp'],\n                    'context': error_dict['context'],\n                    'stack_trace': error_dict['stack_trace']\n                }\n            except Exception as fallback_error:\n                logging.error(f"Fallback handler failed: {fallback_error}")\n\n        # 默认处理\n        error_dict = self._error_info_to_dict(error_info)\n        return {\n            'handled': False,\n            'result': None,\n            'error_type': error_dict['error_type'],\n            'message': error_dict['message'],\n            'severity': error_dict['severity'],\n            'timestamp': error_dict['timestamp'],\n            'context': error_dict['context'],\n            'stack_trace': error_dict['stack_trace']\n        }\n\n    def _find_handler(self, error: Exception) -> Optional[Callable]:\n    """文档字符串"""\n\n        """查找合适的错误处理器"""\n        error_type = type(error)\n\n        # 直接匹配\n        if error_type in self._handlers:\n            return self._handlers[error_type]\n\n        # 查找基类匹配\n        for registered_type, handler in self._handlers.items():\n            if issubclass(error_type, registered_type):\n                return handler\n\n        return None\n\n    def _determine_severity(self, error: Exception) -> ErrorSeverity:\n    """文档字符串"""\n\n        """确定错误严重程度"""\n        if isinstance(error, (SystemExit, KeyboardInterrupt)):\n            return ErrorSeverity.CRITICAL\n        elif isinstance(error, (ImportError, ModuleNotFoundError, SystemError)):\n            return ErrorSeverity.HIGH\n        elif isinstance(error, (TypeError, KeyError, IndexError, RuntimeError)):\n            return ErrorSeverity.MEDIUM\n        elif isinstance(error, ValueError):\n            return ErrorSeverity.LOW  # ValueError作为LOW级别\n        else:\n            return ErrorSeverity.LOW\n\n    def _error_info_to_dict(self, error_info: ErrorInfo) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """将错误信息转换为字典"""\n        return {\n            'error_type': error_info.error_type,\n            'message': error_info.message,\n            'severity': error_info.severity.value,\n            'timestamp': error_info.timestamp,\n            'context': error_info.context,\n            'stack_trace': error_info.stack_trace,\n            'handled': error_info.handled\n        }\n\n    def get_error_history(self) -> List[Dict[str, Any]]:\n    """文档字符串"""\n\n        """获取错误历史记录"""\n        with self._lock:\n            return [self._error_info_to_dict(error_info) for error_info in self._error_history]\n\n    def clear_history(self) -> None:\n    """文档字符串"""\n\n        """清空错误历史记录"""\n        with self._lock:\n            self._error_history.clear()\n\n    def clear_error_history(self) -> None:\n        """清空错误历史记录（别名方法）"""\n        self.clear_history()\n\n    def get_error_statistics(self) -> Dict[str, Any]:\n        """获取错误统计信息（别名方法）"""\n        return self.get_stats()\n\n    def get_errors_by_severity(self, severity: ErrorSeverity) -> List[Dict[str, Any]]:\n        """按严重程度获取错误"""\n        with self._lock:\n            return [\n                self._error_info_to_dict(error_info)\n                for error_info in self._error_history\n                if error_info.severity == severity\n            ]\n\n    def get_errors_by_type(self, error_type: str) -> List[Dict[str, Any]]:\n        """按错误类型获取错误"""\n        with self._lock:\n            return [\n                self._error_info_to_dict(error_info)\n                for error_info in self._error_history\n                if error_info.error_type == error_type\n            ]\n\n    def get_recent_errors(self, limit: int = 10) -> List[Dict[str, Any]]:\n        """获取最近的错误记录"""\n        with self._lock:\n            recent_errors = sorted(\n                self._error_history,\n                key=lambda x: x.timestamp,\n                reverse=True\n            )[:limit]\n            return [self._error_info_to_dict(error_info) for error_info in recent_errors]\n\n    def get_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取统计信息"""\n        with self._lock:\n            severity_counts = {}\n            error_types = {}\n            for error_info in self._error_history:\n                severity = error_info.severity.value\n                severity_counts[severity] = severity_counts.get(severity, 0) + 1\n\n                error_type = error_info.error_type\n                error_types[error_type] = error_types.get(error_type, 0) + 1\n\n            return {\n                'total_errors': len(self._error_history),\n                'severity_counts': severity_counts,\n                'error_types': error_types,\n                'handler_count': len(self._handlers),\n                'has_fallback': self._fallback_handler is not None\n            }\n\n    def _register_default_handlers(self) -> None:\n    """文档字符串"""\n\n        """注册默认错误处理器"""\n        # 注册通用异常处理器\n        self.register_handler(Exception, self._default_exception_handler)\n        self.register_handler(ValueError, self._value_error_handler)\n        self.register_handler(TypeError, self._type_error_handler)\n        self.register_handler(KeyError, self._key_error_handler)\n        self.register_handler(IndexError, self._index_error_handler)\n\n    def _default_exception_handler(self, error: Exception, error_info: ErrorInfo) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """默认异常处理器"""\n        return {\n            'action': 'log_and_continue',\n            'message': f"Handled {error_info.error_type}: {error_info.message}",\n            'severity': error_info.severity.value\n        }\n\n    def _value_error_handler(self, error: ValueError, error_info: ErrorInfo) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """值错误处理器"""\n        return {\n            'action': 'retry_with_default',\n            'message': f"Value error handled: {error_info.message}",\n            'severity': 'medium'\n        }\n\n    def _type_error_handler(self, error: TypeError, error_info: ErrorInfo) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """类型错误处理器"""\n        return {\n            'action': 'convert_type',\n            'message': f"Type error handled: {error_info.message}",\n            'severity': 'medium'\n        }\n\n    def _key_error_handler(self, error: KeyError, error_info: ErrorInfo) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """键错误处理器"""\n        return {\n            'action': 'use_default_value',\n            'message': f"Key error handled: {error_info.message}",\n            'severity': 'low'\n        }\n\n    def _index_error_handler(self, error: IndexError, error_info: ErrorInfo) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """索引错误处理器"""\n        return {\n            'action': 'use_default_index',\n            'message': f"Index error handled: {error_info.message}",\n            'severity': 'low'\n        }\n\n    def recovery_handler(self, error: Exception, error_info: Optional[ErrorInfo] = None) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """恢复处理器（兼容测试）"""\n        if error_info:\n            return {\n                'action': 'recovery_attempted',\n                'message': f"Recovery attempted for {error_info.error_type}: {error_info.message}",\n                'severity': error_info.severity.value,\n                'recovery_success': True\n            }\n        else:\n            return {\n                'action': 'recovery_attempted',\n                'message': f"Recovery attempted for {type(error).__name__}: {str(error)}",\n                'severity': 'medium',\n                'recovery_success': True\n            }\n\n    def analyze_error_patterns(self) -> Dict[str, Any]:\n        """分析错误模式"""\n        with self._lock:\n            if not self._error_history:\n                return {\n                    'total_errors': 0,\n                    'patterns': {},\n                    'most_common_error': None,\n                    'error_frequency': {},\n                    'analysis_duration': 0.0\n                }\n\n            # 统计错误类型频率\n            error_types = {}\n            for error in self._error_history:\n                error_type = error.error_type\n                error_types[error_type] = error_types.get(error_type, 0) + 1\n\n            # 找出最常见的错误\n            most_common_error = max(error_types.items(), key=lambda x: x[1]) if error_types else None\n\n            # 分析错误趋势（简化实现）\n            recent_errors = self._error_history[-min(10, len(self._error_history)):]\n            recent_error_types = [e.error_type for e in recent_errors]\n            recent_most_common = max(set(recent_error_types), key=recent_error_types.count) if recent_error_types else None\n\n            return {\n                'total_errors': len(self._error_history),\n                'patterns': error_types,\n                'most_common_error': most_common_error[0] if most_common_error else None,\n                'error_frequency': error_types,\n                'recent_trend': recent_most_common,\n                'analysis_duration': 0.001  # 模拟分析时间\n            }\n