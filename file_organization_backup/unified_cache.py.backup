"""\n基础设施层 - 缓存系统组件\n\nunified_cache 模块\n\n缓存系统相关的文件\n提供缓存系统相关的功能实现。\n"""\n\n#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n统一缓存实现\n"""\n\nfrom collections import OrderedDict\nfrom datetime import datetime, timedelta\nfrom typing import Dict, Any, Optional, List, Callable\nimport json\nimport pickle\nimport threading\nimport time\n\n# Import cache interfaces and classes\nfrom .caching import (\n    CacheInterface, CacheEntry, CacheStats, CacheStrategy,\n    CacheManagerInterface, CacheFactoryInterface\n)\nfrom .smart_cache_strategies import (\n    LFUCache, LRUKCache, AdaptiveCache, PriorityCache, CostAwareCache\n)\n\nclass LRUCache:\n\n    """LRU缓存实现"""\n\n    def __init__(self, capacity: int = 1000):\n\n        self.capacity = capacity\n        self.cache = OrderedDict()\n        self.lock = threading.RLock()\n        self.hits = 0\n        self.misses = 0\n\n    def get(self, key: str) -> Optional[Any]:\n    """文档字符串"""\n\n        """获取缓存值"""\n        if key is None:\n            raise TypeError("缓存键不能为None")\n\n        with self.lock:\n            if key in self.cache:\n                # 移动到末尾（最近使用）\n                self.cache.move_to_end(key)\n                self.hits += 1\n                return self.cache[key]\n            else:\n                self.misses += 1\n                return None\n\n    def put(self, key: str, value: Any) -> None:\n    """文档字符串"""\n\n        """设置缓存值"""\n        if key is None:\n            raise TypeError("缓存键不能为None")\n\n        with self.lock:\n            if key in self.cache:\n                # 如果已存在，移动到末尾\n                self.cache.move_to_end(key)\n            else:\n                # 如果容量为0，不存储任何内容\n                if self.capacity == 0:\n                    return\n                # 如果容量已满，移除最久未使用的\n                while len(self.cache) >= self.capacity:\n                    self.cache.popitem(last=False)\n            self.cache[key] = value\n\n    def remove(self, key: str) -> bool:\n    """文档字符串"""\n\n        """移除缓存项"""\n        with self.lock:\n            if key in self.cache:\n                del self.cache[key]\n                return True\n            return False\n\n    def clear(self) -> None:\n    """文档字符串"""\n\n        """清空缓存"""\n        with self.lock:\n            self.cache.clear()\n\n    def size(self) -> int:\n    """文档字符串"""\n\n        """获取缓存大小"""\n        return len(self.cache)\n\n    def get_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取缓存统计信息"""\n        total_requests = self.hits + self.misses\n        hit_rate = self.hits / max(total_requests, 1)\n        return {\n            "size": len(self.cache),\n            "capacity": self.capacity,\n            "hit_rate": hit_rate,\n            "hits": self.hits,\n            "misses": self.misses\n        }\n\nclass UnifiedCache(CacheInterface):\n\n    """统一缓存实现"""\n\n    def __init__(self, strategy: CacheStrategy = CacheStrategy.LRU,\n                 capacity: int = 1000, default_ttl: int = 3600, **kwargs):\n        self.strategy = strategy\n        self.capacity = capacity\n        self.default_ttl = default_ttl\n\n        # 根据策略选择缓存实现\n        if strategy == CacheStrategy.LRU:\n            self._cache = LRUCache(capacity)\n        elif strategy == CacheStrategy.LFU:\n            self._cache = LFUCache(capacity)\n        elif strategy == CacheStrategy.LRU_K:\n            k = kwargs.get('k', 2)\n            self._cache = LRUKCache(capacity, k)\n        elif strategy == CacheStrategy.ADAPTIVE:\n            max_memory_mb = kwargs.get('max_memory_mb', 100)\n            self._cache = AdaptiveCache(capacity, max_memory_mb)\n        elif strategy == CacheStrategy.PRIORITY:\n            priority_levels = kwargs.get('priority_levels', 5)\n            self._cache = PriorityCache(capacity, priority_levels)\n        elif strategy == CacheStrategy.COST_AWARE:\n            cost_threshold = kwargs.get('cost_threshold', 10.0)\n            self._cache = CostAwareCache(capacity, cost_threshold)\n        else:\n            # 默认使用LRU\n            self._cache = LRUCache(capacity)\n\n        # 缓存元数据\n        self._metadata: Dict[str, CacheEntry] = {}\n        self._stats = CacheStats()\n        self._lock = threading.RLock()\n\n        # 兼容性属性\n        self._memory_cache = self._cache\n        # Redis缓存兼容性属性\n        self._redis_cache = None\n        self._statistics = self._stats  # 兼容性属性\n\n    def get(self, key: str, default: Any = None) -> Any:\n    """文档字符串"""\n\n        """获取缓存值"""\n        start_time = time.time()\n\n        with self._lock:\n            # 检查是否存在\n            if not self.exists(key):\n                self._stats.misses += 1\n                self._stats.total_requests += 1\n                return default\n\n            # 检查是否过期\n            entry = self._metadata.get(key)\n            if entry and entry.ttl is not None:\n                # TTL为0表示立即过期，负数TTL使用默认TTL\n                if entry.ttl == 0:\n                    # TTL为0，立即过期\n                    self.delete(key)\n                    self._stats.misses += 1\n                    self._stats.total_requests += 1\n                    return default\n                elif entry.ttl < 0:\n                    # 负数TTL，使用默认TTL\n                    effective_ttl = self.default_ttl\n                else:\n                    # 正数TTL，直接使用\n                    effective_ttl = entry.ttl\n\n                if datetime.now() > entry.timestamp + timedelta(seconds=effective_ttl):\n                    self.delete(key)\n                    self._stats.misses += 1\n                    self._stats.total_requests += 1\n                    return default\n\n            # 获取值\n            value = self._cache.get(key)\n            if value is not None:\n                self._stats.hits += 1\n                # 更新访问统计\n                if entry:\n                    entry.access_count += 1\n                    entry.last_access = datetime.now()\n\n            self._stats.total_requests += 1\n            return value if value is not None else default\n\n    def set(self, key: str, value: Any, ttl: Optional[int] = None,\n    """文档字符串"""\n\n            metadata: Optional[Dict[str, Any]] = None, **kwargs):\n        """设置缓存值"""\n        try:\n            # 处理TTL参数\n            if ttl is None:\n                ttl = self.default_ttl\n            elif ttl < 0:\n                ttl = self.default_ttl  # 负数TTL使用默认TTL\n\n            timestamp = datetime.now()\n\n            with self._lock:\n                # 根据缓存策略调用不同的put方法\n                if self.strategy == CacheStrategy.PRIORITY:\n                    priority = kwargs.get('priority', metadata.get('priority', 0) if metadata else 0)\n                    self._cache.put(key, value, priority)\n                elif self.strategy == CacheStrategy.COST_AWARE:\n                    retrieval_cost = kwargs.get('retrieval_cost', metadata.get('retrieval_cost', 1.0) if metadata else 1.0)\n                    self._cache.put(key, value, retrieval_cost)\n                else:\n                    self._cache.put(key, value)\n\n                # 获取当前缓存键（适配不同缓存实现）\n                if hasattr(self._cache, 'cache'):\n                    current_cache_keys = set(self._cache.cache.keys())\n                elif hasattr(self._cache, 'cache') and isinstance(self._cache.cache, dict):\n                    current_cache_keys = set(self._cache.cache.keys())\n                else:\n                    # 对于其他类型的缓存，尝试获取缓存大小信息\n                    current_cache_keys = set()\n                    if hasattr(self._cache, 'size'):\n                        # 如果无法直接获取键列表，跳过元数据清理\n                        pass\n\n                # 同步元数据，移除被淘汰的键\n                if current_cache_keys:\n                    keys_to_remove = [k for k in self._metadata.keys() if k not in current_cache_keys]\n                    for k in keys_to_remove:\n                        del self._metadata[k]\n\n                # 创建缓存条目\n                entry = CacheEntry(\n                    key=key,\n                    value=value,\n                    timestamp=timestamp,\n                    ttl=ttl,\n                    metadata=metadata or {},\n                    access_count=0,\n                    last_access=timestamp,\n                    priority=kwargs.get('priority', 0)\n                )\n\n                # 存储元数据\n                self._metadata[key] = entry\n\n                # 更新统计\n                self._stats.entry_count = len(self._metadata)\n\n                return True\n        except Exception:\n            return False\n\n    def delete(self, key: str) -> bool:\n    """文档字符串"""\n\n        """删除缓存项"""\n        with self._lock:\n            # 从缓存中删除\n            result = self._cache.remove(key)\n\n            # 从元数据中删除\n            if key in self._metadata:\n                del self._metadata[key]\n                self._stats.entry_count = len(self._metadata)\n\n            return result\n\n    def exists(self, key: str) -> bool:\n    """文档字符串"""\n\n        """检查缓存项是否存在"""\n        with self._lock:\n            if key not in self._metadata:\n                return False\n\n            # 检查是否过期\n            entry = self._metadata[key]\n            if entry.ttl:\n                if datetime.now() > entry.timestamp + timedelta(seconds=entry.ttl):\n                    self.delete(key)\n                    return False\n\n            return True\n\n    def clear(self) -> bool:\n    """文档字符串"""\n\n        """清空所有缓存"""\n        try:\n            with self._lock:\n                self._cache.clear()\n                self._metadata.clear()\n                self._stats.entry_count = 0\n                self._stats.evictions += len(self._metadata)\n            return True\n        except Exception:\n            return False\n\n    def size(self) -> int:\n    """文档字符串"""\n\n        """获取缓存大小"""\n        return self._cache.size()\n\n    def get_stats(self) -> CacheStats:\n    """文档字符串"""\n\n        """获取缓存统计信息"""\n        with self._lock:\n            # 计算内存使用（估算）\n            memory_usage = 0\n            for key, entry in self._metadata.items():\n                memory_usage += len(key.encode('utf-8'))\n                if isinstance(entry.value, str):\n                    memory_usage += len(entry.value.encode('utf-8'))\n                elif isinstance(entry.value, (int, float)):\n                    memory_usage += 8\n                else:\n                    memory_usage += 64  # 默认估算\n\n            self._stats.memory_usage = memory_usage\n            return self._stats\n\n    def get_statistics(self) -> CacheStats:\n    """文档字符串"""\n\n        """获取缓存统计信息（别名）"""\n        return self.get_stats()\n\n    def invalidate_pattern(self, pattern: str) -> int:\n    """文档字符串"""\n\n        """按模式失效缓存"""\n        count = 0\n        with self._lock:\n            # 获取所有缓存键（从LRU缓存中）\n            if hasattr(self._cache, 'cache'):\n                # LRU缓存的情况\n                keys_to_remove = []\n                for key in list(self._cache.cache.keys()):\n                    if self._match_pattern(key, pattern):\n                        keys_to_remove.append(key)\n\n                for key in keys_to_remove:\n                    if self.delete(key):\n                        count += 1\n            else:\n                # 其他缓存类型的情况\n                keys_to_remove = []\n                for key in self._metadata.keys():\n                    if self._match_pattern(key, pattern):\n                        keys_to_remove.append(key)\n\n                for key in keys_to_remove:\n                    if self.delete(key):\n                        count += 1\n\n        return count\n\n    def _match_pattern(self, key: str, pattern: str) -> bool:\n    """文档字符串"""\n\n        """简单的模式匹配"""\n        if pattern == "*":\n            return True\n        if pattern.startswith("*") and pattern.endswith("*"):\n            return pattern[1:-1] in key\n        if pattern.startswith("*"):\n            return key.endswith(pattern[1:])\n        if pattern.endswith("*"):\n            return key.startswith(pattern[:-1])\n\n        # 处理中间有通配符的情况，如 "user:*:profile"\n        if "*" in pattern:\n            parts = pattern.split("*")\n            if len(parts) == 2:\n                prefix, suffix = parts\n                return key.startswith(prefix) and key.endswith(suffix)\n\n        return key == pattern\n\nclass UnifiedCacheManager(BaseManager, CacheManagerInterface):\n\n    """统一缓存管理器"""\n\n    def __init__(self):\n\n        self._caches: Dict[str, CacheInterface] = {}\n        self._lock = threading.RLock()\n\n    def get_cache(self, name: str) -> Optional[CacheInterface]:\n    """文档字符串"""\n\n        """获取指定名称的缓存实例"""\n        with self._lock:\n            return self._caches.get(name)\n\n    def create_cache(self, name: str, strategy: CacheStrategy = CacheStrategy.LRU,\n    """文档字符串"""\n\n                     capacity: int = 1000, ttl: int = 3600):\n        """创建新的缓存实例"""\n        with self._lock:\n            if name in self._caches:\n                raise ValueError(f"缓存 '{name}' 已存在")\n\n            cache = UnifiedCache(strategy=strategy, capacity=capacity, default_ttl=ttl)\n            self._caches[name] = cache\n            return cache\n\n    def delete_cache(self, name: str) -> bool:\n    """文档字符串"""\n\n        """删除指定的缓存实例"""\n        with self._lock:\n            if name in self._caches:\n                cache = self._caches[name]\n                cache.clear()\n                del self._caches[name]\n                return True\n            return False\n\n    def list_caches(self) -> List[str]:\n    """文档字符串"""\n\n        """列出所有缓存名称"""\n        with self._lock:\n            return list(self._caches.keys())\n\n    def get_all_stats(self) -> Dict[str, CacheStats]:\n    """文档字符串"""\n\n        """获取所有缓存的统计信息"""\n        with self._lock:\n            stats = {}\n            for name, cache in self._caches.items():\n                stats[name] = cache.get_stats()\n            return stats\n\nclass UnifiedCacheFactory(BaseFactory, CacheFactoryInterface):\n\n    """统一缓存工厂"""\n\n    def __init__(self):\n\n        self._cache_types: Dict[str, Callable] = {\n            "memory": self._create_memory_cache,\n            "lru": self._create_lru_cache,\n            "lfu": self._create_lfu_cache,\n            "lru_k": self._create_lru_k_cache,\n            "adaptive": self._create_adaptive_cache,\n            "priority": self._create_priority_cache,\n            "cost_aware": self._create_cost_aware_cache,\n            "fifo": self._create_fifo_cache,\n        }\n\n    def _create_memory_cache(self, **kwargs) -> UnifiedCache:\n    """文档字符串"""\n\n        """创建内存缓存"""\n        kwargs.pop('strategy', None)  # 移除strategy参数\n        ttl = kwargs.pop('default_ttl', kwargs.pop('ttl', 3600))\n        return UnifiedCache(strategy=CacheStrategy.LRU, default_ttl=ttl, **kwargs)\n\n    def _create_lru_cache(self, **kwargs) -> UnifiedCache:\n    """文档字符串"""\n\n        """创建LRU缓存"""\n        kwargs.pop('strategy', None)  # 移除strategy参数\n        ttl = kwargs.pop('default_ttl', kwargs.pop('ttl', 3600))\n        return UnifiedCache(strategy=CacheStrategy.LRU, default_ttl=ttl, **kwargs)\n\n    def _create_lfu_cache(self, **kwargs) -> UnifiedCache:\n    """文档字符串"""\n\n        """创建LFU缓存"""\n        kwargs.pop('strategy', None)  # 移除strategy参数\n        ttl = kwargs.pop('default_ttl', kwargs.pop('ttl', 3600))\n        return UnifiedCache(strategy=CacheStrategy.LFU, default_ttl=ttl, **kwargs)\n\n    def _create_lru_k_cache(self, **kwargs) -> UnifiedCache:\n    """文档字符串"""\n\n        """创建LRU - K缓存"""\n        kwargs.pop('strategy', None)  # 移除strategy参数\n        ttl = kwargs.pop('default_ttl', kwargs.pop('ttl', 3600))\n        return UnifiedCache(strategy=CacheStrategy.LRU_K, default_ttl=ttl, **kwargs)\n\n    def _create_adaptive_cache(self, **kwargs) -> UnifiedCache:\n    """文档字符串"""\n\n        """创建自适应缓存"""\n        kwargs.pop('strategy', None)  # 移除strategy参数\n        ttl = kwargs.pop('default_ttl', kwargs.pop('ttl', 3600))\n        return UnifiedCache(strategy=CacheStrategy.ADAPTIVE, default_ttl=ttl, **kwargs)\n\n    def _create_priority_cache(self, **kwargs) -> UnifiedCache:\n    """文档字符串"""\n\n        """创建优先级缓存"""\n        kwargs.pop('strategy', None)  # 移除strategy参数\n        ttl = kwargs.pop('default_ttl', kwargs.pop('ttl', 3600))\n        return UnifiedCache(strategy=CacheStrategy.PRIORITY, default_ttl=ttl, **kwargs)\n\n    def _create_cost_aware_cache(self, **kwargs) -> UnifiedCache:\n    """文档字符串"""\n\n        """创建成本感知缓存"""\n        kwargs.pop('strategy', None)  # 移除strategy参数\n        ttl = kwargs.pop('default_ttl', kwargs.pop('ttl', 3600))\n        return UnifiedCache(strategy=CacheStrategy.COST_AWARE, default_ttl=ttl, **kwargs)\n\n    def _create_fifo_cache(self, **kwargs) -> UnifiedCache:\n    """文档字符串"""\n\n        """创建FIFO缓存"""\n        kwargs.pop('strategy', None)  # 移除strategy参数\n        ttl = kwargs.pop('default_ttl', kwargs.pop('ttl', 3600))\n        return UnifiedCache(strategy=CacheStrategy.FIFO, default_ttl=ttl, **kwargs)\n\n    def create_cache(self, cache_type: str, **kwargs) -> CacheInterface:\n    """文档字符串"""\n\n        """创建指定类型的缓存"""\n        if cache_type not in self._cache_types:\n            raise ValueError(f"不支持的缓存类型: {cache_type}")\n\n        # 获取注册的工厂函数\n        factory_func = self._cache_types[cache_type]\n\n        # 调用工厂函数创建缓存\n        return factory_func(**kwargs)\n\n    def register_cache_type(self, cache_type: str, factory_func: callable) -> bool:\n    """文档字符串"""\n\n        """注册新的缓存类型"""\n        try:\n            self._cache_types[cache_type] = factory_func\n            return True\n        except Exception:\n            return False\n\n    def list_cache_types(self) -> List[str]:\n    """文档字符串"""\n\n        """列出所有支持的缓存类型"""\n        return list(self._cache_types.keys())\n\n# 全局实例\n_cache_manager = UnifiedCacheManager()\n_cache_factory = UnifiedCacheFactory()\n\ndef get_cache_manager() -> CacheManagerInterface:\n    """文档字符串"""\n\n    """获取全局缓存管理器"""\n    return _cache_manager\n\ndef get_cache_factory() -> CacheFactoryInterface:\n    """文档字符串"""\n\n    """获取全局缓存工厂"""\n    return _cache_factory\n\ndef get_default_cache() -> CacheInterface:\n    """文档字符串"""\n\n    """获取默认缓存实例"""\n    return _cache_manager.get_cache("default") or _cache_manager.create_cache("default")\n