"""\n错误日志组件\n\n独立的错误日志记录功能，避免循环依赖问题。\n"""\n\nfrom enum import Enum\nfrom typing import Optional, Any, Dict\n\nclass ErrorLogLevel(Enum):\n    """错误日志级别"""\n    DEBUG = "DEBUG"\n    INFO = "INFO"\n    WARNING = "WARNING"\n    ERROR = "ERROR"\n    CRITICAL = "CRITICAL"\n\nfrom .interfaces import ILogger\n\nclass ErrorLogger(ILogger):\n    """错误日志器 - 实现ILogger接口"""\n\n    def __init__(self):\n        self._loggers = {}\n\n    def log_error(self, error: Exception, context: Optional[Dict[str, Any]] = None,\n    """文档字符串"""\n                  level: ErrorLogLevel = ErrorLogLevel.ERROR) -> None:\n        """记录错误信息\n\n        Args:\n            error: 异常对象\n            context: 错误上下文\n            level: 日志级别\n        """\n        # 简单的控制台输出，避免依赖logging模块\n        error_msg = f"[{level.value}] {type(error).__name__}: {str(error)}"\n        if context:\n            error_msg += f" | Context: {context}"\n\n        print(error_msg)\n\n    def log_message(self, message: str, level: ErrorLogLevel = ErrorLogLevel.INFO) -> None:\n        """记录普通消息\n\n        Args:\n            message: 消息内容\n            level: 日志级别\n        """\n        print(f"[{level.value}] {message}")\n\n# 全局错误日志器实例\nerror_logger = ErrorLogger()\n