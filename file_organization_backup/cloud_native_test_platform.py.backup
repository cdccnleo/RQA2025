"""\n云原生测试平台\n支持容器化部署、Kubernetes集成、微服务测试等云原生特性\n"""\n\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\nfrom datetime import datetime, timedelta\nfrom enum import Enum\nfrom typing import Dict, List, Optional, Any, Tuple\nimport json\nimport logging\nimport os\nimport subprocess\nimport sys\nimport threading\nimport time\n\nfrom dataclasses import dataclass, asdict\nimport requests\nimport yaml\n\n# 配置日志\nlogger = logging.getLogger(__name__)\n\nclass PlatformType(Enum):\n\n    """\ncloud_native_test_platform - 配置管理\n\n职责说明：\n负责系统配置的统一管理、配置文件的读取、配置验证和配置分发\n\n核心职责：\n- 配置文件的读取和解析\n- 配置参数的验证\n- 配置的热重载\n- 配置的分发和同步\n- 环境变量管理\n- 配置加密和安全\n\n相关接口：\n- IConfigComponent\n- IConfigManager\n- IConfigValidator\n平台类型枚举 \n    DOCKER = docker\n    KUBERNETES = "kubernetes"\n    OPENSHIFT = "openshift"\n    AWS_ECS = "aws_ecs"\n    AZURE_AKS = "azure_aks"\n    GCP_GKE = "gcp_gke"\n"""\n\nclass ServiceStatus(Enum):\n\n    """服务状态枚举"""\n    PENDING = "pending"\n    RUNNING = "running"\n    FAILED = "failed"\n    STOPPED = "stopped"\n    SCALING = "scaling"\n\nclass TestEnvironment(Enum):\n\n    """测试环境枚举"""\n    DEV = "dev"\n    STAGING = "staging"\n    PROD = "prod"\n    INTEGRATION = "integration"\n\n@dataclass\n\nclass ContainerConfig:\n\n    """容器配置"""\n    image: str\n    tag: str = "latest"\n    ports: Dict[str, str] = None\n    environment: Dict[str, str] = None\n    volumes: Dict[str, str] = None\n    resources: Dict[str, str] = None\n    health_check: str = None\n    restart_policy: str = "unless - stopped"\n\n    def __post_init__(self):\n\n        if self.ports is None:\n            self.ports = {}\n        if self.environment is None:\n            self.environment = {}\n        if self.volumes is None:\n            self.volumes = {}\n        if self.resources is None:\n            self.resources = {}\n\n@dataclass\n\nclass KubernetesConfig:\n\n    """Kubernetes配置"""\n    namespace: str = "default"\n    replicas: int = 1\n    service_type: str = "ClusterIP"\n    ingress_enabled: bool = False\n    ingress_host: str = ""\n    ingress_tls: bool = False\n    resource_limits: Dict[str, str] = None\n    resource_requests: Dict[str, str] = None\n\n    def __post_init__(self):\n\n        if self.resource_limits is None:\n            self.resource_limits = {"cpu": "500m", "memory": "512Mi"}\n        if self.resource_requests is None:\n            self.resource_requests = {"cpu": "250m", "memory": "256Mi"}\n\n@dataclass\n\nclass ServiceInfo:\n\n    """服务信息"""\n    name: str\n    platform_type: PlatformType\n    status: ServiceStatus\n    container_config: Optional[ContainerConfig] = None\n    kubernetes_config: Optional[KubernetesConfig] = None\n    created_at: datetime = None\n    updated_at: datetime = None\n    health_status: str = "unknown"\n    endpoint: str = ""\n\n    def __post_init__(self):\n\n        if self.created_at is None:\n            self.created_at = datetime.now()\n        if self.updated_at is None:\n            self.updated_at = datetime.now()\n\n@dataclass\n\nclass TestResult:\n\n    """测试结果"""\n    test_id: str\n    service_name: str\n    environment: TestEnvironment\n    status: str\n    duration: float\n    error_message: Optional[str] = None\n    metrics: Dict[str, Any] = None\n    timestamp: datetime = None\n\n    def __post_init__(self):\n\n        if self.timestamp is None:\n            self.timestamp = datetime.now()\n        if self.metrics is None:\n            self.metrics = {}\n\nclass ContainerManager:\n\n    """容器管理器"""\n\n    def __init__(self):\n\n        self.containers: Dict[str, Dict[str, Any]] = {}\n        self._lock = threading.Lock()\n\n    def create_container(self, name: str, config: ContainerConfig) -> bool:\n    """文档字符串"""\n\n        """创建容器"""\n        try:\n            with self._lock:\n                # 构建docker run命令\n                cmd = ["docker", "run", "-d", "--name", name]\n\n                # 添加端口映射\n                for host_port, container_port in config.ports.items():\n                    cmd.extend(["-p", f"{host_port}:{container_port}"])\n\n                # 添加环境变量\n                for key, value in config.environment.items():\n                    cmd.extend(["-e", f"{key}={value}"])\n\n                # 添加卷挂载\n                for host_path, container_path in config.volumes.items():\n                    cmd.extend(["-v", f"{host_path}:{container_path}"])\n\n                # 添加资源限制\n                if config.resources:\n                    if "memory" in config.resources:\n                        cmd.extend(["--memory", config.resources["memory"]])\n                    if "cpu" in config.resources:\n                        cmd.extend(["--cpus", config.resources["cpu"]])\n\n                # 添加重启策略\n                cmd.extend(["--restart", config.restart_policy])\n\n                # 添加镜像\n                cmd.append(f"{config.image}:{config.tag}")\n\n                # 执行命令\n                result = subprocess.run(cmd, capture_output=True, text=False, encoding=None)\n\n                # Handle encoding conversion\n                if result.stdout:\n                    try:\n                        result.stdout = result.stdout.decode(sys.getdefaultencoding())\n                    except UnicodeDecodeError:\n                        result.stdout = result.stdout.decode('latin-1', errors='replace')\n                if result.stderr:\n                    try:\n                        result.stderr = result.stderr.decode(sys.getdefaultencoding())\n                    except UnicodeDecodeError:\n                        result.stderr = result.stderr.decode('latin-1', errors='replace')\n\n                if result.returncode == 0:\n                    container_id = result.stdout.strip()\n                    self.containers[name] = {\n                        "id": container_id,\n                        "config": config,\n                        "status": "created",\n                        "created_at": datetime.now()\n                    }\n                    logger.info(f"容器 {name} 创建成功: {container_id}")\n                    return True\n                else:\n                    logger.error(f"容器 {name} 创建失败: {result.stderr}")\n                    return False\n\n        except Exception as e:\n            logger.error(f"创建容器 {name} 时发生错误: {e}")\n            return False\n\n    def start_container(self, name: str) -> bool:\n    """文档字符串"""\n\n        """启动容器"""\n        try:\n            result = subprocess.run(["docker", "start", name], capture_output=True, text=False, encoding=None)\n\n            # Handle encoding conversion\n            if result.stdout:\n                try:\n                    result.stdout = result.stdout.decode(sys.getdefaultencoding())\n                except UnicodeDecodeError:\n                    result.stdout = result.stdout.decode('latin-1', errors='replace')\n            if result.stderr:\n                try:\n                    result.stderr = result.stderr.decode(sys.getdefaultencoding())\n                except UnicodeDecodeError:\n                    result.stderr = result.stderr.decode('latin-1', errors='replace')\n            if result.returncode == 0:\n                with self._lock:\n                    if name in self.containers:\n                        self.containers[name]["status"] = "running"\n                        self.containers[name]["updated_at"] = datetime.now()\n                logger.info(f"容器 {name} 启动成功")\n                return True\n            else:\n                logger.error(f"容器 {name} 启动失败: {result.stderr}")\n                return False\n        except Exception as e:\n            logger.error(f"启动容器 {name} 时发生错误: {e}")\n            return False\n\n    def stop_container(self, name: str) -> bool:\n    """文档字符串"""\n\n        """停止容器"""\n        try:\n            result = subprocess.run(["docker", "stop", name], capture_output=True, text=False, encoding=None)\n\n            # Handle encoding conversion\n            if result.stdout:\n                try:\n                    result.stdout = result.stdout.decode(sys.getdefaultencoding())\n                except UnicodeDecodeError:\n                    result.stdout = result.stdout.decode('latin-1', errors='replace')\n            if result.stderr:\n                try:\n                    result.stderr = result.stderr.decode(sys.getdefaultencoding())\n                except UnicodeDecodeError:\n                    result.stderr = result.stderr.decode('latin-1', errors='replace')\n            if result.returncode == 0:\n                with self._lock:\n                    if name in self.containers:\n                        self.containers[name]["status"] = "stopped"\n                        self.containers[name]["updated_at"] = datetime.now()\n                logger.info(f"容器 {name} 停止成功")\n                return True\n            else:\n                logger.error(f"容器 {name} 停止失败: {result.stderr}")\n                return False\n        except Exception as e:\n            logger.error(f"停止容器 {name} 时发生错误: {e}")\n            return False\n\n    def remove_container(self, name: str) -> bool:\n    """文档字符串"""\n\n        """删除容器"""\n        try:\n            result = subprocess.run(["docker", "rm", "-f", name], capture_output=True, text=False, encoding=None)\n\n            # Handle encoding conversion\n            if result.stdout:\n                try:\n                    result.stdout = result.stdout.decode(sys.getdefaultencoding())\n                except UnicodeDecodeError:\n                    result.stdout = result.stdout.decode('latin-1', errors='replace')\n            if result.stderr:\n                try:\n                    result.stderr = result.stderr.decode(sys.getdefaultencoding())\n                except UnicodeDecodeError:\n                    result.stderr = result.stderr.decode('latin-1', errors='replace')\n            if result.returncode == 0:\n                with self._lock:\n                    if name in self.containers:\n                        del self.containers[name]\n                logger.info(f"容器 {name} 删除成功")\n                return True\n            else:\n                logger.error(f"容器 {name} 删除失败: {result.stderr}")\n                return False\n        except Exception as e:\n            logger.error(f"删除容器 {name} 时发生错误: {e}")\n            return False\n\n    def get_container_status(self, name: str) -> Optional[str]:\n    """文档字符串"""\n\n        """获取容器状态"""\n        try:\n            result = subprocess.run(["docker", "ps", "-a", "--format", "{{.Names}}\t{{.Status}}"], \n                                  capture_output=True, text=True)\n            if result.returncode == 0:\n                for line in result.stdout.strip().split('\n'):\n                    if line:\n                        container_name, status = line.split('\t', 1)\n                        if container_name == name:\n                            return status\n            return None\n        except Exception as e:\n            logger.error(f"获取容器 {name} 状态时发生错误: {e}")\n            return None\n\n    def list_containers(self) -> List[Dict[str, Any]]:\n    """文档字符串"""\n\n        """列出所有容器"""\n        with self._lock:\n            return list(self.containers.values())\n\nclass KubernetesManager:\n\n    """Kubernetes管理器"""\n\n    def __init__(self, config_path: str = None):\n\n        self.config_path = config_path\n        self.namespaces: List[str] = []\n        self.deployments: Dict[str, Dict[str, Any]] = {}\n        self.services: Dict[str, Dict[str, Any]] = {}\n        self._lock = threading.Lock()\n\n    def check_kubectl(self) -> bool:\n    """文档字符串"""\n\n        """检查kubectl是否可用"""\n        try:\n            result = subprocess.run(["kubectl", "version", "--client"], \n                                  capture_output=True, text=True)\n            return result.returncode == 0\n        except Exception:\n            return False\n\n    def create_namespace(self, name: str) -> bool:\n    """文档字符串"""\n\n        """创建命名空间"""\n        try:\n            result = subprocess.run(["kubectl", "create", "namespace", name], \n                                  capture_output=True, text=True)\n            if result.returncode == 0:\n                with self._lock:\n                    if name not in self.namespaces:\n                        self.namespaces.append(name)\n                logger.info(f"命名空间 {name} 创建成功")\n                return True\n            else:\n                logger.error(f"命名空间 {name} 创建失败: {result.stderr}")\n                return False\n        except Exception as e:\n            logger.error(f"创建命名空间 {name} 时发生错误: {e}")\n            return False\n\n    def deploy_service(self, name: str, config: KubernetesConfig, container_config: ContainerConfig):\n    """文档字符串"""\n\n        """部署服务到Kubernetes"""\n        try:\n            # 创建deployment YAML\n            deployment_yaml = self._create_deployment_yaml(name, config, container_config)\n\n            # 创建service YAML\n            service_yaml = self._create_service_yaml(name, config)\n\n            # 应用deployment\n            deployment_file = f"/tmp/{name}_deployment.yaml"\n            with open(deployment_file, 'w') as f:\n                yaml.dump(deployment_yaml, f)\n\n            result = subprocess.run(["kubectl", "apply", "-f", deployment_file, "-n", config.namespace],\n                                   capture_output=True, text=True)\n\n            if result.returncode == 0:\n                # 应用service\n                service_file = f"/tmp/{name}_service.yaml"\n                with open(service_file, 'w') as f:\n                    yaml.dump(service_yaml, f)\n\n                result = subprocess.run(["kubectl", "apply", "-f", service_file, "-n", config.namespace],\n                                       capture_output=True, text=True)\n\n                if result.returncode == 0:\n                    with self._lock:\n                        self.deployments[name] = {\n                            "namespace": config.namespace,\n                            "config": config,\n                            "status": "deployed",\n                            "deployed_at": datetime.now()\n                        }\n\n                        self.services[name] = {\n                            "namespace": config.namespace,\n                            "config": config,\n                            "status": "deployed",\n                            "deployed_at": datetime.now()\n                        }\n\n                    # 清理临时文件\n                    os.remove(deployment_file)\n                    os.remove(service_file)\n\n                    logger.info(f"服务 {name} 部署成功")\n                    return True\n                else:\n                    logger.error(f"服务 {name} 部署失败: {result.stderr}")\n                    return False\n            else:\n                logger.error(f"部署 {name} 失败: {result.stderr}")\n                return False\n\n        except Exception as e:\n            logger.error(f"部署服务 {name} 时发生错误: {e}")\n            return False\n\n    def _create_deployment_yaml(self, name: str, config: KubernetesConfig, container_config: ContainerConfig):\n    """文档字符串"""\n\n        """创建deployment YAML"""\n        return {\n            "apiVersion": "apps/v1",\n            "kind": "Deployment",\n            "metadata": {\n                "name": name,\n                "namespace": config.namespace\n            },\n            "spec": {\n                "replicas": config.replicas,\n                "selector": {\n                    "matchLabels": {\n                        "app": name\n                    }\n                },\n                "template": {\n                    "metadata": {\n                        "labels": {\n                            "app": name\n                        }\n                    },\n                    "spec": {\n                        "containers": [{\n                            "name": name,\n                            "image": f"{container_config.image}:{container_config.tag}",\n                            "ports": [{"containerPort": int(port)} for port in container_config.ports.values()],\n                            "env": [{"name": k, "value": v} for k, v in container_config.environment.items()],\n                            "resources": {\n                                "limits": config.resource_limits,\n                                "requests": config.resource_requests\n                            }\n                        }]\n                    }\n                }\n            }\n        }\n\n    def _create_service_yaml(self, name: str, config: KubernetesConfig) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """创建service YAML"""\n        return {\n            "apiVersion": "v1",\n            "kind": "Service",\n            "metadata": {\n                "name": name,\n                "namespace": config.namespace\n            },\n            "spec": {\n                "type": config.service_type,\n                "selector": {\n                    "app": name\n                },\n\n                "ports": [{\n                    "port": 80,\n                    "targetPort": 80,\n                    "protocol": "TCP"\n                }]\n            }\n        }\n\n    def scale_service(self, name: str, replicas: int) -> bool:\n    """文档字符串"""\n\n        """扩缩容服务"""\n        try:\n            result = subprocess.run([\n                "kubectl", "scale", "deployment", name,\n                f"--replicas={replicas}", "-n", "default"\n            ], capture_output=True, text=True)\n            if result.returncode == 0:\n                with self._lock:\n                    if name in self.deployments:\n                        self.deployments[name]["status"] = "scaling"\n                        self.deployments[name]["updated_at"] = datetime.now()\n                logger.info(f"服务 {name} 扩缩容成功: {replicas}")\n                return True\n            else:\n                logger.error(f"服务 {name} 扩缩容失败: {result.stderr}")\n                return False\n        except Exception as e:\n            logger.error(f"扩缩容服务 {name} 时发生错误: {e}")\n            return False\n\n    def delete_service(self, name: str, namespace: str = "default") -> bool:\n    """文档字符串"""\n\n        """删除服务"""\n        try:\n            # 删除deployment\n            result = subprocess.run([\n                "kubectl", "delete", "deployment", name, "-n", namespace\n            ], capture_output=True, text=True)\n\n            # 删除service\n            result2 = subprocess.run([\n                "kubectl", "delete", "service", name, "-n", namespace\n            ], capture_output=True, text=True)\n\n            if result.returncode == 0 and result2.returncode == 0:\n                with self._lock:\n                    if name in self.deployments:\n                        del self.deployments[name]\n                    if name in self.services:\n                        del self.services[name]\n                logger.info(f"服务 {name} 删除成功")\n                return True\n            else:\n                logger.error(f"服务 {name} 删除失败")\n                return False\n        except Exception as e:\n            logger.error(f"删除服务 {name} 时发生错误: {e}")\n            return False\n\n    def get_service_status(self, name: str, namespace: str = "default") -> Optional[str]:\n    """文档字符串"""\n\n        """获取服务状态"""\n        try:\n            result = subprocess.run([\n                "kubectl", "get", "deployment", name,\n                "-n", namespace, "-o", "jsonpath={.status.conditions[0].type}"\n            ], capture_output=True, text=True)\n            if result.returncode == 0:\n                return result.stdout.strip()\n            return None\n        except Exception as e:\n            logger.error(f"获取服务 {name} 状态时发生错误: {e}")\n            return None\n\nclass MicroserviceTestRunner:\n\n    """微服务测试运行器"""\n\n    def __init__(self, platform_type: PlatformType):\n\n        self.platform_type = platform_type\n        self.test_results: List[TestResult] = []\n        self._lock = threading.Lock()\n\n    def run_health_check(self, service_name: str, endpoint: str) -> TestResult:\n    """文档字符串"""\n\n        """运行健康检查测试"""\n        start_time = time.time()\n        test_id = f"health_check_{service_name}_{int(time.time())}"\n\n        try:\n            response = requests.get(endpoint, timeout=30)\n            duration = time.time() - start_time\n\n            if response.status_code == 200:\n                status = "passed"\n                error_message = None\n            else:\n                status = "failed"\n                error_message = f"HTTP {response.status_code}: {response.text}"\n\n            result = TestResult(\n                test_id=test_id,\n                service_name=service_name,\n                environment=TestEnvironment.INTEGRATION,\n                status=status,\n                duration=duration,\n                error_message=error_message,\n                metrics={\n                    "status_code": response.status_code,\n                    "response_time": duration,\n                    "content_length": len(response.content)\n                }\n            )\n\n            with self._lock:\n                self.test_results.append(result)\n\n            return result\n\n        except Exception as e:\n            duration = time.time() - start_time\n            result = TestResult(\n                test_id=test_id,\n                service_name=service_name,\n                environment=TestEnvironment.INTEGRATION,\n                status="failed",\n                duration=duration,\n                error_message=str(e),\n                metrics={"error_type": type(e).__name__}\n            )\n\n            with self._lock:\n                self.test_results.append(result)\n\n            return result\n\n    def run_load_test(self, service_name: str, endpoint: str, concurrent_users: int = 10, duration: int = 60):\n    """文档字符串"""\n\n        """运行负载测试"""\n        results = []\n        start_time = time.time()\n\n        def single_request():\n    """文档字符串"""\n\n            request_start = time.time()\n            try:\n                response = requests.get(endpoint, timeout=30)\n                request_duration = time.time() - request_start\n\n                result = TestResult(\n                    test_id=f"load_test_{service_name}_{int(time.time() * 1000)}",\n                    service_name=service_name,\n                    environment=TestEnvironment.INTEGRATION,\n                    status="passed" if response.status_code == 200 else "failed",\n                    duration=request_duration,\n                    error_message=None if response.status_code == 200 else f"HTTP {response.status_code}",\n                    metrics={\n                        "status_code": response.status_code,\n                        "response_time": request_duration\n                    }\n                )\n                return result\n            except Exception as e:\n                request_duration = time.time() - request_start\n                result = TestResult(\n                    test_id=f"load_test_{service_name}_{int(time.time() * 1000)}",\n                    service_name=service_name,\n                    environment=TestEnvironment.INTEGRATION,\n                    status="failed",\n                    duration=request_duration,\n                    error_message=str(e),\n                    metrics={"error_type": type(e).__name__}\n                )\n                return result\n\n        # 使用线程池执行并发请求\n        with ThreadPoolExecutor(max_workers=concurrent_users) as executor:\n            futures = []\n            end_time = start_time + duration\n\n            while time.time() < end_time:\n                futures.append(executor.submit(single_request))\n                time.sleep(1)  # 每秒发送一个请求\n\n            # 收集结果\n            for future in as_completed(futures):\n                try:\n                    result = future.result()\n                    results.append(result)\n                except Exception as e:\n                    logger.error(f"负载测试请求执行失败: {e}")\n\n        with self._lock:\n            self.test_results.extend(results)\n\n        return results\n\n    def run_integration_test(self, services: List[str], test_script: str) -> TestResult:\n    """文档字符串"""\n\n        """运行集成测试"""\n        start_time = time.time()\n        test_id = f"integration_test_{int(time.time())}"\n\n        try:\n            # 这里可以集成实际的测试框架，如pytest\n            # 目前使用模拟执行\n            result = subprocess.run([test_script], capture_output=True, text=False, encoding=None, timeout=300)\n\n            # Handle encoding conversion\n            if result.stdout:\n                try:\n                    result.stdout = result.stdout.decode(sys.getdefaultencoding())\n                except UnicodeDecodeError:\n                    result.stdout = result.stdout.decode('latin-1', errors='replace')\n            if result.stderr:\n                try:\n                    result.stderr = result.stderr.decode(sys.getdefaultencoding())\n                except UnicodeDecodeError:\n                    result.stderr = result.stderr.decode('latin-1', errors='replace')\n            duration = time.time() - start_time\n\n            if result.returncode == 0:\n                status = "passed"\n                error_message = None\n            else:\n                status = "failed"\n                error_message = result.stderr\n\n            test_result = TestResult(\n                test_id=test_id,\n                service_name=",".join(services),\n                environment=TestEnvironment.INTEGRATION,\n                status=status,\n                duration=duration,\n                error_message=error_message,\n                metrics={\n                    "return_code": result.returncode,\n                    "stdout_length": len(result.stdout),\n                    "stderr_length": len(result.stderr)\n                }\n            )\n\n            with self._lock:\n                self.test_results.append(test_result)\n\n            return test_result\n\n        except Exception as e:\n            duration = time.time() - start_time\n            test_result = TestResult(\n                test_id=test_id,\n                service_name=",".join(services),\n                environment=TestEnvironment.INTEGRATION,\n                status="failed",\n                duration=duration,\n                error_message=str(e),\n                metrics={"error_type": type(e).__name__}\n            )\n\n            with self._lock:\n                self.test_results.append(test_result)\n\n            return test_result\n\n    def get_test_results(self, service_name: str = None) -> List[TestResult]:\n    """文档字符串"""\n\n        """获取测试结果"""\n        with self._lock:\n            if service_name:\n                return [r for r in self.test_results if r.service_name == service_name]\n            return self.test_results.copy()\n\nclass CloudNativeTestPlatform:\n\n    """云原生测试平台主类"""\n\n    def __init__(self, platform_type: PlatformType = PlatformType.DOCKER):\n\n        self.platform_type = platform_type\n        self.container_manager = ContainerManager()\n        self.kubernetes_manager = KubernetesManager()\n        self.test_runner = MicroserviceTestRunner(platform_type)\n        self.services: Dict[str, ServiceInfo] = {}\n        self._lock = threading.Lock()\n\n    def deploy_service(self, name: str, container_config: ContainerConfig, kubernetes_config: Optional[KubernetesConfig] = None):\n    """文档字符串"""\n\n        """部署服务"""\n        try:\n            if self.platform_type == PlatformType.DOCKER:\n                success = self.container_manager.create_container(name, container_config)\n                if success:\n                    success = self.container_manager.start_container(name)\n                if success:\n                    with self._lock:\n                        self.services[name] = ServiceInfo(\n                            name=name,\n                            platform_type=self.platform_type,\n                            status=ServiceStatus.RUNNING,\n                            container_config=container_config,\n                            endpoint=f"http://localhost:{list(container_config.ports.keys())[0] if container_config.ports else '8080'}"\n                        )\n                    return True\n                return False\n\n            elif self.platform_type == PlatformType.KUBERNETES:\n                if kubernetes_config is None:\n                    kubernetes_config = KubernetesConfig()\n\n                success = self.kubernetes_manager.deploy_service(name, kubernetes_config, container_config)\n                if success:\n                    with self._lock:\n                        self.services[name] = ServiceInfo(\n                            name=name,\n                            platform_type=self.platform_type,\n                            status=ServiceStatus.RUNNING,\n                            kubernetes_config=kubernetes_config,\n                            endpoint=f"http://{name}.{kubernetes_config.namespace}.svc.cluster.local"\n                        )\n                    return True\n                return False\n\n            return False\n\n        except Exception as e:\n            logger.error(f"部署服务 {name} 时发生错误: {e}")\n            return False\n\n    def run_tests(self, service_name: str, test_type: str = "health_check", **kwargs) -> Any:\n    """文档字符串"""\n\n        """运行测试"""\n        if service_name not in self.services:\n            raise ValueError(f"服务 {service_name} 不存在")\n\n        service = self.services[service_name]\n\n        if test_type == "health_check":\n            return self.test_runner.run_health_check(service_name, service.endpoint)\n        elif test_type == "load_test":\n            return self.test_runner.run_load_test(service_name, service.endpoint, **kwargs)\n        elif test_type == "integration_test":\n            return self.test_runner.run_integration_test([service_name], **kwargs.get("test_script", ""))\n        else:\n            raise ValueError(f"不支持的测试类型: {test_type}")\n\n    def get_service_info(self, name: str) -> Optional[ServiceInfo]:\n    """文档字符串"""\n\n        """获取服务信息"""\n        with self._lock:\n            return self.services.get(name)\n\n    def list_services(self) -> List[ServiceInfo]:\n    """文档字符串"""\n\n        """列出所有服务"""\n        with self._lock:\n            return list(self.services.values())\n\n    def remove_service(self, name: str) -> bool:\n    """文档字符串"""\n\n        """移除服务"""\n        try:\n            if name not in self.services:\n                return False\n\n            service = self.services[name]\n\n            if service.platform_type == PlatformType.DOCKER:\n                success = self.container_manager.remove_container(name)\n            elif service.platform_type == PlatformType.KUBERNETES:\n                namespace = service.kubernetes_config.namespace if service.kubernetes_config else "default"\n                success = self.kubernetes_manager.delete_service(name, namespace)\n            else:\n                success = False\n\n            if success:\n                with self._lock:\n                    del self.services[name]\n                return True\n\n            return False\n\n        except Exception as e:\n            logger.error(f"移除服务 {name} 时发生错误: {e}")\n            return False\n\n    def get_platform_status(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取平台状态"""\n        with self._lock:\n            return {\n                "platform_type": self.platform_type.value,\n                "total_services": len(self.services),\n                "running_services": len([s for s in self.services.values() if s.status == ServiceStatus.RUNNING]),\n                "failed_services": len([s for s in self.services.values() if s.status == ServiceStatus.FAILED]),\n                "total_tests": len(self.test_runner.get_test_results()),\n                "passed_tests": len([t for t in self.test_runner.get_test_results() if t.status == "passed"]),\n                "failed_tests": len([t for t in self.test_runner.get_test_results() if t.status == "failed"])\n            }\n# 便捷函数\n\ndef create_cloud_platform(platform_type: PlatformType = PlatformType.DOCKER) -> CloudNativeTestPlatform:\n    """文档字符串"""\n\n    """创建云原生测试平台实例"""\n    return CloudNativeTestPlatform(platform_type)\n\ndef deploy_microservice(name: str, image: str, ports: Dict[str, str], platform_type: PlatformType = PlatformType.DOCKER):\n    """文档字符串"""\n\n    """快速部署微服务"""\n    platform = create_cloud_platform(platform_type)\n    container_config = ContainerConfig(\n        image=image,\n        ports=ports,\n        environment={"ENV": "test"},\n        restart_policy="unless-stopped"\n    )\n\n    return platform.deploy_service(name, container_config)\n