"""\n基础设施层 - 日志系统组件\n\nmetrics_aggregator 模块\n\n日志系统相关的文件\n提供日志系统相关的功能实现。\n"""\n\n#!/usr/bin/env python3\nfrom ..interfaces.standard_interfaces import IMonitor\nfrom collections import defaultdict, deque\nfrom datetime import datetime, timedelta\nfrom enum import Enum\nfrom typing import Dict, Any, Optional, List, Tuple, Union\nimport json\nimport logging\nimport statistics\nimport threading\nimport time\n\nfrom dataclasses import dataclass, field\n\n# -*- coding: utf-8 -*-\n"""\nRQA2025 基础设施层 - 监控指标聚合器\n\n实现监控指标的聚合、统计和分析功能：\n- 指标聚合\n- 统计分析\n- 趋势分析\n- 告警聚合\n- 性能分析\n"""\n\nclass MetricType(Enum):\n\n    """指标类型"""\n    COUNTER = "counter"\n    GAUGE = "gauge"\n    HISTOGRAM = "histogram"\n    SUMMARY = "summary"\n\nclass AggregationType(Enum):\n\n    """聚合类型"""\n    SUM = "sum"\n    AVG = "avg"\n    MIN = "min"\n    MAX = "max"\n    COUNT = "count"\n    MEDIAN = "median"\n    PERCENTILE_95 = "percentile_95"\n    PERCENTILE_99 = "percentile_99"\n\n@dataclass\n\nclass MetricPoint:\n\n    """指标数据点"""\n    name: str\n    value: float\n    timestamp: datetime\n    tags: Dict[str, str] = field(default_factory=dict)\n    metric_type: MetricType = MetricType.GAUGE\n\n@dataclass\n\nclass AggregatedMetric:\n\n    """聚合指标"""\n    name: str\n    aggregation_type: AggregationType\n    value: float\n    timestamp: datetime\n    count: int\n    min_value: float\n    max_value: float\n    tags: Dict[str, str] = field(default_factory=dict)\n\n@dataclass\n\nclass AlertSummary:\n\n    """告警汇总"""\n    level: str\n    count: int\n    first_occurrence: datetime\n    last_occurrence: datetime\n    messages: List[str] = field(default_factory=list)\n\nclass MetricsAggregator:\n\n    """监控指标聚合器"""\n\n    def __init__(self, window_size: int = 3600, max_points: int = 10000):\n\n        """\n        初始化指标聚合器\n\n        Args:\n            window_size: 聚合窗口大小（秒）\n            max_points: 最大数据点数量\n        """\n        self.window_size = window_size\n        self.max_points = max_points\n        self.logger = logging.getLogger(__name__)\n        self._lock = threading.RLock()\n\n        # 指标数据存储\n        self._metrics: Dict[str, deque] = defaultdict(lambda: deque(maxlen=max_points))\n        self._alerts: Dict[str, List[Dict[str, Any]]] = defaultdict(list)\n\n        # 聚合缓存\n        self._aggregation_cache: Dict[str, AggregatedMetric] = {}\n        self._cache_timestamp = datetime.now()\n\n        # 统计信息\n        self._stats = {\n            'total_metrics': 0,\n            'total_alerts': 0,\n            'last_aggregation': None\n        }\n\n    def record_metric(self, name: str, value: float,\n    """文档字符串"""\n\n                      tags: Optional[Dict[str, str]] = None,\n                      metric_type: MetricType = MetricType.GAUGE):\n        """\n        记录指标\n\n        Args:\n            name: 指标名称\n            value: 指标值\n            tags: 标签\n            metric_type: 指标类型\n        """\n        with self._lock:\n            point = MetricPoint(\n                name=name,\n                value=value,\n                timestamp=datetime.now(),\n                tags=tags or {},\n                metric_type=metric_type\n            )\n\n            self._metrics[name].append(point)\n            self._stats['total_metrics'] += 1\n\n            # 清除过期缓存\n            self._clear_expired_cache()\n\n    def record_alert(self, level: str, message: str,\n    """文档字符串"""\n\n                     tags: Optional[Dict[str, str]] = None):\n        """\n        记录告警\n\n        Args:\n            level: 告警级别\n            message: 告警消息\n            tags: 标签\n        """\n        with self._lock:\n            alert = {\n                'level': level,\n                'message': message,\n                'timestamp': datetime.now(),\n                'tags': tags or {}\n            }\n\n            self._alerts[level].append(alert)\n            self._stats['total_alerts'] += 1\n\n    def aggregate_metrics(self, metric_name: str,\n    """文档字符串"""\n\n                          aggregation_type: AggregationType,\n                          window: Optional[timedelta] = None):\n        """\n        聚合指标\n\n        Args:\n            metric_name: 指标名称\n            aggregation_type: 聚合类型\n            window: 时间窗口\n\n        Returns:\n            聚合结果\n        """\n        with self._lock:\n            if metric_name not in self._metrics:\n                return None\n\n            # 确定时间窗口\n            if window is None:\n                window = timedelta(seconds=self.window_size)\n\n            cutoff_time = datetime.now() - window\n            points = [p for p in self._metrics[metric_name]\n                      if p.timestamp >= cutoff_time]\n            if not points:\n                return None\n\n            values = [p.value for p in points]\n\n            # 计算聚合值\n            if aggregation_type == AggregationType.SUM:\n                agg_value = sum(values)\n            elif aggregation_type == AggregationType.AVG:\n                agg_value = statistics.mean(values)\n            elif aggregation_type == AggregationType.MIN:\n                agg_value = min(values)\n            elif aggregation_type == AggregationType.MAX:\n                agg_value = max(values)\n            elif aggregation_type == AggregationType.COUNT:\n                agg_value = len(values)\n            elif aggregation_type == AggregationType.MEDIAN:\n                agg_value = statistics.median(values)\n            elif aggregation_type == AggregationType.PERCENTILE_95:\n                agg_value = statistics.quantiles(values, n=20)[18] if len(values) > 1 else values[0]\n            elif aggregation_type == AggregationType.PERCENTILE_99:\n                agg_value = statistics.quantiles(values, n=100)[98] if len(values) > 1 else values[0]\n            else:\n                agg_value = statistics.mean(values)\n\n            result = AggregatedMetric(\n                name=metric_name,\n                aggregation_type=aggregation_type,\n                value=agg_value,\n                timestamp=datetime.now(),\n                count=len(points),\n                min_value=min(values),\n                max_value=max(values),\n                tags=points[0].tags if points else {}\n            )\n\n            # 缓存结果\n            cache_key = f"{metric_name}_{aggregation_type.value}"\n            self._aggregation_cache[cache_key] = result\n\n            return result\n\n    def get_metric_summary(self, metric_name: str) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取指标摘要\n\n        Args:\n            metric_name: 指标名称\n\n        Returns:\n            指标摘要\n        """\n        with self._lock:\n            if metric_name not in self._metrics:\n                return {}\n\n            points = list(self._metrics[metric_name])\n            if not points:\n                return {}\n\n            values = [p.value for p in points]\n            recent_points = [p for p in points\n                             if p.timestamp >= datetime.now() - timedelta(minutes=5)]\n\n            return {\n                'name': metric_name,\n                'total_points': len(points),\n                'recent_points': len(recent_points),\n                'current_value': values[-1] if values else None,\n                'min_value': min(values) if values else None,\n                'max_value': max(values) if values else None,\n                'avg_value': statistics.mean(values) if values else None,\n                'median_value': statistics.median(values) if values else None,\n                'last_update': points[-1].timestamp if points else None,\n                'tags': points[-1].tags if points else {}\n            }\n\n    def get_alert_summary(self, level: Optional[str] = None) -> Dict[str, AlertSummary]:\n    """文档字符串"""\n\n        """\n        获取告警摘要\n\n        Args:\n            level: 告警级别（可选）\n\n        Returns:\n            告警摘要\n        """\n        with self._lock:\n            summaries = {}\n\n            if level:\n                alert_levels = [level]\n            else:\n                alert_levels = list(self._alerts.keys())\n\n            for alert_level in alert_levels:\n                if alert_level not in self._alerts:\n                    continue\n\n                alerts = self._alerts[alert_level]\n                if not alerts:\n                    continue\n\n                # 获取最近1小时的告警\n                cutoff_time = datetime.now() - timedelta(hours=1)\n                recent_alerts = [a for a in alerts if a['timestamp'] >= cutoff_time]\n\n                if recent_alerts:\n                    summary = AlertSummary(\n                        level=alert_level,\n                        count=len(recent_alerts),\n                        first_occurrence=min(a['timestamp'] for a in recent_alerts),\n                        last_occurrence=max(a['timestamp'] for a in recent_alerts),\n                        messages=[a['message'] for a in recent_alerts[-5:]]  # 最近5条消息\n                    )\n\n                    summaries[alert_level] = summary\n\n            return summaries\n\n    def get_performance_trends(self, metric_name: str,\n    """文档字符串"""\n\n                               window: timedelta = timedelta(hours=1)):\n        """\n        获取性能趋势\n\n        Args:\n            metric_name: 指标名称\n            window: 时间窗口\n\n        Returns:\n            趋势分析结果\n        """\n        with self._lock:\n            if metric_name not in self._metrics:\n                return {}\n\n            cutoff_time = datetime.now() - window\n            points = [p for p in self._metrics[metric_name]\n                      if p.timestamp >= cutoff_time]\n            if len(points) < 2:\n                return {}\n\n            # 按时间排序\n            points.sort(key=lambda p: p.timestamp)\n\n            # 计算趋势\n            values = [p.value for p in points]\n            timestamps = [p.timestamp for p in points]\n\n            # 简单线性回归\n            n = len(values)\n            if n > 1:\n                x_mean = sum(range(n)) / n\n                y_mean = sum(values) / n\n\n                numerator = sum((i - x_mean) * (values[i] - y_mean) for i in range(n))\n                denominator = sum((i - x_mean) ** 2 for i in range(n))\n\n                if denominator != 0:\n                    slope = numerator / denominator\n                    trend = "increasing" if slope > 0 else "decreasing" if slope < 0 else "stable"\n                else:\n                    trend = "stable"\n            else:\n                trend = "stable"\n\n            return {\n                'metric_name': metric_name,\n                'trend': trend,\n                'data_points': len(points),\n                'time_range': {\n                    'start': timestamps[0],\n                    'end': timestamps[-1]\n                },\n                'statistics': {\n                    'min': min(values),\n                    'max': max(values),\n                    'avg': statistics.mean(values),\n                    'median': statistics.median(values)\n                },\n                'recent_values': values[-10:] if len(values) >= 10 else values\n            }\n\n    def get_system_health_score(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取系统健康评分\n\n        Returns:\n            健康评分\n        """\n        with self._lock:\n            # 计算各种指标的健康度\n            health_scores = {}\n            total_score = 0\n            total_weight = 0\n\n            # 检查告警密度\n            alert_summary = self.get_alert_summary()\n            alert_score = 100\n            for level, summary in alert_summary.items():\n                if level == 'critical':\n                    alert_score -= summary.count * 20\n                elif level == 'error':\n                    alert_score -= summary.count * 10\n                elif level == 'warning':\n                    alert_score -= summary.count * 5\n\n            alert_score = max(0, alert_score)\n            health_scores['alerts'] = alert_score\n            total_score += alert_score * 0.4  # 40 % 权重\n            total_weight += 0.4\n\n            # 检查指标稳定性\n            stability_score = 100\n            for metric_name in list(self._metrics.keys())[:5]:  # 检查前5个指标\n                trend = self.get_performance_trends(metric_name)\n                if trend and trend.get('trend') == 'increasing':\n                    stability_score -= 10\n\n            stability_score = max(0, stability_score)\n            health_scores['stability'] = stability_score\n            total_score += stability_score * 0.3  # 30 % 权重\n            total_weight += 0.3\n\n            # 检查数据完整性\n            data_score = 100\n            total_metrics = sum(len(points) for points in self._metrics.values())\n            if total_metrics < 100:\n                data_score -= (100 - total_metrics) * 0.5\n\n            data_score = max(0, data_score)\n            health_scores['data_integrity'] = data_score\n            total_score += data_score * 0.3  # 30 % 权重\n            total_weight += 0.3\n\n            overall_score = total_score / total_weight if total_weight > 0 else 0\n\n            return {\n                'overall_score': round(overall_score, 2),\n                'component_scores': health_scores,\n                'timestamp': datetime.now(),\n                'total_metrics': self._stats['total_metrics'],\n                'total_alerts': self._stats['total_alerts']\n            }\n\n    def export_metrics(self, format_type: str = 'json') -> str:\n    """文档字符串"""\n\n        """\n        导出指标数据\n\n        Args:\n            format_type: 导出格式\n\n        Returns:\n            导出的数据\n        """\n        with self._lock:\n            export_data = {\n                'timestamp': datetime.now().isoformat(),\n                'metrics': {},\n                'alerts': {},\n                'statistics': self._stats\n            }\n\n            # 导出指标数据\n            for metric_name, points in self._metrics.items():\n                export_data['metrics'][metric_name] = [\n                    {\n                        'value': p.value,\n                        'timestamp': p.timestamp.isoformat(),\n                        'tags': p.tags,\n                        'type': p.metric_type.value\n                    }\n                    for p in list(points)[-100:]  # 最近100个点\n                ]\n\n            # 导出告警数据\n            for level, alerts in self._alerts.items():\n                export_data['alerts'][level] = [\n                    {\n                        'message': a['message'],\n                        'timestamp': a['timestamp'].isoformat(),\n                        'tags': a['tags']\n                    }\n                    for a in alerts[-50:]  # 最近50条告警\n                ]\n\n            if format_type == 'json':\n                return json.dumps(export_data, indent=2, default=str)\n            else:\n                return str(export_data)\n\n    def clear_old_data(self, max_age: timedelta = timedelta(hours=24)) -> int:\n    """文档字符串"""\n\n        """\n        清理旧数据\n\n        Args:\n            max_age: 最大保留时间\n\n        Returns:\n            清理的数据点数量\n        """\n        with self._lock:\n            cutoff_time = datetime.now() - max_age\n            cleared_count = 0\n\n            # 清理指标数据\n            for metric_name in list(self._metrics.keys()):\n                points = self._metrics[metric_name]\n                original_count = len(points)\n\n                # 移除过期数据点\n                while points and points[0].timestamp < cutoff_time:\n                    points.popleft()\n\n                cleared_count += original_count - len(points)\n\n            # 清理告警数据\n            for level in list(self._alerts.keys()):\n                alerts = self._alerts[level]\n                original_count = len(alerts)\n\n                # 移除过期告警\n                self._alerts[level] = [\n                    a for a in alerts if a['timestamp'] >= cutoff_time\n                ]\n\n                cleared_count += original_count - len(self._alerts[level])\n\n            self.logger.info(f"清理了 {cleared_count} 个过期数据点")\n            return cleared_count\n\n    def _clear_expired_cache(self):\n    """文档字符串"""\n\n        """清理过期缓存"""\n        cache_age = datetime.now() - self._cache_timestamp\n        if cache_age > timedelta(minutes=5):\n            self._aggregation_cache.clear()\n            self._cache_timestamp = datetime.now()\n\n    def get_status(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取状态信息"""\n        with self._lock:\n            return {\n                'total_metrics': self._stats['total_metrics'],\n                'total_alerts': self._stats['total_alerts'],\n                'metric_count': len(self._metrics),\n                'alert_levels': list(self._alerts.keys()),\n                'cache_size': len(self._aggregation_cache),\n                'last_aggregation': self._stats['last_aggregation']\n            }\n\ndef create_metrics_aggregator(window_size: int = 3600,\n    """文档字符串"""\n\n                              max_points: int = 10000):\n    """创建指标聚合器"""\n    return MetricsAggregator(window_size, max_points)\n\ndef aggregate_monitor_metrics(monitor: IMonitor,\n    """文档字符串"""\n\n                              aggregator: MetricsAggregator):\n    """聚合监控器指标"""\n    try:\n        # 获取监控器摘要\n        if hasattr(monitor, 'get_summary'):\n            summary = monitor.get_summary()\n\n            # 记录关键指标\n            if 'metrics' in summary:\n                for metric_name, metric_data in summary['metrics'].items():\n                    if isinstance(metric_data, dict) and 'value' in metric_data:\n                        aggregator.record_metric(\n                            name=f"{monitor.__class__.__name__}_{metric_name}",\n                            value=metric_data['value'],\n                            tags={'monitor_type': monitor.__class__.__name__}\n                        )\n\n            # 记录告警\n            if 'alerts' in summary:\n                for alert in summary['alerts']:\n                    aggregator.record_alert(\n                        level=alert.get('level', 'info'),\n                        message=alert.get('message', ''),\n                        tags={'monitor_type': monitor.__class__.__name__}\n                    )\n    except Exception as e:\n        logging.getLogger(__name__).error(f"聚合监控器指标失败: {str(e)}")\n