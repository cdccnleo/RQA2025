"""\n统一日志器模块\n提供统一的日志接口和实现\n"""\n\nfrom datetime import datetime\nfrom enum import Enum\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional, Union, List\nimport datetime as dt\nimport json\nimport logging\nimport os\nimport sys\nimport threading\nimport time\n\nclass LogLevel(Enum):\n\n    """\n    unified_logger - Log System\n\n    Responsibilities:\n    Handle system logging, log formatting, log storage and log analysis\n\n    Core responsibilities:\n    - Log recording and formatting\n    - Log level management\n    - Log storage and rotation\n    - Log analysis and monitoring\n    - Log search and filtering\n    - Log performance optimization\n\n    Related interfaces:\n    - ILoggingComponent\n    - ILogger\n    - ILogHandler\n    """\n\n    # Log levels\n    DEBUG = logging.DEBUG\n    INFO = logging.INFO\n    WARNING = logging.WARNING\n    ERROR = logging.ERROR\n    CRITICAL = logging.CRITICAL\n\nclass UnifiedLogFormatter(logging.Formatter):\n\n    """\n    统一日志格式化器 - 标准化日志输出格式\n\n    统一格式：\n    [YYYY - MM - DD HH:mm:ss.SSS] [LEVEL] [COMPONENT] [THREAD] MESSAGE\n    """\n\n    def __init__(self):\n\n        super().__init__()\n        # ANSI颜色代码用于控制台彩色输出\n        self.colors = {\n            'DEBUG': '\033[36m',     # 青色\n            'INFO': '\033[32m',      # 绿色\n            'WARNING': '\033[33m',   # 黄色\n            'ERROR': '\033[31m',     # 红色\n            'CRITICAL': '\033[35m',  # 紫色\n            'RESET': '\033[0m'       # 重置\n        }\n\n    def format(self, record: logging.LogRecord) -> str:\n    """文档字符串"""\n\n        """格式化日志记录"""\n        try:\n            # 获取当前时间（毫秒精度）\n            import time\n            current_time = time.time()\n            time_struct = time.localtime(current_time)\n            milliseconds = int((current_time - int(current_time)) * 1000)\n\n            # 格式化时间戳\n            timestamp = time.strftime('%Y-%m-%d %H:%M:%S', time_struct)\n            timestamp = f"{timestamp}.{milliseconds:03d}"\n\n            # 获取组件名称（从logger名称中提取）\n            component = record.name.split('.')[-1] if '.' in record.name else record.name\n\n            # 获取线程名称\n            thread_name = getattr(record, 'threadName', 'MainThread')[:10]\n\n            # 构建统一格式\n            level_name = record.levelname\n            message = record.getMessage()\n\n            # 控制台格式（带颜色）\n            if hasattr(record, 'is_console') and record.is_console:\n                color = self.colors.get(level_name, self.colors['RESET'])\n                reset = self.colors['RESET']\n                formatted = f"[{timestamp}] [{color}{level_name}{reset}] [{component}] [{thread_name}] {message}"\n            else:\n                # 文件格式（无颜色）\n                formatted = f"[{timestamp}] [{level_name}] [{component}] [{thread_name}] {message}"\n\n            # 添加异常信息\n            if record.exc_info:\n                formatted += f"\n{self.formatException(record.exc_info)}"\n\n            return formatted\n\n        except Exception as e:\n            # 如果格式化失败，使用简单格式\n            return f"[{time.strftime('%Y-%m-%d %H:%M:%S')}] [ERROR] [FORMATTER] 格式化失败: {str(e)} - 原始消息: {record.getMessage()}"\n\nclass StructuredLogFormatter(logging.Formatter):\n\n    """\n    结构化日志格式化器 - JSON格式\n\n    用于日志分析和监控系统，支持结构化数据输出\n    """\n\n    def format(self, record: logging.LogRecord) -> str:\n    """文档字符串"""\n\n        """格式化为JSON格式"""\n        try:\n            current_time = time.time()\n\n            # 构建结构化日志数据\n            log_data = {\n                'timestamp': current_time,\n                'timestamp_iso': datetime.fromtimestamp(current_time).isoformat(),\n                'level': record.levelname,\n                'level_no': record.levelno,\n                'component': record.name.split('.')[-1] if '.' in record.name else record.name,\n                'thread': getattr(record, 'threadName', 'MainThread'),\n                'process': getattr(record, 'processName', 'MainProcess'),\n                'message': record.getMessage(),\n                'pathname': record.pathname,\n                'lineno': record.lineno,\n                'funcName': record.funcName\n            }\n\n            # 添加异常信息\n            if record.exc_info:\n                log_data['exception'] = self.formatException(record.exc_info)\n\n            # 添加额外字段\n            if hasattr(record, 'extra_data') and record.extra_data:\n                log_data.update(record.extra_data)\n\n            return json.dumps(log_data, ensure_ascii=False)\n\n        except Exception as e:\n            # 如果JSON格式化失败，回退到简单格式\n            return f'{{"timestamp": {time.time()}, "level": "ERROR", "component": "FORMATTER", "message": "JSON格式化失败: {str(e)}", "original": "{record.getMessage()}"}}'\n\nclass UnifiedLogger:\n\n    """统一日志器"""\n\n    def __init__(self, name: str = "RQA2025", level: LogLevel = LogLevel.INFO):\n\n        self.name = name\n        self.level = level\n        self.logger = logging.getLogger(name)\n        self.logger.setLevel(level.value)\n\n        # 日志器缓存\n        self._loggers = {}\n        self._default_level = level\n        self._format = '%(asctime)s - %(name)s - %(levelname)s - %(message)s'\n\n        # 设置默认处理器\n        if not self.logger.handlers:\n            self._setup_default_handlers()\n\n        # 线程安全\n        self._lock = threading.Lock()\n\n    def _setup_default_handlers(self) -> None:\n    """文档字符串"""\n\n        """设置默认处理器"""\n        # 控制台处理器\n        console_handler = logging.StreamHandler(sys.stdout)\n        console_handler.setLevel(self.level.value)\n\n        # 文件处理器\n        log_dir = Path("logs")\n        log_dir.mkdir(exist_ok=True)\n        file_handler = logging.FileHandler(\n            log_dir / f"{self.name}.log",\n            encoding='utf - 8'\n        )\n\n        file_handler.setLevel(self.level.value)\n\n        # 控制台格式化器（带颜色）\n        console_formatter = UnifiedLogFormatter()\n        console_handler.setFormatter(console_formatter)\n\n        # 文件格式化器（无颜色）\n        file_formatter = UnifiedLogFormatter()\n        file_handler.setFormatter(file_formatter)\n\n        # 为处理器添加标识\n        console_handler.is_console = True\n        file_handler.is_console = False\n\n        # 添加处理器\n        self.logger.addHandler(console_handler)\n        self.logger.addHandler(file_handler)\n\n    def debug(self, message: str, **kwargs) -> None:\n    """文档字符串"""\n\n        """调试日志"""\n        self.log(LogLevel.DEBUG, message, **kwargs)\n\n    def info(self, message: str, **kwargs) -> None:\n    """文档字符串"""\n\n        """信息日志"""\n        self.log(LogLevel.INFO, message, **kwargs)\n\n    def warning(self, message: str, **kwargs) -> None:\n    """文档字符串"""\n\n        """警告日志"""\n        self.log(LogLevel.WARNING, message, **kwargs)\n\n    def error(self, message: str, **kwargs) -> None:\n    """文档字符串"""\n\n        """错误日志"""\n        self.log(LogLevel.ERROR, message, **kwargs)\n\n    def critical(self, message: str, **kwargs) -> None:\n    """文档字符串"""\n\n        """严重错误日志"""\n        self.log(LogLevel.CRITICAL, message, **kwargs)\n\n    def log(self, level: LogLevel, message: str, **kwargs) -> None:\n    """文档字符串"""\n\n        """通用日志方法"""\n        with self._lock:\n            # 检查logger是否已被禁用\n            if getattr(self.logger, 'disabled', False):\n                return\n\n            if kwargs:\n                # 格式化额外参数\n                extra_info = " ".join([f"{k}={v}" for k, v in kwargs.items()])\n                message = f"{message} | {extra_info}"\n\n            self.logger.log(level.value, message)\n\n    def set_context(self, context: Any) -> None:\n        """设置日志上下文"""\n        # 将上下文信息存储为实例属性\n        self.context = context\n\n        # 在logger中设置extra信息以供格式化器使用\n        if hasattr(context, 'to_dict'):\n            context_dict = context.to_dict()\n        else:\n            context_dict = {'context': str(context)}\n\n        # 设置logger的默认extra信息\n        self.logger = logging.LoggerAdapter(self.logger, context_dict)\n\n    def set_level(self, level: LogLevel) -> None:\n    """文档字符串"""\n\n        """设置日志级别"""\n        with self._lock:\n            self.level = level\n            self.logger.setLevel(level.value)\n            for handler in self.logger.handlers:\n                handler.setLevel(level.value)\n\n    def get_level(self) -> LogLevel:\n    """文档字符串"""\n\n        """获取日志级别"""\n        return self.level\n\n    def get_logger(self, name: str) -> logging.Logger:\n    """文档字符串"""\n\n        """获取或创建日志器实例"""\n        if name not in self._loggers:\n            self._loggers[name] = logging.getLogger(name)\n            self._loggers[name].setLevel(self.level.value)\n\n            # 如果没有处理器，添加默认处理器\n            if not self._loggers[name].handlers:\n                # 使用相同的格式化器\n                console_handler = logging.StreamHandler(sys.stdout)\n                console_handler.setLevel(self.level.value)\n                console_formatter = UnifiedLogFormatter()\n                console_handler.setFormatter(console_formatter)\n                console_handler.is_console = True\n                self._loggers[name].addHandler(console_handler)\n\n        return self._loggers[name]\n\n    def add_handler(self, handler: logging.Handler) -> None:\n    """文档字符串"""\n\n        """添加处理器"""\n        with self._lock:\n            self.logger.addHandler(handler)\n\n    def remove_handler(self, handler: logging.Handler) -> None:\n    """文档字符串"""\n\n        """移除处理器"""\n        with self._lock:\n            self.logger.removeHandler(handler)\n\n    def get_handlers(self) -> List[logging.Handler]:\n    """文档字符串"""\n\n        """获取所有处理器"""\n        return self.logger.handlers.copy()\n\n    def clear_handlers(self) -> None:\n    """文档字符串"""\n\n        """清空所有处理器"""\n        with self._lock:\n            for handler in self.logger.handlers[:]:\n                self.logger.removeHandler(handler)\n\n    def log_structured(self, level: LogLevel, message: str, **kwargs) -> None:\n    """文档字符串"""\n\n        """结构化日志"""\n        with self._lock:\n            log_data = {\n                "message": message,\n                "timestamp": datetime.now().isoformat(),\n                "level": level.name,\n                "logger": self.name,\n                "context": kwargs\n            }\n\n            structured_message = json.dumps(log_data, ensure_ascii=False)\n            self.logger.log(level.value, structured_message)\n\n    def log_performance(self, operation: str, duration: float, **kwargs) -> None:\n    """文档字符串"""\n\n        """性能日志"""\n        self.info(\n            f"Performance: {operation}",\n            duration=f"{duration:.3f}s",\n            **kwargs\n        )\n\n    def log_error_with_context(self, error: Exception, context: Dict[str, Any] = None) -> None:\n    """文档字符串"""\n\n        """带上下文的错误日志"""\n        error_data = {\n            "error_type": type(error).__name__,\n            "error_message": str(error),\n            "context": context or {}\n        }\n\n        self.error(\n            f"Exception occurred: {error}",\n            **error_data\n        )\n\n    def log_business_event(self, event_type: str, event_data: Dict[str, Any]) -> None:\n    """文档字符串"""\n\n        """业务事件日志"""\n        self.info(\n            f"Business Event: {event_type}",\n            event_type=event_type,\n            **event_data\n        )\n\n    def log_security_event(self, event_type: str, user_id: str = None, **kwargs) -> None:\n    """文档字符串"""\n\n        """安全事件日志"""\n        self.warning(\n            f"Security Event: {event_type}",\n            event_type=event_type,\n            user_id=user_id,\n            **kwargs\n        )\n\n    def log_data_operation(self, operation: str, table: str, record_count: int = None, **kwargs) -> None:\n    """文档字符串"""\n\n        """数据操作日志"""\n        self.info(\n            f"Data Operation: {operation} on {table}",\n            operation=operation,\n            table=table,\n            record_count=record_count,\n            **kwargs\n        )\n\n    def log_trading_event(self, event_type: str, symbol: str = None, **kwargs) -> None:\n    """文档字符串"""\n\n        """交易事件日志"""\n        self.info(\n            f"Trading Event: {event_type}",\n            event_type=event_type,\n            symbol=symbol,\n            **kwargs\n        )\n\n    def get_log_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取日志统计信息"""\n        return {\n            "logger_name": self.name,\n            "log_level": self.level.name,\n            "handler_count": len(self.logger.handlers),\n            "handlers": [type(h).__name__ for h in self.logger.handlers]\n        }\n\n    def shutdown(self) -> None:\n        """关闭日志器，清理资源"""\n        with self._lock:\n            # 移除所有处理器\n            for handler in self.logger.handlers[:]:\n                handler.close()\n                self.logger.removeHandler(handler)\n\n            # 完全禁用logger，防止后续日志记录\n            self.logger.disabled = True\n\n    # 兼容性方法\n    def setLevel(self, level: Union[int, LogLevel]) -> None:\n        """设置日志级别（兼容标准logging接口）"""\n        if isinstance(level, LogLevel):\n            level = level.value\n        self.set_level(LogLevel(level))\n\n    def addHandler(self, handler: logging.Handler) -> None:\n        """添加处理器（兼容标准logging接口）"""\n        self.add_handler(handler)\n\n    def removeHandler(self, handler: logging.Handler) -> None:\n        """移除处理器（兼容标准logging接口）"""\n        self.remove_handler(handler)\n\n    def addFilter(self, filter_obj) -> None:\n        """添加过滤器（兼容接口）"""\n        with self._lock:\n            self.logger.addFilter(filter_obj)\n\n# 全局日志器实例\n_global_logger = None\n\ndef get_logger(name: str = "RQA2025", level: LogLevel = LogLevel.INFO) -> UnifiedLogger:\n    """文档字符串"""\n\n    """获取日志器实例"""\n    global _global_logger\n    if _global_logger is None:\n        _global_logger = UnifiedLogger(name, level)\n    return _global_logger\n\ndef set_global_logger(logger: UnifiedLogger) -> None:\n    """文档字符串"""\n\n    """设置全局日志器"""\n    global _global_logger\n    _global_logger = logger\n\ndef log_function_call(func_name: str, **kwargs):\n    """文档字符串"""\n\n    """函数调用日志装饰器"""\n\n    def decorator(func):\n    """文档字符串"""\n\n        def wrapper(*args, **func_kwargs):\n    """文档字符串"""\n\n            logger = get_logger()\n            logger.debug(f"Function call: {func_name}", **kwargs)\n            try:\n                result = func(*args, **func_kwargs)\n                logger.debug(f"Function completed: {func_name}")\n                return result\n            except Exception as e:\n                logger.error(f"Function error: {func_name}", error=str(e))\n                raise\n        return wrapper\n    return decorator\n\n# 全局日志器实例\n_unified_logger_instance: Optional[UnifiedLogger] = None\n_unified_logger_lock = threading.Lock()\n\ndef get_unified_logger(name: str = "RQA2025", level: LogLevel = LogLevel.INFO) -> UnifiedLogger:\n    """文档字符串"""\n\n    """\n    获取统一日志器实例\n\n    Args:\n        name: 日志器名称\n        level: 日志级别\n\n    Returns:\n        UnifiedLogger: 统一日志器实例\n    """\n    global _unified_logger_instance\n\n    with _unified_logger_lock:\n        if _unified_logger_instance is None:\n            _unified_logger_instance = UnifiedLogger(name=name, level=level)\n        return _unified_logger_instance\n