"""\n基础设施层 - 资源管理组件\n\nbusiness_metrics_monitor 模块\n\n资源管理相关的文件\n提供资源管理相关的功能实现。\n"""\n\n#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n业务指标监控器\n\n专门用于监控业务相关的指标，包括交易指标、模型性能、业务KPI等。\n"""\n\nfrom collections import defaultdict, deque\nfrom datetime import datetime, timedelta\nfrom typing import Dict, Any, Optional, List, Callable, Union, Tuple\nimport logging\nimport threading\nimport time\n\nfrom ..core.base_monitor import ResourceBaseMonitor\nfrom .monitoring_alert_system import AlertLevel\nfrom enum import Enum\n\nclass TradingMetricType(Enum):\n\n    """交易指标类型"""\n    VOLUME = "volume"           # 交易量\n    TURNOVER = "turnover"       # 成交额\n    PROFIT_LOSS = "profit_loss"  # 盈亏\n    WIN_RATE = "win_rate"       # 胜率\n    SHARPE_RATIO = "sharpe_ratio"  # 夏普比率\n    MAX_DRAWDOWN = "max_drawdown"  # 最大回撤\n    POSITION_SIZE = "position_size"  # 持仓规模\n    TRADE_COUNT = "trade_count"  # 交易次数\n\nclass ModelMetricType(Enum):\n\n    """模型指标类型"""\n    ACCURACY = "accuracy"       # 准确率\n    PRECISION = "precision"     # 精确率\n    RECALL = "recall"          # 召回率\n    F1_SCORE = "f1_score"      # F1分数\n    LATENCY = "latency"        # 延迟\n    THROUGHPUT = "throughput"  # 吞吐量\n    MEMORY_USAGE = "memory_usage"  # 内存使用\n    CPU_USAGE = "cpu_usage"    # CPU使用\n\nclass BusinessMetricType(Enum):\n\n    """业务指标类型"""\n    USER_ACTIVE = "user_active"     # 活跃用户\n    REVENUE = "revenue"             # 收入\n    COST = "cost"                   # 成本\n    PROFIT = "profit"               # 利润\n    CONVERSION_RATE = "conversion_rate"  # 转化率\n    RETENTION_RATE = "retention_rate"    # 留存率\n    CUSTOMER_SATISFACTION = "customer_satisfaction"  # 客户满意度\n\nclass BusinessMetricsMonitor(ResourceBaseMonitor):\n\n    """业务指标监控器"""\n\n    def __init__(self, config: Optional[Dict[str, Any]] = None,\n                 collection_interval: float = 60.0,\n                 max_history_size: int = 1000):\n\n        """\n        初始化业务指标监控器\n\n        Args:\n            config: 监控配置\n            collection_interval: 收集间隔（秒）\n            max_history_size: 历史记录最大大小\n        """\n        if config is None:\n            config = {}\n\n        # 添加参数到配置中\n        config.update({\n            'collection_interval': collection_interval,\n            'max_history_size': max_history_size\n        })\n\n        super().__init__(config)\n\n        # 设置实例属性供测试访问\n        self.collection_interval = collection_interval\n        self.max_history_size = max_history_size\n\n        # 线程锁\n        self._lock = threading.RLock()\n\n        # 业务指标存储\n        self._trading_metrics = defaultdict(list)\n        self._model_metrics = defaultdict(list)\n        self._business_metrics = defaultdict(list)\n\n        # 确保_metrics字典存在（从BaseMonitorComponent继承）\n        if not hasattr(self, '_metrics'):\n            self._metrics = {}\n\n        # 阈值配置\n        self._thresholds = config.get('thresholds', {}) if config else {}\n\n        # 告警规则\n        self._alert_rules = config.get('alert_rules', {}) if config else {}\n\n        # 最大指标数量限制\n        self._max_metrics = config.get('max_metrics', 10000) if config else 10000\n\n        # 初始化\n        self._initialize()\n        self.logger = logging.getLogger(__name__)\n\n    def record_metric(self, name, value: float, tags: Optional[Dict[str, str]] = None) -> None:\n        """\n        记录指标（重写基类方法以支持业务指标分类）\n\n        Args:\n            name: 指标名称（字符串或枚举）\n            value: 指标值\n            tags: 标签\n        """\n        # 处理枚举类型，直接记录到业务指标存储\n        if isinstance(name, TradingMetricType):\n            # 直接记录交易指标\n            strategy = tags.get('strategy', 'default') if tags else 'default'\n            # 直接记录到业务指标存储，避免递归\n            with self._lock:\n                key = f"{strategy}.{name.value}"\n                if key not in self._trading_metrics:\n                    self._trading_metrics[key] = []\n                self._trading_metrics[key].append({\n                    'value': value,\n                    'timestamp': datetime.now(),\n                    'tags': tags or {}\n                })\n                # 限制存储大小\n                if len(self._trading_metrics[key]) > self._max_metrics:\n                    self._trading_metrics[key] = self._trading_metrics[key][-self._max_metrics:]\n\n                # 检查告警规则\n                self._check_alerts(name.value, value, tags)\n            return\n        elif isinstance(name, ModelMetricType):\n            # 直接记录模型指标\n            model = tags.get('model', 'default') if tags else 'default'\n            # 直接记录到业务指标存储，避免递归\n            with self._lock:\n                key = f"{model}.{name.value}"\n                if key not in self._model_metrics:\n                    self._model_metrics[key] = []\n                self._model_metrics[key].append({\n                    'value': value,\n                    'timestamp': datetime.now(),\n                    'tags': tags or {}\n                })\n                # 限制存储大小\n                if len(self._model_metrics[key]) > self._max_metrics:\n                    self._model_metrics[key] = self._model_metrics[key][-self._max_metrics:]\n            return\n\n        # 处理字符串名称\n        name_str = str(name)\n\n        # 调用父类方法记录到通用指标存储\n        super().record_metric(name_str, value, tags)\n\n    def get_metric_stats(self, metric_name) -> Dict[str, Any]:\n        """\n        获取指标统计信息\n\n        Args:\n            metric_name: 指标名称（字符串或枚举）\n\n        Returns:\n            Dict: 统计信息\n        """\n        # 调用自己的get_metric方法\n        metrics = self.get_metric(metric_name)\n        if not metrics:\n            return {}\n\n        values = [m['value'] for m in metrics]\n        return {\n            'count': len(values),\n            'min': min(values) if values else 0,\n            'max': max(values) if values else 0,\n            'avg': sum(values) / len(values) if values else 0,\n            'mean': sum(values) / len(values) if values else 0\n        }\n\n    def set_alert_rule(self, metric_name: str, threshold: float, condition: str, alert_handler: Callable) -> None:\n        """\n        设置告警规则\n\n        Args:\n            metric_name: 指标名称\n            threshold: 阈值\n            condition: 条件 ('above', 'below', 'equals')\n            alert_handler: 告警处理器\n        """\n        if not hasattr(self, '_alert_rules'):\n            self._alert_rules = {}\n\n        self._alert_rules[metric_name] = {\n            'threshold': threshold,\n            'condition': condition,\n            'handler': alert_handler\n        }\n\n    def get_metric(self, metric_name):\n        """\n        获取指标数据（重写基类方法以支持枚举类型）\n\n        Args:\n            metric_name: 指标名称（字符串或枚举）\n\n        Returns:\n            List[Dict]: 指标数据列表\n        """\n        # 处理枚举类型\n        if isinstance(metric_name, TradingMetricType):\n            # 查找所有匹配的交易指标数据\n            result = []\n            for key, data_list in self._trading_metrics.items():\n                if key.endswith(f".{metric_name.value}"):\n                    result.extend(data_list)\n            return result\n        elif isinstance(metric_name, ModelMetricType):\n            # 查找所有匹配的模型指标数据\n            result = []\n            for key, data_list in self._model_metrics.items():\n                if key.endswith(f".{metric_name.value}"):\n                    result.extend(data_list)\n            return result\n\n        # 处理字符串名称\n        return super().get_metrics(str(metric_name))\n\n    def get_all_metrics(self):\n        """\n        获取所有指标数据\n\n        Returns:\n            Dict: 包含所有指标数据的字典\n        """\n        result = {\n            'trading_metrics': dict(self._trading_metrics),\n            'model_metrics': dict(self._model_metrics),\n            'business_metrics': dict(self._business_metrics)\n        }\n\n        # 也包含通用指标\n        if hasattr(self, '_metrics'):\n            result['general_metrics'] = dict(self._metrics)\n\n        return result\n\n    def record_trading_metric(self, strategy: str, metric_type: TradingMetricType, \n    """文档字符串"""\n\n                             value: float, tags: Optional[Dict[str, str]] = None):\n        """\n        记录交易指标\n\n        Args:\n            strategy: 策略名称\n            metric_type: 指标类型\n            value: 指标值\n            tags: 标签\n        """\n        metric_name = f"trading.{strategy}.{metric_type.value}"\n\n        # 记录指标\n        self.record_metric(metric_name, value, tags)\n\n        # 存储到交易指标\n        with self._lock:\n            self._trading_metrics[f"{strategy}.{metric_type.value}"].append({\n                'value': value,\n                'timestamp': datetime.now(),\n                'tags': tags or {}\n            })\n\n            # 限制存储大小\n            if len(self._trading_metrics[f"{strategy}.{metric_type.value}"]) > self._max_metrics:\n                self._trading_metrics[f"{strategy}.{metric_type.value}"] = \\n                    self._trading_metrics[f"{strategy}.{metric_type.value}"][-self._max_metrics:]\n\n        # 检查告警阈值\n        self._check_trading_alert(strategy, metric_type, value)\n\n    def record_model_performance(self, model: str, metric_type: ModelMetricType,\n    """文档字符串"""\n\n                                value: float, tags: Optional[Dict[str, str]] = None):\n        """\n        记录模型性能指标\n\n        Args:\n            model: 模型名称\n            metric_type: 指标类型\n            value: 指标值\n            tags: 标签\n        """\n        metric_name = f"model.{model}.{metric_type.value}"\n\n        # 记录指标\n        self.record_metric(metric_name, value, tags)\n\n        # 存储到模型指标\n        with self._lock:\n            self._model_metrics[f"{model}.{metric_type.value}"].append({\n                'value': value,\n                'timestamp': datetime.now(),\n                'tags': tags or {}\n            })\n\n            # 限制存储大小\n            if len(self._model_metrics[f"{model}.{metric_type.value}"]) > self._max_metrics:\n                self._model_metrics[f"{model}.{metric_type.value}"] = \\n                    self._model_metrics[f"{model}.{metric_type.value}"][-self._max_metrics:]\n\n        # 检查告警阈值\n        self._check_model_alert(model, metric_type, value)\n\n    def record_business_metric(self, metric_type: BusinessMetricType,\n    """文档字符串"""\n\n                              value: float, tags: Optional[Dict[str, str]] = None):\n        """\n        记录业务指标\n\n        Args:\n            metric_type: 指标类型\n            value: 指标值\n            tags: 标签\n        """\n        metric_name = f"business.{metric_type.value}"\n\n        # 记录指标\n        self.record_metric(metric_name, value, tags)\n\n        # 存储到业务指标\n        with self._lock:\n            self._business_metrics[metric_type.value].append({\n                'value': value,\n                'timestamp': datetime.now(),\n                'tags': tags or {}\n            })\n\n            # 限制存储大小\n            if len(self._business_metrics[metric_type.value]) > self._max_metrics:\n                self._business_metrics[metric_type.value] = \\n                    self._business_metrics[metric_type.value][-self._max_metrics:]\n\n        # 检查告警阈值\n        self._check_business_alert(metric_type, value)\n\n    def get_trading_metrics(self, strategy: str, metric_type: TradingMetricType,\n    """文档字符串"""\n\n                           time_range: Optional[Tuple[datetime, datetime]] = None):\n        """\n        获取交易指标\n\n        Args:\n            strategy: 策略名称\n            metric_type: 指标类型\n            time_range: 时间范围\n\n        Returns:\n            交易指标列表\n        """\n        with self._lock:\n            key = f"{strategy}.{metric_type.value}"\n            metrics = self._trading_metrics.get(key, [])\n\n        if time_range:\n            start_time, end_time = time_range\n            metrics = [m for m in metrics if start_time <= m['timestamp'] <= end_time]\n\n        return metrics.copy()\n\n    def get_model_metrics(self, model: str, metric_type: ModelMetricType,\n    """文档字符串"""\n\n                         time_range: Optional[Tuple[datetime, datetime]] = None):\n        """\n        获取模型指标\n\n        Args:\n            model: 模型名称\n            metric_type: 指标类型\n            time_range: 时间范围\n\n        Returns:\n            模型指标列表\n        """\n        with self._lock:\n            key = f"{model}.{metric_type.value}"\n            metrics = self._model_metrics.get(key, [])\n\n        if time_range:\n            start_time, end_time = time_range\n            metrics = [m for m in metrics if start_time <= m['timestamp'] <= end_time]\n\n        return metrics.copy()\n\n    def get_business_metrics(self, metric_type: BusinessMetricType,\n    """文档字符串"""\n\n                           time_range: Optional[Tuple[datetime, datetime]] = None):\n        """\n        获取业务指标\n\n        Args:\n            metric_type: 指标类型\n            time_range: 时间范围\n\n        Returns:\n            业务指标列表\n        """\n        with self._lock:\n            metrics = self._business_metrics.get(metric_type.value, [])\n\n        if time_range:\n            start_time, end_time = time_range\n            metrics = [m for m in metrics if start_time <= m['timestamp'] <= end_time]\n\n        return metrics.copy()\n\n    def get_trading_summary(self, strategy: str) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取交易摘要\n\n        Args:\n            strategy: 策略名称\n\n        Returns:\n            交易摘要\n        """\n        with self._lock:\n            summary = {}\n\n        for metric_type in TradingMetricType:\n            key = f"{strategy}.{metric_type.value}"\n            metrics = self._trading_metrics.get(key, [])\n\n            if metrics:\n                values = [m['value'] for m in metrics]\n                summary[metric_type.value] = {\n                    'latest': values[-1],\n                    'avg': sum(values) / len(values),\n                    'min': min(values),\n                    'max': max(values),\n                    'count': len(values)\n                }\n\n            return summary\n\n    def get_model_summary(self, model: str) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取模型摘要\n\n        Args:\n            model: 模型名称\n\n        Returns:\n            模型摘要\n        """\n        with self._lock:\n            summary = {}\n\n        for metric_type in ModelMetricType:\n            key = f"{model}.{metric_type.value}"\n            metrics = self._model_metrics.get(key, [])\n\n            if metrics:\n                values = [m['value'] for m in metrics]\n                summary[metric_type.value] = {\n                    'latest': values[-1],\n                    'avg': sum(values) / len(values),\n                    'min': min(values),\n                    'max': max(values),\n                    'count': len(values)\n                }\n\n            return summary\n\n    def get_business_summary(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取业务摘要\n\n        Returns:\n            业务摘要\n        """\n        with self._lock:\n            summary = {}\n\n        for metric_type in BusinessMetricType:\n            metrics = self._business_metrics.get(metric_type.value, [])\n\n            if metrics:\n                values = [m['value'] for m in metrics]\n                summary[metric_type.value] = {\n                    'latest': values[-1],\n                    'avg': sum(values) / len(values),\n                    'min': min(values),\n                    'max': max(values),\n                    'count': len(values)\n                }\n\n            return summary\n\n    def set_threshold(self, metric_name: str, threshold: float, condition: str):\n        """\n        设置阈值\n\n        Args:\n            metric_name: 指标名称\n            threshold: 阈值\n            condition: 条件 ('low' 或 'high')\n        """\n        with self._lock:\n            if condition == 'low':\n                self._thresholds[metric_name] = {\n                    'min': threshold,\n                    'max': None\n                }\n            elif condition == 'high':\n                self._thresholds[metric_name] = {\n                    'min': None,\n                    'max': threshold\n                }\n            else:\n                # 默认设置为最小值阈值\n                self._thresholds[metric_name] = {\n                    'min': threshold,\n                    'max': None\n                }\n\n    def add_alert_rule(self, rule_name: str, condition: Callable[[str, float], bool],\n    """文档字符串"""\n\n                       alert_message: str, alert_level: str = "warning"):\n        """\n        添加告警规则\n\n        Args:\n            rule_name: 规则名称\n            condition: 条件函数\n            alert_message: 告警消息\n            alert_level: 告警级别\n        """\n        with self._lock:\n            self._alert_rules[rule_name] = {\n                'condition': condition,\n                'message': alert_message,\n                'level': alert_level\n            }\n\n    def _check_trading_alert(self, strategy: str, metric_type: TradingMetricType, value: float) -> None:\n    """文档字符串"""\n\n        """\n        检查交易告警\n\n        Args:\n            strategy: 策略名称\n            metric_type: 指标类型\n            value: 指标值\n        """\n        metric_name = f"trading.{strategy}.{metric_type.value}"\n        self._check_threshold_alert(metric_name, value)\n        self._check_custom_alert_rule(metric_name, value)\n\n    def _check_model_alert(self, model: str, metric_type: ModelMetricType, value: float) -> None:\n    """文档字符串"""\n\n        """\n        检查模型告警\n\n        Args:\n            model: 模型名称\n            metric_type: 指标类型\n            value: 指标值\n        """\n        metric_name = f"model.{model}.{metric_type.value}"\n        self._check_threshold_alert(metric_name, value)\n        self._check_custom_alert_rule(metric_name, value)\n\n    def _check_business_alert(self, metric_type: BusinessMetricType, value: float) -> None:\n    """文档字符串"""\n\n        """\n        检查业务告警\n\n        Args:\n            metric_type: 指标类型\n            value: 指标值\n        """\n        metric_name = f"business.{metric_type.value}"\n        self._check_threshold_alert(metric_name, value)\n        self._check_custom_alert_rule(metric_name, value)\n\n    def _check_threshold_alert(self, metric_name: str, value: float) -> None:\n    """文档字符串"""\n\n        """\n        检查阈值告警\n\n        Args:\n            metric_name: 指标名称\n            value: 指标值\n        """\n        threshold = self._thresholds.get(metric_name)\n        if not threshold:\n            return\n\n        min_value = threshold.get('min')\n        max_value = threshold.get('max')\n\n        if min_value is not None and value < min_value:\n            self.record_alert(\n                "warning",\n                f"指标 {metric_name} 值 {value} 低于阈值 {min_value}",\n                {'metric': metric_name, 'value': value, 'threshold': min_value}\n            )\n\n        if max_value is not None and value > max_value:\n            self.record_alert(\n                "warning",\n                f"指标 {metric_name} 值 {value} 高于阈值 {max_value}",\n                {'metric': metric_name, 'value': value, 'threshold': max_value}\n            )\n\n    def _check_custom_alert_rule(self, metric_name: str, value: float) -> None:\n    """文档字符串"""\n\n        """\n        检查自定义告警规则\n\n        Args:\n            metric_name: 指标名称\n            value: 指标值\n        """\n        for rule_name, rule in self._alert_rules.items():\n            try:\n                if rule['condition'](metric_name, value):\n                    self.record_alert(\n                        rule['level'],\n                        rule['message'].format(metric=metric_name, value=value),\n                        {'metric': metric_name, 'value': value, 'rule': rule_name}\n                    )\n            except Exception as e:\n                print(f"执行告警规则 {rule_name} 失败: {e}")\n\n    def get_business_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取业务统计信息\n\n        Returns:\n            业务统计信息\n        """\n        with self._lock:\n            return {\n                'trading_metrics_count': len(self._trading_metrics),\n                'model_metrics_count': len(self._model_metrics),\n                'business_metrics_count': len(self._business_metrics),\n                'thresholds_count': len(self._thresholds),\n                'alert_rules_count': len(self._alert_rules),\n                'total_alerts': len(self._alerts)\n            }\n\n    def _initialize(self) -> None:\n    """文档字符串"""\n\n        """初始化监控器"""\n        # 设置默认阈值\n        self._setup_default_thresholds()\n\n        # 设置默认告警规则\n        self._setup_default_alert_rules()\n\n    def _setup_default_thresholds(self) -> None:\n    """文档字符串"""\n\n        """设置默认阈值"""\n        # 交易指标阈值\n        self.set_threshold("trading.*.max_drawdown", 0.1, "high")  # 最大回撤不超过10%\n        self.set_threshold("trading.*.win_rate", 0.5, "low")      # 胜率不低于50%\n\n        # 模型指标阈值\n        self.set_threshold("model.*.accuracy", 0.8, "low")        # 准确率不低于80%\n        self.set_threshold("model.*.latency", 1000, "high")        # 延迟不超过1000ms\n\n        # 业务指标阈值\n        self.set_threshold("business.conversion_rate", 0.02, "low")  # 转化率不低于2%\n        self.set_threshold("business.customer_satisfaction", 4.0, "low")  # 满意度不低于4.0\n\n    def _setup_default_alert_rules(self) -> None:\n    """文档字符串"""\n\n        """设置默认告警规则"""\n        # 连续亏损告警\n\n        def consecutive_loss_rule(metric_name: str, value: float) -> bool:\n    """文档字符串"""\n\n            if "profit_loss" in metric_name and value < 0:\n                # 这里应该检查连续亏损次数\n                return True\n            return False\n\n        self.add_alert_rule(\n            "consecutive_loss",\n            consecutive_loss_rule,\n            "策略 {metric} 连续亏损，当前值: {value}",\n            "warning"\n        )\n\n        # 模型性能下降告警\n\n        def model_performance_decline_rule(metric_name: str, value: float) -> bool:\n    """文档字符串"""\n\n            if "accuracy" in metric_name and value < 0.7:\n                return True\n            return False\n\n        self.add_alert_rule(\n            "model_performance_decline",\n            model_performance_decline_rule,\n            "模型 {metric} 性能下降，当前值: {value}",\n            "error"\n        )\n\n    def _check_alerts(self, metric_name: str, value: float, tags: Optional[Dict[str, str]] = None) -> None:\n        """检查告警规则并触发告警"""\n        if not hasattr(self, '_alert_rules') or not self._alert_rules:\n            return\n\n        for rule_name, rule_config in self._alert_rules.items():\n            try:\n                # 检查是否匹配指标名称\n                rule_str = str(rule_name).lower()\n                metric_str = str(metric_name).lower()\n                if rule_str in metric_str or metric_str in rule_str or rule_str == metric_str:\n                    threshold = rule_config.get('threshold')\n                    condition = rule_config.get('condition')\n                    handler = rule_config.get('handler')\n\n                    if threshold is not None and condition and handler:\n                        should_alert = False\n\n                        if condition == 'above' and value > threshold:\n                            should_alert = True\n                        elif condition == 'below' and value < threshold:\n                            should_alert = True\n                        elif condition == 'equals' and abs(value - threshold) < 0.001:\n                            should_alert = True\n\n                        if should_alert:\n                            alert_info = {\n                                'metric': metric_name,\n                                'value': value,\n                                'threshold': threshold,\n                                'condition': condition,\n                                'tags': tags or {},\n                                'timestamp': datetime.now()\n                            }\n                            handler(alert_info)\n\n            except Exception as e:\n                logger.error(f"Error checking alert rule {rule_name}: {e}")\n\n    def get_recent_metrics(self, limit: int = 100) -> List[Dict[str, Any]]:\n        """\n        获取最近的指标数据\n\n        Args:\n            limit: 返回的最大指标数量\n\n        Returns:\n            最近指标的列表\n        """\n        recent_metrics = []\n\n        # 收集所有类型的指标\n        for metric_type, data in [\n            ('trading', self._trading_metrics),\n            ('model', self._model_metrics),\n            ('business', self._business_metrics)\n        ]:\n            for name, values in data.items():\n                if values:\n                    latest_value = values[-1]  # 获取最新的值\n                    recent_metrics.append({\n                        'name': f"{metric_type}.{name}",\n                        'value': latest_value['value'],\n                        'timestamp': latest_value['timestamp'],\n                        'tags': latest_value.get('tags', {})\n                    })\n\n        # 收集通用指标\n        for name, metric_list in self._metrics.items():\n            if isinstance(metric_list, list) and metric_list:\n                latest_metric = metric_list[-1]  # 获取最新的指标\n                recent_metrics.append({\n                    'name': name,\n                    'value': latest_metric.get('value'),\n                    'timestamp': latest_metric.get('timestamp', datetime.now()),\n                    'tags': latest_metric.get('tags', {})\n                })\n\n        # 按时间戳排序并限制数量\n        recent_metrics.sort(key=lambda x: x['timestamp'], reverse=True)\n        return recent_metrics[:limit]\n\n    def check_thresholds(self) -> List[Dict[str, Any]]:\n        """\n        检查所有指标是否超过阈值\n\n        Returns:\n            超过阈值的指标列表\n        """\n        alerts = []\n\n        # 检查所有指标是否超过阈值\n        for metric_name, metric_list in self._metrics.items():\n            if isinstance(metric_list, list) and metric_list:\n                latest_metric = metric_list[-1]\n                metric_value = latest_metric.get('value')\n\n                if metric_value is not None and isinstance(metric_value, (int, float)):\n                    # 检查是否有匹配的阈值设置\n                    for threshold_name, threshold_config in self._thresholds.items():\n                        try:\n                            # 支持通配符匹配\n                            import fnmatch\n                            if fnmatch.fnmatch(metric_name, threshold_name):\n                                threshold_exceeded = False\n                                condition = 'unknown'\n\n                                # 检查最小值阈值\n                                if threshold_config.get('min') is not None:\n                                    if metric_value < threshold_config['min']:\n                                        threshold_exceeded = True\n                                        condition = 'below_min'\n\n                                # 检查最大值阈值\n                                if threshold_config.get('max') is not None:\n                                    if metric_value > threshold_config['max']:\n                                        threshold_exceeded = True\n                                        condition = 'above_max'\n\n                                if threshold_exceeded:\n                                    alerts.append({\n                                        'rule_name': f"{metric_name}_threshold",\n                                        'metric_name': metric_name,\n                                        'current_value': metric_value,\n                                        'threshold': threshold_config.get('min') or threshold_config.get('max'),\n                                        'condition': condition,\n                                        'timestamp': time.time()\n                                    })\n                        except Exception as e:\n                            print(f"Error checking threshold for metric {metric_name}: {e}")\n\n        return alerts