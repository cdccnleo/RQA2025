"""\n基础设施层 - 日志系统组件\n\napi_endpoints 模块\n\n日志系统相关的文件\n提供日志系统相关的功能实现。\n"""\n\n#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\n"""\n健康检查API端点\n提供健康检查、监控和告警的HTTP接口\n"""\n\nfrom typing import Dict, Any, Optional, List\nimport asyncio\nimport logging\n\nfrom fastapi import APIRouter, Depends, HTTPException, Query\nfrom fastapi.responses import JSONResponse, Response\n\nfrom .enhanced_health_checker import get_enhanced_health_checker, HealthCheckResult\nfrom ..cache.unified_cache import get_cache_manager\nfrom .prometheus_exporter import get_prometheus_exporter\nfrom ..monitoring.alert_system import AlertSeverity, AlertStatus\n\nlogger = logging.getLogger(__name__)\n\n# 创建路由器\nhealth_router = APIRouter(prefix="/health", tags=["健康检查"])\n\n# 依赖注入\n\ndef get_health_checker():\n    """文档字符串"""\n    return get_enhanced_health_checker()\n\ndef get_cache_manager_dep():\n    """文档字符串"""\n    return get_cache_manager()\n\ndef get_prometheus_exporter_dep():\n    """文档字符串"""\n    return get_prometheus_exporter()\n\ndef get_alert_manager():\n    """Simple alert manager for health endpoints"""\n    from ..monitoring.alert_system import AlertSystem\n    return AlertSystem()\n\ndef get_alert_manager_dep():\n    """文档字符串"""\n    return get_alert_manager()\n\n@health_router.get("/")\nasync def health_check(checker=Depends(get_health_checker)):\n    """\n    基础健康检查端点\n\n    Returns:\n        健康状态信息\n    """\n    try:\n        result = await checker.get_comprehensive_health_status()\n        return result\n    except Exception as e:\n        logger.error(f"Error in health check endpoint: {e}")\n        raise HTTPException(status_code=500, detail=str(e))\n\n@health_router.get("/ready")\nasync def readiness_check(checker=Depends(get_health_checker)):\n    """\n    就绪检查端点\n\n    Returns:\n        就绪状态信息\n    """\n    try:\n        # 执行关键健康检查\n        critical_checks = ["system_resources", "disk_space"]\n        results = []\n\n        for check_type in critical_checks:\n            result = await checker.perform_health_check("system", check_type)\n            results.append(result)\n\n        # 判断整体就绪状态\n        all_ready = all(r.status == "healthy" for r in results)\n\n        response = {\n            "timestamp": results[0].timestamp.isoformat() if results else None,\n            "ready": all_ready,\n            "checks": [\n                {\n                    "type": r.check_type,\n                    "status": r.status,\n                    "response_time": r.response_time\n                }\n                for r in results\n            ]\n        }\n\n        if not all_ready:\n            raise HTTPException(status_code=503, detail="Service not ready")\n\n        return response\n\n    except HTTPException:\n        raise\n    except Exception as e:\n        logger.error(f"Error in readiness check endpoint: {e}")\n        raise HTTPException(status_code=500, detail=str(e))\n\n@health_router.get("/live")\n\nasync def liveness_check() -> Dict[str, Any]:\n    """\n    存活检查端点\n\n    Returns:\n        存活状态信息\n    """\n    return {\n        "timestamp": asyncio.get_event_loop().time(),\n        "alive": True,\n        "status": "healthy"\n    }\n\n@health_router.get("/metrics")\nasync def prometheus_metrics(exporter=Depends(get_prometheus_exporter_dep)):\n    """\n    Prometheus指标端点\n\n    Returns:\n        Prometheus格式的指标数据\n    """\n    try:\n        metrics_data = exporter.generate_metrics()\n        return Response(\n            content=metrics_data,\n            media_type=exporter.get_metrics_content_type()\n        )\n    except Exception as e:\n        logger.error(f"Error generating Prometheus metrics: {e}")\n        raise HTTPException(status_code=500, detail=str(e))\n\n@health_router.get("/metrics/summary")\nasync def metrics_summary(exporter=Depends(get_prometheus_exporter_dep)):\n    """\n    指标摘要端点\n\n    Returns:\n        指标摘要信息\n    """\n    try:\n        return exporter.get_metrics_summary()\n    except Exception as e:\n        logger.error(f"Error getting metrics summary: {e}")\n        raise HTTPException(status_code=500, detail=str(e))\n\n@health_router.get("/cache/stats")\nasync def cache_stats(cache_manager=Depends(get_cache_manager_dep)):\n    """\n    缓存统计端点\n\n    Returns:\n        缓存统计信息\n    """\n    try:\n        return cache_manager.get_stats()\n    except Exception as e:\n        logger.error(f"Error getting cache stats: {e}")\n        raise HTTPException(status_code=500, detail=str(e))\n\n@health_router.post("/cache/clear")\nasync def clear_cache(\n    cache_manager=Depends(get_cache_manager_dep),\n    pattern: Optional[str] = Query(None, description="清除模式，支持通配符")\n):\n    """\n    清除缓存端点\n\n    Args:\n        pattern: 清除模式，None表示清除所有缓存\n\n    Returns:\n        清除结果\n    """\n    try:\n        if pattern:\n            cleared_count = cache_manager.invalidate_pattern(pattern)\n            return {\n                "message": f"Cleared {cleared_count} cache entries matching pattern: {pattern}",\n                "cleared_count": cleared_count\n            }\n        else:\n            cache_manager.clear()\n            return {\n                "message": "All cache cleared",\n                "cleared_count": "all"\n            }\n    except Exception as e:\n        logger.error(f"Error clearing cache: {e}")\n        raise HTTPException(status_code=500, detail=str(e))\n\n@health_router.get("/alerts")\nasync def get_alerts(\n    alert_manager=Depends(get_alert_manager_dep),\n    status: Optional[AlertStatus] = Query(None, description="告警状态过滤"),\n    severity: Optional[AlertSeverity] = Query(None, description="告警严重程度过滤"),\n    limit: int = Query(100, description="返回告警数量限制", ge=1, le=1000)\n):\n    """\n    获取告警列表端点\n\n    Args:\n        status: 告警状态过滤\n        severity: 告警严重程度过滤\n        limit: 返回数量限制\n\n    Returns:\n        告警列表\n    """\n    try:\n        if status == AlertStatus.ACTIVE:\n            alerts = alert_manager.get_active_alerts(severity)\n        else:\n            alerts = alert_manager.get_alert_history(limit)\n        if severity:\n            alerts = [a for a in alerts if a.severity == severity]\n\n        return {\n            "alerts": [\n                {\n                    "id": alert.id,\n                    "rule_name": alert.rule_name,\n                    "severity": alert.severity.value,\n                    "status": alert.status.value,\n                    "message": alert.message,\n                    "created_at": alert.created_at.isoformat(),\n                    "updated_at": alert.updated_at.isoformat(),\n                    "acknowledged_at": alert.acknowledged_at.isoformat() if alert.acknowledged_at else None,\n                    "resolved_at": alert.resolved_at.isoformat() if alert.resolved_at else None,\n                    "acknowledged_by": alert.acknowledged_by,\n                    "resolution_notes": alert.resolution_notes\n                }\n                for alert in alerts[:limit]\n            ],\n            "total_count": len(alerts),\n            "returned_count": min(len(alerts), limit)\n        }\n    except Exception as e:\n        logger.error(f"Error getting alerts: {e}")\n        raise HTTPException(status_code=500, detail=str(e))\n\n@health_router.post("/alerts/{alert_id}/acknowledge")\nasync def acknowledge_alert(\n    alert_id: str,\n    user: str = Query(..., description="确认用户"),\n    notes: Optional[str] = Query(None, description="确认备注"),\n    alert_manager=Depends(get_alert_manager_dep)\n):\n    """\n    确认告警端点\n\n    Args:\n        alert_id: 告警ID\n        user: 确认用户\n        notes: 确认备注\n\n    Returns:\n        确认结果\n    """\n    try:\n        success = alert_manager.acknowledge_alert(alert_id, user, notes)\n        if success:\n            return {\n                "message": f"Alert {alert_id} acknowledged successfully",\n                "alert_id": alert_id,\n                "acknowledged_by": user,\n                "acknowledged_at": asyncio.get_event_loop().time()\n            }\n        else:\n            raise HTTPException(status_code=404, detail=f"Alert {alert_id} not found")\n    except HTTPException:\n        raise\n    except Exception as e:\n        logger.error(f"Error acknowledging alert {alert_id}: {e}")\n        raise HTTPException(status_code=500, detail=str(e))\n\n@health_router.post("/alerts/{alert_id}/resolve")\nasync def resolve_alert(\n    alert_id: str,\n    notes: Optional[str] = Query(None, description="解决备注"),\n    alert_manager=Depends(get_alert_manager_dep)\n):\n    """\n    解决告警端点\n\n    Args:\n        alert_id: 告警ID\n        notes: 解决备注\n\n    Returns:\n        解决结果\n    """\n    try:\n        success = alert_manager.resolve_alert(alert_id, notes)\n        if success:\n            return {\n                "message": f"Alert {alert_id} resolved successfully",\n                "alert_id": alert_id,\n                "resolved_at": asyncio.get_event_loop().time()\n            }\n        else:\n            raise HTTPException(status_code=404, detail=f"Alert {alert_id} not found")\n    except HTTPException:\n        raise\n    except Exception as e:\n        logger.error(f"Error resolving alert {alert_id}: {e}")\n        raise HTTPException(status_code=500, detail=str(e))\n\n@health_router.get("/alerts/summary")\nasync def alerts_summary(checker=Depends(get_health_checker)):\n    """\n    告警摘要端点\n\n    Returns:\n        告警摘要信息\n    """\n    try:\n        return checker.get_alert_summary()\n    except Exception as e:\n        logger.error(f"Error getting alerts summary: {e}")\n        raise HTTPException(status_code=500, detail=str(e))\n\n@health_router.get("/check/{check_type}")\nasync def specific_health_check(\n    check_type: str,\n    service: str = Query("system", description="服务名称"),\n    use_cache: bool = Query(True, description="是否使用缓存"),\n    checker=Depends(get_health_checker)\n):\n    """\n    特定健康检查端点\n\n    Args:\n        check_type: 检查类型\n        service: 服务名称\n        use_cache: 是否使用缓存\n\n    Returns:\n        健康检查结果\n    """\n    try:\n        result = await checker.perform_health_check(service, check_type, use_cache)\n        return {\n            "service": result.service,\n            "check_type": result.check_type,\n            "status": result.status,\n            "response_time": result.response_time,\n            "details": result.details,\n            "timestamp": result.timestamp.isoformat(),\n            "error_code": result.error_code,\n            "error_message": result.error_message\n        }\n    except Exception as e:\n        logger.error(f"Error in specific health check {check_type}: {e}")\n        raise HTTPException(status_code=500, detail=str(e))\n\n@health_router.get("/system/metrics")\nasync def system_metrics(checker=Depends(get_health_checker)):\n    """\n    系统指标端点\n\n    Returns:\n        系统指标信息\n    """\n    try:\n        metrics = await checker.get_system_metrics()\n        return {\n            "timestamp": metrics.timestamp.isoformat(),\n            "cpu_percent": metrics.cpu_percent,\n            "memory_percent": metrics.memory_percent,\n            "memory_bytes": metrics.memory_bytes,\n            "disk_usage": metrics.disk_usage,\n            "network_io": metrics.network_io\n        }\n    except Exception as e:\n        logger.error(f"Error getting system metrics: {e}")\n        raise HTTPException(status_code=500, detail=str(e))\n\n@health_router.get("/config")\nasync def get_config(checker=Depends(get_health_checker)):\n    """\n    获取配置端点\n\n    Returns:\n        配置信息\n    """\n    try:\n        return {\n            "monitoring_enabled": checker.monitoring_enabled,\n            "alerting_enabled": checker.alerting_enabled,\n            "cache_enabled": checker.cache_enabled,\n            "cache_ttl": checker.cache_ttl,\n            "system_metrics_cache_ttl": checker.system_metrics_cache_ttl,\n            "registered_health_checks": list(checker.health_checks.keys()),\n            "registered_dependency_checks": list(checker.dependency_checks.keys())\n        }\n    except Exception as e:\n        logger.error(f"Error getting config: {e}")\n        raise HTTPException(status_code=500, detail=str(e))\n\n@health_router.get("/status")\nasync def detailed_status(checker=Depends(get_health_checker)):\n    """\n    详细状态端点\n\n    Returns:\n        详细状态信息\n    """\n    try:\n        # 获取各种状态信息\n        cache_stats = checker.get_cache_stats()\n        alert_summary = checker.get_alert_summary()\n        metrics_summary = checker.get_metrics_summary()\n\n        return {\n            "timestamp": asyncio.get_event_loop().time(),\n            "cache": cache_stats,\n            "alerts": alert_summary,\n            "metrics": metrics_summary,\n            "system_info": {\n                "python_version": asyncio.get_event_loop().time(),\n                "platform": "unknown"  # 可以添加更多系统信息\n            }\n        }\n    except Exception as e:\n        logger.error(f"Error getting detailed status: {e}")\n        raise HTTPException(status_code=500, detail=str(e))\n\n