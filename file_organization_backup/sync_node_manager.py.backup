"""\n同步节点管理器\n负责管理分布式同步中的节点信息和状态\n"""\n\nfrom enum import Enum\nfrom typing import Dict, List, Optional, Any\nimport time\n\nfrom dataclasses import dataclass\n\nclass SyncStatus(Enum):\n\n    """同步状态枚举"""\n    IDLE = "idle"\n    SYNCING = "syncing"\n    SUCCESS = "success"\n    FAILED = "failed"\n    OFFLINE = "offline"\n\n@dataclass\n\nclass SyncNode:\n\n    """同步节点信息"""\n    node_id: str\n    address: str\n    port: int\n    status: SyncStatus = SyncStatus.IDLE\n    last_sync_time: float = None\n    version: str = "1.0"\n    priority: int = 1\n\nclass SyncNodeManager:\n\n    """同步节点管理器"""\n\n    def __init__(self):\n\n        self.nodes: Dict[str, SyncNode] = {}\n\n    def register_node(self, node_id: str, address: str, port: int) -> bool:\n    """文档字符串"""\n\n        """注册同步节点"""\n        if node_id in self.nodes:\n            return False\n\n        self.nodes[node_id] = SyncNode(\n            node_id=node_id,\n            address=address,\n            port=port,\n            status=SyncStatus.IDLE,\n            last_sync_time=time.time()\n        )\n        return True\n\n    def unregister_node(self, node_id: str) -> bool:\n    """文档字符串"""\n\n        """注销同步节点"""\n        if node_id in self.nodes:\n            del self.nodes[node_id]\n            return True\n        return False\n\n    def get_node(self, node_id: str) -> Optional[SyncNode]:\n    """文档字符串"""\n\n        """获取节点信息"""\n        return self.nodes.get(node_id)\n\n    def update_node_status(self, node_id: str, status: SyncStatus) -> bool:\n    """文档字符串"""\n\n        """更新节点状态"""\n        if node_id in self.nodes:\n            self.nodes[node_id].status = status\n            if status in [SyncStatus.SUCCESS, SyncStatus.FAILED]:\n                self.nodes[node_id].last_sync_time = time.time()\n            return True\n        return False\n\n    def update_node_sync_time(self, node_id: str) -> bool:\n    """文档字符串"""\n\n        """更新节点同步时间"""\n        if node_id in self.nodes:\n            self.nodes[node_id].last_sync_time = time.time()\n            return True\n        return False\n\n    def list_nodes(self) -> List[Dict[str, Any]]:\n    """文档字符串"""\n\n        """列出所有节点"""\n        return [\n            {\n                "node_id": node.node_id,\n                "address": node.address,\n                "port": node.port,\n                "status": node.status.value,\n                "last_sync_time": node.last_sync_time,\n                "version": node.version\n            }\n            for node in self.nodes.values()\n        ]\n\n    def get_active_nodes(self) -> List[str]:\n    """文档字符串"""\n\n        """获取活跃节点列表"""\n        return [\n            node_id for node_id, node in self.nodes.items()\n            if node.status not in [SyncStatus.OFFLINE, SyncStatus.FAILED]\n        ]\n\n    def get_node_count(self) -> int:\n    """文档字符串"""\n\n        """获取节点数量"""\n        return len(self.nodes)\n\n    def get_node_status_summary(self) -> Dict[str, int]:\n    """文档字符串"""\n\n        """获取节点状态统计"""\n        summary = {}\n        for node in self.nodes.values():\n            status = node.status.value\n            summary[status] = summary.get(status, 0) + 1\n        return summary\n