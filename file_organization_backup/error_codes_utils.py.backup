from enum import Enum\nfrom typing import Dict, Any, Optional\nimport time\n\nfrom dataclasses import dataclass\n\n"""\n基础设施层 - 配置管理组件\n\nerror_codes_utils 模块\n\n配置管理相关的文件\n提供配置管理相关的功能实现。\n"""\n\n#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n统一错误码系统\n\n定义RQA2025系统的错误码规范和映射，包括：\n- 错误码分类\n- 错误码映射\n- 错误描述\n- 错误处理策略\n"""\n\nclass ErrorCategory(Enum):\n\n    """错误分类枚举"""\n    SYSTEM = "SYSTEM"           # 系统级错误\n    CONFIGURATION = "CONFIG"     # 配置错误\n    DATABASE = "DATABASE"        # 数据库错误\n    NETWORK = "NETWORK"          # 网络错误\n    TRADING = "TRADING"          # 交易错误\n    RISK = "RISK"               # 风控错误\n    MODEL = "MODEL"             # 模型错误\n    DATA = "DATA"               # 数据错误\n    SECURITY = "SECURITY"       # 安全错误\n    MONITORING = "MONITORING"   # 监控错误\n\n@dataclass\n\nclass ErrorCode:\n\n    """错误码定义"""\n    code: str\n    category: ErrorCategory\n    description: str\n    severity: str  # CRITICAL, ERROR, WARNING, INFO\n    recovery_strategy: str\n    retry_allowed: bool\n    alert_required: bool\n\nclass ErrorCodeRegistry:\n\n    """错误码注册表"""\n\n    def __init__(self):\n\n        self._error_codes: Dict[str, ErrorCode] = {}\n        self._category_mappings: Dict[ErrorCategory, Dict[str, ErrorCode]] = {}\n        self._initialize_error_codes()\n\n    def _initialize_error_codes(self):\n    """文档字符串"""\n\n        """初始化错误码"""\n        # 系统级错误码 (1000 - 1999)\n        self._register_error_code(ErrorCode(\n            code="SYS001",\n            category=ErrorCategory.SYSTEM,\n            description="系统初始化失败",\n            severity="CRITICAL",\n            recovery_strategy="restart",\n            retry_allowed=False,\n            alert_required=True\n        ))\n\n        self._register_error_code(ErrorCode(\n            code="SYS002",\n            category=ErrorCategory.SYSTEM,\n            description="内存不足",\n            severity="ERROR",\n            recovery_strategy="cleanup",\n            retry_allowed=True,\n            alert_required=True\n        ))\n\n        # 配置错误码 (2000 - 2999)\n        self._register_error_code(ErrorCode(\n            code="CONFIG001",\n            category=ErrorCategory.CONFIGURATION,\n            description="配置文件加载失败",\n            severity="ERROR",\n            recovery_strategy="fallback",\n            retry_allowed=True,\n            alert_required=False\n        ))\n\n        self._register_error_code(ErrorCode(\n            code="CONFIG002",\n            category=ErrorCategory.CONFIGURATION,\n            description="配置验证失败",\n            severity="WARNING",\n            recovery_strategy="default",\n            retry_allowed=False,\n            alert_required=False\n        ))\n\n        # 数据库错误码 (3000 - 3999)\n        self._register_error_code(ErrorCode(\n            code="DB001",\n            category=ErrorCategory.DATABASE,\n            description="数据库连接失败",\n            severity="ERROR",\n            recovery_strategy="retry",\n            retry_allowed=True,\n            alert_required=True\n        ))\n\n        self._register_error_code(ErrorCode(\n            code="DB002",\n            category=ErrorCategory.DATABASE,\n            description="数据库查询超时",\n            severity="WARNING",\n            recovery_strategy="timeout",\n            retry_allowed=True,\n            alert_required=False\n        ))\n\n        # 网络错误码 (4000 - 4999)\n        self._register_error_code(ErrorCode(\n            code="NET001",\n            category=ErrorCategory.NETWORK,\n            description="网络连接超时",\n            severity="ERROR",\n            recovery_strategy="retry",\n            retry_allowed=True,\n            alert_required=True\n        ))\n\n        self._register_error_code(ErrorCode(\n            code="NET002",\n            category=ErrorCategory.NETWORK,\n            description="API调用失败",\n            severity="WARNING",\n            recovery_strategy="fallback",\n            retry_allowed=True,\n            alert_required=False\n        ))\n\n        # 交易错误码 (5000 - 5999)\n        self._register_error_code(ErrorCode(\n            code="TRADE001",\n            category=ErrorCategory.TRADING,\n            description="订单提交失败",\n            severity="ERROR",\n            recovery_strategy="retry",\n            retry_allowed=True,\n            alert_required=True\n        ))\n\n        self._register_error_code(ErrorCode(\n            code="TRADE002",\n            category=ErrorCategory.TRADING,\n            description="风控拦截",\n            severity="WARNING",\n            recovery_strategy="reject",\n            retry_allowed=False,\n            alert_required=False\n        ))\n\n        # 风控错误码 (6000 - 6999)\n        self._register_error_code(ErrorCode(\n            code="RISK001",\n            category=ErrorCategory.RISK,\n            description="风险指标超限",\n            severity="ERROR",\n            recovery_strategy="stop",\n            retry_allowed=False,\n            alert_required=True\n        ))\n\n        # 模型错误码 (7000 - 7999)\n        self._register_error_code(ErrorCode(\n            code="MODEL001",\n            category=ErrorCategory.MODEL,\n            description="模型预测失败",\n            severity="ERROR",\n            recovery_strategy="fallback",\n            retry_allowed=True,\n            alert_required=True\n        ))\n\n        # 数据错误码 (8000 - 8999)\n        self._register_error_code(ErrorCode(\n            code="DATA001",\n            category=ErrorCategory.DATA,\n            description="数据格式错误",\n            severity="WARNING",\n            recovery_strategy="skip",\n            retry_allowed=False,\n            alert_required=False\n        ))\n\n        # 安全错误码 (9000 - 9999)\n        self._register_error_code(ErrorCode(\n            code="SEC001",\n            category=ErrorCategory.SECURITY,\n            description="权限验证失败",\n            severity="ERROR",\n            recovery_strategy="deny",\n            retry_allowed=False,\n            alert_required=True\n        ))\n\n        # 监控错误码 (10000 - 10999)\n        self._register_error_code(ErrorCode(\n            code="MON001",\n            category=ErrorCategory.MONITORING,\n            description="监控指标收集失败",\n            severity="WARNING",\n            recovery_strategy="skip",\n            retry_allowed=True,\n            alert_required=False\n        ))\n\n    def _register_error_code(self, error_code: ErrorCode):\n    """文档字符串"""\n\n        """注册错误码"""\n        self._error_codes[error_code.code] = error_code\n\n        if error_code.category not in self._category_mappings:\n            self._category_mappings[error_code.category] = {}\n\n        self._category_mappings[error_code.category][error_code.code] = error_code\n\n    def get_error_code(self, code: str) -> Optional[ErrorCode]:\n    """文档字符串"""\n\n        """获取错误码定义"""\n        return self._error_codes.get(code)\n\n    def get_category_errors(self, category: ErrorCategory) -> Dict[str, ErrorCode]:\n    """文档字符串"""\n\n        """获取分类下的所有错误码"""\n        return self._category_mappings.get(category, {})\n\n    def get_all_error_codes(self) -> Dict[str, ErrorCode]:\n    """文档字符串"""\n\n        """获取所有错误码"""\n        return self._error_codes.copy()\n\n    def get_critical_errors(self) -> Dict[str, ErrorCode]:\n    """文档字符串"""\n\n        """获取严重错误码"""\n        return {\n            code: error_code for code, error_code in self._error_codes.items()\n            if error_code.severity == "CRITICAL"\n        }\n\n    def get_retryable_errors(self) -> Dict[str, ErrorCode]:\n    """文档字符串"""\n\n        """获取可重试错误码"""\n        return {\n            code: error_code for code, error_code in self._error_codes.items()\n            if error_code.retry_allowed\n        }\n\n# 全局错误码注册表实例\nerror_code_registry = ErrorCodeRegistry()\n\nclass ErrorCodeMapper:\n\n    """错误码映射器"""\n\n    def __init__(self):\n\n        self.registry = error_code_registry\n        self._exception_mappings: Dict[type, str] = {}\n        self._initialize_exception_mappings()\n\n    def _initialize_exception_mappings(self):\n    """文档字符串"""\n\n        """初始化异常映射"""\n        # 系统异常映射\n        self._exception_mappings.update({\n            MemoryError: "SYS002",\n            OSError: "SYS001",\n            SystemError: "SYS001",\n        })\n\n        # 配置异常映射\n        self._exception_mappings.update({\n            ValueError: "CONFIG002",\n            KeyError: "CONFIG001",\n            FileNotFoundError: "CONFIG001",\n        })\n\n        # 数据库异常映射\n        self._exception_mappings.update({\n            ConnectionError: "DB001",\n            TimeoutError: "DB002",\n        })\n\n        # 网络异常映射\n        self._exception_mappings.update({\n            ConnectionError: "NET001",\n            TimeoutError: "NET001",\n        })\n\n    def map_exception_to_code(self, exception: Exception) -> str:\n    """文档字符串"""\n\n        """将异常映射到错误码"""\n        exception_type = type(exception)\n\n        # 查找直接映射\n        if exception_type in self._exception_mappings:\n            return self._exception_mappings[exception_type]\n\n        # 查找继承关系\n        for base_type, code in self._exception_mappings.items():\n            if isinstance(exception, base_type):\n                return code\n\n        # 默认返回系统错误\n        return "SYS001"\n\n    def get_error_info(self, exception: Exception) -> Optional[ErrorCode]:\n    """文档字符串"""\n\n        """获取错误信息"""\n        code = self.map_exception_to_code(exception)\n        return self.registry.get_error_code(code)\n\n    def add_exception_mapping(self, exception_type: type, error_code: str):\n    """文档字符串"""\n\n        """添加异常映射"""\n        self._exception_mappings[exception_type] = error_code\n\n# 全局错误码映射器实例\nerror_code_mapper = ErrorCodeMapper()\n\ndef get_error_code(exception: Exception) -> str:\n    """文档字符串"""\n\n    """获取异常对应的错误码"""\n    return error_code_mapper.map_exception_to_code(exception)\n\ndef get_error_info(exception: Exception) -> Optional[ErrorCode]:\n    """文档字符串"""\n\n    """获取异常对应的错误信息"""\n    return error_code_mapper.get_error_info(exception)\n\ndef register_error_code(error_code: ErrorCode):\n    """文档字符串"""\n\n    """注册新的错误码"""\n    error_code_registry._register_error_code(error_code)\n\ndef get_all_error_codes() -> Dict[str, ErrorCode]:\n    """文档字符串"""\n\n    """获取所有错误码"""\n    return error_code_registry.get_all_error_codes()\n\ndef get_critical_errors() -> Dict[str, ErrorCode]:\n    """文档字符串"""\n\n    """获取严重错误码"""\n    return error_code_registry.get_critical_errors()\n\ndef get_retryable_errors() -> Dict[str, ErrorCode]:\n    """文档字符串"""\n\n    """获取可重试错误码"""\n    return error_code_registry.get_retryable_errors()\n\n__all__ = [\n    'ErrorCategory',\n    'ErrorCode',\n    'ErrorCodeRegistry',\n    'ErrorCodeMapper',\n    'error_code_registry',\n    'error_code_mapper',\n    'get_error_code',\n    'get_error_info',\n    'register_error_code',\n    'get_all_error_codes',\n    'get_critical_errors',\n    'get_retryable_errors'\n]\n