"""InfluxDB异常处理策略"""\nfrom functools import wraps\nfrom typing import Callable, TypeVar\nimport logging\nimport time\n\nfrom src.infrastructure.error.error_handler import ErrorHandler, ErrorLevel\n\n# 跨层级导入：infrastructure层组件\n\nT = TypeVar('T')\n\nclass InfluxDBErrorHandler:\n\n    """InfluxDB专用异常处理器"""\n    logger = logging.getLogger(__name__)\n\n    def __init__(self, error_handler: ErrorHandler, recovery_timeout: int = 60, failure_threshold: int = 3):\n\n        self.error_handler = error_handler\n        self.retry_config = {\n            'max_attempts': 3,\n            'delay': 1,\n            'backoff': 2\n        }\n\n        self._circuit_open = False\n        self._failures = 0\n        self._last_failure = 0\n        self.recovery_timeout = recovery_timeout\n        self.failure_threshold = failure_threshold\n\n    def configure_retry(self, max_attempts: int = 3,\n    """文档字符串"""\n\n                        delay: float = 1, backoff: float = 2):\n        """配置重试策略"""\n        self.retry_config = {\n            'max_attempts': max_attempts,\n            'delay': delay,\n            'backoff': backoff\n        }\n\n    def handle(self, operation: str, exception: Exception):\n    """文档字符串"""\n\n        """通用错误处理方法"""\n        self.error_handler.log(\n            f"InfluxDB错误 - 操作: {operation}",\n            exception,\n            ErrorLevel.ERROR\n        )\n\n    def handle_connection_error(self, operation: str, exception: Exception):\n    """文档字符串"""\n\n        """处理连接错误"""\n        self.error_handler.log(\n            f"InfluxDB连接失败 - 操作: {operation}",\n            exception,\n            ErrorLevel.CRITICAL\n        )\n\n        # 触发连接恢复流程\n        self._recover_connection()\n\n    def log_error(self, operation: str, exception: Exception, level: str, action: str):\n    """文档字符串"""\n\n        """记录错误日志"""\n        self.error_handler.log_error(\n            operation,\n            exception,\n            level,\n            action\n        )\n\n    def handle_write_error(self, exception: Exception) -> None:\n    """文档字符串"""\n\n        """处理写入错误"""\n        if hasattr(exception, 'status') and exception.status == 429:\n            # 速率限制错误\n            self.log_error(\n                "写入操作",\n                exception,\n                "WARNING",\n                "等待后重试"\n            )\n\n        else:\n            # 其他写入错误\n            self.log_error(\n                "写入操作",\n                exception,\n                "ERROR",\n                "写入失败"\n            )\n\n        if self.error_handler:\n            self.error_handler.handle_error(exception)\n\n    def handle_query_error(self, operation: str, exception: Exception):\n    """文档字符串"""\n\n        """处理查询错误"""\n        self.error_handler.log(\n            f"InfluxDB查询错误 - 操作: {operation}",\n            exception,\n            ErrorLevel.ERROR\n        )\n\n    def handle_management_error(self, operation: str, exception: Exception):\n    """文档字符串"""\n\n        """处理管理操作错误"""\n        self.error_handler.log(\n            f"InfluxDB管理操作错误 - 操作: {operation}",\n            exception,\n            ErrorLevel.WARNING\n        )\n\n    def retry_on_exception(self, func: Callable[..., T]) -> Callable[..., T]:\n    """文档字符串"""\n\n        """自动重试装饰器"""\n        @wraps(func)\n\n        def wrapper(*args, **kwargs) -> T:\n    """文档字符串"""\n\n            last_exception = None\n            delay = self.retry_config['delay']\n\n            for attempt in range(1, self.retry_config['max_attempts'] + 1):\n                try:\n                    return func(*args, **kwargs)\n                except Exception as e:\n                    last_exception = e\n                    operation = f"{func.__name__} (尝试 {attempt}/{self.retry_config['max_attempts']})"\n\n                    # 根据异常类型调用不同的处理方法\n                    if isinstance(e, ConnectionError):\n                        self.handle_connection_error(operation, e)\n                        raise  # 连接错误直接抛出，不重试\n                    elif "write" in func.__name__.lower():\n                        self.handle_write_error(e)\n                    elif "query" in func.__name__.lower():\n                        self.handle_query_error(operation, e)\n                    else:\n                        self.handle_management_error(operation, e)\n\n                    if attempt < self.retry_config['max_attempts']:\n                        time.sleep(delay)\n                        delay *= self.retry_config['backoff']\n\n            raise last_exception if last_exception else RuntimeError("未知错误")\n        return wrapper\n\n    def fallback_on_exception(self, func: Callable[..., T]) -> Callable[..., T]:\n    """文档字符串"""\n\n        """异常时回退装饰器"""\n        @wraps(func)\n\n        def wrapper(*args, **kwargs) -> T:\n    """文档字符串"""\n\n            try:\n                return func(*args, **kwargs)\n            except Exception as e:\n                InfluxDBErrorHandler.logger.warning(f"Exception occurred in {func.__name__}: {e}. Returning fallback value.")\n                return "default"\n        return wrapper\n\n    def _recover_connection(self):\n    """文档字符串"""\n\n        """连接恢复策略"""\n        # 1. 尝试重新连接\n        # 2. 如果失败，切换到备用实例\n        # 3. 发送告警通知\n\n    def circuit_breaker(self, func: Callable[..., T]) -> Callable[..., T]:\n    """文档字符串"""\n\n        """熔断器装饰器"""\n        @wraps(func)\n\n        def wrapper(*args, **kwargs) -> T:\n    """文档字符串"""\n\n            current_time = time.time()\n            # 检查熔断状态\n            if self._circuit_open:\n                if current_time - self._last_failure > self.recovery_timeout:\n                    # 尝试恢复\n                    self._circuit_open = False\n                    self._failures = 0\n                else:\n                    raise RuntimeError("Circuit is open")\n            try:\n                result = func(*args, **kwargs)\n                self._failures = 0\n                return result\n            except Exception as e:\n                self._failures += 1\n                self._last_failure = current_time\n                if self._failures >= self.failure_threshold:\n                    self._circuit_open = True\n                    self.error_handler.log(\n                        f"InfluxDB熔断器触发 - 操作: {func.__name__}",\n                        e,\n                        ErrorLevel.CRITICAL\n                    )\n                raise\n        return wrapper\n\n    @property\n\n    def circuit_state(self):\n    """文档字符串"""\n\n        """获取熔断器状态"""\n        return "open" if self._circuit_open else "closed"\n