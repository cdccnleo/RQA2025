"""\n基础设施层 - 边界条件处理组件\n\n提供边界条件检测、验证和处理功能，确保系统在异常情况下仍能正常运行。\n"""\n\nfrom enum import Enum\nfrom typing import Dict, Any, Optional, Callable, List, Union\nimport logging\nimport os\nimport sys\nimport time\n\nfrom dataclasses import dataclass, field\nimport traceback\n\nlogger = logging.getLogger(__name__)\n\nclass BoundaryCondition(Enum):\n    """边界条件类型"""\n\n    NULL_VALUE = "null_value"\n    EMPTY_COLLECTION = "empty_collection"\n    INVALID_RANGE = "invalid_range"\n    TYPE_MISMATCH = "type_mismatch"\n    RESOURCE_EXHAUSTED = "resource_exhausted"\n    NETWORK_FAILURE = "network_failure"\n    TIMEOUT = "timeout"\n    INVALID_FORMAT = "invalid_format"\n    PERMISSION_DENIED = "permission_denied"\n    DATA_CORRUPTION = "data_corruption"\n\n@dataclass\nclass BoundaryCheckResult:\n    """边界检查结果"""\n\n    condition_type: BoundaryCondition\n    is_boundary_case: bool = False\n    severity: str = "low"  # low, medium, high, critical\n    description: str = ""\n    suggested_action: str = ""\n    metadata: Dict[str, Any] = field(default_factory=dict)\n    timestamp: float = field(default_factory=time.time)\n\n@dataclass\nclass BoundaryHandlingResult:\n    """边界处理结果"""\n\n    handled: bool = False\n    fallback_used: bool = False\n    recovery_action: str = ""\n    processing_time: float = 0.0\n    error_message: Optional[str] = None\n    result_data: Any = None\n\nclass BoundaryConditionHandler:\n    """边界条件处理器"""\n\n    def __init__(self):\n        self.handlers: Dict[BoundaryCondition, Callable] = {}\n        self.fallback_strategies: Dict[BoundaryCondition, Callable] = {}\n        self.check_stats = {\n            'total_checks': 0,\n            'boundary_cases': 0,\n            'handled_cases': 0,\n            'failed_cases': 0\n        }\n\n        self._register_default_handlers()\n\n    def _register_default_handlers(self):\n        """注册默认边界条件处理器"""\n\n        # 空值处理\n        self.register_handler(\n            BoundaryCondition.NULL_VALUE,\n            self._handle_null_value\n        )\n\n        # 空集合处理\n        self.register_handler(\n            BoundaryCondition.EMPTY_COLLECTION,\n            self._handle_empty_collection\n        )\n\n        # 无效范围处理\n        self.register_handler(\n            BoundaryCondition.INVALID_RANGE,\n            self._handle_invalid_range\n        )\n\n        # 类型不匹配处理\n        self.register_handler(\n            BoundaryCondition.TYPE_MISMATCH,\n            self._handle_type_mismatch\n        )\n\n        # 资源耗尽处理\n        self.register_handler(\n            BoundaryCondition.RESOURCE_EXHAUSTED,\n            self._handle_resource_exhausted\n        )\n\n        # 网络故障处理\n        self.register_handler(\n            BoundaryCondition.NETWORK_FAILURE,\n            self._handle_network_failure\n        )\n\n        # 超时处理\n        self.register_handler(\n            BoundaryCondition.TIMEOUT,\n            self._handle_timeout\n        )\n\n        # 格式无效处理\n        self.register_handler(\n            BoundaryCondition.INVALID_FORMAT,\n            self._handle_invalid_format\n        )\n\n        # 权限拒绝处理\n        self.register_handler(\n            BoundaryCondition.PERMISSION_DENIED,\n            self._handle_permission_denied\n        )\n\n        # 数据损坏处理\n        self.register_handler(\n            BoundaryCondition.DATA_CORRUPTION,\n            self._handle_data_corruption\n        )\n\n    def register_handler(self, condition: BoundaryCondition, handler: Callable):\n        """注册边界条件处理器"""\n        self.handlers[condition] = handler\n\n    def register_fallback(self, condition: BoundaryCondition, fallback: Callable):\n        """注册后备策略"""\n        self.fallback_strategies[condition] = fallback\n\n    def check_boundary_conditions(self, data: Any, context: Dict[str, Any] = None) -> List[BoundaryCheckResult]:\n        """检查边界条件"""\n        self.check_stats['total_checks'] += 1\n        results = []\n\n        # 空值检查\n        if data is None:\n            results.append(BoundaryCheckResult(\n                condition_type=BoundaryCondition.NULL_VALUE,\n                is_boundary_case=True,\n                severity="high",\n                description="Null value detected",\n                suggested_action="Provide default value or skip processing"\n            ))\n\n        # 空集合检查\n        elif isinstance(data, (list, dict, set, tuple)) and len(data) == 0:\n            results.append(BoundaryCheckResult(\n                condition_type=BoundaryCondition.EMPTY_COLLECTION,\n                is_boundary_case=True,\n                severity="medium",\n                description="Empty collection detected",\n                suggested_action="Handle empty collection gracefully"\n            ))\n\n        # 类型检查\n        elif not self._is_expected_type(data, context):\n            results.append(BoundaryCheckResult(\n                condition_type=BoundaryCondition.TYPE_MISMATCH,\n                is_boundary_case=True,\n                severity="high",\n                description=f"Type mismatch: expected {context.get('expected_type', 'unknown')}, got {type(data).__name__}",\n                suggested_action="Convert to expected type or reject"\n            ))\n\n        # 范围检查\n        range_check = self._check_value_range(data, context)\n        if range_check:\n            results.append(range_check)\n\n        # 资源检查\n        resource_check = self._check_resource_limits(data, context)\n        if resource_check:\n            results.append(resource_check)\n\n        # 网络状态检查\n        network_check = self._check_network_status(context)\n        if network_check:\n            results.append(network_check)\n\n        if results:\n            self.check_stats['boundary_cases'] += 1\n\n        return results\n\n    def handle_boundary_case(self, result: BoundaryCheckResult, data: Any,\n    """文档字符串"""\n                           context: Dict[str, Any] = None) -> BoundaryHandlingResult:\n        """处理边界情况"""\n        start_time = time.time()\n\n        try:\n            handler = self.handlers.get(result.condition_type)\n            if handler:\n                handling_result = handler(data, context or {})\n                if handling_result.handled:\n                    self.check_stats['handled_cases'] += 1\n                else:\n                    self.check_stats['failed_cases'] += 1\n                handling_result.processing_time = time.time() - start_time\n                return handling_result\n\n            # 使用后备策略\n            fallback = self.fallback_strategies.get(result.condition_type)\n            if fallback:\n                fallback_result = fallback(data, context or {})\n                return BoundaryHandlingResult(\n                    handled=True,\n                    fallback_used=True,\n                    recovery_action="fallback_strategy",\n                    processing_time=time.time() - start_time,\n                    result_data=fallback_result\n                )\n\n            # 默认处理\n            return BoundaryHandlingResult(\n                handled=False,\n                error_message=f"No handler for boundary condition: {result.condition_type.value}",\n                processing_time=time.time() - start_time\n            )\n\n        except Exception as e:\n            logger.error(f"Error handling boundary condition {result.condition_type.value}: {e}")\n            return BoundaryHandlingResult(\n                handled=False,\n                error_message=str(e),\n                processing_time=time.time() - start_time\n            )\n\n    def _is_expected_type(self, data: Any, context: Dict[str, Any]) -> bool:\n        """检查是否为期望类型"""\n        # 如果context为None，返回True（不进行类型检查）\n        if context is None:\n            return True\n\n        expected_type = context.get('expected_type')\n        if not expected_type:\n            return True\n\n        if isinstance(expected_type, type):\n            return isinstance(data, expected_type)\n        elif isinstance(expected_type, str):\n            return type(data).__name__ == expected_type\n        elif isinstance(expected_type, (list, tuple)):\n            return any(isinstance(data, t) for t in expected_type)\n\n        return True\n\n    def _check_value_range(self, data: Any, context: Dict[str, Any]) -> Optional[BoundaryCheckResult]:\n        """检查值范围"""\n        # 如果context为None，返回None\n        if context is None:\n            return None\n\n        min_val = context.get('min_value')\n        max_val = context.get('max_value')\n\n        if min_val is not None and max_val is not None:\n            try:\n                if isinstance(data, (int, float)):\n                    if data < min_val or data > max_val:\n                        return BoundaryCheckResult(\n                            condition_type=BoundaryCondition.INVALID_RANGE,\n                            is_boundary_case=True,\n                            severity="medium",\n                            description=f"Value {data} out of range [{min_val}, {max_val}]",\n                            suggested_action="Clamp value to range or reject"\n                        )\n            except (TypeError, ValueError):\n                pass\n\n        return None\n\n    def _check_resource_limits(self, data: Any, context: Dict[str, Any]) -> Optional[BoundaryCheckResult]:\n        """检查资源限制"""\n        # 如果context为None，返回None\n        if context is None:\n            return None\n\n        # 内存使用检查\n        if hasattr(data, '__sizeof__'):\n            size = sys.getsizeof(data)\n            max_size = context.get('max_memory_size', 100 * 1024 * 1024)  # 100MB\n            if size > max_size:\n                return BoundaryCheckResult(\n                    condition_type=BoundaryCondition.RESOURCE_EXHAUSTED,\n                    is_boundary_case=True,\n                    severity="high",\n                    description=f"Memory usage {size} exceeds limit {max_size}",\n                    suggested_action="Reduce data size or use streaming"\n                )\n\n        # 文件大小检查\n        file_path = context.get('file_path')\n        if file_path and os.path.exists(file_path):\n            file_size = os.path.getsize(file_path)\n            max_file_size = context.get('max_file_size', 100 * 1024 * 1024)  # 100MB\n            if file_size > max_file_size:\n                return BoundaryCheckResult(\n                    condition_type=BoundaryCondition.RESOURCE_EXHAUSTED,\n                    is_boundary_case=True,\n                    severity="high",\n                    description=f"File size {file_size} exceeds limit {max_file_size}",\n                    suggested_action="Split file or use compression"\n                )\n\n        return None\n\n    def _check_network_status(self, context: Dict[str, Any]) -> Optional[BoundaryCheckResult]:\n        """检查网络状态"""\n        # 这里可以实现网络连通性检查\n        # 为了简化，这里返回None表示网络正常\n        return None\n\n    # 边界条件处理器实现\n    def _handle_null_value(self, data: Any, context: Dict[str, Any]) -> BoundaryHandlingResult:\n        """处理空值"""\n        # 如果context为None，返回默认处理结果\n        if context is None:\n            return BoundaryHandlingResult(\n                handled=False,\n                recovery_action="none",\n                replacement_value=None,\n                error_message="Context is None"\n            )\n\n        default_value = context.get('default_value')\n        if default_value is not None:\n            return BoundaryHandlingResult(\n                handled=True,\n                recovery_action="default_value",\n                result_data=default_value\n            )\n\n        return BoundaryHandlingResult(\n            handled=False,\n            error_message="Null value with no default provided"\n        )\n\n    def _handle_empty_collection(self, data: Any, context: Dict[str, Any]) -> BoundaryHandlingResult:\n        """处理空集合"""\n        # 如果context为None，返回默认处理结果\n        if context is None:\n            return BoundaryHandlingResult(\n                handled=False,\n                recovery_action="none",\n                replacement_value=None,\n                error_message="Context is None"\n            )\n\n        if context.get('allow_empty', False):\n            return BoundaryHandlingResult(\n                handled=True,\n                recovery_action="allow_empty",\n                result_data=data\n            )\n\n        default_collection = context.get('default_collection', [])\n        return BoundaryHandlingResult(\n            handled=True,\n            recovery_action="default_collection",\n            result_data=default_collection\n        )\n\n    def _handle_invalid_range(self, data: Any, context: Dict[str, Any]) -> BoundaryHandlingResult:\n        """处理无效范围"""\n        min_val = context.get('min_value')\n        max_val = context.get('max_value')\n        clamp = context.get('clamp_values', True)\n\n        if clamp and isinstance(data, (int, float)):\n            clamped = max(min_val, min(data, max_val))\n            return BoundaryHandlingResult(\n                handled=True,\n                recovery_action="clamp_value",\n                result_data=clamped\n            )\n\n        return BoundaryHandlingResult(\n            handled=False,\n            error_message=f"Value {data} out of range [{min_val}, {max_val}]"\n        )\n\n    def _handle_type_mismatch(self, data: Any, context: Dict[str, Any]) -> BoundaryHandlingResult:\n        """处理类型不匹配"""\n        expected_type = context.get('expected_type')\n        convert = context.get('auto_convert', True)\n\n        if convert:\n            try:\n                if expected_type == 'int' and isinstance(data, str):\n                    result_data = int(data)\n                elif expected_type == 'float' and isinstance(data, str):\n                    result_data = float(data)\n                elif expected_type == 'str':\n                    result_data = str(data)\n                else:\n                    result_data = data\n\n                return BoundaryHandlingResult(\n                    handled=True,\n                    recovery_action="type_conversion",\n                    result_data=result_data\n                )\n            except (ValueError, TypeError):\n                pass\n\n        return BoundaryHandlingResult(\n            handled=False,\n            error_message=f"Cannot convert {type(data).__name__} to {expected_type}"\n        )\n\n    def _handle_resource_exhausted(self, data: Any, context: Dict[str, Any]) -> BoundaryHandlingResult:\n        """处理资源耗尽"""\n        # 实现资源清理或优化策略\n        return BoundaryHandlingResult(\n            handled=True,\n            recovery_action="resource_cleanup",\n            result_data=None\n        )\n\n    def _handle_network_failure(self, data: Any, context: Dict[str, Any]) -> BoundaryHandlingResult:\n        """处理网络故障"""\n        retry_count = context.get('retry_count', 3)\n        # 实现重试逻辑\n        return BoundaryHandlingResult(\n            handled=True,\n            recovery_action="network_retry",\n            result_data=data\n        )\n\n    def _handle_timeout(self, data: Any, context: Dict[str, Any]) -> BoundaryHandlingResult:\n        """处理超时"""\n        return BoundaryHandlingResult(\n            handled=True,\n            recovery_action="timeout_handling",\n            result_data=None\n        )\n\n    def _handle_invalid_format(self, data: Any, context: Dict[str, Any]) -> BoundaryHandlingResult:\n        """处理格式无效"""\n        return BoundaryHandlingResult(\n            handled=False,\n            error_message="Invalid data format"\n        )\n\n    def _handle_permission_denied(self, data: Any, context: Dict[str, Any]) -> BoundaryHandlingResult:\n        """处理权限拒绝"""\n        return BoundaryHandlingResult(\n            handled=False,\n            error_message="Permission denied"\n        )\n\n    def _handle_data_corruption(self, data: Any, context: Dict[str, Any]) -> BoundaryHandlingResult:\n        """处理数据损坏"""\n        # 尝试数据恢复\n        return BoundaryHandlingResult(\n            handled=True,\n            recovery_action="data_recovery",\n            result_data=data\n        )\n\n    def get_stats(self) -> Dict[str, Any]:\n        """获取统计信息"""\n        return self.check_stats.copy()\n\n    def reset_stats(self):\n        """重置统计信息"""\n        self.check_stats = {\n            'total_checks': 0,\n            'boundary_cases': 0,\n            'handled_cases': 0,\n            'failed_cases': 0\n        }\n\ndef create_boundary_condition_handler() -> BoundaryConditionHandler:\n    """创建边界条件处理器"""\n    return BoundaryConditionHandler()\n