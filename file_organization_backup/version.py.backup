"""\n基础设施层 - 工具组件组件\n\nversion 模块\n\n通用工具组件\n提供工具组件相关的功能实现。\n"""\n\nfrom typing import Dict, Optional, List\nimport threading\n\nclass VersionProxy:\n\n    """版本控制代理，管理配置版本历史"""\n\n    def __init__(self):\n        self._versions: Dict[str, Dict[int, Dict]] = {}\n        self._latest_versions: Dict[str, int] = {}\n        self._lock = threading.Lock()\n\n    def add_version(self, env: str, config: Dict) -> int:\n    """文档字符串"""\n\n        """添加新版本配置"\n\n        Args:\n            env: 环境名称\n            config: 配置字典\n\n        Returns:\n            int: 新版本号\n        """\n        with self._lock:\n            if env not in self._versions:\n                self._versions[env] = {}\n                self._latest_versions[env] = 0\n\n            new_version = self._latest_versions[env] + 1\n            self._versions[env][new_version] = config.copy()\n            self._latest_versions[env] = new_version\n            return new_version\n\n    def get_version(self, env: str, version: int) -> Optional[Dict]:\n        """\n        获取特定版本配置\n\n        Args:\n            env: 环境名称\n            version: 版本号，-1表示最新版本\n\n        Returns:\n            Optional[Dict]: 配置字典，不存在返回None\n        """\n        with self._lock:\n            if env not in self._versions:\n                return None\n\n            if version == -1:\n                version = self._latest_versions.get(env, 0)\n\n        return self._versions[env].get(version, None)\n\n    def get_latest_version(self, env: str) -> int:\n        """获取最新版本号\n\n        Args:\n            env: 环境名称\n\n        Returns:\n            int: 最新版本号\n        """\n        with self._lock:\n            return self._latest_versions.get(env, 0)\n\n    def diff_versions(self, env: str, v1: int, v2: int) -> Dict:\n        """比较两个版本差异\n\n        Args:\n            env: 环境名称\n            v1: 版本号1\n            v2: 版本号2\n\n        Returns:\n            Dict: 差异结果\n        """\n        config1 = self.get_version(env, v1)\n        config2 = self.get_version(env, v2)\n\n        if not config1 or not config2:\n            return {}\n\n        # 简单实现 - 实际项目中应该使用更专业的diff算法\n        diff = {}\n        all_keys = set(config1.keys()) | set(config2.keys())\n        for key in all_keys:\n            if config1.get(key) != config2.get(key):\n                diff[key] = {\n                    'old': config1.get(key),\n                    'new': config2.get(key)\n                }\n        return diff\n\n# 快速修复：添加测试文件期望的缺失类\n\n# 全局版本代理实例\n_default_version_proxy_instance = None\n\ndef get_default_version_proxy() -> 'VersionProxy':\n    """获取默认版本代理实例"""\n    global _default_version_proxy_instance\n    if _default_version_proxy_instance is None:\n        _default_version_proxy_instance = VersionProxy()\n    return _default_version_proxy_instance\n\nclass Version:\n    """版本类, 用于表示和管理版本号"""\n\n    def __init__(self, major=0, minor=0, patch=0, prerelease=None, build=None):\n        # 支持字符串输入，如 Version("1.0.0")\n        if isinstance(major, str):\n            version_str = major\n            # 解析版本字符串\n            if '+' in version_str:\n                version_str, build = version_str.split('+', 1)\n            else:\n                build = None\n\n            if '-' in version_str:\n                version_str, prerelease = version_str.split('-', 1)\n            else:\n                prerelease = None\n\n            parts = version_str.split('.')\n            if len(parts) != 3:\n                raise ValueError(f"无效的版本字符串: {major}")\n\n        try:\n            major = int(parts[0])\n            minor = int(parts[1])\n            patch = int(parts[2])\n        except ValueError:\n            raise ValueError(f"无效的版本字符串: {major}")\n\n        if major < 0 or minor < 0 or patch < 0:\n            raise ValueError("版本号不能为负数")\n\n        self.major = major\n        self.minor = minor\n        self.patch = patch\n        self.prerelease = prerelease\n        self.build = build\n\n    def __str__(self):\n        result = f"{self.major}.{self.minor}.{self.patch}"\n        if self.prerelease:\n            result += f"-{self.prerelease}"\n        if self.build:\n            result += f"+{self.build}"\n        return result\n\n    def __eq__(self, other):\n        if isinstance(other, str):\n            # 支持与字符串比较\n            try:\n                other_version = Version(other)\n                return (self.major == other_version.major and\n                        self.minor == other_version.minor and\n                        self.patch == other_version.patch and\n                        self.prerelease == other_version.prerelease)\n            except ValueError:\n                return False\n        elif isinstance(other, Version):\n            return (self.major == other.major and\n                    self.minor == other.minor and\n                    self.patch == other.patch and\n                    self.prerelease == other.prerelease)\n\n    def __hash__(self):\n        return hash((self.major, self.minor, self.patch, self.prerelease))\n\n    def is_prerelease(self) -> bool:\n        """检查是否为预发布版本"""\n        return self.prerelease is not None\n\n    def is_stable(self) -> bool:\n        """检查是否为稳定版本"""\n        return not self.is_prerelease() and self.major >= 1\n\nclass VersionComparator:\n    """版本比较器"""\n\n    def __init__(self):\n        pass\n\n    def compare(self, v1, v2) -> int:\n        """比较两个版本，返回 - 1, 0, 1"""\n        # 支持字符串输入\n        if isinstance(v1, str):\n            v1 = Version(v1)\n        if isinstance(v2, str):\n            v2 = Version(v2)\n\n        if v1.major != v2.major:\n            return -1 if v1.major < v2.major else 1\n        if v1.minor != v2.minor:\n            return -1 if v1.minor < v2.minor else 1\n        if v1.patch != v2.patch:\n            return -1 if v1.patch < v2.patch else 1\n\n        # 处理预发布版本比较\n        if v1.prerelease is None and v2.prerelease is not None:\n            return 1  # 稳定版本 > 预发布版本\n        elif v1.prerelease is not None and v2.prerelease is None:\n            return -1  # 预发布版本 < 稳定版本\n        elif v1.prerelease is not None and v2.prerelease is not None:\n            # 预发布版本之间比较\n            prerelease1 = v1.prerelease\n            prerelease2 = v2.prerelease\n\n            # 处理带数字的预发布版本，如 "beta.2" vs "beta.11"\n            if '.' in prerelease1 or '.' in prerelease2:\n                # 分割预发布版本，如 "beta.2" -> ["beta", "2"]\n                parts1 = prerelease1.split('.')\n                parts2 = prerelease2.split('.')\n\n                # 比较主要部分（如 "beta"）\n                if parts1[0] != parts2[0]:\n                    # 主要部分不同，按预定义顺序比较\n                    prerelease_order = ['alpha', 'beta', 'rc']\n                    try:\n                        idx1 = prerelease_order.index(parts1[0].lower())\n                        idx2 = prerelease_order.index(parts2[0].lower())\n                        if idx1 != idx2:\n                            return -1 if idx1 < idx2 else 1\n                    except ValueError:\n                        # 如果不在预定义列表中，按字符串比较\n                        if parts1[0] != parts2[0]:\n                            return -1 if parts1[0] < parts2[0] else 1\n\n                # 主要部分相同，比较数字部分\n                if len(parts1) > 1 and len(parts2) > 1:\n                    try:\n                        num1 = int(parts1[1])\n                        num2 = int(parts2[1])\n                        if num1 != num2:\n                            return -1 if num1 < num2 else 1\n                    except ValueError:\n                        # 如果数字部分无效，按字符串比较\n                        if prerelease1 != prerelease2:\n                            return -1 if prerelease1 < prerelease2 else 1\n                elif len(parts1) > 1:\n                    # v1有数字部分，v2没有，v1更大\n                    return 1\n                elif len(parts2) > 1:\n                    # v2有数字部分，v1没有，v1更小\n                    return -1\n            else:\n                # 简单预发布版本比较\n                prerelease_order = ['alpha', 'beta', 'rc']\n                try:\n                    idx1 = prerelease_order.index(prerelease1.lower())\n                    idx2 = prerelease_order.index(prerelease2.lower())\n                    if idx1 != idx2:\n                        return -1 if idx1 < idx2 else 1\n                except ValueError:\n                    # 如果不在预定义列表中，按字符串比较\n                    if prerelease1 != prerelease2:\n                        return -1 if prerelease1 < prerelease2 else 1\n\n        return 0\n\n    def less_than(self, v1, v2) -> bool:\n    """文档字符串"""\n        return self.compare(v1, v2) < 0\n\n    def greater_than(self, v1, v2) -> bool:\n    """文档字符串"""\n        return self.compare(v1, v2) > 0\n\n    def equal(self, v1, v2) -> bool:\n    """文档字符串"""\n        return self.compare(v1, v2) == 0\n\n    def is_less_than(self, v1, v2) -> bool:\n        """检查v1是否小于v2"""\n        return self.compare(v1, v2) < 0\n\n    def is_greater_than(self, v1, v2) -> bool:\n        """检查v1是否大于v2"""\n        return self.compare(v1, v2) > 0\n\n    def is_equal_to(self, v1, v2) -> bool:\n        """检查v1是否等于v2"""\n        return self.compare(v1, v2) == 0\n\n    def is_less_than_or_equal_to(self, v1, v2) -> bool:\n        """检查v1是否小于等于v2"""\n        return self.compare(v1, v2) <= 0\n\n    def is_greater_than_or_equal_to(self, v1, v2) -> bool:\n        """检查v1是否大于等于v2"""\n        return self.compare(v1, v2) >= 0\n\nclass VersionManager:\n    """版本管理器"""\n\n    def __init__(self):\n        self._versions: Dict[str, Version] = {}\n        self._current_version: Optional[str] = None\n\n    def register_version(self, name: str, version) -> None:\n        """注册版本"""\n        if isinstance(version, str):\n            version = Version(version)\n        self._versions[name] = version\n\n    def get_version(self, name: str) -> Optional[Version]:\n        """获取版本"""\n        return self._versions.get(name)\n\n    def set_current_version(self, name: str, version) -> bool:\n        """设置当前版本"""\n        if isinstance(version, str):\n            # 如果提供了版本字符串，先注册\n            self.register_version(name, version)\n        elif isinstance(version, Version):\n            # 如果提供了Version对象，直接注册\n            self.register_version(name, version)\n\n        if name in self._versions:\n            self._current_version = name  # 存储应用名称，不是Version对象\n            return True\n        return False\n\n    def get_current_version(self) -> Optional[Version]:\n        """获取当前版本"""\n        if self._current_version:\n            return self._versions.get(self._current_version)\n        return None\n\n    def list_versions(self) -> Dict[str, Version]:\n        """列出所有版本"""\n        return self._versions.copy()\n\n    def remove_version(self, name: str) -> bool:\n        """移除版本"""\n        if name in self._versions:\n            del self._versions[name]\n            if self._current_version == name:\n                self._current_version = None\n            return True\n        return False\n\n    def clear_versions(self) -> None:\n        """清空所有版本"""\n        self._versions.clear()\n        self._current_version = None\n\n    def version_exists(self, name: str) -> bool:\n        """检查版本是否存在"""\n        return name in self._versions\n\n    def update_version(self, name: str, new_version) -> bool:\n        """更新版本"""\n        if isinstance(new_version, str):\n            new_version = Version(new_version)\n\n        # 如果版本不存在，创建新版本\n        if name not in self._versions:\n            self._versions[name] = new_version\n            return True\n\n        # 如果版本存在，更新它\n        self._versions[name] = new_version\n        return True\n\nclass VersionPolicy:\n    """版本策略"""\n\n    def __init__(self):\n        self._policies: Dict[str, callable] = {}\n        # 默认策略函数，但不立即添加到策略字典中\n        self._default_policy = lambda v: v.is_stable() and v.major >= 1\n\n    def add_policy(self, name: str, policy_func: callable) -> None:\n        """添加策略"""\n        self._policies[name] = policy_func\n\n    def remove_policy(self, name: str) -> bool:\n        """移除策略"""\n        if name in self._policies and name != "default":\n            del self._policies[name]\n            return True\n        return False\n\n    def validate_version(self, version, policy_name: str = None) -> bool:\n        """验证版本"""\n        if isinstance(version, str):\n            version = Version(version)\n\n        if policy_name and policy_name in self._policies:\n            # 使用指定的策略\n            return self._policies[policy_name](version)\n        else:\n            # 使用默认策略\n            return self._default_policy(version)\n\n    def list_policies(self) -> List[str]:\n        """列出所有策略"""\n        policies = list(self._policies.keys())\n        # 确保默认策略也在列表中\n        if "default" not in policies:\n            policies.append("default")\n        return policies\n\n    def clear_policies(self) -> None:\n        """清空所有策略"""\n        self._policies.clear()\n