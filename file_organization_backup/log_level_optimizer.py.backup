#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n日志级别优化系统\n提供动态日志级别调整和智能级别推荐\n"""\n\nfrom collections import defaultdict, deque\nfrom enum import Enum\nfrom typing import Dict, List, Any, Optional, Callable\nimport json\nimport logging\nimport threading\nimport time\nimport weakref\n\nfrom dataclasses import dataclass\n\nclass LogLevel(Enum):\n    """日志级别"""\n    TRACE = 0\n    DEBUG = 10\n    INFO = 20\n    WARNING = 30\n    ERROR = 40\n    CRITICAL = 50\n\n@dataclass\nclass LogLevelRule:\n    """日志级别规则"""\n    name: str\n    condition: Callable[[], bool]\n    level: LogLevel\n    priority: int = 0\n    module_pattern: str = "*"\n    function_pattern: str = "*"\n\n@dataclass\nclass LogContext:\n    """日志上下文"""\n    module: str\n    function: str\n    level: LogLevel\n    message: str\n    timestamp: float\n    metadata: Dict[str, Any] = None\n\n    def __post_init__(self):\n        if self.metadata is None:\n            self.metadata = {}\n        if not hasattr(self, 'timestamp') or self.timestamp is None:\n            self.timestamp = time.time()\n\nclass DynamicLogLevelManager:\n    """动态日志级别管理器"""\n\n    def __init__(self):\n        self.rules: List[LogLevelRule] = []\n        self.current_levels: Dict[str, LogLevel] = {}\n        self.default_level = LogLevel.INFO\n        self._lock = threading.RLock()\n\n        # 性能监控\n        self.stats = defaultdict(int)\n        self.level_changes = deque(maxlen=100)\n\n        # 自动调整\n        self.auto_adjust_enabled = True\n        self.adjustment_window = 300  # 5分钟\n        self.error_threshold = 10  # 每5分钟错误数量阈值\n\n    def add_rule(self, rule: LogLevelRule):\n        """添加日志级别规则"""\n        with self._lock:\n            self.rules.append(rule)\n            # 按优先级排序\n            self.rules.sort(key=lambda r: r.priority, reverse=True)\n\n    def get_level(self, module: str, function: str = "",\n    """文档字符串"""\n                 context: Dict[str, Any] = None) -> LogLevel:\n        """获取模块的日志级别"""\n        context = context or {}\n\n        # 检查规则\n        for rule in self.rules:\n            if self._matches_rule(rule, module, function, context):\n                return rule.level\n\n        # 返回默认级别\n        return self.default_level\n\n    def _matches_rule(self, rule: LogLevelRule, module: str,\n    """文档字符串"""\n                     function: str, context: Dict[str, Any]) -> bool:\n        """检查是否匹配规则"""\n        import fnmatch\n\n        # 检查模块模式\n        if not fnmatch.fnmatch(module, rule.module_pattern):\n            return False\n\n        # 检查函数模式\n        if function and rule.function_pattern != "*" and \\n           not fnmatch.fnmatch(function, rule.function_pattern):\n            return False\n\n        # 检查条件\n        if rule.conditions:\n            for key, expected_value in rule.conditions.items():\n                actual_value = context.get(key)\n                if actual_value != expected_value:\n                    return False\n\n        return True\n\n    def set_module_level(self, module: str, level: LogLevel):\n        """设置模块日志级别"""\n        with self._lock:\n            old_level = self.current_levels.get(module)\n            self.current_levels[module] = level\n\n            # 记录级别变更\n            self.level_changes.append({\n                'module': module,\n                'old_level': old_level.name if old_level else None,\n                'new_level': level.name,\n                'timestamp': time.time()\n            })\n\n            self.stats['level_changes'] += 1\n\n    def auto_adjust_levels(self):\n        """自动调整日志级别"""\n        if not self.auto_adjust_enabled:\n            return\n\n        current_time = time.time()\n        window_start = current_time - self.adjustment_window\n\n        # 统计各模块的错误数量\n        module_errors = defaultdict(int)\n\n        for change in self.level_changes:\n            if change['timestamp'] >= window_start:\n                # 这里可以根据实际的错误日志统计来调整\n                pass\n\n        # 基于错误率调整级别\n        for module, error_count in module_errors.items():\n            if error_count > self.error_threshold:\n                # 提高调试级别\n                self.set_module_level(module, LogLevel.DEBUG)\n            elif error_count == 0:\n                # 降低到信息级别\n                self.set_module_level(module, LogLevel.INFO)\n\n    def get_module_levels(self) -> Dict[str, str]:\n        """获取所有模块的日志级别"""\n        with self._lock:\n            return {module: level.name for module, level in self.current_levels.items()}\n\n    def reset_to_defaults(self):\n        """重置为默认级别"""\n        with self._lock:\n            self.current_levels.clear()\n            self.stats['resets'] += 1\n\n    def get_stats(self) -> Dict[str, Any]:\n        """获取统计信息"""\n        with self._lock:\n            return {\n                'total_rules': len(self.rules),\n                'active_modules': len(self.current_levels),\n                'level_changes': self.stats['level_changes'],\n                'resets': self.stats.get('resets', 0),\n                'recent_changes': len(self.level_changes)\n            }\n\nclass LogLevelRecommender:\n    """日志级别推荐器"""\n\n    def __init__(self):\n        self.module_stats = defaultdict(lambda: {\n            'debug_count': 0,\n            'info_count': 0,\n            'warning_count': 0,\n            'error_count': 0,\n            'total_count': 0\n        })\n        self.recommendations = {}\n\n    def analyze_log_entry(self, context: LogContext):\n        """分析日志条目"""\n        module = context.module\n        level = context.level.name.lower()\n\n        stats = self.module_stats[module]\n        stats[f'{level}_count'] += 1\n        stats['total_count'] += 1\n\n    def generate_recommendations(self) -> Dict[str, LogLevel]:\n        """生成级别推荐"""\n        recommendations = {}\n\n        for module, stats in self.module_stats.items():\n            total = stats['total_count']\n            if total < 10:  # 样本不足\n                continue\n\n            error_ratio = (stats['error_count'] + stats['warning_count']) / total\n            debug_ratio = stats['debug_count'] / total\n\n            if error_ratio > 0.3:  # 错误率高\n                recommendations[module] = LogLevel.WARNING\n            elif debug_ratio > 0.8:  # 大多是调试日志\n                recommendations[module] = LogLevel.INFO\n            elif error_ratio < 0.05 and debug_ratio < 0.1:  # 正常运行\n                recommendations[module] = LogLevel.WARNING\n            else:\n                recommendations[module] = LogLevel.INFO\n\n        self.recommendations = recommendations\n        return recommendations\n\n    def get_recommendation(self, module: str) -> Optional[LogLevel]:\n        """获取模块推荐级别"""\n        return self.recommendations.get(module)\n\nclass AdaptiveLogLevelController:\n    """自适应日志级别控制器"""\n\n    def __init__(self, manager=None):\n        self.manager = manager or DynamicLogLevelManager()\n        self.recommender = LogLevelRecommender()\n        self.monitoring_enabled = True\n        self.adjustment_interval = 300  # 5分钟\n        self._monitor_thread = None\n        self._shutdown_event = threading.Event()\n\n    def start_adaptive_control(self):\n        """启动自适应控制"""\n        if self._monitor_thread is None:\n            self._monitor_thread = threading.Thread(\n                target=self._adaptive_loop,\n                daemon=True,\n                name="AdaptiveLogController"\n            )\n            self._monitor_thread.start()\n\n    def stop_adaptive_control(self):\n        """停止自适应控制"""\n        self._shutdown_event.set()\n        if self._monitor_thread and self._monitor_thread.is_alive():\n            self._monitor_thread.join(timeout=5)\n\n    def log_entry_received(self, context: LogContext):\n        """接收日志条目"""\n        if self.monitoring_enabled:\n            self.recommender.analyze_log_entry(context)\n\n    def _adaptive_loop(self):\n        """自适应控制循环"""\n        while not self._shutdown_event.is_set():\n            try:\n                # 生成推荐\n                recommendations = self.recommender.generate_recommendations()\n\n                # 应用推荐\n                for module, recommended_level in recommendations.items():\n                    current_level = self.manager.get_level(module)\n                    if current_level != recommended_level:\n                        self.manager.set_module_level(module, recommended_level)\n\n                # 自动调整\n                self.manager.auto_adjust_levels()\n\n                # 等待下一个调整周期\n                time.sleep(self.adjustment_interval)\n\n            except Exception as e:\n                print(f"自适应日志控制错误: {e}")\n                time.sleep(60)\n\n    def get_current_config(self) -> Dict[str, Any]:\n        """获取当前配置"""\n        return {\n            'manager_stats': self.manager.get_stats(),\n            'recommendations': {k: v.name for k, v in self.recommender.recommendations.items()},\n            'module_levels': self.manager.get_module_levels(),\n            'monitoring_enabled': self.monitoring_enabled\n        }\n\n# 全局实例\n_global_level_manager = None\n_manager_lock = threading.Lock()\n\ndef get_log_level_manager() -> DynamicLogLevelManager:\n    """获取全局日志级别管理器"""\n    global _global_level_manager\n\n    if _global_level_manager is None:\n        with _manager_lock:\n            if _global_level_manager is None:\n                _global_level_manager = DynamicLogLevelManager()\n\n    return _global_level_manager\n\ndef setup_adaptive_logging():\n    """设置自适应日志记录"""\n    manager = get_log_level_manager()\n\n    # 添加一些默认规则\n    rules = [\n        LogLevelRule(\n            module_pattern="src.trading.*",\n            level=LogLevel.DEBUG,\n            priority=10,\n            conditions={"env": "development"}\n        ),\n        LogLevelRule(\n            module_pattern="src.risk.*",\n            level=LogLevel.WARNING,\n            priority=9\n        ),\n        LogLevelRule(\n            module_pattern="src.monitoring.*",\n            level=LogLevel.INFO,\n            priority=8\n        )\n    ]\n\n    for rule in rules:\n        manager.add_rule(rule)\n\n    return manager\n\nif __name__ == "__main__":\n    # 测试日志级别优化系统\n    manager = setup_adaptive_logging()\n\n    # 测试级别获取\n    test_modules = [\n        "src.trading.execution",\n        "src.risk.monitor",\n        "src.monitoring.alert",\n        "src.data.loader"\n    ]\n\n    print("模块日志级别:")\n    for module in test_modules:\n        level = manager.get_level(module)\n        print(f"  {module}: {level.name}")\n\n    # 测试级别设置\n    manager.set_module_level("src.data.loader", LogLevel.DEBUG)\n    print(f"\\n设置后: src.data.loader = {manager.get_level('src.data.loader').name}")\n\n    # 获取统计信息\n    stats = manager.get_stats()\n    print(f"\\n统计信息: {stats}")\n