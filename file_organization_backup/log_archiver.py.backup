#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n日志压缩和归档系统\n提供高效的日志压缩、归档和清理功能\n"""\n\nfrom concurrent.futures import ThreadPoolExecutor\nfrom enum import Enum\nfrom pathlib import Path\nfrom typing import Dict, List, Any, Optional, Callable, Union\nimport bz2\nimport gzip\nimport hashlib\nimport json\nimport os\nimport shutil\nimport tarfile\nimport threading\nimport time\nimport weakref\nimport zipfile\n\nfrom dataclasses import dataclass, field\nimport lz4.frame\n\nclass CompressionType(Enum):\n    """压缩类型"""\n    NONE = "none"\n    GZIP = "gzip"\n    LZ4 = "lz4"\n    BZIP2 = "bzip2"\n    ZIP = "zip"\n    TAR_GZ = "tar.gz"\n\n@dataclass\nclass ArchiveConfig:\n    """归档配置"""\n    compression_type: CompressionType = CompressionType.GZIP\n    max_file_size: int = 100 * 1024 * 1024  # 100MB\n    max_age_days: int = 30\n    backup_count: int = 5\n    archive_path: str = "archives"\n    temp_path: str = "temp"\n    compression_level: int = 6  # 1-9 for gzip/bzip2\n    enable_checksum: bool = True\n    auto_cleanup: bool = True\n\n@dataclass\nclass ArchiveJob:\n    """归档任务"""\n    source_files: List[Path]\n    archive_name: str\n    compression_type: CompressionType\n    priority: int = 0\n    created_at: float = field(default_factory=time.time)\n    completed_at: Optional[float] = None\n    status: str = "pending"\n    error_message: str = ""\n    archive_size: int = 0\n    checksum: str = ""\n\nclass LogArchiver:\n    """日志归档器"""\n\n    def __init__(self, config):\n        # 支持ArchiveConfig对象或dict\n        if isinstance(config, dict):\n            # 从dict创建ArchiveConfig\n            self.config = ArchiveConfig(**config)\n        else:\n            self.config = config\n\n        self._executor = ThreadPoolExecutor(max_workers=4, thread_name_prefix="LogArchiver")\n        self._jobs: Dict[str, ArchiveJob] = {}\n        self._job_lock = threading.RLock()\n        self._shutdown_event = threading.Event()\n\n        # 创建目录\n        self.archive_dir = Path(self.config.archive_path)\n        self.temp_dir = Path(self.config.temp_path)\n        self.archive_dir.mkdir(parents=True, exist_ok=True)\n        self.temp_dir.mkdir(parents=True, exist_ok=True)\n\n        # 统计信息\n        self.stats = {\n            'total_archives': 0,\n            'total_size_saved': 0,\n            'compression_ratio': 0.0,\n            'failed_jobs': 0,\n            'successful_jobs': 0\n        }\n\n    def archive_files(self, files: List[Union[str, Path]],\n    """文档字符串"""\n                     archive_name: Optional[str] = None) -> str:\n        """归档文件列表"""\n        file_paths = [Path(f) for f in files]\n\n        if not archive_name:\n            timestamp = time.strftime("%Y%m%d_%H%M%S")\n            archive_name = f"archive_{timestamp}"\n\n        job = ArchiveJob(\n            source_files=file_paths,\n            archive_name=archive_name,\n            compression_type=self.config.compression_type\n        )\n\n        job_id = self._generate_job_id()\n        with self._job_lock:\n            self._jobs[job_id] = job\n\n        # 提交异步任务\n        self._executor.submit(self._process_archive_job, job_id)\n\n        return job_id\n\n    def archive_single_file(self, file_path: Union[str, Path],\n    """文档字符串"""\n                           archive_name: Optional[str] = None) -> str:\n        """归档单个文件"""\n        return self.archive_files([file_path], archive_name)\n\n    def archive_directory(self, dir_path: Union[str, Path],\n    """文档字符串"""\n                         pattern: str = "*.log",\n                         archive_name: Optional[str] = None) -> str:\n        """归档目录中的文件"""\n        dir_path = Path(dir_path)\n        files = list(dir_path.glob(pattern))\n\n        if not files:\n            raise ValueError(f"在目录 {dir_path} 中没有找到匹配 {pattern} 的文件")\n\n        return self.archive_files(files, archive_name)\n\n    def get_job_status(self, job_id: str) -> Optional[Dict[str, Any]]:\n        """获取任务状态"""\n        with self._job_lock:\n            job = self._jobs.get(job_id)\n            if not job:\n                return None\n\n            return {\n                'job_id': job_id,\n                'status': job.status,\n                'created_at': job.created_at,\n                'completed_at': job.completed_at,\n                'source_files': len(job.source_files),\n                'archive_name': job.archive_name,\n                'compression_type': job.compression_type.value,\n                'archive_size': job.archive_size,\n                'checksum': job.checksum,\n                'error_message': job.error_message\n            }\n\n    def list_archives(self) -> List[Dict[str, Any]]:\n        """列出所有归档文件"""\n        archives = []\n\n        for archive_file in self.archive_dir.glob("*"):\n            if archive_file.is_file():\n                stat = archive_file.stat()\n                archives.append({\n                    'name': archive_file.name,\n                    'path': str(archive_file),\n                    'size': stat.st_size,\n                    'created': stat.st_ctime,\n                    'modified': stat.st_mtime\n                })\n\n        # 按创建时间排序\n        archives.sort(key=lambda x: x['created'], reverse=True)\n        return archives\n\n    def extract_archive(self, archive_name: str, extract_path: Union[str, Path]) -> bool:\n        """解压归档文件"""\n        extract_path = Path(extract_path)\n        extract_path.mkdir(parents=True, exist_ok=True)\n\n        archive_path = self.archive_dir / archive_name\n\n        if not archive_path.exists():\n            raise FileNotFoundError(f"归档文件不存在: {archive_path}")\n\n        try:\n            if archive_name.endswith('.tar.gz') or archive_name.endswith('.tgz'):\n                with tarfile.open(archive_path, 'r:gz') as tar:\n                    tar.extractall(extract_path)\n            elif archive_name.endswith('.zip'):\n                with zipfile.ZipFile(archive_path, 'r') as zip_ref:\n                    zip_ref.extractall(extract_path)\n            elif archive_name.endswith('.gz'):\n                # 单文件gzip\n                with gzip.open(archive_path, 'rb') as f_in:\n                    output_file = extract_path / archive_path.stem\n                    with open(output_file, 'wb') as f_out:\n                        shutil.copyfileobj(f_in, f_out)\n            elif archive_name.endswith('.lz4'):\n                # LZ4文件\n                with lz4.frame.open(archive_path, 'rb') as f_in:\n                    output_file = extract_path / archive_path.stem\n                    with open(output_file, 'wb') as f_out:\n                        shutil.copyfileobj(f_in, f_out)\n            elif archive_name.endswith('.bz2'):\n                with bz2.open(archive_path, 'rb') as f_in:\n                    output_file = extract_path / archive_path.stem\n                    with open(output_file, 'wb') as f_out:\n                        shutil.copyfileobj(f_in, f_out)\n            else:\n                # 复制未压缩文件\n                shutil.copy2(archive_path, extract_path)\n\n            return True\n\n        except Exception as e:\n            print(f"解压归档文件失败: {e}")\n            return False\n\n    def cleanup_old_archives(self, max_age_days: Optional[int] = None):\n        """清理旧的归档文件"""\n        if max_age_days is None:\n            max_age_days = self.config.max_age_days\n\n        current_time = time.time()\n        max_age_seconds = max_age_days * 24 * 60 * 60\n\n        removed_count = 0\n        total_size_freed = 0\n\n        for archive_file in self.archive_dir.glob("*"):\n            if archive_file.is_file():\n                file_age = current_time - archive_file.stat().st_mtime\n                if file_age > max_age_seconds:\n                    file_size = archive_file.stat().st_size\n                    archive_file.unlink()\n                    removed_count += 1\n                    total_size_freed += file_size\n\n        print(f"清理完成: 删除 {removed_count} 个旧归档文件，释放 {total_size_freed} 字节空间")\n\n        # 更新统计信息\n        self.stats['cleanup_removed'] = removed_count\n        self.stats['cleanup_size_freed'] = total_size_freed\n\n    def get_stats(self) -> Dict[str, Any]:\n        """获取统计信息"""\n        with self._job_lock:\n            stats = self.stats.copy()\n            stats['active_jobs'] = len([j for j in self._jobs.values() if j.status == 'running'])\n            stats['pending_jobs'] = len([j for j in self._jobs.values() if j.status == 'pending'])\n            return stats\n\n    def shutdown(self):\n        """关闭归档器"""\n        self._shutdown_event.set()\n        self._executor.shutdown(wait=True)\n\n    def _generate_job_id(self) -> str:\n        """生成任务ID"""\n        return f"archive_{int(time.time() * 1000000)}"\n\n    def _process_archive_job(self, job_id: str):\n        """处理归档任务"""\n        with self._job_lock:\n            job = self._jobs.get(job_id)\n            if not job:\n                return\n\n            job.status = "running"\n\n        try:\n            # 创建临时归档文件\n            temp_archive_path = self._create_archive(job)\n\n            # 计算校验和\n            if self.config.enable_checksum:\n                job.checksum = self._calculate_checksum(temp_archive_path)\n\n            # 移动到归档目录\n            final_archive_path = self.archive_dir / f"{job.archive_name}{self._get_extension()}"\n            shutil.move(temp_archive_path, final_archive_path)\n\n            # 更新任务状态\n            job.completed_at = time.time()\n            job.status = "completed"\n            job.archive_size = final_archive_path.stat().st_size\n\n            # 更新统计信息\n            self.stats['successful_jobs'] += 1\n            self.stats['total_archives'] += 1\n\n            # 计算压缩比\n            original_size = sum(f.stat().st_size for f in job.source_files)\n            if original_size > 0:\n                ratio = (original_size - job.archive_size) / original_size * 100\n                self.stats['compression_ratio'] = (\n                    (self.stats['compression_ratio'] * (self.stats['total_archives'] - 1)) +\n                    ratio\n                ) / self.stats['total_archives']\n                self.stats['total_size_saved'] += (original_size - job.archive_size)\n\n            # 清理源文件（如果需要）\n            if self.config.auto_cleanup:\n                for source_file in job.source_files:\n                    if source_file.exists():\n                        source_file.unlink()\n\n        except Exception as e:\n            # 更新任务状态\n            job.status = "failed"\n            job.error_message = str(e)\n            self.stats['failed_jobs'] += 1\n\n            print(f"归档任务失败: {e}")\n\n    def _create_archive(self, job: ArchiveJob) -> Path:\n        """创建归档文件"""\n        temp_file = self.temp_dir / f"temp_{job.archive_name}"\n\n        if job.compression_type == CompressionType.GZIP:\n            return self._create_gzip_archive(job.source_files, temp_file)\n        elif job.compression_type == CompressionType.LZ4:\n            return self._create_lz4_archive(job.source_files, temp_file)\n        elif job.compression_type == CompressionType.BZIP2:\n            return self._create_bzip2_archive(job.source_files, temp_file)\n        elif job.compression_type == CompressionType.ZIP:\n            return self._create_zip_archive(job.source_files, temp_file)\n        elif job.compression_type == CompressionType.TAR_GZ:\n            return self._create_tar_gz_archive(job.source_files, temp_file)\n        else:\n            # 无压缩\n            return self._create_no_compression_archive(job.source_files, temp_file)\n\n    def _create_gzip_archive(self, files: List[Path], output_path: Path) -> Path:\n        """创建GZIP归档"""\n        if len(files) == 1:\n            # 单文件\n            gzip_path = output_path.with_suffix('.gz')\n            with open(files[0], 'rb') as f_in:\n                with gzip.open(gzip_path, 'wb',\n                              compresslevel=self.config.compression_level) as f_out:\n                    shutil.copyfileobj(f_in, f_out)\n            return gzip_path\n        else:\n            # 多文件，使用tar.gz\n            tar_gz_path = output_path.with_suffix('.tar.gz')\n            with tarfile.open(tar_gz_path, 'w:gz',\n                            compresslevel=self.config.compression_level) as tar:\n                for file_path in files:\n                    tar.add(file_path, arcname=file_path.name)\n            return tar_gz_path\n\n    def _create_lz4_archive(self, files: List[Path], output_path: Path) -> Path:\n        """创建LZ4归档"""\n        try:\n            import lz4.frame\n        except ImportError:\n            raise ImportError("LZ4压缩需要安装lz4库: pip install lz4")\n\n        if len(files) == 1:\n            lz4_path = output_path.with_suffix('.lz4')\n            with open(files[0], 'rb') as f_in:\n                with lz4.frame.open(lz4_path, 'wb') as f_out:\n                    shutil.copyfileobj(f_in, f_out)\n            return lz4_path\n        else:\n            # 多文件不支持原生LZ4，使用tar.lz4\n            raise NotImplementedError("多文件LZ4归档暂不支持")\n\n    def _create_bzip2_archive(self, files: List[Path], output_path: Path) -> Path:\n        """创建BZIP2归档"""\n        if len(files) == 1:\n            bz2_path = output_path.with_suffix('.bz2')\n            with open(files[0], 'rb') as f_in:\n                with bz2.open(bz2_path, 'wb',\n                             compresslevel=self.config.compression_level) as f_out:\n                    shutil.copyfileobj(f_in, f_out)\n            return bz2_path\n        else:\n            raise NotImplementedError("多文件BZIP2归档暂不支持")\n\n    def _create_zip_archive(self, files: List[Path], output_path: Path) -> Path:\n        """创建ZIP归档"""\n        zip_path = output_path.with_suffix('.zip')\n        with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zip_file:\n            for file_path in files:\n                zip_file.write(file_path, file_path.name)\n        return zip_path\n\n    def _create_tar_gz_archive(self, files: List[Path], output_path: Path) -> Path:\n        """创建TAR.GZ归档"""\n        tar_gz_path = output_path.with_suffix('.tar.gz')\n        with tarfile.open(tar_gz_path, 'w:gz',\n                         compresslevel=self.config.compression_level) as tar:\n            for file_path in files:\n                tar.add(file_path, arcname=file_path.name)\n        return tar_gz_path\n\n    def _create_no_compression_archive(self, files: List[Path], output_path: Path) -> Path:\n        """创建无压缩归档"""\n        if len(files) == 1:\n            # 单文件直接复制\n            no_comp_path = output_path.with_suffix('.log')\n            shutil.copy2(files[0], no_comp_path)\n            return no_comp_path\n        else:\n            raise NotImplementedError("多文件无压缩归档暂不支持")\n\n    def _get_extension(self) -> str:\n        """获取文件扩展名"""\n        if self.config.compression_type == CompressionType.GZIP:\n            return '.gz'\n        elif self.config.compression_type == CompressionType.LZ4:\n            return '.lz4'\n        elif self.config.compression_type == CompressionType.BZIP2:\n            return '.bz2'\n        elif self.config.compression_type == CompressionType.ZIP:\n            return '.zip'\n        elif self.config.compression_type == CompressionType.TAR_GZ:\n            return '.tar.gz'\n        else:\n            return ''\n\n    def _calculate_checksum(self, file_path: Path) -> str:\n        """计算文件校验和"""\n        hash_md5 = hashlib.md5()\n        with open(file_path, 'rb') as f:\n            for chunk in iter(lambda: f.read(4096), b""):\n                hash_md5.update(chunk)\n        return hash_md5.hexdigest()\n\n# 全局归档器实例\n_global_archiver = None\n_archiver_lock = threading.Lock()\n\ndef get_log_archiver(config: Optional[ArchiveConfig] = None) -> LogArchiver:\n    """获取全局日志归档器"""\n    global _global_archiver\n\n    if _global_archiver is None:\n        with _archiver_lock:\n            if _global_archiver is None:\n                if config is None:\n                    config = ArchiveConfig()\n                _global_archiver = LogArchiver(config)\n\n    return _global_archiver\n\ndef setup_log_archiving(archive_path: str = "logs/archives",\n    """文档字符串"""\n                       compression: str = "gzip") -> LogArchiver:\n    """设置日志归档"""\n    comp_type = CompressionType(compression.lower())\n\n    config = ArchiveConfig(\n        compression_type=comp_type,\n        archive_path=archive_path,\n        auto_cleanup=True,\n        enable_checksum=True\n    )\n\n    return get_log_archiver(config)\n\nif __name__ == "__main__":\n    # 测试日志归档系统\n    print("设置日志归档系统...")\n    archiver = setup_log_archiving()\n\n    # 创建测试日志文件\n    test_dir = Path("test_logs")\n    test_dir.mkdir(exist_ok=True)\n\n    for i in range(3):\n        test_file = test_dir / f"test_log_{i}.log"\n        with open(test_file, 'w') as f:\n            for j in range(100):\n                f.write(f"2025-02-05 10:00:{j:02d} INFO Test message {j} from file {i}\n")\n\n    print("创建归档任务...")\n    job_id = archiver.archive_directory(test_dir, "*.log", "test_archive")\n\n    # 等待归档完成\n    import time\n    time.sleep(2)\n\n    # 检查任务状态\n    status = archiver.get_job_status(job_id)\n    if status:\n        print(f"归档任务状态: {status['status']}")\n        print(f"归档文件大小: {status['archive_size']} 字节")\n\n    # 列出归档文件\n    archives = archiver.list_archives()\n    print(f"\\n归档文件列表 ({len(archives)} 个):")\n    for archive in archives[:5]:  # 只显示前5个\n        print(f"  {archive['name']}: {archive['size']} 字节")\n\n    # 获取统计信息\n    stats = archiver.get_stats()\n    print(f"\\n归档统计: {stats}")\n\n    # 清理测试文件\n    shutil.rmtree(test_dir)\n    archiver.shutdown()\n