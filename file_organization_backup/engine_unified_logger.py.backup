#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n引擎层统一日志记录器\n整合所有引擎组件的日志记录需求，提供统一的日志接口\n"""\n\nfrom contextlib import contextmanager\nfrom enum import Enum\nfrom typing import Dict, Any, Optional, Union\nimport json\nimport logging\nimport threading\nimport time\nimport uuid\n\nfrom dataclasses import dataclass, asdict\nimport traceback\n\nfrom .unified_formatter import UnifiedStructuredFormatter\nfrom .unified_context import UnifiedLogContext\nfrom .correlation_tracker import CorrelationTracker\nfrom .core_logger import EngineLogger\n\nclass LogLevel(Enum):\n\n    """日志级别枚举"""\n    DEBUG = logging.DEBUG\n    INFO = logging.INFO\n    WARNING = logging.WARNING\n    ERROR = logging.ERROR\n    CRITICAL = logging.CRITICAL\n\nclass LogCategory(Enum):\n\n    """日志分类枚举"""\n    SYSTEM = "system"\n    BUSINESS = "business"\n    PERFORMANCE = "performance"\n    SECURITY = "security"\n    MONITORING = "monitoring"\n    DEBUGGING = "debugging"\n\n# 使用统一的日志上下文\n# @dataclass\n# class LogContext:\n#     """日志上下文信息"""\n#     component: str\n#     operation: str\n#     correlation_id: Optional[str] = None\n    #     user_id: Optional[str] = None\n    #     session_id: Optional[str] = None\n    #     request_id: Optional[str] = None\n    #     extra: Optional[Dict[str, Any]] = None\n\nclass UnifiedEngineLogger:\n\n    """引擎层统一日志记录器"""\n\n    def __init__(self, name: str, config: Optional[Dict[str, Any]] = None):\n\n        self.name = name\n        self.logger = logging.getLogger(name)\n        self._configure_logger(config or {})\n        self._lock = threading.RLock()\n\n        # 创建临时日志记录器用于关联追踪器（使用不同的名称避免冲突）\n        temp_logger = EngineLogger(f"{name}_correlation", config or {})\n        self.correlation_tracker = CorrelationTracker(temp_logger)\n\n    def _configure_logger(self, config: Dict[str, Any]):\n    """文档字符串"""\n\n        """配置日志记录器"""\n        # 设置日志级别\n        level = config.get('level', 'INFO')\n        self.logger.setLevel(getattr(logging, level.upper()))\n\n        # 清除现有处理器\n        for handler in self.logger.handlers[:]:\n            self.logger.removeHandler(handler)\n\n        # 添加控制台处理器\n        if config.get('console_output', True):\n            console_handler = logging.StreamHandler()\n            console_handler.setFormatter(UnifiedStructuredFormatter())\n            self.logger.addHandler(console_handler)\n\n        # 添加文件处理器\n        log_file = config.get('log_file')\n        if log_file:\n            file_handler = logging.FileHandler(log_file, encoding='utf - 8')\n            file_handler.setFormatter(UnifiedStructuredFormatter())\n            self.logger.addHandler(file_handler)\n\n        # 设置传播\n        self.logger.propagate = config.get('propagate', False)\n\n    def _format_message(self, message: str, context: Optional[UnifiedLogContext] = None,\n    """文档字符串"""\n\n                        extra: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:\n        """格式化日志消息"""\n        log_data = {\n            'timestamp': time.time(),\n            'timestamp_iso': time.strftime('%Y-%m-%d %H:%M:%S'),\n            'logger': self.name,\n            'message': message,\n            'correlation_id': self.correlation_tracker.get_current_correlation_id(),\n        }\n\n        if context:\n            log_data.update(asdict(context))\n\n        if extra:\n            log_data.update(extra)\n\n        return log_data\n\n    def _log(self, level: LogLevel, message: str, context: Optional[UnifiedLogContext] = None,\n    """文档字符串"""\n\n             extra: Optional[Dict[str, Any]] = None, exc_info: Optional[Exception] = None):\n        """记录日志"""\n        with self._lock:\n            log_data = self._format_message(message, context, extra)\n\n        if exc_info:\n            log_data['exception'] = {\n                'type': type(exc_info).__name__,\n                'message': str(exc_info),\n                'traceback': traceback.format_exc()\n            }\n\n            # 创建LogRecord并设置额外属性\n        record = self.logger.makeRecord(\n            self.name, level.value, "", 0, message, (), None\n        )\n\n        # 设置额外属性\n        for key, value in log_data.items():\n            setattr(record, key, value)\n\n            # 设置异常信息（如果存在）\n        if exc_info:\n            record.exc_info = (type(exc_info), exc_info, None)\n\n        # 记录日志\n        self.logger.handle(record)\n\n    def debug(self, message: str, context: Optional[UnifiedLogContext] = None,\n    """文档字符串"""\n\n              extra: Optional[Dict[str, Any]] = None):\n        """记录调试日志"""\n        self._log(LogLevel.DEBUG, message, context, extra)\n\n    def info(self, message: str, context: Optional[UnifiedLogContext] = None,\n    """文档字符串"""\n\n             extra: Optional[Dict[str, Any]] = None):\n        """记录信息日志"""\n        self._log(LogLevel.INFO, message, context, extra)\n\n    def warning(self, message: str, context: Optional[UnifiedLogContext] = None,\n    """文档字符串"""\n\n                extra: Optional[Dict[str, Any]] = None):\n        """记录警告日志"""\n        self._log(LogLevel.WARNING, message, context, extra)\n\n    def error(self, message: str, context: Optional[UnifiedLogContext] = None,\n    """文档字符串"""\n\n              extra: Optional[Dict[str, Any]] = None, exc_info: Optional[Exception] = None):\n        """记录错误日志"""\n        self._log(LogLevel.ERROR, message, context, extra, exc_info)\n\n    def critical(self, message: str, context: Optional[UnifiedLogContext] = None,\n    """文档字符串"""\n\n                 extra: Optional[Dict[str, Any]] = None, exc_info: Optional[Exception] = None):\n        """记录严重错误日志"""\n        self._log(LogLevel.CRITICAL, message, context, extra, exc_info)\n\n    @contextmanager\n\n    def operation_context(self, operation: str, component: str = None,\n    """文档字符串"""\n\n                          correlation_id: Optional[str] = None):\n        """操作上下文管理器"""\n        context = UnifiedLogContext(\n            component=component or self.name,\n            operation=operation,\n            correlation_id=correlation_id or str(uuid.uuid4())\n        )\n\n        # 设置当前关联ID\n        self.correlation_tracker.set_current_correlation_id(context.correlation_id)\n        try:\n            self.info(f"开始操作: {operation}", context)\n            yield context\n            self.info(f"操作完成: {operation}", context)\n        except Exception as e:\n            self.error(f"操作失败: {operation}", context, exc_info=e)\n            raise\n\n    def performance_log(self, operation: str, duration: float,\n    """文档字符串"""\n\n                        context: Optional[UnifiedLogContext] = None,\n                        extra: Optional[Dict[str, Any]] = None):\n        """记录性能日志"""\n        perf_data = {\n            'operation': operation,\n            'duration_ms': duration * 1000,\n            'category': LogCategory.PERFORMANCE.value\n        }\n        if extra:\n            perf_data.update(extra)\n\n        self.info(f"性能指标: {operation} 耗时 {duration:.3f}s", context, perf_data)\n\n    def business_log(self, event: str, data: Dict[str, Any],\n    """文档字符串"""\n\n                     context: Optional[UnifiedLogContext] = None):\n        """记录业务日志"""\n        business_data = {\n            'event': event,\n            'data': data,\n            'category': LogCategory.BUSINESS.value\n        }\n        self.info(f"业务事件: {event}", context, business_data)\n\n    def security_log(self, action: str, details: Dict[str, Any],\n    """文档字符串"""\n\n                     context: Optional[UnifiedLogContext] = None):\n        """记录安全日志"""\n        security_data = {\n            'action': action,\n            'details': details,\n            'category': LogCategory.SECURITY.value\n        }\n        self.warning(f"安全事件: {action}", context, security_data)\n\n# 全局日志记录器实例\n_engine_loggers: Dict[str, UnifiedEngineLogger] = {}\n\ndef get_unified_logger(name: str, config: Optional[Dict[str, Any]] = None) -> UnifiedEngineLogger:\n    """文档字符串"""\n\n    """获取统一日志记录器"""\n    if name not in _engine_loggers:\n        _engine_loggers[name] = UnifiedEngineLogger(name, config)\n    return _engine_loggers[name]\n\ndef configure_engine_logging(config: Dict[str, Any]):\n    """文档字符串"""\n\n    """配置引擎日志系统"""\n    # 配置根日志记录器\n    root_config = config.get('root', {})\n    if root_config:\n        root_logger = logging.getLogger()\n        root_logger.setLevel(getattr(logging, root_config.get('level', 'INFO').upper()))\n\n    # 配置特定组件的日志记录器\n    components = config.get('components', {})\n    for component_name, component_config in components.items():\n        get_unified_logger(component_name, component_config)\n\n# 便捷函数\n\ndef get_engine_logger(name: str) -> UnifiedEngineLogger:\n    """文档字符串"""\n\n    """获取引擎日志记录器（便捷函数）"""\n    return get_unified_logger(name)\n\ndef log_operation(operation: str, component: str = None):\n    """文档字符串"""\n\n    """操作日志装饰器"""\n\n    def decorator(func):\n    """文档字符串"""\n\n        def wrapper(*args, **kwargs):\n    """文档字符串"""\n\n            logger = get_engine_logger(component or func.__module__)\n            with logger.operation_context(operation, component):\n                return func(*args, **kwargs)\n        return wrapper\n    return decorator\n\ndef log_performance(operation: str, component: str = None, config: Dict[str, Any] = None):\n    """文档字符串"""\n\n    """性能日志装饰器"""\n\n    def decorator(func):\n    """文档字符串"""\n\n        def wrapper(*args, **kwargs):\n    """文档字符串"""\n\n            if config:\n                logger = get_unified_logger(component or func.__module__, config)\n            else:\n                logger = get_engine_logger(component or func.__module__)\n            start_time = time.time()\n            try:\n                result = func(*args, **kwargs)\n                duration = time.time() - start_time\n                logger.performance_log(operation, duration)\n                return result\n            except Exception as e:\n                duration = time.time() - start_time\n                logger.performance_log(operation, duration, exc_info=e)\n                raise\n        return wrapper\n    return decorator\n