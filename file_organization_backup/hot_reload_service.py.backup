"""\n配置热重载服务\n支持配置文件变更的自动重载\n"""\n\nfrom pathlib import Path\nfrom typing import Callable, Dict, Any, Optional, List\nimport json\nimport logging\nimport os\nimport threading\nimport time\n\nfrom watchdog.events import FileSystemEventHandler\nfrom watchdog.observers import Observer\nimport yaml\n\nlogger = logging.getLogger(__name__)\n\nclass ConfigFileHandler(FileSystemEventHandler):\n\n    """\n    hot_reload_service - 日志系统\n\n    职责说明：\n    负责系统日志记录、日志格式化、日志存储和日志分析\n\n    核心职责：\n    - 日志记录和格式化\n    - 日志级别管理\n    - 日志存储和轮转\n    - 日志分析和监控\n    - 日志搜索和过滤\n    - 日志性能优化\n\n    相关接口：\n    - ILoggingComponent\n    - ILogger\n    - ILogHandler\n    """ """配置文件变更处理器"""\n\n    def __init__(self, callback: Callable[[str, Dict[str, Any]], None]):\n\n        self.callback = callback\n        self.last_modified = {}\n        self.debounce_time = 1.0  # 防抖时间（秒）\n\n    def on_modified(self, event):\n    """文档字符串"""\n\n        """文件修改事件"""\n        if event.is_directory:\n            return\n\n        file_path = event.src_path\n        current_time = time.time()\n\n        # 防抖处理\n        if file_path in self.last_modified:\n            if current_time - self.last_modified[file_path] < self.debounce_time:\n                return\n\n            self.last_modified[file_path] = current_time\n\n        # 延迟处理，确保文件写入完成\n        threading.Timer(0.5, self._process_file_change, args=[file_path]).start()\n\n    def _process_file_change(self, file_path: str):\n    """文档字符串"""\n\n        """处理文件变更"""\n        try:\n            # 检查文件是否存在\n            if not os.path.exists(file_path):\n                logger.warning(f"配置文件不存在: {file_path}")\n                return\n\n            # 读取配置文件\n            config = self._load_config_file(file_path)\n            if config is not None:\n                logger.info(f"配置文件已更新: {file_path}")\n                self.callback(file_path, config)\n\n        except Exception as e:\n            logger.error(f"处理配置文件变更失败: {file_path}, 错误: {e}")\n\n    def _load_config_file(self, file_path: str) -> Optional[Dict[str, Any]]:\n    """文档字符串"""\n\n        """加载配置文件"""\n        try:\n            file_ext = Path(file_path).suffix.lower()\n\n            if file_ext == '.json':\n                with open(file_path, 'r', encoding='utf - 8') as f:\n                    return json.load(f)\n\n            elif file_ext in ['.yml', '.yaml']:\n                with open(file_path, 'r', encoding='utf - 8') as f:\n                    return yaml.safe_load(f)\n\n            elif file_ext == '.ini':\n                import configparser\n                config = configparser.ConfigParser()\n                config.read(file_path, encoding='utf - 8')\n\n                # 转换为字典格式\n                result = {}\n                for section in config.sections():\n                    result[section] = dict(config[section])\n                return result\n\n            else:\n                logger.warning(f"不支持的文件格式: {file_ext}")\n                return None\n\n        except Exception as e:\n            logger.error(f"加载配置文件失败: {file_path}, 错误: {e}")\n            return None\n\nclass HotReloadService:\n\n    """配置热重载服务"""\n\n    def __init__(self):\n\n        self.observer = Observer()\n        self.handlers = {}\n        self.callbacks = {}\n        self.watched_files = set()\n        self._lock = threading.RLock()\n        self._running = False\n\n    def watch_file(self, file_path: str, callback: Callable[[str, Dict[str, Any]], None]) -> bool:\n    """文档字符串"""\n\n        """监听配置文件"""\n        try:\n            file_path = os.path.abspath(file_path)\n\n            with self._lock:\n                if file_path in self.watched_files:\n                    logger.warning(f"文件已在监听中: {file_path}")\n                    return False\n\n                # 检查文件是否存在\n                if not os.path.exists(file_path):\n                    logger.error(f"配置文件不存在: {file_path}")\n                    return False\n\n                # 创建处理器\n                handler = ConfigFileHandler(callback)\n                self.handlers[file_path] = handler\n                self.callbacks[file_path] = callback\n                self.watched_files.add(file_path)\n\n                # 添加到观察者\n                directory = os.path.dirname(file_path)\n                self.observer.schedule(handler, directory, recursive=False)\n\n                logger.info(f"开始监听配置文件: {file_path}")\n                return True\n\n        except Exception as e:\n            logger.error(f"监听配置文件失败: {file_path}, 错误: {e}")\n            return False\n\n    def unwatch_file(self, file_path: str) -> bool:\n    """文档字符串"""\n\n        """取消监听配置文件"""\n        try:\n            file_path = os.path.abspath(file_path)\n\n            with self._lock:\n                if file_path not in self.watched_files:\n                    logger.warning(f"文件未在监听中: {file_path}")\n                    return False\n\n                # 从观察者中移除\n                if file_path in self.handlers:\n                    handler = self.handlers[file_path]\n                    try:\n                        self.observer.unschedule(handler)\n                    except Exception as e:\n                        logger.warning(f"取消调度处理器时出现警告: {e}")\n                    finally:\n                        del self.handlers[file_path]\n\n                # 清理记录\n                self.watched_files.discard(file_path)\n                self.callbacks.pop(file_path, None)\n\n                logger.info(f"停止监听配置文件: {file_path}")\n                return True\n\n        except Exception as e:\n            logger.error(f"取消监听配置文件失败: {file_path}, 错误: {e}")\n            return False\n\n    def watch_directory(self, directory: str, pattern: str = "*.json",\n    """文档字符串"""\n\n                        callback: Callable[[str, Dict[str, Any]], None] = None):\n        """监听目录下的配置文件"""\n        try:\n            directory = os.path.abspath(directory)\n\n            if not os.path.exists(directory):\n                logger.error(f"目录不存在: {directory}")\n                return False\n\n            # 查找匹配的文件\n            import glob\n            pattern_path = os.path.join(directory, pattern)\n            matching_files = glob.glob(pattern_path)\n\n            success_count = 0\n            for file_path in matching_files:\n                if self.watch_file(file_path, callback):\n                    success_count += 1\n\n            logger.info(f"监听目录 {directory} 中的 {success_count} 个配置文件")\n            return success_count > 0\n\n        except Exception as e:\n            logger.error(f"监听目录失败: {directory}, 错误: {e}")\n            return False\n\n    def start(self) -> bool:\n    """文档字符串"""\n\n        """启动热重载服务"""\n        try:\n            with self._lock:\n                if self._running:\n                    logger.warning("热重载服务已在运行")\n                    return False\n\n                self.observer.start()\n                self._running = True\n                logger.info("配置热重载服务已启动")\n                return True\n\n        except Exception as e:\n            logger.error(f"启动热重载服务失败: {e}")\n            return False\n\n    def stop(self) -> bool:\n    """文档字符串"""\n\n        """停止热重载服务"""\n        try:\n            with self._lock:\n                if not self._running:\n                    logger.warning("热重载服务未在运行")\n                    return False\n\n                self.observer.stop()\n                self.observer.join()\n                self._running = False\n\n                # 清理所有监听\n                self.watched_files.clear()\n                self.handlers.clear()\n                self.callbacks.clear()\n\n                logger.info("配置热重载服务已停止")\n                return True\n\n        except Exception as e:\n            logger.error(f"停止热重载服务失败: {e}")\n            return False\n\n    def is_running(self) -> bool:\n    """文档字符串"""\n\n        """检查服务是否运行"""\n        return self._running\n\n    def get_status(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取服务状态"""\n        with self._lock:\n            return {\n                "running": self._running,\n                "watched_files": list(self.watched_files),\n                "total_handlers": len(self.handlers),\n                "total_callbacks": len(self.callbacks)\n            }\n\n    def stop_watching(self) -> bool:\n    """文档字符串"""\n\n        """停止监听所有文件（stop方法的别名，保持向后兼容性）"""\n        return self.stop()\n\n    @classmethod\n\n    def get_instance(cls) -> 'HotReloadService':\n    """文档字符串"""\n\n        """获取全局实例（类方法，保持向后兼容性）"""\n        return get_hot_reload_service()\n\n    def get_watched_files(self) -> List[str]:\n    """文档字符串"""\n\n        """获取正在监听的文件列表"""\n        with self._lock:\n            return list(self.watched_files)\n\n    def reload_all(self) -> Dict[str, bool]:\n    """文档字符串"""\n\n        """重新加载所有监听的配置文件"""\n        results = {}\n\n        with self._lock:\n            for file_path in self.watched_files:\n                try:\n                    if os.path.exists(file_path):\n                        # 手动触发文件变更处理\n                        handler = self.handlers.get(file_path)\n                        if handler:\n                            handler._process_file_change(file_path)\n                            results[file_path] = True\n                        else:\n                            results[file_path] = False\n                    else:\n                        results[file_path] = False\n                        logger.warning(f"配置文件不存在: {file_path}")\n\n                except Exception as e:\n                    results[file_path] = False\n                    logger.error(f"重新加载配置文件失败: {file_path}, 错误: {e}")\n\n        return results\n\n# 全局热重载服务实例\n_global_hot_reload_service = None\n_hot_reload_lock = threading.Lock()\n\ndef get_hot_reload_service() -> HotReloadService:\n    """文档字符串"""\n\n    """获取全局热重载服务实例"""\n    global _global_hot_reload_service\n\n    if _global_hot_reload_service is None:\n        with _hot_reload_lock:\n            if _global_hot_reload_service is None:\n                _global_hot_reload_service = HotReloadService()\n\n    return _global_hot_reload_service\n\ndef start_hot_reload() -> bool:\n    """文档字符串"""\n\n    """启动全局热重载服务"""\n    service = get_hot_reload_service()\n    return service.start()\n\ndef stop_hot_reload() -> bool:\n    """文档字符串"""\n\n    """停止全局热重载服务"""\n    global _global_hot_reload_service\n\n    if _global_hot_reload_service is not None:\n        result = _global_hot_reload_service.stop()\n        if result:\n            _global_hot_reload_service = None\n            return result\n\n    return False\n\ndef watch_config_file(file_path: str, callback: Callable[[str, Dict[str, Any]], None]) -> bool:\n    """文档字符串"""\n\n    """监听配置文件"""\n    service = get_hot_reload_service()\n    return service.watch_file(file_path, callback)\n\ndef unwatch_config_file(file_path: str) -> bool:\n    """文档字符串"""\n\n    """取消监听配置文件"""\n    service = get_hot_reload_service()\n    return service.unwatch_file(file_path)\n\ndef watch_config_directory(directory: str, pattern: str = "*.json",\n    """文档字符串"""\n\n                           callback: Callable[[str, Dict[str, Any]], None] = None):\n    """监听目录下的配置文件"""\n    service = get_hot_reload_service()\n    return service.watch_directory(directory, pattern, callback)\n