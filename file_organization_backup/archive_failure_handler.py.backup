"""
archive_failure_handler 模块

提供 archive_failure_handler 相关功能
"""


from datetime import datetime\nfrom enum import Enum\nfrom typing import Dict, List, Optional, Any, Callable\nimport json\nimport logging\nimport threading\nimport time\n\nfrom dataclasses import dataclass\n\n"""\n基础设施层 - 日志系统组件\n\narchive_failure_handler 模块\n\n日志系统相关的文件\n提供日志系统相关的功能实现。\n"""\n\n#!/usr / bin / env python\n# -*- coding: utf-8 -*-\n\n"""\n归档失败处理策略\n处理InfluxDB到Parquet归档过程中的各种失败情况\n"""\n\nlogger = logging.getLogger(__name__)\n\nclass FailureType(Enum):\n\n    """失败类型"""\n    NETWORK_ERROR = "network_error"\n    STORAGE_ERROR = "storage_error"\n    DATA_CORRUPTION = "data_corruption"\n    TIMEOUT_ERROR = "timeout_error"\n    PERMISSION_ERROR = "permission_error"\n    RESOURCE_EXHAUSTED = "resource_exhausted"\n    UNKNOWN_ERROR = "unknown_error"\n\nclass RecoveryStrategy(Enum):\n\n    """恢复策略"""\n    RETRY = "retry"\n    FALLBACK = "fallback"\n    SKIP = "skip"\n    MANUAL_INTERVENTION = "manual_intervention"\n\n@dataclass\n\nclass ArchiveTask:\n\n    """归档任务"""\n    task_id: str\n    symbol: str\n    data_type: str\n    start_time: datetime\n    end_time: datetime\n    source_storage: str\n    target_storage: str\n    status: str = "pending"\n    retry_count: int = 0\n    max_retries: int = 3\n    error_message: Optional[str] = None\n    failure_type: Optional[FailureType] = None\n    created_at: datetime = None\n    updated_at: datetime = None\n\n    def __post_init__(self):\n\n        if self.created_at is None:\n            self.created_at = datetime.now()\n        if self.updated_at is None:\n            self.updated_at = datetime.now()\n\n@dataclass\n\nclass RecoveryAction:\n\n    """恢复动作"""\n    action_id: str\n    task_id: str\n    strategy: RecoveryStrategy\n    description: str\n    executed: bool = False\n    success: Optional[bool] = None\n    error_message: Optional[str] = None\n    executed_at: Optional[datetime] = None\n\nclass ArchiveFailureHandler:\n\n    """归档失败处理器"""\n\n    def __init__(self, config: Dict[str, Any]):\n\n        """\n        初始化归档失败处理器\n\n        Args:\n            config: 配置字典\n        """\n        self.config = config\n        self.max_retries = config.get("max_retries", 3)\n        self.retry_delay = config.get("retry_delay", 5)  # 秒\n        self.backoff_multiplier = config.get("backoff_multiplier", 2)\n        self.alert_threshold = config.get("alert_threshold", 5)  # 连续失败次数阈值\n\n        # 失败任务队列\n        self.failed_tasks: List[ArchiveTask] = []\n        self.failed_tasks_lock = threading.RLock()\n\n        # 恢复动作历史\n        self.recovery_actions: List[RecoveryAction] = []\n        self.recovery_lock = threading.RLock()\n\n        # 失败统计\n        self.failure_stats = {\n            "total_failures": 0,\n            "resolved_failures": 0,\n            "pending_failures": 0,\n            "failure_types": {}\n        }\n\n        # 告警回调\n        self.alert_callbacks: List[Callable] = []\n\n        # 启动失败处理监控线程\n        self._running = True\n        self._monitor_thread = threading.Thread(\n            target=self._monitor_failed_tasks,\n            daemon=True,\n            name="ArchiveFailureMonitor"\n        )\n\n        self._monitor_thread.start()\n\n        logger.info("归档失败处理器已启动")\n\n    def handle_archive_failure(self, task: ArchiveTask, error: Exception) -> bool:\n    """文档字符串"""\n\n        """\n        处理归档失败\n\n        Args:\n            task: 归档任务\n            error: 错误信息\n\n        Returns:\n            bool: 处理是否成功\n        """\n        try:\n            # 更新任务状态\n            task.status = "failed"\n            task.error_message = str(error)\n            task.failure_type = self._classify_failure(error)\n            task.updated_at = datetime.now()\n\n            # 添加到失败队列\n            with self.failed_tasks_lock:\n                self.failed_tasks.append(task)\n\n            # 更新统计信息\n            self._update_failure_stats(task.failure_type)\n\n            # 选择恢复策略\n            strategy = self._select_recovery_strategy(task)\n\n            # 执行恢复动作\n            action = RecoveryAction(\n                action_id=f"recovery_{int(time.time())}",\n                task_id=task.task_id,\n                strategy=strategy,\n                description=f"自动恢复: {strategy.value}"\n            )\n\n            success = self._execute_recovery_action(action, task)\n\n            # 记录恢复动作\n            with self.recovery_lock:\n                self.recovery_actions.append(action)\n\n            if success:\n                logger.info(f"归档失败处理成功: {task.task_id}")\n                self._update_failure_stats(task.failure_type, resolved=True)\n            else:\n                logger.error(f"归档失败处理失败: {task.task_id}")\n                self._check_alert_threshold()\n\n            return success\n\n        except Exception as e:\n            logger.error(f"处理归档失败时发生异常: {e}")\n            return False\n\n    def retry_failed_task(self, task_id: str) -> bool:\n    """文档字符串"""\n\n        """\n        重试失败任务\n\n        Args:\n            task_id: 任务ID\n\n        Returns:\n            bool: 重试是否成功\n        """\n        task = self._find_task_by_id(task_id)\n        if not task:\n            logger.error(f"未找到任务: {task_id}")\n            return False\n\n        if task.retry_count >= task.max_retries:\n            logger.warning(f"任务 {task_id} 重试次数已达上限")\n            return False\n\n        try:\n            # 增加重试次数\n            task.retry_count += 1\n            task.status = "retrying"\n            task.updated_at = datetime.now()\n\n            # 执行重试\n            success = self._retry_archive_task(task)\n\n            if success:\n                # 从失败队列中移除\n                with self.failed_tasks_lock:\n                    self.failed_tasks.remove(task)\n                logger.info(f"任务重试成功: {task_id}")\n            else:\n                task.status = "failed"\n                logger.error(f"任务重试失败: {task_id}")\n\n            return success\n\n        except Exception as e:\n            logger.error(f"重试任务时发生异常: {e}")\n            task.status = "failed"\n            return False\n\n    def get_failed_tasks(self, failure_type: Optional[FailureType] = None) -> List[ArchiveTask]:\n    """文档字符串"""\n\n        """\n        获取失败任务列表\n\n        Args:\n            failure_type: 失败类型过滤\n\n        Returns:\n            List[ArchiveTask]: 失败任务列表\n        """\n        with self.failed_tasks_lock:\n            if failure_type:\n                return [task for task in self.failed_tasks if task.failure_type == failure_type]\n            else:\n                return self.failed_tasks.copy()\n\n    def get_failure_statistics(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取失败统计信息\n\n        Returns:\n            Dict: 失败统计信息\n        """\n        with self.failed_tasks_lock:\n            pending_count = len(self.failed_tasks)\n\n        stats = self.failure_stats.copy()\n        stats["pending_failures"] = pending_count\n\n        return stats\n\n    def add_alert_callback(self, callback: Callable[[str, Dict], None]):\n    """文档字符串"""\n\n        """\n        添加告警回调\n\n        Args:\n            callback: 告警回调函数\n        """\n        self.alert_callbacks.append(callback)\n\n    def _classify_failure(self, error: Exception) -> FailureType:\n    """文档字符串"""\n\n        """分类失败类型"""\n        error_str = str(error).lower()\n\n        if any(keyword in error_str for keyword in ["connection", "network", "timeout"]):\n            return FailureType.NETWORK_ERROR\n        elif any(keyword in error_str for keyword in ["disk", "storage", "io"]):\n            return FailureType.STORAGE_ERROR\n        elif any(keyword in error_str for keyword in ["corrupt", "invalid", "format"]):\n            return FailureType.DATA_CORRUPTION\n        elif "timeout" in error_str:\n            return FailureType.TIMEOUT_ERROR\n        elif any(keyword in error_str for keyword in ["permission", "access", "denied"]):\n            return FailureType.PERMISSION_ERROR\n        elif any(keyword in error_str for keyword in ["memory", "disk space", "quota"]):\n            return FailureType.RESOURCE_EXHAUSTED\n        else:\n            return FailureType.UNKNOWN_ERROR\n\n    def _select_recovery_strategy(self, task: ArchiveTask) -> RecoveryStrategy:\n    """文档字符串"""\n\n        """选择恢复策略"""\n        if task.failure_type == FailureType.NETWORK_ERROR:\n            if task.retry_count < task.max_retries:\n                return RecoveryStrategy.RETRY\n            else:\n                return RecoveryStrategy.FALLBACK\n        elif task.failure_type == FailureType.STORAGE_ERROR:\n            return RecoveryStrategy.FALLBACK\n        elif task.failure_type == FailureType.DATA_CORRUPTION:\n            return RecoveryStrategy.MANUAL_INTERVENTION\n        elif task.failure_type == FailureType.TIMEOUT_ERROR:\n            if task.retry_count < task.max_retries:\n                return RecoveryStrategy.RETRY\n            else:\n                return RecoveryStrategy.SKIP\n        elif task.failure_type == FailureType.PERMISSION_ERROR:\n            return RecoveryStrategy.MANUAL_INTERVENTION\n        elif task.failure_type == FailureType.RESOURCE_EXHAUSTED:\n            return RecoveryStrategy.FALLBACK\n        else:\n            return RecoveryStrategy.MANUAL_INTERVENTION\n\n    def _execute_recovery_action(self, action: RecoveryAction, task: ArchiveTask) -> bool:\n    """文档字符串"""\n\n        """执行恢复动作"""\n        try:\n            action.executed = True\n            action.executed_at = datetime.now()\n\n            if action.strategy == RecoveryStrategy.RETRY:\n                success = self._retry_archive_task(task)\n            elif action.strategy == RecoveryStrategy.FALLBACK:\n                success = self._fallback_archive_task(task)\n            elif action.strategy == RecoveryStrategy.SKIP:\n                success = self._skip_archive_task(task)\n            elif action.strategy == RecoveryStrategy.MANUAL_INTERVENTION:\n                success = self._request_manual_intervention(task)\n            else:\n                success = False\n\n            action.success = success\n            if not success:\n                action.error_message = f"恢复策略 {action.strategy.value} 执行失败"\n\n            return success\n\n        except Exception as e:\n            action.success = False\n            action.error_message = str(e)\n            logger.error(f"执行恢复动作失败: {e}")\n            return False\n\n    def _retry_archive_task(self, task: ArchiveTask) -> bool:\n    """文档字符串"""\n\n        """重试归档任务"""\n        try:\n            # 计算重试延迟\n            delay = self.retry_delay * (self.backoff_multiplier ** task.retry_count)\n            time.sleep(delay)\n\n            # 执行归档\n            success = self._execute_archive_task(task)\n\n            if success:\n                logger.info(f"任务重试成功: {task.task_id}")\n            else:\n                logger.warning(f"任务重试失败: {task.task_id}")\n\n            return success\n\n        except Exception as e:\n            logger.error(f"重试任务异常: {e}")\n            return False\n\n    def _fallback_archive_task(self, task: ArchiveTask) -> bool:\n    """文档字符串"""\n\n        """降级归档任务"""\n        try:\n            logger.info(f"执行降级策略: {task.task_id}")\n\n            # 尝试使用备用存储\n            if task.target_storage == "parquet":\n                # 如果目标存储是parquet，尝试使用其他格式\n                success = self._archive_to_alternative_format(task)\n            else:\n                # 如果目标存储不是parquet，尝试使用parquet\n                success = self._archive_to_parquet(task)\n\n            return success\n\n        except Exception as e:\n            logger.error(f"降级归档失败: {e}")\n            return False\n\n    def _skip_archive_task(self, task: ArchiveTask) -> bool:\n    """文档字符串"""\n\n        """跳过归档任务"""\n        try:\n            logger.warning(f"跳过归档任务: {task.task_id}")\n\n            # 记录跳过操作\n            self._log_skipped_task(task)\n\n            # 从失败队列中移除\n            with self.failed_tasks_lock:\n                if task in self.failed_tasks:\n                    self.failed_tasks.remove(task)\n\n            return True\n\n        except Exception as e:\n            logger.error(f"跳过任务失败: {e}")\n            return False\n\n    def _request_manual_intervention(self, task: ArchiveTask) -> bool:\n    """文档字符串"""\n\n        """请求人工干预"""\n        try:\n            alert_message = f"需要人工干预的归档失败: {task.task_id}"\n            alert_data = {\n                "task_id": task.task_id,\n                "symbol": task.symbol,\n                "data_type": task.data_type,\n                "failure_type": task.failure_type.value,\n                "error_message": task.error_message,\n                "retry_count": task.retry_count\n            }\n\n            # 发送告警\n            self._send_alert(alert_message, alert_data)\n\n            logger.warning(f"已请求人工干预: {task.task_id}")\n            return True\n\n        except Exception as e:\n            logger.error(f"请求人工干预失败: {e}")\n            return False\n\n    def _execute_archive_task(self, task: ArchiveTask) -> bool:\n    """文档字符串"""\n\n        """执行归档任务"""\n        try:\n            # 这里应该实现具体的归档逻辑\n            # 简化实现，实际项目中需要对接具体的存储系统\n            logger.info(f"执行归档任务: {task.task_id}")\n\n            # 模拟归档操作\n            time.sleep(1)\n\n            # 模拟成功或失败\n            import random\n            return random.random() > 0.3  # 70 % 成功率\n\n        except Exception as e:\n            logger.error(f"执行归档任务异常: {e}")\n            return False\n\n    def _archive_to_alternative_format(self, task: ArchiveTask) -> bool:\n    """文档字符串"""\n\n        """归档到替代格式"""\n        try:\n            logger.info(f"归档到替代格式: {task.task_id}")\n\n            # 尝试使用CSV格式\n            success = self._archive_to_csv(task)\n\n            if not success:\n                # 尝试使用JSON格式\n                success = self._archive_to_json(task)\n\n            return success\n\n        except Exception as e:\n            logger.error(f"归档到替代格式失败: {e}")\n            return False\n\n    def _archive_to_parquet(self, task: ArchiveTask) -> bool:\n    """文档字符串"""\n\n        """归档到Parquet格式"""\n        try:\n            logger.info(f"归档到Parquet: {task.task_id}")\n\n            # 实现Parquet归档逻辑\n            return self._execute_archive_task(task)\n\n        except Exception as e:\n            logger.error(f"归档到Parquet失败: {e}")\n            return False\n\n    def _archive_to_csv(self, task: ArchiveTask) -> bool:\n    """文档字符串"""\n\n        """归档到CSV格式"""\n        try:\n            logger.info(f"归档到CSV: {task.task_id}")\n\n            # 实现CSV归档逻辑\n            return self._execute_archive_task(task)\n\n        except Exception as e:\n            logger.error(f"归档到CSV失败: {e}")\n            return False\n\n    def _archive_to_json(self, task: ArchiveTask) -> bool:\n    """文档字符串"""\n\n        """归档到JSON格式"""\n        try:\n            logger.info(f"归档到JSON: {task.task_id}")\n\n            # 实现JSON归档逻辑\n            return self._execute_archive_task(task)\n\n        except Exception as e:\n            logger.error(f"归档到JSON失败: {e}")\n            return False\n\n    def _log_skipped_task(self, task: ArchiveTask):\n    """文档字符串"""\n\n        """记录跳过的任务"""\n        skip_log = {\n            "task_id": task.task_id,\n            "symbol": task.symbol,\n            "data_type": task.data_type,\n            "failure_type": task.failure_type.value,\n            "error_message": task.error_message,\n            "skipped_at": datetime.now().isoformat()\n        }\n\n        logger.warning(f"跳过归档任务: {skip_log}")\n\n    def _update_failure_stats(self, failure_type: FailureType, resolved: bool = False):\n    """文档字符串"""\n\n        """更新失败统计"""\n        self.failure_stats["total_failures"] += 1\n\n        if resolved:\n            self.failure_stats["resolved_failures"] += 1\n        else:\n            self.failure_stats["pending_failures"] += 1\n\n        failure_type_str = failure_type.value\n        if failure_type_str not in self.failure_stats["failure_types"]:\n            self.failure_stats["failure_types"][failure_type_str] = 0\n        self.failure_stats["failure_types"][failure_type_str] += 1\n\n    def _check_alert_threshold(self):\n    """文档字符串"""\n\n        """检查告警阈值"""\n        with self.failed_tasks_lock:\n            pending_count = len(self.failed_tasks)\n\n        if pending_count >= self.alert_threshold:\n            alert_message = f"归档失败数量超过阈值: {pending_count}"\n            alert_data = {\n                "pending_failures": pending_count,\n                "alert_threshold": self.alert_threshold,\n                "failure_stats": self.failure_stats\n            }\n\n            self._send_alert(alert_message, alert_data)\n\n    def _send_alert(self, message: str, data: Dict[str, Any]):\n    """文档字符串"""\n\n        """发送告警"""\n        try:\n            for callback in self.alert_callbacks:\n                try:\n                    callback(message, data)\n                except Exception as e:\n                    logger.error(f"告警回调执行失败: {e}")\n\n            logger.critical(f"告警: {message}")\n\n        except Exception as e:\n            logger.error(f"发送告警失败: {e}")\n\n    def _find_task_by_id(self, task_id: str) -> Optional[ArchiveTask]:\n    """文档字符串"""\n\n        """根据任务ID查找任务"""\n        with self.failed_tasks_lock:\n            for task in self.failed_tasks:\n                if task.task_id == task_id:\n                    return task\n        return None\n\n    def _monitor_failed_tasks(self):\n    """文档字符串"""\n\n        """监控失败任务的后台线程"""\n        while self._running:\n            try:\n                # 检查长时间未处理的失败任务\n                current_time = datetime.now()\n                stale_tasks = []\n\n                with self.failed_tasks_lock:\n                    for task in self.failed_tasks:\n                        if (current_time - task.updated_at).total_seconds() > 3600:  # 1小时\n                            stale_tasks.append(task)\n\n                # 处理过期任务\n                for task in stale_tasks:\n                    logger.warning(f"发现过期失败任务: {task.task_id}")\n                    self._handle_stale_task(task)\n\n                time.sleep(300)  # 每5分钟检查一次\n\n            except Exception as e:\n                logger.error(f"失败任务监控异常: {e}")\n                time.sleep(60)\n\n    def _handle_stale_task(self, task: ArchiveTask):\n    """文档字符串"""\n\n        """处理过期任务"""\n        try:\n            # 尝试最后一次重试\n            if task.retry_count < task.max_retries:\n                logger.info(f"对过期任务进行最后一次重试: {task.task_id}")\n                success = self._retry_archive_task(task)\n                if success:\n                    return\n\n            # 如果重试失败，请求人工干预\n            logger.warning(f"过期任务需要人工干预: {task.task_id}")\n            self._request_manual_intervention(task)\n\n        except Exception as e:\n            logger.error(f"处理过期任务异常: {e}")\n\n    def shutdown(self):\n    """文档字符串"""\n\n        """关闭失败处理器"""\n        self._running = False\n        if self._monitor_thread:\n            self._monitor_thread.join(timeout=5)\n        logger.info("归档失败处理器已关闭")\n