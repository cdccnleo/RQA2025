"""\n基础设施层 - 日志系统组件\n\nenhanced_container 模块\n\n日志系统相关的文件\n提供日志系统相关的功能实现。\n"""\n\n#!/usr/bin/env python3\nfrom contextlib import contextmanager\nfrom datetime import datetime, timedelta\nfrom enum import Enum\nfrom typing import Any, Callable, Dict, Optional, Type, Union, List, Set\nimport inspect\nimport logging\nimport threading\nimport time\nimport weakref\n\nfrom dataclasses import dataclass, field\n\n# -*- coding: utf-8 -*-\n"""\nenhanced_container - 日志系统\n\n职责说明：\n负责系统日志记录、日志格式化、日志存储和日志分析\n\n核心职责：\n- 日志记录和格式化\n- 日志级别管理\n- 日志存储和轮转\n- 日志分析和监控\n- 日志搜索和过滤\n- 日志性能优化\n\n相关接口：\n- ILoggingComponent\n- ILogger\n- ILogHandler\n""" """\n增强的依赖注入容器\n\n提供高级依赖注入功能，包括装饰器支持、条件注册、服务验证、性能监控、自动发现等。\n"""\n\nlogger = logging.getLogger(__name__)\n\nclass Lifecycle(Enum):\n\n    """服务生命周期枚举"""\n    SINGLETON = "singleton"  # 单例\n    TRANSIENT = "transient"  # 瞬时\n    SCOPED = "scoped"  # 作用域\n\nclass ServiceStatus(Enum):\n\n    """服务状态枚举"""\n    REGISTERED = "registered"\n    RESOLVED = "resolved"\n    ERROR = "error"\n    DISPOSED = "disposed"\n\n@dataclass\n\nclass ServiceMetrics:\n\n    """服务性能指标"""\n    resolve_count: int = 0\n    total_resolve_time: float = 0.0\n    last_resolve_time: Optional[datetime] = None\n    error_count: int = 0\n    last_error_time: Optional[datetime] = None\n    memory_usage: Optional[int] = None\n\n    @property\n\n    def avg_resolve_time(self) -> float:\n    """文档字符串"""\n\n        """平均解析时间"""\n        return self.total_resolve_time / self.resolve_count if self.resolve_count > 0 else 0.0\n\n    @property\n\n    def success_rate(self) -> float:\n    """文档字符串"""\n\n        """成功率"""\n        total = self.resolve_count + self.error_count\n        return (self.resolve_count / total * 100) if total > 0 else 0.0\n\n@dataclass\n\nclass ServiceInfo:\n\n    """服务信息"""\n    service_type: Type\n    implementation: Optional[Type]\n    factory: Optional[Callable]\n    lifecycle: Lifecycle\n    status: ServiceStatus\n    registration_time: datetime\n    last_resolve_time: Optional[datetime] = None\n    dependencies: List[Type] = field(default_factory=list)\n    metadata: Dict[str, Any] = field(default_factory=dict)\n    metrics: ServiceMetrics = field(default_factory=ServiceMetrics)\n\nclass ServiceValidationError(Exception):\n\n    """服务验证错误"""\n    pass\n\nclass CircularDependencyError(Exception):\n\n    """循环依赖错误"""\n    pass\n\nclass ServiceNotFoundException(Exception):\n\n    """服务未找到异常"""\n    pass\n\nclass ServiceDecorators:\n\n    """服务装饰器"""\n\n    @staticmethod\n\n    def injectable(cls: Type) -> Type:\n    """文档字符串"""\n\n        """可注入装饰器"""\n        cls._is_injectable = True\n        return cls\n\n    @staticmethod\n\n    def singleton(cls: Type) -> Type:\n    """文档字符串"""\n\n        """单例装饰器"""\n        cls._is_singleton = True\n        return cls\n\n    @staticmethod\n\n    def transient(cls: Type) -> Type:\n    """文档字符串"""\n\n        """瞬时装饰器"""\n        cls._is_transient = True\n        return cls\n\n    @staticmethod\n\n    def scoped(cls: Type) -> Type:\n    """文档字符串"""\n\n        """作用域装饰器"""\n        cls._is_scoped = True\n        return cls\n\nclass ServiceValidator:\n\n    """服务验证器"""\n\n    @staticmethod\n\n    def validate_service_type(service_type: Type) -> None:\n    """文档字符串"""\n\n        """验证服务类型"""\n        if not inspect.isclass(service_type):\n            raise ServiceValidationError(f"Service type must be a class: {service_type}")\n\n    @staticmethod\n\n    def validate_factory(factory: Callable) -> None:\n    """文档字符串"""\n\n        """验证工厂函数"""\n        if not callable(factory):\n            raise ServiceValidationError(f"Factory must be callable: {factory}")\n\n    @staticmethod\n\n    def validate_dependencies(service_type: Type, container: 'EnhancedDependencyContainer') -> None:\n    """文档字符串"""\n\n        """验证依赖关系"""\n        try:\n            # 模拟解析以检查依赖\n            container._validate_dependencies(service_type, set())\n        except Exception as e:\n            raise ServiceValidationError(f"Dependency validation failed for {service_type.__name__}: {str(e)}")\n\nclass ServicePerformanceMonitor:\n\n    """服务性能监控器"""\n\n    def __init__(self):\n\n        self._metrics: Dict[Type, ServiceMetrics] = {}\n        self._lock = threading.RLock()\n\n    def record_resolve(self, service_type: Type, resolve_time: float, success: bool = True) -> None:\n    """文档字符串"""\n\n        """记录解析性能"""\n        with self._lock:\n            if service_type not in self._metrics:\n                self._metrics[service_type] = ServiceMetrics()\n\n            metrics = self._metrics[service_type]\n            metrics.resolve_count += 1\n            metrics.total_resolve_time += resolve_time\n            metrics.last_resolve_time = datetime.now()\n\n            if not success:\n                metrics.error_count += 1\n                metrics.last_error_time = datetime.now()\n\n    def get_metrics(self, service_type: Type) -> Optional[ServiceMetrics]:\n    """文档字符串"""\n\n        """获取服务性能指标"""\n        return self._metrics.get(service_type)\n\n    def get_all_metrics(self) -> Dict[Type, ServiceMetrics]:\n    """文档字符串"""\n\n        """获取所有性能指标"""\n        return self._metrics.copy()\n\n    def clear_metrics(self) -> None:\n    """文档字符串"""\n\n        """清空性能指标"""\n        with self._lock:\n            self._metrics.clear()\n\nclass ServiceAutoDiscovery:\n\n    """服务自动发现器"""\n\n    def __init__(self, container: 'EnhancedDependencyContainer'):\n\n        self.container = container\n        self._discovered_services: Set[Type] = set()\n\n    def discover_services(self, module_path: str) -> List[Type]:\n    """文档字符串"""\n\n        """自动发现服务"""\n        try:\n            import importlib\n            module = importlib.import_module(module_path)\n\n            discovered = []\n            for name in dir(module):\n                obj = getattr(module, name)\n                if self._is_injectable_service(obj):\n                    discovered.append(obj)\n                    self._discovered_services.add(obj)\n\n            return discovered\n        except ImportError as e:\n            logger.warning(f"Failed to import module {module_path}: {e}")\n            return []\n\n    def _is_injectable_service(self, obj: Any) -> bool:\n    """文档字符串"""\n\n        """检查是否为可注入服务"""\n        return (inspect.isclass(obj)\n                and hasattr(obj, '_is_injectable')\n                and obj._is_injectable)\n\n    def auto_register_discovered_services(self, module_path: str) -> None:\n    """文档字符串"""\n\n        """自动注册发现的服务"""\n        services = self.discover_services(module_path)\n        for service in services:\n            lifecycle = self._determine_lifecycle(service)\n            self.container.register(service, lifecycle=lifecycle)\n\n    def _determine_lifecycle(self, service: Type) -> Lifecycle:\n    """文档字符串"""\n\n        """确定服务生命周期"""\n        if hasattr(service, '_is_singleton') and service._is_singleton:\n            return Lifecycle.SINGLETON\n        elif hasattr(service, '_is_transient') and service._is_transient:\n            return Lifecycle.TRANSIENT\n        elif hasattr(service, '_is_scoped') and service._is_scoped:\n            return Lifecycle.SCOPED\n        else:\n            return Lifecycle.SINGLETON  # 默认单例\n\nclass EnhancedDependencyContainer:\n\n    """增强的依赖注入容器"""\n\n    def __init__(self):\n\n        self._services: Dict[Type, ServiceInfo] = {}\n        self._scoped_instances: Dict[Type, Any] = {}\n        self._lock = threading.RLock()\n        self._scope_stack = []\n        self._performance_monitor = ServicePerformanceMonitor()\n        self._auto_discovery = ServiceAutoDiscovery(self)\n        self._disposal_callbacks: Dict[Type, List[Callable]] = {}\n        self._circular_dependency_cache: Dict[Type, bool] = {}\n\n    def register(self,\n    """文档字符串"""\n\n                 service_type: Type,\n                 implementation: Optional[Type] = None,\n                 factory: Optional[Callable] = None,\n                 lifecycle: Lifecycle = Lifecycle.SINGLETON,\n                 metadata: Optional[Dict[str, Any]] = None,\n                 disposal_callback: Optional[Callable] = None):\n        """\n        注册服务\n\n        Args:\n            service_type: 服务类型\n            implementation: 实现类型\n            factory: 工厂函数\n            lifecycle: 生命周期\n            metadata: 元数据\n            disposal_callback: 销毁回调\n\n        Returns:\n            容器实例，支持链式调用\n        """\n        with self._lock:\n            # 验证服务\n            ServiceValidator.validate_service_type(service_type)\n            if factory:\n                ServiceValidator.validate_factory(factory)\n\n            # 创建服务信息\n            service_info = ServiceInfo(\n                service_type=service_type,\n                implementation=implementation or service_type,\n                factory=factory,\n                lifecycle=lifecycle,\n                status=ServiceStatus.REGISTERED,\n                registration_time=datetime.now(),\n                metadata=metadata or {}\n            )\n\n            # 分析依赖关系\n            service_info.dependencies = self._analyze_dependencies(service_info)\n\n            # 验证依赖\n            ServiceValidator.validate_dependencies(service_type, self)\n\n            self._services[service_type] = service_info\n\n            # 注册销毁回调\n            if disposal_callback:\n                if service_type not in self._disposal_callbacks:\n                    self._disposal_callbacks[service_type] = []\n                self._disposal_callbacks[service_type].append(disposal_callback)\n\n        return self\n\n    def register_singleton(self,\n    """文档字符串"""\n\n                           service_type: Type,\n                           implementation: Optional[Type] = None,\n                           factory: Optional[Callable] = None,\n                           metadata: Optional[Dict[str, Any]] = None):\n        """注册单例服务"""\n        return self.register(service_type, implementation, factory, Lifecycle.SINGLETON, metadata)\n\n    def register_transient(self,\n    """文档字符串"""\n\n                           service_type: Type,\n                           implementation: Optional[Type] = None,\n                           factory: Optional[Callable] = None,\n                           metadata: Optional[Dict[str, Any]] = None):\n        """注册瞬时服务"""\n        return self.register(service_type, implementation, factory, Lifecycle.TRANSIENT, metadata)\n\n    def register_scoped(self,\n    """文档字符串"""\n\n                        service_type: Type,\n                        implementation: Optional[Type] = None,\n                        factory: Optional[Callable] = None,\n                        metadata: Optional[Dict[str, Any]] = None):\n        """注册作用域服务"""\n        return self.register(service_type, implementation, factory, Lifecycle.SCOPED, metadata)\n\n    def resolve(self, service_type: Type) -> Any:\n    """文档字符串"""\n\n        """\n        解析服务\n\n        Args:\n            service_type: 服务类型\n\n        Returns:\n            服务实例\n\n        Raises:\n            ServiceNotFoundException: 服务未注册\n            CircularDependencyError: 循环依赖\n            Exception: 服务创建失败\n        """\n        start_time = time.time()\n        success = False\n\n        try:\n            with self._lock:\n                if service_type not in self._services:\n                    service_name = getattr(service_type, '__name__', str(service_type))\n                    raise ServiceNotFoundException(f"Service {service_name} not registered")\n\n                service_info = self._services[service_type]\n\n                # 检查循环依赖\n                if self._has_circular_dependency(service_type):\n                    service_name = getattr(service_type, '__name__', str(service_type))\n                    raise CircularDependencyError(f"Circular dependency detected for {service_name}")\n\n                # 根据生命周期返回实例\n                if service_info.lifecycle == Lifecycle.SINGLETON:\n                    instance = self._resolve_singleton(service_info)\n                elif service_info.lifecycle == Lifecycle.TRANSIENT:\n                    instance = self._resolve_transient(service_info)\n                elif service_info.lifecycle == Lifecycle.SCOPED:\n                    instance = self._resolve_scoped(service_info)\n                else:\n                    raise ValueError(f"Unknown lifecycle: {service_info.lifecycle}")\n\n                # 更新服务信息\n                service_info.last_resolve_time = datetime.now()\n                service_info.status = ServiceStatus.RESOLVED\n\n                success = True\n                return instance\n\n        except Exception as e:\n            service_name = getattr(service_type, '__name__', str(service_type))\n            logger.error(f"Failed to resolve service {service_name}: {e}")\n            raise\n        finally:\n            resolve_time = time.time() - start_time\n            self._performance_monitor.record_resolve(service_type, resolve_time, success)\n\n    def _resolve_singleton(self, service_info: ServiceInfo) -> Any:\n    """文档字符串"""\n\n        """解析单例服务"""\n        if not hasattr(service_info, '_instance') or service_info._instance is None:\n            service_info._instance = self._create_instance(service_info)\n        return service_info._instance\n\n    def _resolve_transient(self, service_info: ServiceInfo) -> Any:\n    """文档字符串"""\n\n        """解析瞬时服务"""\n        return self._create_instance(service_info)\n\n    def _resolve_scoped(self, service_info: ServiceInfo) -> Any:\n    """文档字符串"""\n\n        """解析作用域服务"""\n        if not self._scope_stack:\n            raise RuntimeError("Cannot resolve scoped service outside of scope")\n\n        scope_id = id(self._scope_stack[-1])\n        key = (service_info.service_type, scope_id)\n\n        if key not in self._scoped_instances:\n            self._scoped_instances[key] = self._create_instance(service_info)\n\n        return self._scoped_instances[key]\n\n    def _create_instance(self, service_info: ServiceInfo) -> Any:\n    """文档字符串"""\n\n        """创建服务实例"""\n        try:\n            if service_info.factory:\n                return service_info.factory(self)\n            else:\n                # 获取构造函数参数\n                sig = inspect.signature(service_info.implementation.__init__)\n                params = {}\n\n                for name, param in sig.parameters.items():\n                    if name == 'self':\n                        continue\n\n                    if param.annotation != inspect.Parameter.empty:\n                        try:\n                            params[name] = self.resolve(param.annotation)\n                        except ServiceNotFoundException:\n                            if param.default == inspect.Parameter.empty:\n                                annotation_name = getattr(param.annotation, '__name__', str(param.annotation))\n                                service_name = getattr(service_info.service_type, '__name__', str(service_info.service_type))\n                                raise ServiceNotFoundException(f"Cannot resolve dependency {annotation_name} for {service_name}")\n                            params[name] = param.default\n                    else:\n                        if param.default == inspect.Parameter.empty:\n                            service_name = getattr(service_info.service_type, '__name__', str(service_info.service_type))\n                            raise ValueError(f"Parameter {name} in {service_name} has no type annotation")\n                        params[name] = param.default\n\n                return service_info.implementation(**params)\n        except Exception as e:\n            service_info.status = ServiceStatus.ERROR\n            service_name = getattr(service_info.service_type, '__name__', str(service_info.service_type))\n            raise Exception(f"Failed to create instance of {service_name}: {str(e)}") from e\n\n    def _analyze_dependencies(self, service_info: ServiceInfo) -> List[Type]:\n    """文档字符串"""\n\n        """分析服务依赖"""\n        dependencies = []\n\n        if service_info.factory:\n            # 工厂函数的依赖分析比较复杂，暂时跳过\n            return dependencies\n\n        try:\n            sig = inspect.signature(service_info.implementation.__init__)\n            for name, param in sig.parameters.items():\n                if name == 'self':\n                    continue\n\n                if param.annotation != inspect.Parameter.empty:\n                    dependencies.append(param.annotation)\n        except Exception:\n            # 如果无法分析依赖，返回空列表\n            pass\n\n        return dependencies\n\n    def _validate_dependencies(self, service_type: Type, visited: Set[Type]) -> None:\n    """文档字符串"""\n\n        """验证依赖关系"""\n        if service_type in visited:\n            return\n\n        visited.add(service_type)\n\n        if service_type not in self._services:\n            return\n\n        service_info = self._services[service_type]\n        for dependency in service_info.dependencies:\n            self._validate_dependencies(dependency, visited)\n\n    def _has_circular_dependency(self, service_type: Type) -> bool:\n    """文档字符串"""\n\n        """检查循环依赖"""\n        if service_type in self._circular_dependency_cache:\n            return self._circular_dependency_cache[service_type]\n\n        def check_circular(service: Type, visited: Set[Type], path: List[Type]) -> bool:\n    """文档字符串"""\n\n            if service in visited:\n                if service in path:\n                    return True\n                return False\n\n            visited.add(service)\n            path.append(service)\n\n            if service not in self._services:\n                path.pop()\n                return False\n\n            service_info = self._services[service]\n            for dependency in service_info.dependencies:\n                if check_circular(dependency, visited, path):\n                    return True\n\n            path.pop()\n            return False\n\n        has_circular = check_circular(service_type, set(), [])\n        self._circular_dependency_cache[service_type] = has_circular\n        return has_circular\n\n    @contextmanager\n\n    def scope(self):\n    """文档字符串"""\n\n        """创建作用域上下文"""\n        scope_id = object()\n        self._scope_stack.append(scope_id)\n        try:\n            yield self\n        finally:\n            self._scope_stack.pop()\n            # 清理作用域实例\n            keys_to_remove = [key for key in self._scoped_instances.keys() if key[1] == id(scope_id)]\n            for key in keys_to_remove:\n                del self._scoped_instances[key]\n\n    def has_service(self, service_type: Type) -> bool:\n    """文档字符串"""\n\n        """检查服务是否已注册"""\n        return service_type in self._services\n\n    def get_service_info(self, service_type: Type) -> Optional[ServiceInfo]:\n    """文档字符串"""\n\n        """获取服务信息"""\n        return self._services.get(service_type)\n\n    def get_all_services(self) -> Dict[Type, ServiceInfo]:\n    """文档字符串"""\n\n        """获取所有服务信息"""\n        return self._services.copy()\n\n    def get_performance_metrics(self, service_type: Type) -> Optional[ServiceMetrics]:\n    """文档字符串"""\n\n        """获取服务性能指标"""\n        return self._performance_monitor.get_metrics(service_type)\n\n    def get_all_performance_metrics(self) -> Dict[Type, ServiceMetrics]:\n    """文档字符串"""\n\n        """获取所有性能指标"""\n        return self._performance_monitor.get_all_metrics()\n\n    def auto_discover_services(self, module_path: str) -> List[Type]:\n    """文档字符串"""\n\n        """自动发现服务"""\n        return self._auto_discovery.discover_services(module_path)\n\n    def auto_register_discovered_services(self, module_path: str) -> None:\n    """文档字符串"""\n\n        """自动注册发现的服务"""\n        self._auto_discovery.auto_register_discovered_services(module_path)\n\n    def dispose_service(self, service_type: Type) -> None:\n    """文档字符串"""\n\n        """销毁服务"""\n        if service_type in self._disposal_callbacks:\n            for callback in self._disposal_callbacks[service_type]:\n                try:\n                    callback()\n                except Exception as e:\n                    logger.error(f"Error in disposal callback for {service_type.__name__}: {e}")\n\n    def clear(self):\n    """文档字符串"""\n\n        """清空容器"""\n        with self._lock:\n            # 销毁所有服务\n            for service_type in self._services:\n                self.dispose_service(service_type)\n\n            self._services.clear()\n            self._scoped_instances.clear()\n            self._scope_stack.clear()\n            self._circular_dependency_cache.clear()\n            self._performance_monitor.clear_metrics()\n\n# 全局增强容器实例\n_enhanced_container = None\n_enhanced_container_lock = threading.Lock()\n\ndef get_enhanced_container() -> EnhancedDependencyContainer:\n    """文档字符串"""\n\n    """获取全局增强容器实例"""\n    global _enhanced_container\n    if _enhanced_container is None:\n        with _enhanced_container_lock:\n            if _enhanced_container is None:\n                _enhanced_container = EnhancedDependencyContainer()\n    return _enhanced_container\n\ndef register_enhanced(service_type: Type,\n    """文档字符串"""\n\n                      implementation: Optional[Type] = None,\n                      factory: Optional[Callable] = None,\n                      lifecycle: Lifecycle = Lifecycle.SINGLETON,\n                      metadata: Optional[Dict[str, Any]] = None):\n    """注册服务到全局增强容器"""\n    return get_enhanced_container().register(service_type, implementation, factory, lifecycle, metadata)\n\ndef resolve_enhanced(service_type: Type) -> Any:\n    """文档字符串"""\n\n    """从全局增强容器解析服务"""\n    return get_enhanced_container().resolve(service_type)\n\ndef has_service_enhanced(service_type: Type) -> bool:\n    """文档字符串"""\n\n    """检查全局增强容器中是否有服务"""\n    return get_enhanced_container().has_service(service_type)\n\n@contextmanager\n\ndef scope_enhanced():\n    """文档字符串"""\n\n    """创建全局增强容器作用域"""\n    with get_enhanced_container().scope() as container:\n        yield container\n