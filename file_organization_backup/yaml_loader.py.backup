"""\n基础设施层 - 配置管理组件\n\nyaml_loader 模块\n\n配置管理相关的文件\n提供配置管理相关的功能实现。\n"""\n\nfrom pathlib import Path\nfrom typing import Dict, Any, Tuple\n\nfrom ..config_strategy import ConfigLoaderStrategy\nfrom ..exceptions import ConfigError\n\nclass YAMLLoader(ConfigLoaderStrategy):\n\n    """YAML配置加载策略"""\n\n    def __init__(self, registry=None):\n\n        super().__init__()\n        self._registry = registry\n        self._resource_usage_histogram = None\n        self._resource_error_counter = None\n\n    def load(self, source: str) -> Tuple[Dict[str, Any], Dict[str, Any]]:\n    """文档字符串"""\n\n        if self._resource_usage_histogram is None or self._resource_error_counter is None:\n            from prometheus_client import Histogram, Counter\n            self._resource_usage_histogram = Histogram(\n                'resource_usage_seconds',\n                'Time spent processing resource',\n                ['resource_type', 'operation'],\n                buckets=(0.01, 0.1, 0.5, 1, 5, 10, float('inf')),\n                registry=self._registry\n            )\n            self._resource_error_counter = Counter(\n                'resource_errors_total',\n                'Total number of resource processing errors',\n                ['resource_type', 'operation', 'error_type'],\n                registry=self._registry\n            )\n        return self._load_impl(source)\n\n    def _load_impl(self, source: str) -> Tuple[Dict[str, Any], Dict[str, Any]]:\n    """文档字符串"""\n\n        import time\n        import yaml\n        path = Path(source).absolute()\n        operation = 'load'\n        start_time = time.time()\n        try:\n            if not path.exists():\n                raise ConfigError(\n                    f"YAML文件不存在: {source}",\n                    details={'file': str(path), 'error_type': 'file_not_found'}\n                )\n            with open(path, 'r', encoding='utf - 8') as f:\n                data = yaml.safe_load(f)\n                return data, {\n                    'format': 'yaml',\n                    'source': str(path),\n                    'load_time': time.time() - start_time,\n                    'size': path.stat().st_size,\n                    'safe_load': True\n                }\n        except yaml.YAMLError as e:\n            error_type = e.__class__.__name__\n            context = {\n                'file': str(path),\n                'error_type': 'parse_error',\n            }\n            if hasattr(e, 'problem_mark'):\n                context['mark'] = getattr(e, 'problem_mark')\n\n            if self._resource_error_counter is not None:\n                self._resource_error_counter.labels(\n                    resource_type='yaml_loader',\n                    operation=operation,\n                    error_type=error_type\n                ).inc()\n\n            raise ConfigError(\n                f"YAML解析失败: {str(e)}",\n                details=context\n            )\n        except Exception as e:\n            error_type = e.__class__.__name__\n            context = {\n                'file': str(path),\n                'error_type': 'io_error',\n                'error': str(e)\n            }\n\n            if self._resource_error_counter is not None:\n                self._resource_error_counter.labels(\n                    resource_type='yaml_loader',\n                    operation=operation,\n                    error_type=error_type\n                ).inc()\n\n            raise ConfigError(\n                f"加载YAML文件失败: {str(e)}",\n                details=context\n            )\n        finally:\n            duration = time.time() - start_time\n            if self._resource_usage_histogram is not None:\n                self._resource_usage_histogram.labels(\n                    resource_type='yaml_loader',\n                    operation=operation\n                ).observe(duration)\n\n    def can_load(self, source: str) -> bool:\n    """文档字符串"""\n\n        """检查是否为YAML文件"""\n        return isinstance(source, str) and source.lower().endswith(('.yaml', '.yml'))\n\n    def get_supported_extensions(self) -> list:\n    """文档字符串"""\n\n        """获取支持的扩展名"""\n        return ['.yaml', '.yml']\n