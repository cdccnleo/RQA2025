#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n增强版日志记录优化系统\n提供更高性能、更智能的日志处理能力\n"""\n\nfrom collections import defaultdict, deque\nfrom concurrent.futures import ThreadPoolExecutor\nfrom datetime import datetime\nfrom enum import Enum\nfrom pathlib import Path\nfrom typing import Dict, List, Any, Optional, Callable, Union\nimport asyncio\nimport gzip\nimport hashlib\nimport json\nimport logging\nimport os\nimport queue\nimport re\nimport shutil\nimport struct\nimport sys\nimport threading\nimport time\nimport uuid\nimport weakref\n\nfrom dataclasses import dataclass, field\nimport lz4.frame\n\nclass LogLevel(Enum):\n    """日志级别"""\n    TRACE = 0\n    DEBUG = 10\n    INFO = 20\n    WARNING = 30\n    ERROR = 40\n    CRITICAL = 50\n\nclass LogFormat(Enum):\n    """日志格式"""\n    TEXT = "text"\n    JSON = "json"\n    BINARY = "binary"\n    STRUCTURED = "structured"\n\n@dataclass\nclass OptimizedLogEntry:\n    """优化版日志条目"""\n    timestamp: float\n    level: LogLevel\n    logger_name: str\n    message: str\n    module: str = ""\n    function: str = ""\n    line: int = 0\n    thread_id: int = 0\n    process_id: int = 0\n    trace_id: str = ""\n    span_id: str = ""\n    metadata: Dict[str, Any] = field(default_factory=dict)\n    tags: List[str] = field(default_factory=list)\n\n    def __post_init__(self):\n        if not self.trace_id:\n            self.trace_id = str(uuid.uuid4())[:8]\n        if not self.span_id:\n            self.span_id = str(uuid.uuid4())[:8]\n\n@dataclass\nclass LogFilterRule:\n    """日志过滤规则"""\n    name: str\n    condition: Callable[[OptimizedLogEntry], bool]\n    action: str  # "drop", "sample", "modify"\n    sample_rate: float = 1.0\n    enabled: bool = True\n\nclass AsyncLogQueue:\n    """异步日志队列"""\n\n    def __init__(self, max_size: int = 10000, batch_size: int = 100):\n        self.queue = queue.Queue(maxsize=max_size)\n        self.batch_size = batch_size\n        self._shutdown_event = threading.Event()\n        self._worker_thread = None\n        self._processing_lock = threading.Lock()\n\n    def start(self):\n        """启动异步处理"""\n        if self._worker_thread is None:\n            self._worker_thread = threading.Thread(\n                target=self._process_queue,\n                daemon=True,\n                name="AsyncLogProcessor"\n            )\n            self._worker_thread.start()\n\n    def stop(self):\n        """停止异步处理"""\n        self._shutdown_event.set()\n        if self._worker_thread and self._worker_thread.is_alive():\n            self._worker_thread.join(timeout=5)\n\n    def put(self, log_entry: OptimizedLogEntry, timeout: float = 1.0):\n        """添加日志条目"""\n        try:\n            self.queue.put(log_entry, timeout=timeout)\n        except queue.Full:\n            # 队列满时，丢弃低优先级日志\n            if log_entry.level.value <= LogLevel.DEBUG.value:\n                return\n            # 阻塞等待\n            self.queue.put(log_entry)\n\n    def _process_queue(self):\n        """处理队列中的日志"""\n        batch = []\n\n        while not self._shutdown_event.is_set():\n            try:\n                # 收集一批日志\n                while len(batch) < self.batch_size:\n                    try:\n                        log_entry = self.queue.get(timeout=0.1)\n                        batch.append(log_entry)\n                    except queue.Empty:\n                        break\n\n                if batch:\n                    with self._processing_lock:\n                        self._process_batch(batch)\n                    batch.clear()\n\n            except Exception as e:\n                print(f"日志队列处理错误: {e}")\n                time.sleep(1)\n\nclass IntelligentLogFilter:\n    """智能日志过滤器"""\n\n    def __init__(self):\n        self.rules: List[LogFilterRule] = []\n        self.stats = defaultdict(int)\n        self._lock = threading.RLock()\n\n    def add_rule(self, rule: LogFilterRule):\n        """添加过滤规则"""\n        with self._lock:\n            self.rules.append(rule)\n\n    def filter(self, log_entry: OptimizedLogEntry) -> Optional[OptimizedLogEntry]:\n        """过滤日志条目"""\n        for rule in self.rules:\n            if not rule.enabled:\n                continue\n\n            try:\n                if rule.condition(log_entry):\n                    if rule.action == "drop":\n                        self.stats[f"dropped_{rule.name}"] += 1\n                        return None\n                    elif rule.action == "sample":\n                        if self._should_sample(rule.sample_rate):\n                            self.stats[f"sampled_{rule.name}"] += 1\n                            return log_entry\n                        else:\n                            self.stats[f"dropped_{rule.name}"] += 1\n                            return None\n                    elif rule.action == "modify":\n                        self._modify_log_entry(log_entry, rule)\n                        return log_entry\n            except Exception as e:\n                print(f"日志过滤规则执行错误: {e}")\n\n        return log_entry\n\n    def _should_sample(self, sample_rate: float) -> bool:\n        """判断是否采样"""\n        import random\n        return random.random() < sample_rate\n\n    def _modify_log_entry(self, log_entry: OptimizedLogEntry, rule: LogFilterRule):\n        """修改日志条目"""\n        # 这里可以根据规则修改日志条目的内容\n        pass\n\n    def get_stats(self) -> Dict[str, int]:\n        """获取统计信息"""\n        with self._lock:\n            return dict(self.stats)\n\nclass OptimizedLogFormatter:\n    """优化版日志格式化器"""\n\n    def __init__(self, format_type: LogFormat = LogFormat.JSON):\n        self.format_type = format_type\n        self._formatters = {\n            LogFormat.TEXT: self._format_text,\n            LogFormat.JSON: self._format_json,\n            LogFormat.BINARY: self._format_binary,\n            LogFormat.STRUCTURED: self._format_structured\n        }\n\n    def format(self, log_entry: OptimizedLogEntry) -> Union[str, bytes]:\n        """格式化日志条目"""\n        formatter = self._formatters.get(self.format_type, self._format_json)\n        return formatter(log_entry)\n\n    def _format_text(self, log_entry: OptimizedLogEntry) -> str:\n        """格式化为文本"""\n        timestamp = datetime.fromtimestamp(log_entry.timestamp).strftime('%Y-%m-%d %H:%M:%S.%f')\n        level = log_entry.level.name\n        tags = f" [{','.join(log_entry.tags)}]" if log_entry.tags else ""\n\n        return f"{timestamp} [{level}] {log_entry.logger_name}{tags}: {log_entry.message}"\n\n    def _format_json(self, log_entry: OptimizedLogEntry) -> str:\n        """格式化为JSON"""\n        data = {\n            "timestamp": log_entry.timestamp,\n            "level": log_entry.level.name,\n            "logger_name": log_entry.logger_name,\n            "message": log_entry.message,\n            "module": log_entry.module,\n            "function": log_entry.function,\n            "line": log_entry.line,\n            "thread_id": log_entry.thread_id,\n            "process_id": log_entry.process_id,\n            "trace_id": log_entry.trace_id,\n            "span_id": log_entry.span_id,\n            "tags": log_entry.tags,\n            "metadata": log_entry.metadata\n        }\n\n        return json.dumps(data, ensure_ascii=False, separators=(',', ':'))\n\n    def _format_binary(self, log_entry: OptimizedLogEntry) -> bytes:\n        """格式化为二进制"""\n        # 使用紧凑的二进制格式\n        data = json.dumps({\n            "ts": log_entry.timestamp,\n            "lvl": log_entry.level.value,\n            "name": log_entry.logger_name,\n            "msg": log_entry.message,\n            "mod": log_entry.module,\n            "func": log_entry.function,\n            "line": log_entry.line,\n            "tid": log_entry.thread_id,\n            "pid": log_entry.process_id,\n            "trace": log_entry.trace_id,\n            "span": log_entry.span_id,\n            "tags": log_entry.tags,\n            "meta": log_entry.metadata\n        }, separators=(',', ':'))\n\n        return data.encode('utf-8')\n\n    def _format_structured(self, log_entry: OptimizedLogEntry) -> str:\n        """格式化为结构化文本"""\n        timestamp = datetime.fromtimestamp(log_entry.timestamp).strftime('%Y-%m-%d %H:%M:%S')\n        level = log_entry.level.name.ljust(8)\n        logger = log_entry.logger_name.ljust(20)\n        location = f"{log_entry.module}:{log_entry.function}:{log_entry.line}".ljust(30)\n        trace = f"{log_entry.trace_id}/{log_entry.span_id}".ljust(20)\n        tags = f"[{','.join(log_entry.tags)}]" if log_entry.tags else ""\n\n        return f"{timestamp} | {level} | {logger} | {location} | {trace} | {tags} | {log_entry.message}"\n\nclass SmartLogRotator:\n    """智能日志轮转器"""\n\n    def __init__(self, log_dir: str, max_size: int = 100*1024*1024,  # 100MB\n                 backup_count: int = 5, compression: str = "gzip"):\n        self.log_dir = Path(log_dir)\n        self.max_size = max_size\n        self.backup_count = backup_count\n        self.compression = compression\n        self.current_file = None\n        self.current_size = 0\n\n        # 确保日志目录存在\n        self.log_dir.mkdir(parents=True, exist_ok=True)\n\n    def should_rotate(self, new_data_size: int) -> bool:\n        """检查是否需要轮转"""\n        if self.current_file is None:\n            return True\n        return self.current_size + new_data_size > self.max_size\n\n    def rotate(self, current_file: Path) -> Path:\n        """执行日志轮转"""\n        # 重命名当前文件\n        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")\n        rotated_file = current_file.with_suffix(f".{timestamp}{current_file.suffix}")\n\n        if current_file.exists():\n            current_file.rename(rotated_file)\n\n            # 压缩旧日志\n            if self.compression == "gzip":\n                self._compress_gzip(rotated_file)\n            elif self.compression == "lz4":\n                self._compress_lz4(rotated_file)\n\n        # 删除过期的备份\n        self._cleanup_old_backups()\n\n        return current_file\n\n    def _compress_gzip(self, file_path: Path):\n        """GZIP压缩"""\n        compressed_file = file_path.with_suffix(f"{file_path.suffix}.gz")\n\n        with open(file_path, 'rb') as f_in:\n            with gzip.open(compressed_file, 'wb') as f_out:\n                shutil.copyfileobj(f_in, f_out)\n\n        file_path.unlink()  # 删除原始文件\n\n    def _compress_lz4(self, file_path: Path):\n        """LZ4压缩"""\n        try:\n            compressed_file = file_path.with_suffix(f"{file_path.suffix}.lz4")\n\n            with open(file_path, 'rb') as f_in:\n                with lz4.frame.open(compressed_file, 'wb') as f_out:\n                    shutil.copyfileobj(f_in, f_out)\n\n            file_path.unlink()  # 删除原始文件\n        except ImportError:\n            print("LZ4压缩不可用，使用GZIP替代")\n            self._compress_gzip(file_path)\n\n    def _cleanup_old_backups(self):\n        """清理旧的备份文件"""\n        pattern = re.compile(r'.*\.\d{8}_\d{6}\.(log|txt)(\.gz|\.lz4)?$')\n\n        backup_files = []\n        for file_path in self.log_dir.glob("*"):\n            if pattern.match(file_path.name):\n                backup_files.append((file_path, file_path.stat().st_mtime))\n\n        # 按修改时间排序，保留最新的备份\n        backup_files.sort(key=lambda x: x[1], reverse=True)\n\n        for old_file, _ in backup_files[self.backup_count:]:\n            old_file.unlink()\n\nclass EnhancedLogger:\n    """增强版日志记录器"""\n\n    def __init__(self, name: str = "enhanced_logger", level: LogLevel = LogLevel.INFO,\n                 format_type: LogFormat = LogFormat.JSON, log_dir: str = "logs"):\n        self.name = name\n        self.level = level\n        self.format_type = format_type\n        self.log_dir = Path(log_dir)\n\n        # 初始化组件\n        self.queue = AsyncLogQueue()\n        self.filter = IntelligentLogFilter()\n        self.formatter = OptimizedLogFormatter(format_type)\n        self.rotator = SmartLogRotator(log_dir)\n\n        # 日志文件\n        self.log_file = self.log_dir / f"{name}.log"\n        self._file_handle = None\n\n        # 统计信息\n        self.stats = defaultdict(int)\n\n        # 启动异步处理\n        self.queue.start()\n\n    def get_logger(self, name: str) -> 'EnhancedLogger':\n        """获取日志器实例（兼容性方法）"""\n        if name != self.name:\n            # 如果请求不同的名称，返回一个新的实例\n            return EnhancedLogger(name=name, level=self.level)\n        return self\n\n    def log(self, level: LogLevel, message: str, **kwargs):\n        """记录日志"""\n        if level.value < self.level.value:\n            return\n\n        # 获取调用信息\n        frame = sys._getframe(1)\n        module = frame.f_code.co_filename\n        function = frame.f_code.co_name\n        line = frame.f_lineno\n\n        # 创建日志条目\n        log_entry = OptimizedLogEntry(\n            timestamp=time.time(),\n            level=level,\n            logger_name=self.name,\n            message=message,\n            module=module,\n            function=function,\n            line=line,\n            thread_id=threading.get_ident(),\n            process_id=os.getpid(),\n            **kwargs\n        )\n\n        # 应用过滤器\n        filtered_entry = self.filter.filter(log_entry)\n        if filtered_entry is None:\n            return\n\n        # 添加到异步队列\n        self.queue.put(filtered_entry)\n\n        # 更新统计\n        self.stats[f"level_{level.name.lower()}"] += 1\n\n    def debug(self, message: str, **kwargs):\n        """调试日志"""\n        self.log(LogLevel.DEBUG, message, **kwargs)\n\n    def info(self, message: str, **kwargs):\n        """信息日志"""\n        self.log(LogLevel.INFO, message, **kwargs)\n\n    def warning(self, message: str, **kwargs):\n        """警告日志"""\n        self.log(LogLevel.WARNING, message, **kwargs)\n\n    def error(self, message: str, **kwargs):\n        """错误日志"""\n        self.log(LogLevel.ERROR, message, **kwargs)\n\n    def critical(self, message: str, **kwargs):\n        """严重错误日志"""\n        self.log(LogLevel.CRITICAL, message, **kwargs)\n\n    def trace(self, message: str, **kwargs):\n        """跟踪日志"""\n        self.log(LogLevel.TRACE, message, **kwargs)\n\n    def add_filter_rule(self, rule: LogFilterRule):\n        """添加过滤规则"""\n        self.filter.add_rule(rule)\n\n    def set_level(self, level: LogLevel):\n        """设置日志级别"""\n        self.level = level\n\n    def set_format(self, format_type: LogFormat):\n        """设置日志格式"""\n        self.format_type = format_type\n        self.formatter = OptimizedLogFormatter(format_type)\n\n    def get_stats(self) -> Dict[str, Any]:\n        """获取统计信息"""\n        stats = dict(self.stats)\n        stats.update(self.filter.get_stats())\n        stats["queue_size"] = self.queue.queue.qsize()\n        return stats\n\n    def shutdown(self):\n        """关闭日志记录器"""\n        self.queue.stop()\n        if self._file_handle:\n            self._file_handle.close()\n\n    def _process_batch(self, batch: List[OptimizedLogEntry]):\n        """处理一批日志条目"""\n        # 格式化日志\n        formatted_logs = []\n        for entry in batch:\n            formatted = self.formatter.format(entry)\n            formatted_logs.append(formatted)\n\n        # 检查是否需要轮转\n        total_size = sum(len(log.encode('utf-8')) for log in formatted_logs)\n\n        if self.rotator.should_rotate(total_size):\n            if self._file_handle:\n                self._file_handle.close()\n            self.log_file = self.rotator.rotate(self.log_file)\n            self._file_handle = None\n\n        # 写入文件\n        if self._file_handle is None:\n            self._file_handle = open(self.log_file, 'a', encoding='utf-8')\n\n        for formatted_log in formatted_logs:\n            if isinstance(formatted_log, str):\n                self._file_handle.write(formatted_log + '\n')\n            else:\n                # 二进制格式\n                self._file_handle.write(formatted_log.decode('utf-8') + '\n')\n\n        self._file_handle.flush()\n\n# 全局日志记录器实例\n_global_logger = None\n_logger_lock = threading.Lock()\n\ndef get_enhanced_logger(name: str = "rqa2025") -> EnhancedLogger:\n    """获取增强版日志记录器实例"""\n    global _global_logger\n\n    if _global_logger is None:\n        with _logger_lock:\n            if _global_logger is None:\n                _global_logger = EnhancedLogger(name)\n\n    return _global_logger\n\n# 便捷函数\ndef setup_logging(name: str = "rqa2025", level: str = "INFO",\n    """文档字符串"""\n                 format_type: str = "json", log_dir: str = "logs") -> EnhancedLogger:\n    """设置日志记录"""\n    logger = get_enhanced_logger(name)\n\n    # 设置级别\n    level_map = {\n        "TRACE": LogLevel.TRACE,\n        "DEBUG": LogLevel.DEBUG,\n        "INFO": LogLevel.INFO,\n        "WARNING": LogLevel.WARNING,\n        "ERROR": LogLevel.ERROR,\n        "CRITICAL": LogLevel.CRITICAL\n    }\n    logger.set_level(level_map.get(level.upper(), LogLevel.INFO))\n\n    # 设置格式\n    format_map = {\n        "text": LogFormat.TEXT,\n        "json": LogFormat.JSON,\n        "binary": LogFormat.BINARY,\n        "structured": LogFormat.STRUCTURED\n    }\n    logger.set_format(format_map.get(format_type.lower(), LogFormat.JSON))\n\n    return logger\n\nif __name__ == "__main__":\n    # 测试增强版日志记录器\n    logger = setup_logging("test_logger", "DEBUG", "json")\n\n    # 添加过滤规则\n    debug_filter = LogFilterRule(\n        name="debug_sampler",\n        condition=lambda entry: entry.level == LogLevel.DEBUG,\n        action="sample",\n        sample_rate=0.5\n    )\n    logger.add_filter_rule(debug_filter)\n\n    # 测试不同级别的日志\n    for i in range(100):\n        logger.debug(f"调试信息 {i}", tags=["test", "debug"])\n        logger.info(f"信息日志 {i}", tags=["test", "info"])\n        logger.warning(f"警告日志 {i}", tags=["test", "warning"])\n        logger.error(f"错误日志 {i}", tags=["test", "error"])\n\n    # 获取统计信息\n    stats = logger.get_stats()\n    print(f"日志统计: {stats}")\n\n    # 关闭日志记录器\n    logger.shutdown()\n