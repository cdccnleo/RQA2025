\n"""\nRQA2025 Base Cache Manager\n\n基础缓存管理器实现\n"""\n\nfrom abc import ABC, abstractmethod\nfrom enum import Enum\nfrom typing import Any, Dict, List, Optional\nimport logging\nimport threading\nimport time\n\nfrom src.infrastructure.interfaces.cache import (\n\n# 导入统一接口\n    ICacheManager, ICacheComponent, ICacheStrategy,\n    CacheType, CacheStrategy, CacheConfig\n)\n\nlogger = logging.getLogger(__name__)\n\n# 保持向后兼容的别名\nclass ICacheManagerOld(BaseManager, ABC):\n    """缓存管理器接口 (向后兼容)"""\n\n    @abstractmethod\n    def get(self, key: str) -> Optional[Any]:\n        """获取缓存项"""\n        pass\n\n    @abstractmethod\n    def set(self, key: str, value: Any, ttl: Optional[int] = None) -> bool:\n        """设置缓存项"""\n        pass\n\n    @abstractmethod\n    def delete(self, key: str) -> bool:\n        """删除缓存项"""\n        pass\n\n    @abstractmethod\n    def exists(self, key: str) -> bool:\n        """检查缓存项是否存在"""\n        pass\n\n    @abstractmethod\n    def clear(self) -> bool:\n        """清空缓存"""\n        pass\n\nclass CacheLevel(Enum):\n    """缓存级别枚举"""\n    L1 = "L1"             # 内存缓存\n    L2 = "L2"             # Redis缓存\n    L3 = "L3"             # 磁盘缓存\n    MEMORY = "memory"      # 内存缓存\n    REDIS = "redis"        # Redis缓存\n    FILE = "file"          # 本地文件缓存\n    HYBRID = "hybrid"      # 混合缓存\n\nclass BaseCacheManager(ICacheComponent):\n    """基础缓存管理器"""\n\n    def __init__(self, max_size: int = 1000, ttl: int = 3600, strategy: Optional[ICacheStrategy] = None):\n\n        self.max_size = max_size\n        self.ttl = ttl\n        self.strategy = strategy or CacheEvictionStrategy.LRU\n        self.cache = {}\n        self.access_times = {}\n        self.creation_times = {}\n        self.expiry_times = {}  # 存储每个key的过期时间\n        self.lock = threading.RLock()\n\n        logger.info(f"初始化基础缓存管理器: max_size={max_size}, ttl={ttl}")\n\n    def get(self, key: str) -> Any:\n    """文档字符串"""\n\n        """获取缓存项"""\n        with self.lock:\n            if key in self.cache:\n                current_time = time.time()\n                expiry_time = self.expiry_times.get(key, 0)\n\n                # 检查是否过期\n                if current_time > expiry_time:\n                    self._remove_item(key)\n                    return None\n\n                # 更新访问时间\n                self.access_times[key] = current_time\n                return self.cache[key]\n\n            return None\n\n    def set(self, key: str, value: Any, ttl: Optional[int] = None) -> bool:\n    """文档字符串"""\n\n        """设置缓存项"""\n        with self.lock:\n            try:\n                current_time = time.time()\n                item_ttl = ttl if ttl is not None and ttl > 0 else self.ttl\n\n                # 检查缓存是否已满（只有在添加新key且缓存已满时才淘汰）\n                if len(self.cache) >= self.max_size and key not in self.cache:\n                    self._evict_items()\n\n                # 设置缓存项\n                self.cache[key] = value\n                self.creation_times[key] = current_time\n                self.access_times[key] = current_time\n                self.expiry_times[key] = current_time + item_ttl  # 设置过期时间\n\n                logger.debug(f"缓存项设置成功: {key}, TTL={item_ttl}")\n                return True\n\n            except Exception as e:\n                logger.error(f"设置缓存项失败 {key}: {e}")\n                return False\n\n    def delete(self, key: str) -> bool:\n    """文档字符串"""\n\n        """删除缓存项"""\n        with self.lock:\n            if key in self.cache:\n                self._remove_item(key)\n                return True\n            return False\n\n    def exists(self, key: str) -> bool:\n    """文档字符串"""\n\n        """检查缓存项是否存在"""\n        with self.lock:\n            if key not in self.cache:\n                return False\n\n            # 检查是否过期\n            current_time = time.time()\n            expiry_time = self.expiry_times.get(key, 0)\n\n            if current_time > expiry_time:\n                self._remove_item(key)\n                return False\n\n            return True\n\n    def clear(self) -> bool:\n    """文档字符串"""\n\n        """清空缓存"""\n        with self.lock:\n            try:\n                self.cache.clear()\n                self.access_times.clear()\n                self.creation_times.clear()\n                self.expiry_times.clear()  # 清理过期时间\n                logger.info("缓存已清空")\n                return True\n            except Exception as e:\n                logger.error(f"清空缓存失败: {e}")\n                return False\n\n    def size(self) -> int:\n    """文档字符串"""\n\n        """获取缓存大小"""\n        return len(self.cache)\n\n    def keys(self) -> List[str]:\n    """文档字符串"""\n\n        """获取所有键"""\n        return list(self.cache.keys())\n\n    def _remove_item(self, key: str):\n    """文档字符串"""\n\n        """移除缓存项"""\n        if key in self.cache:\n            del self.cache[key]\n        if key in self.access_times:\n            del self.access_times[key]\n        if key in self.creation_times:\n            del self.creation_times[key]\n        if key in self.expiry_times:\n            del self.expiry_times[key]\n\n    def _evict_items(self):\n    """文档字符串"""\n\n        """驱逐缓存项"""\n        if not self.cache:\n            return\n\n        # 简单的LRU策略：移除最少访问的项\n        if len(self.access_times) > 0:\n            # 找到最少访问的键（最早访问的）\n            # 如果有多个相同时间戳，选择第一个\n            min_time = min(self.access_times.values())\n            lru_candidates = [k for k, v in self.access_times.items() if v == min_time]\n\n            # 从LRU候选者中选择一个（按key排序以保证确定性）\n            lru_key = min(lru_candidates)\n\n            # 但是我们应该优先淘汰最早创建的项目，而不是最早访问的\n            # 如果访问时间相同，使用创建时间\n            if len(lru_candidates) > 1:\n                oldest_creation = min(lru_candidates, key=lambda k: self.creation_times.get(k, float('inf')))\n                lru_key = oldest_creation\n\n            self._remove_item(lru_key)\n            logger.debug(f"LRU驱逐缓存项: {lru_key}, 驱逐时间: {self.access_times.get(lru_key, 'unknown')}")\n        else:\n            # 如果没有访问时间记录，移除第一个key\n            first_key = next(iter(self.cache))\n            self._remove_item(first_key)\n            logger.debug(f"LRU驱逐缓存项(无访问记录): {first_key}")\n\n    def get_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取缓存统计信息"""\n        return {\n            'size': len(self.cache),\n            'max_size': self.max_size,\n            'ttl': self.ttl,\n            'hit_rate': 0.0,  # 需要实现命中率统计\n            'strategy': str(self.strategy)\n        }\n