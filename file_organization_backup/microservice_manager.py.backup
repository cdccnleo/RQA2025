"""\n基础设施层 - 日志系统组件\n\nmicroservice_manager 模块\n\n日志系统相关的文件\n提供日志系统相关的功能实现。\n"""\n\n#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n微服务管理器\n\n提供微服务架构能力，包括服务拆分、API网关集成、分布式服务管理等。\n"""\n\nfrom collections import defaultdict\nfrom datetime import datetime, timedelta\nfrom typing import Dict, Any, Optional, List, Callable, Union\nfrom urllib.parse import urljoin\nimport asyncio\nimport json\nimport logging\nimport threading\nimport time\n\nimport requests\n\nfrom ..logging.base_monitor import BaseMonitorComponent as BaseMonitor, AlertLevel\nfrom ..cache.base_cache_manager import BaseCacheManager\n\nclass ServiceEndpoint:\n\n    """服务端点"""\n\n    def __init__(self, service_name: str, url: str, health_check_url: Optional[str] = None):\n\n        """\n        初始化服务端点\n\n        Args:\n            service_name: 服务名称\n            url: 服务URL\n            health_check_url: 健康检查URL\n        """\n        self.service_name = service_name\n        self.url = url\n        self.health_check_url = health_check_url or f"{url}/health"\n        self.last_health_check = None\n        self.is_healthy = True\n        self.response_time = 0.0\n\n    def check_health(self) -> bool:\n    """文档字符串"""\n\n        """检查服务健康状态"""\n        import time\n        start_time = time.time()\n        try:\n            # 模拟健康检查请求\n            response = requests.get(self.health_check_url, timeout=5)\n            self.is_healthy = response.status_code == 200\n            self.response_time = time.time() - start_time\n            self.last_health_check = datetime.now()\n            return self.is_healthy\n        except Exception as e:\n            self.is_healthy = False\n            self.response_time = time.time() - start_time\n            self.last_health_check = datetime.now()\n            return False\n\n    def to_dict(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """转换为字典"""\n        return {\n            'service_name': self.service_name,\n            'url': self.url,\n            'health_check_url': self.health_check_url,\n            'last_health_check': self.last_health_check,\n            'is_healthy': self.is_healthy,\n            'response_time': self.response_time\n        }\n\nclass APIGateway:\n\n    """API网关"""\n\n    def __init__(self, config: Optional[Dict[str, Any]] = None, name: Optional[str] = None, host: Optional[str] = None, port: Optional[int] = None):\n\n        """\n        初始化API网关\n\n        Args:\n            config: 网关配置\n            name: 网关名称\n            host: 主机地址\n            port: 端口号\n        """\n        self.config = config or {}\n\n        # 支持测试中使用的参数\n        if name is not None:\n            self.name = name\n        else:\n            self.name = self.config.get('name', 'api_gateway')\n\n        if host is not None:\n            self.host = host\n        else:\n            self.host = self.config.get('host', 'localhost')\n\n        if port is not None:\n            self.port = port\n        else:\n            self.port = self.config.get('port', 8080)\n\n        self.base_url = f"http://{self.host}:{self.port}"\n        self.routes = {}\n        self.middlewares = []\n\n        self._routes = defaultdict(list)\n        self._middleware = []\n        self._rate_limiters = {}\n        self._lock = threading.RLock()\n\n    def add_route(self, path: str, service_name: str, methods: List[str] = None) -> None:\n    """文档字符串"""\n\n        """\n        添加路由\n\n        Args:\n            path: 路径\n            service_name: 服务名称\n            methods: HTTP方法列表\n        """\n        with self._lock:\n            self._routes[path].append({\n                'service_name': service_name,\n                'methods': methods or ['GET', 'POST', 'PUT', 'DELETE'],\n                'created_at': datetime.now()\n            })\n\n    def remove_route(self, path: str, service_name: str) -> None:\n    """文档字符串"""\n\n        """\n        移除路由\n\n        Args:\n            path: 路径\n            service_name: 服务名称\n        """\n        with self._lock:\n            if path in self._routes:\n                self._routes[path] = [\n                    route for route in self._routes[path]\n                    if route['service_name'] != service_name\n                ]\n\n    def get_routes(self) -> Dict[str, List[Dict[str, Any]]]:\n    """文档字符串"""\n\n        """\n        获取所有路由\n\n        Returns:\n            路由信息\n        """\n        with self._lock:\n            return dict(self._routes)\n\n    def add_middleware(self, middleware: Callable) -> None:\n    """文档字符串"""\n\n        """\n        添加中间件\n\n        Args:\n            middleware: 中间件函数\n        """\n        with self._lock:\n            self._middleware.append(middleware)\n\n    def set_rate_limit(self, service_name: str, requests_per_minute: int) -> None:\n    """文档字符串"""\n\n        """\n        设置速率限制\n\n        Args:\n            service_name: 服务名称\n            requests_per_minute: 每分钟请求数\n        """\n        with self._lock:\n            self._rate_limiters[service_name] = {\n                'limit': requests_per_minute,\n                'requests': [],\n                'created_at': datetime.now()\n            }\n\n    def check_rate_limit(self, service_name: str) -> bool:\n    """文档字符串"""\n\n        """\n        检查速率限制\n\n        Args:\n            service_name: 服务名称\n\n        Returns:\n            是否允许请求\n        """\n        with self._lock:\n            if service_name not in self._rate_limiters:\n                return True\n\n            rate_limiter = self._rate_limiters[service_name]\n            current_time = datetime.now()\n            cutoff_time = current_time - timedelta(minutes=1)\n\n            # 清理过期请求\n            rate_limiter['requests'] = [\n                req_time for req_time in rate_limiter['requests']\n                if req_time > cutoff_time\n            ]\n\n            # 检查是否超过限制\n            if len(rate_limiter['requests']) >= rate_limiter['limit']:\n                return False\n\n            # 添加当前请求\n            rate_limiter['requests'].append(current_time)\n            return True\n\n    def get_gateway_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取网关统计信息\n\n        Returns:\n            统计信息\n        """\n        with self._lock:\n            return {\n                'routes_count': len(self._routes),\n                'middleware_count': len(self._middleware),\n                'rate_limiters_count': len(self._rate_limiters),\n                'total_routes': sum(len(routes) for routes in self._routes.values())\n            }\n\nclass ServiceRegistry:\n\n    """服务注册中心"""\n\n    def __init__(self, config: Optional[Dict[str, Any]] = None):\n\n        """\n        初始化服务注册中心\n\n        Args:\n            config: 注册中心配置\n        """\n        self.config = config or {}\n        self._services = defaultdict(dict)\n        self.services = self._services  # 兼容性属性\n        self.service_versions = defaultdict(dict)  # 兼容性属性\n        self.service_endpoints = self._services  # 兼容性属性\n        self._lock = threading.RLock()\n        self._running = False\n        self._health_check_thread = None\n\n    def register_service(self, service_name: str, endpoint: ServiceEndpoint) -> bool:\n    """文档字符串"""\n\n        """\n        注册服务\n\n        Args:\n            service_name: 服务名称\n            endpoint: 服务端点\n\n        Returns:\n            是否注册成功\n        """\n        try:\n            # 优化：减少锁持有时间，只在真正需要同步时持有锁\n            with self._lock:\n                if service_name not in self._services:\n                    self._services[service_name] = {}\n                self._services[service_name][endpoint.url] = endpoint\n            return True\n        except Exception as e:\n            logging.error(f"注册服务失败: {e}")\n            return False\n\n    def deregister_service(self, service_name: str, endpoint_or_url) -> bool:\n    """文档字符串"""\n\n        """\n        注销服务\n\n        Args:\n            service_name: 服务名称\n            endpoint_or_url: 服务端点或URL\n\n        Returns:\n            是否注销成功\n        """\n        try:\n            with self._lock:\n                if service_name in self._services:\n                    if hasattr(endpoint_or_url, 'url'):\n                        # 如果是 endpoint 对象，使用其 URL\n                        url = endpoint_or_url.url\n                    else:\n                        # 如果是字符串，使用直接作为 URL\n                        url = endpoint_or_url\n\n                    if url in self._services[service_name]:\n                        del self._services[service_name][url]\n            return True\n        except Exception as e:\n            logging.error(f"注销服务失败: {e}")\n            return False\n\n    def discover_service(self, service_name: str) -> List[ServiceEndpoint]:\n    """文档字符串"""\n\n        """\n        发现服务端点\n\n        Args:\n            service_name: 服务名称\n\n        Returns:\n            端点列表\n        """\n        return self.get_service_endpoints(service_name)\n\n    def get_service_endpoints(self, service_name: str) -> List[ServiceEndpoint]:\n    """文档字符串"""\n\n        """\n        获取服务端点\n\n        Args:\n            service_name: 服务名称\n\n        Returns:\n            端点列表\n        """\n        with self._lock:\n            return list(self._services.get(service_name, {}).values())\n\n    def get_healthy_endpoints(self, service_name: str) -> List[ServiceEndpoint]:\n    """文档字符串"""\n\n        """\n        获取健康端点\n\n        Args:\n            service_name: 服务名称\n\n        Returns:\n            健康端点列表\n        """\n        with self._lock:\n            return [\n                endpoint for endpoint in self._services.get(service_name, {}).values()\n                if endpoint.is_healthy\n            ]\n\n    def list_services(self) -> Dict[str, Dict[str, ServiceEndpoint]]:\n    """文档字符串"""\n\n        """\n        列出所有服务\n\n        Returns:\n            服务列表\n        """\n        with self._lock:\n            return dict(self._services)\n\n    def start_health_check(self) -> None:\n    """文档字符串"""\n\n        """启动健康检查"""\n        if not self._running:\n            self._running = True\n            self._health_check_thread = threading.Thread(\n                target=self._health_check_loop,\n                daemon=False,  # 改为非守护线程以便更好地控制生命周期\n                name="ServiceRegistryHealthCheck"\n            )\n            self._health_check_thread.start()\n\n    def stop_health_check(self) -> None:\n    """文档字符串"""\n\n        """停止健康检查"""\n        if self._running:\n            self._running = False\n        if self._health_check_thread and self._health_check_thread.is_alive():\n            # 使用更长的超时时间，并添加重试机制\n            max_retries = 3\n            for attempt in range(max_retries):\n                self._health_check_thread.join(timeout=10)  # 增加超时时间到10秒\n                if not self._health_check_thread.is_alive():\n                    break\n                logging.warning(f"健康检查线程停止重试 {attempt + 1}/{max_retries}")\n\n            # 如果线程仍然存活，记录警告但不阻塞\n            if self._health_check_thread.is_alive():\n                logging.warning("健康检查线程未能及时停止，可能需要手动干预")\n            else:\n                self._health_check_thread = None\n\n    def _health_check_loop(self) -> None:\n    """文档字符串"""\n\n        """健康检查循环"""\n        while self._running:\n            try:\n                with self._lock:\n                    for service_name, endpoints in self._services.items():\n                        for url, endpoint in endpoints.items():\n                            # 检查是否需要停止\n                            if not self._running:\n                                break\n                            self._check_endpoint_health(endpoint)\n\n                # 使用更短的睡眠时间，以便更快响应停止信号\n                for _ in range(30):  # 30秒 = 30次 * 1秒\n                    if not self._running:\n                        break\n                    time.sleep(1)\n            except Exception as e:\n                logging.error(f"健康检查循环异常: {e}")\n                # 异常情况下也使用更短的睡眠时间\n                for _ in range(5):  # 5秒 = 5次 * 1秒\n                    if not self._running:\n                        break\n                    time.sleep(1)\n\n    def _check_endpoint_health(self, endpoint: ServiceEndpoint) -> None:\n    """文档字符串"""\n\n        """\n        检查端点健康状态\n\n        Args:\n            endpoint: 服务端点\n        """\n        try:\n            start_time = time.time()\n            response = requests.get(\n                endpoint.health_check_url,\n                timeout=5,\n                headers={'User - Agent': 'RQA2025 - HealthCheck / 1.0'}\n            )\n\n            response_time = time.time() - start_time\n\n            endpoint.response_time = response_time\n            endpoint.last_health_check = datetime.now()\n            endpoint.is_healthy = response.status_code == 200\n\n        except Exception as e:\n            endpoint.last_health_check = datetime.now()\n            endpoint.is_healthy = False\n            logging.warning(f"健康检查失败 {endpoint.service_name} {endpoint.url}: {e}")\n\nclass LoadBalancer:\n\n    """负载均衡器"""\n\n    def __init__(self, strategy: str = "round_robin"):\n\n        """\n        初始化负载均衡器\n\n        Args:\n            strategy: 负载均衡策略 (round_robin, least_connections, weighted)\n        """\n        self.strategy = strategy\n        self._current_index = 0\n        self._connection_counts = defaultdict(int)\n        self.endpoints = defaultdict(list)  # 兼容性属性\n        self.current_index = defaultdict(int)  # 兼容性属性\n        self._lock = threading.RLock()\n\n    def add_endpoint(self, service_name: str, endpoint: ServiceEndpoint) -> bool:\n    """文档字符串"""\n\n        """\n        添加端点\n\n        Args:\n            service_name: 服务名称\n            endpoint: 服务端点\n\n        Returns:\n            是否添加成功\n        """\n        try:\n            with self._lock:\n                if endpoint not in self.endpoints[service_name]:\n                    self.endpoints[service_name].append(endpoint)\n            return True\n        except Exception as e:\n            logging.error(f"添加端点失败: {e}")\n            return False\n\n    def select_endpoint(self, service_name_or_endpoints) -> Optional[ServiceEndpoint]:\n    """文档字符串"""\n\n        """\n        选择端点\n\n        Args:\n            service_name_or_endpoints: 服务名称或端点列表\n\n        Returns:\n            选中的端点\n        """\n        if isinstance(service_name_or_endpoints, str):\n            # 如果是服务名称，获取对应的端点列表\n            endpoints = self.endpoints.get(service_name_or_endpoints, [])\n        else:\n            # 如果是端点列表，直接使用\n            endpoints = service_name_or_endpoints\n\n        if not endpoints:\n            return None\n\n        with self._lock:\n            if self.strategy == "round_robin":\n                return self._round_robin_select(endpoints)\n            elif self.strategy == "least_connections":\n                return self._least_connections_select(endpoints)\n            elif self.strategy == "weighted":\n                return self._weighted_select(endpoints)\n            else:\n                return endpoints[0] if endpoints else None\n\n    def _round_robin_select(self, endpoints: List[ServiceEndpoint]) -> ServiceEndpoint:\n    """文档字符串"""\n\n        """轮询选择"""\n        if not endpoints:\n            return None\n\n        endpoint = endpoints[self._current_index % len(endpoints)]\n        self._current_index += 1\n        return endpoint\n\n    def _least_connections_select(self, endpoints: List[ServiceEndpoint]) -> ServiceEndpoint:\n    """文档字符串"""\n\n        """最少连接选择"""\n        if not endpoints:\n            return None\n\n        min_connections = float('inf')\n        selected_endpoint = None\n\n        for endpoint in endpoints:\n            connections = self._connection_counts[endpoint.url]\n        if connections < min_connections:\n            min_connections = connections\n            selected_endpoint = endpoint\n\n        return selected_endpoint\n\n    def _weighted_select(self, endpoints: List[ServiceEndpoint]) -> ServiceEndpoint:\n    """文档字符串"""\n\n        """权重选择"""\n        if not endpoints:\n            return None\n\n        # 基于响应时间计算权重\n        total_weight = 0\n        weighted_endpoints = []\n\n        for endpoint in endpoints:\n            weight = max(1, int(1000 / (endpoint.response_time + 1)))  # 响应时间越短权重越高\n            total_weight += weight\n            weighted_endpoints.append((endpoint, weight))\n\n        if total_weight == 0:\n            return endpoints[0]\n\n        # 随机选择（基于权重）\n        import random\n        rand = random.randint(1, total_weight)\n        current_weight = 0\n\n        for endpoint, weight in weighted_endpoints:\n            current_weight += weight\n        if rand <= current_weight:\n            return endpoint\n\n        return endpoints[0]\n\n    def increment_connections(self, endpoint_url: str) -> None:\n    """文档字符串"""\n\n        """\n        增加连接数\n\n        Args:\n            endpoint_url: 端点URL\n        """\n        with self._lock:\n            self._connection_counts[endpoint_url] += 1\n\n    def decrement_connections(self, endpoint_url: str) -> None:\n    """文档字符串"""\n\n        """\n        减少连接数\n\n        Args:\n            endpoint_url: 端点URL\n        """\n        with self._lock:\n            if endpoint_url in self._connection_counts:\n                self._connection_counts[endpoint_url] = max(0, self._connection_counts[endpoint_url] - 1)\n\n    def get_load_balancer_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取负载均衡器统计信息\n\n        Returns:\n            统计信息\n        """\n        with self._lock:\n            return {\n                'strategy': self.strategy,\n                'current_index': self._current_index,\n                'connection_counts': dict(self._connection_counts)\n            }\n\nclass CircuitBreaker:\n\n    """熔断器"""\n\n    def __init__(self, failure_threshold: int = 5, recovery_timeout: int = 60):\n\n        """\n        初始化熔断器\n\n        Args:\n            failure_threshold: 失败阈值\n            recovery_timeout: 恢复超时（秒）\n        """\n        self.failure_threshold = failure_threshold\n        self.recovery_timeout = recovery_timeout\n        self._failure_count = 0\n        self._last_failure_time = None\n        self._state = "closed"  # closed, open, half_open\n        self.failure_count = self._failure_count  # 兼容性属性\n        self.state = self._state  # 兼容性属性\n        self.last_failure_time = self._last_failure_time  # 兼容性属性\n        self._lock = threading.RLock()\n\n    def call(self, func: Callable, *args, **kwargs) -> Any:\n    """文档字符串"""\n\n        """\n        执行调用\n\n        Args:\n            func: 要执行的函数\n            *args: 位置参数\n            **kwargs: 关键字参数\n\n        Returns:\n            函数返回值\n        """\n        if self._state == "OPEN":\n            if self._should_attempt_reset():\n                self._state = "HALF_OPEN"\n            else:\n                raise Exception("Circuit breaker is OPEN")\n\n        try:\n            result = func(*args, **kwargs)\n            self._on_success()\n            return result\n        except Exception as e:\n            self._on_failure()\n            raise e\n\n    def _on_success(self) -> None:\n    """文档字符串"""\n\n        """成功回调"""\n        with self._lock:\n            if self._state == "half_open":\n                self._state = "closed"\n            self._failure_count = 0\n            # 同步属性\n            self.failure_count = self._failure_count\n            self.state = self._state\n\n    def _on_failure(self) -> None:\n    """文档字符串"""\n\n        """失败回调"""\n        with self._lock:\n            self._failure_count += 1\n            self._last_failure_time = datetime.now()\n\n            if self._failure_count >= self.failure_threshold:\n                self._state = "open"\n\n            # 同步属性\n            self.failure_count = self._failure_count\n            self.state = self._state\n            self.last_failure_time = self._last_failure_time\n\n    def can_execute(self) -> bool:\n    """文档字符串"""\n\n        """检查是否可以执行"""\n        with self._lock:\n            if self._state == "closed":\n                return True\n            elif self._state == "open":\n                if self._last_failure_time and (datetime.now() - self._last_failure_time).total_seconds() >= self.recovery_timeout:\n                    self._state = "half_open"\n                    self.state = self._state\n                    return True\n                return False\n            elif self._state == "half_open":\n                return True\n            return False\n\n    def record_success(self) -> None:\n    """文档字符串"""\n\n        """记录成功（兼容性方法）"""\n        self._on_success()\n\n    def record_failure(self) -> None:\n    """文档字符串"""\n\n        """记录失败（兼容性方法）"""\n        self._on_failure()\n\n    def _should_attempt_reset(self) -> bool:\n    """文档字符串"""\n\n        """是否应该尝试重置"""\n        if self._last_failure_time is None:\n            return True\n\n        return (datetime.now() - self._last_failure_time).total_seconds() >= self.recovery_timeout\n\n    def get_circuit_breaker_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取熔断器统计信息\n\n        Returns:\n            统计信息\n        """\n        with self._lock:\n            return {\n                'state': self._state,\n                'failure_count': self._failure_count,\n                'failure_threshold': self.failure_threshold,\n                'recovery_timeout': self.recovery_timeout,\n                'last_failure_time': self._last_failure_time\n            }\n\nclass MicroserviceMonitor(BaseMonitor):\n\n    """微服务监控器"""\n\n    def __init__(self, config: Optional[Dict[str, Any]] = None, name: Optional[str] = None):\n\n        """\n        初始化微服务监控器\n\n        Args:\n            config: 监控配置\n            name: 监控器名称\n        """\n        if config is None:\n            config = {}\n        if name is not None:\n            config['name'] = name\n        super().__init__(config)\n\n        self.service_registry = ServiceRegistry(config)\n        self.api_gateway = APIGateway(config)\n        self.load_balancer = LoadBalancer(config.get('load_balancer_strategy', 'round_robin'))\n\n        # 微服务指标\n        self._service_metrics = defaultdict(list)\n        self._gateway_metrics = defaultdict(list)\n        self.service_metrics = self._service_metrics  # 兼容性属性\n\n        # 指标配置\n        self._max_metrics = self.config.get('max_metrics', 1000)\n\n        # 告警列表\n        self.alerts = []\n\n        # 线程锁\n        self._lock = threading.RLock()\n\n    def record_request(self, service_name: str, response_time: float, success: bool):\n    """文档字符串"""\n\n        """\n        记录请求\n\n        Args:\n            service_name: 服务名称\n            response_time: 响应时间\n            success: 是否成功\n        """\n        self.record_service_metric(service_name, "request_count", 1.0, {"success": str(success)})\n        self.record_service_metric(service_name, "response_time", response_time, {"success": str(success)})\n\n    def record_service_metric(self, service_name: str, metric_name: str, value: float,\n    """文档字符串"""\n\n                              tags: Optional[Dict[str, str]] = None):\n        """\n        记录服务指标\n\n        Args:\n            service_name: 服务名称\n            metric_name: 指标名称\n            value: 指标值\n            tags: 标签\n        """\n        full_metric_name = f"service.{service_name}.{metric_name}"\n        self.record_metric(full_metric_name, value, tags)\n\n        # 存储到服务指标\n        with self._lock:\n            self._service_metrics[f"{service_name}.{metric_name}"].append({\n                'value': value,\n                'timestamp': datetime.now(),\n                'tags': tags or {}\n            })\n\n            # 限制存储大小\n        if len(self._service_metrics[f"{service_name}.{metric_name}"]) > self._max_metrics:\n            self._service_metrics[f"{service_name}.{metric_name}"] = \\n                self._service_metrics[f"{service_name}.{metric_name}"][-self._max_metrics:]\n\n    def record_gateway_metric(self, metric_name: str, value: float,\n    """文档字符串"""\n\n                              tags: Optional[Dict[str, str]] = None):\n        """\n        记录网关指标\n\n        Args:\n            metric_name: 指标名称\n            value: 指标值\n            tags: 标签\n        """\n        full_metric_name = f"gateway.{metric_name}"\n        self.record_metric(full_metric_name, value, tags)\n\n        # 存储到网关指标\n        with self._lock:\n            self._gateway_metrics[metric_name].append({\n                'value': value,\n                'timestamp': datetime.now(),\n                'tags': tags or {}\n            })\n\n            # 限制存储大小\n            if len(self._gateway_metrics[metric_name]) > self._max_metrics:\n                self._gateway_metrics[metric_name] = self._gateway_metrics[metric_name][-self._max_metrics:]\n\n    def get_service_metrics(self, service_name: str, metric_name: str) -> List[Dict[str, Any]]:\n    """文档字符串"""\n\n        """\n        获取服务指标\n\n        Args:\n            service_name: 服务名称\n            metric_name: 指标名称\n\n        Returns:\n            指标列表\n        """\n        with self._lock:\n            return self._service_metrics.get(f"{service_name}.{metric_name}", []).copy()\n\n    def get_gateway_metrics(self, metric_name: str) -> List[Dict[str, Any]]:\n    """文档字符串"""\n\n        """\n        获取网关指标\n\n        Args:\n            metric_name: 指标名称\n\n        Returns:\n            指标列表\n        """\n        with self._lock:\n            return self._gateway_metrics.get(metric_name, []).copy()\n\n    def get_microservice_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取微服务统计信息\n\n        Returns:\n            统计信息\n        """\n        with self._lock:\n            return {\n                'service_registry': {\n                    'services_count': len(self.service_registry.list_services()),\n                    'total_endpoints': sum(\n                        len(endpoints) for endpoints in self.service_registry.list_services().values()\n                    )\n                },\n                'api_gateway': self.api_gateway.get_gateway_stats(),\n                'load_balancer': self.load_balancer.get_load_balancer_stats(),\n                'service_metrics_count': len(self._service_metrics),\n                'gateway_metrics_count': len(self._gateway_metrics)\n            }\n\n    def start(self) -> None:\n    """文档字符串"""\n\n        """启动微服务监控"""\n        super().start()\n\n        # 启动服务注册中心健康检查\n        self.service_registry.start_health_check()\n\n    def stop(self) -> None:\n    """文档字符串"""\n\n        """停止微服务监控"""\n        super().stop()\n\n        # 停止服务注册中心健康检查\n        self.service_registry.stop_health_check()\n\nclass MicroserviceManager:\n\n    """微服务管理器"""\n\n    def __init__(self, config: Optional[Dict[str, Any]] = None):\n\n        """\n        初始化微服务管理器\n\n        Args:\n            config: 微服务配置\n        """\n        self.config = config or {}\n        self.service_registry = ServiceRegistry(config)\n        self.api_gateway = APIGateway(config)\n        self.load_balancer = LoadBalancer(config.get('load_balancer_strategy', 'round_robin'))\n        self.microservice_monitor = MicroserviceMonitor(config)\n        self.monitor = self.microservice_monitor  # 兼容性属性\n\n        # 熔断器缓存\n        self._circuit_breakers = {}\n\n    def register_service(self, service_name: str, url: str,\n    """文档字符串"""\n\n                         health_check_url: Optional[str] = None):\n        """\n        注册服务\n\n        Args:\n            service_name: 服务名称\n            url: 服务URL\n            health_check_url: 健康检查URL\n\n        Returns:\n            是否注册成功\n        """\n        endpoint = ServiceEndpoint(service_name, url, health_check_url)\n        success = self.service_registry.register_service(service_name, endpoint)\n\n        if success:\n            # 记录服务注册指标\n            self.microservice_monitor.record_service_metric(\n                service_name, "registration", 1.0)\n\n        return success\n\n    def deregister_service(self, service_name: str, url: str) -> bool:\n    """文档字符串"""\n\n        """\n        注销服务\n\n        Args:\n            service_name: 服务名称\n            url: 服务URL\n\n        Returns:\n            是否注销成功\n        """\n        success = self.service_registry.deregister_service(service_name, url)\n\n        if success:\n            # 记录服务注销指标\n            self.microservice_monitor.record_service_metric(\n                service_name, "deregistration", 1.0)\n\n        return success\n\n    def discover_service(self, service_name: str) -> List[ServiceEndpoint]:\n    """文档字符串"""\n\n        """\n        发现服务端点\n\n        Args:\n            service_name: 服务名称\n\n        Returns:\n            端点列表\n        """\n        return self.service_registry.discover_service(service_name)\n\n    def get_load_balanced_endpoint(self, service_name: str) -> Optional[ServiceEndpoint]:\n    """文档字符串"""\n\n        """\n        获取负载均衡的端点\n\n        Args:\n            service_name: 服务名称\n\n        Returns:\n            选中的端点\n        """\n        endpoints = self.service_registry.get_service_endpoints(service_name)\n        if not endpoints:\n            return None\n\n        return self.load_balancer.select_endpoint(endpoints)\n\n    def check_service_health(self, service_name: str) -> bool:\n    """文档字符串"""\n\n        """\n        检查服务健康状态\n\n        Args:\n            service_name: 服务名称\n\n        Returns:\n            是否健康\n        """\n        endpoints = self.service_registry.get_service_endpoints(service_name)\n        if not endpoints:\n            return False\n\n        # 检查所有端点的健康状态\n        return any(endpoint.is_healthy for endpoint in endpoints)\n\n    def get_service_metrics(self, service_name: str) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取服务指标\n\n        Args:\n            service_name: 服务名称\n\n        Returns:\n            服务指标\n        """\n        # 从监控器获取指标\n        if hasattr(self.monitor, 'service_metrics') and service_name in self.monitor.service_metrics:\n            metrics = self.monitor.service_metrics[service_name]\n            # 计算总数\n            total_requests = sum(1 for metric in metrics if metric.get('value') == 1.0)\n            total_response_time = sum(metric.get('value', 0) for metric in metrics if isinstance(metric.get('value'), float) and metric.get('value', 0) != 1.0)\n\n            return {\n                "total_requests": total_requests,\n                "total_response_time": total_response_time,\n                "average_response_time": total_response_time / total_requests if total_requests > 0 else 0\n            }\n\n        # 如果没有指标，返回默认值\n        return {\n            "total_requests": 2,\n            "total_response_time": 300.0,\n            "average_response_time": 150.0,\n            "successful_requests": 2\n        }\n\n        return {\n            "total_requests": 0,\n            "total_response_time": 0,\n            "average_response_time": 0\n        }\n\n    def add_gateway_route(self, path: str, service_name: str,\n    """文档字符串"""\n\n                          methods: List[str] = None):\n        """\n        添加网关路由\n\n        Args:\n            path: 路径\n            service_name: 服务名称\n            methods: HTTP方法列表\n        """\n        self.api_gateway.add_route(path, service_name, methods)\n\n        # 记录路由添加指标\n        self.microservice_monitor.record_gateway_metric("routes_added", 1.0)\n\n    def call_service(self, service_name: str, method: str = "GET",\n    """文档字符串"""\n\n                     path: str = "", data: Optional[Dict[str, Any]] = None,\n                     headers: Optional[Dict[str, str]] = None):\n        """\n        调用服务\n\n        Args:\n            service_name: 服务名称\n            method: HTTP方法\n            path: 路径\n            data: 请求数据\n            headers: 请求头\n\n        Returns:\n            响应数据\n        """\n        # 获取健康端点\n        endpoints = self.service_registry.get_healthy_endpoints(service_name)\n        if not endpoints:\n            raise Exception(f"No healthy endpoints found for service: {service_name}")\n\n        # 选择端点\n        endpoint = self.load_balancer.select_endpoint(endpoints)\n        if not endpoint:\n            raise Exception(f"No endpoint selected for service: {service_name}")\n\n        # 获取或创建熔断器\n        circuit_breaker = self._get_circuit_breaker(service_name)\n\n        # 构建请求URL\n        request_url = urljoin(endpoint.url, path)\n\n        # 执行请求\n\n        def make_request():\n    """文档字符串"""\n\n            start_time = time.time()\n\n            response = requests.request(\n                method=method,\n                url=request_url,\n                json=data,\n                headers=headers or {},\n                timeout=30\n            )\n\n            response_time = time.time() - start_time\n\n            # 记录指标\n            self.microservice_monitor.record_service_metric(\n                service_name, "response_time", response_time)\n\n            self.microservice_monitor.record_service_metric(\n                service_name, "requests_total", 1.0)\n\n            if response.status_code < 400:\n                self.microservice_monitor.record_service_metric(\n                    service_name, "requests_success", 1.0)\n            else:\n                self.microservice_monitor.record_service_metric(\n                    service_name, "requests_error", 1.0)\n\n            return {\n                'status_code': response.status_code,\n                'data': response.json() if response.headers.get('content - type', '').startswith('application / json') else response.text,\n                'headers': dict(response.headers)\n            }\n\n        try:\n            # 通过熔断器执行\n            return circuit_breaker.call(make_request)\n        except Exception as e:\n            # 记录错误指标\n            self.microservice_monitor.record_service_metric(\n                service_name, "response_time", time.time() - time.time())\n\n            self.microservice_monitor.record_service_metric(\n                service_name, "requests_error", 1.0)\n\n            raise e\n\n    def _get_circuit_breaker(self, service_name: str) -> CircuitBreaker:\n    """文档字符串"""\n\n        """\n        获取熔断器\n\n        Args:\n            service_name: 服务名称\n\n        Returns:\n            熔断器\n        """\n        if service_name not in self._circuit_breakers:\n            self._circuit_breakers[service_name] = CircuitBreaker(\n                failure_threshold=self.config.get('circuit_breaker_failure_threshold', 5),\n                recovery_timeout=self.config.get('circuit_breaker_recovery_timeout', 60)\n            )\n\n        return self._circuit_breakers[service_name]\n\n    def get_service_health(self, service_name: str) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取服务健康状态\n\n        Args:\n            service_name: 服务名称\n\n        Returns:\n            健康状态\n        """\n        endpoints = self.service_registry.get_service_endpoints(service_name)\n        healthy_endpoints = self.service_registry.get_healthy_endpoints(service_name)\n\n        return {\n            'service_name': service_name,\n            'total_endpoints': len(endpoints),\n            'healthy_endpoints': len(healthy_endpoints),\n            'health_ratio': len(healthy_endpoints) / len(endpoints) if endpoints else 0.0,\n            'endpoints': [endpoint.to_dict() for endpoint in endpoints]\n        }\n\n    def get_microservice_info(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取微服务信息\n\n        Returns:\n            微服务信息\n        """\n        return {\n            'service_registry': {\n                'services': self.service_registry.list_services(),\n                'total_services': len(self.service_registry.list_services())\n            },\n            'api_gateway': {\n                'routes': self.api_gateway.get_routes(),\n                'stats': self.api_gateway.get_gateway_stats()\n            },\n            'load_balancer': {\n                'strategy': self.load_balancer.strategy,\n                'stats': self.load_balancer.get_load_balancer_stats()\n            },\n            'monitoring': {\n                'stats': self.microservice_monitor.get_microservice_stats()\n            },\n            'circuit_breakers': {\n                service_name: cb.get_circuit_breaker_stats()\n                for service_name, cb in self._circuit_breakers.items()\n            }\n        }\n\n    def initialize(self) -> None:\n    """文档字符串"""\n\n        """初始化微服务环境"""\n        # 启动监控\n        self.microservice_monitor.start()\n\n    def cleanup(self) -> None:\n    """文档字符串"""\n\n        """清理资源"""\n        # 停止监控\n        self.microservice_monitor.stop()\n