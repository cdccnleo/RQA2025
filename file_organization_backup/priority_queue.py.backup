import logging\n\n"""\n优先级队列\n提供基于优先级的任务队列管理\n"""\n\nimport time\nfrom typing import Any, List, Optional\nfrom dataclasses import dataclass\nfrom enum import Enum\n\nlogger = logging.getLogger(__name__)\n\nclass TaskPriority(Enum):\n\n    """\npriority_queue - 日志系统\n\n职责说明：\n负责系统日志记录、日志格式化、日志存储和日志分析\n\n核心职责：\n- 日志记录和格式化\n- 日志级别管理\n- 日志存储和轮转\n- 日志分析和监控\n- 日志搜索和过滤\n- 日志性能优化\n\n相关接口：\n- ILoggingComponent\n- ILogger\n- ILogHandler\n""" """任务优先级"""\n    CRITICAL = 1\n    HIGH = 2\n    NORMAL = 3\n    LOW = 4\n    BACKGROUND = 5\n\n@dataclass\n\nclass QueueTask:\n\n    """队列任务对象"""\n    id: str\n    priority: TaskPriority\n    func: Any\n    args: tuple\n    kwargs: dict\n    created_at: float\n    scheduled_at: Optional[float] = None\n    max_retries: int = 3\n    retry_count: int = 0\n    timeout: Optional[float] = None\n    tags: Optional[List[str]] = None\n\n    def __post_init__(self):\n\n        if self.tags is None:\n            self.tags = []\n        if self.created_at == 0:\n            self.created_at = time.time()\n\nclass PriorityQueue:\n\n    def __init__(self, max_size=1000):\n\n        self.max_size = max_size\n        self._queue = []\n\n    def put(self, item):\n    """文档字符串"""\n\n        if len(self._queue) >= self.max_size:\n            return False\n        self._queue.append(item)\n        # 按优先级排序（高优先级在前）\n        # 支持Task对象和QueueTask对象\n        self._queue.sort(key=lambda x: self._get_priority_value(x), reverse=True)\n        return True\n\n    def _get_priority_value(self, item):\n    """文档字符串"""\n\n        """获取优先级值，支持不同类型的对象"""\n        if hasattr(item, 'priority'):\n            # Task对象或QueueTask对象\n            if hasattr(item.priority, 'value'):\n                # 枚举类型\n                return item.priority.value\n            else:\n                # 直接数值\n                return item.priority\n        elif isinstance(item, tuple) and len(item) == 2:\n            # 元组格式 (priority, task)\n            priority, task = item\n            if hasattr(priority, 'value'):\n                return priority.value\n            else:\n                return priority\n        else:\n            # 默认优先级\n            return 3  # NORMAL\n\n    def get(self):\n    """文档字符串"""\n\n        if not self._queue:\n            return None\n        return self._queue.pop(0)\n\n    def peek(self):\n    """文档字符串"""\n\n        """查看下一个任务但不移除"""\n        if not self._queue:\n            return None\n        return self._queue[0]\n\n    def remove(self, task_id):\n    """文档字符串"""\n\n        self._queue = [item for item in self._queue if getattr(item, 'id', None) != task_id]\n\n    def size(self):\n    """文档字符串"""\n\n        return len(self._queue)\n\n    def get_stats(self):\n    """文档字符串"""\n\n        return {'size': len(self._queue)}\n