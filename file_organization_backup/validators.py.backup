#!/usr/bin/env python3\n"""\n统一配置验证器 (优化版)\n\n整合所有验证器功能，提供统一的配置验证框架\n合并了validators.py, validator_factory.py, validator_components.py, unified_validator.py的功能\n\n支持:\n- 多策略验证组合\n- 工厂模式管理\n- 组件化架构\n- 标准化的验证结果\n- 丰富的验证规则\n"""\n\nfrom abc import ABC, abstractmethod\nfrom datetime import datetime\nfrom enum import Enum\nfrom typing import Dict, Any, List, Optional, Tuple, Callable, Union\nimport json\nimport logging\nimport re\n\nlogger = logging.getLogger(__name__)\n\n# ==================== 枚举定义 ====================\n\nclass ValidationSeverity(Enum):\n    """验证严重程度"""\n    INFO = "info"\n    WARNING = "warning"\n    ERROR = "error"\n    CRITICAL = "critical"\n\n    def __lt__(self, other):\n        """定义比较顺序"""\n        order = {'info': 0, 'warning': 1, 'error': 2, 'critical': 3}\n        return order[self.value] < order[other.value]\n\nclass ValidationType(Enum):\n    """验证类型"""\n    REQUIRED = "required"\n    TYPE = "type"\n    RANGE = "range"\n    PATTERN = "pattern"\n    CUSTOM = "custom"\n    DEPENDENCY = "dependency"\n\n# ==================== 数据类定义 ====================\n\nclass ValidationResult:\n    """\n    验证结果\n\n    统一验证结果格式\n    """\n\n    def __init__(self, is_valid: bool, errors: List[str] = None):\n        self.is_valid = is_valid\n        self.errors = errors or []\n        self.warnings: List[str] = []\n        self.severity = ValidationSeverity.INFO\n\n    def add_error(self, error: str, severity: ValidationSeverity = ValidationSeverity.ERROR) -> None:\n        """添加错误信息"""\n        self.errors.append(error)\n        self.is_valid = False\n        if severity > self.severity:\n            self.severity = severity\n\n    def add_warning(self, warning: str) -> None:\n        """添加警告信息"""\n        self.warnings.append(warning)\n        if ValidationSeverity.WARNING > self.severity:\n            self.severity = ValidationSeverity.WARNING\n\n    def to_dict(self) -> Dict[str, Any]:\n        """转换为字典"""\n        return {\n            'is_valid': self.is_valid,\n            'errors': self.errors,\n            'warnings': self.warnings,\n            'severity': self.severity.value,\n            'error_count': len(self.errors),\n            'warning_count': len(self.warnings)\n        }\n\n    def merge(self, other: 'ValidationResult') -> None:\n        """合并验证结果"""\n        self.is_valid = self.is_valid and other.is_valid\n        self.errors.extend(other.errors)\n        self.warnings.extend(other.warnings)\n        if other.severity > self.severity:\n            self.severity = other.severity\n\n# ==================== 验证器接口 ====================\n\nclass IConfigValidator(ABC):\n    """配置验证器接口"""\n\n    @abstractmethod\n    def validate(self, config: Dict[str, Any]) -> ValidationResult:\n        """\n        验证配置\n\n        Args:\n            config: 配置字典\n\n        Returns:\n            ValidationResult: 验证结果\n        """\n        pass\n\n    @property\n    @abstractmethod\n    def name(self) -> str:\n        """验证器名称"""\n        pass\n\n    @property\n    @abstractmethod\n    def description(self) -> str:\n        """验证器描述"""\n        pass\n\n# ==================== 基础验证器实现 ====================\n\nclass BaseConfigValidator(IConfigValidator):\n    """基础配置验证器"""\n\n    def __init__(self, name: str = "", description: str = ""):\n        self._name = name or self.__class__.__name__\n        self._description = description or f"{self._name} validator"\n\n    @property\n    def name(self) -> str:\n    """文档字符串"""\n        return self._name\n\n    @property\n    def description(self) -> str:\n    """文档字符串"""\n        return self._description\n\nclass TradingHoursValidator(BaseConfigValidator):\n    """交易时段验证器"""\n\n    def __init__(self):\n        super().__init__("TradingHoursValidator", "验证交易时段配置")\n\n    def validate(self, config: Dict[str, Any]) -> ValidationResult:\n        """验证交易时段配置"""\n        result = ValidationResult(True)\n\n        if "trading_hours" not in config:\n            result.add_error("缺少trading_hours字段", ValidationSeverity.ERROR)\n            return result\n\n        trading_hours = config["trading_hours"]\n        if not isinstance(trading_hours, dict):\n            result.add_error("trading_hours必须是字典类型", ValidationSeverity.ERROR)\n            return result\n\n        # 收集所有时间段\n        time_slots = []\n        for period_name, time_range in trading_hours.items():\n            if not isinstance(time_range, list) or len(time_range) != 2:\n                result.add_error(f"{period_name}的时间段格式不正确，应为[开始时间,结束时间]",\n                               ValidationSeverity.ERROR)\n                continue\n\n            try:\n                start = datetime.strptime(time_range[0], "%H:%M").time()\n                end = datetime.strptime(time_range[1], "%H:%M").time()\n                time_slots.append((start, end))\n            except (ValueError, TypeError) as e:\n                result.add_error(f"{period_name}的时间格式不正确: {e}",\n                               ValidationSeverity.ERROR)\n\n        # 检查时间段是否重叠\n        if len(time_slots) > 1:\n            time_slots.sort()  # 按开始时间排序\n            for i in range(1, len(time_slots)):\n                prev_end = time_slots[i - 1][1]\n                curr_start = time_slots[i][0]\n                if curr_start < prev_end:\n                    result.add_warning("交易时段存在重叠")\n\n        return result\n\nclass DatabaseConfigValidator(BaseConfigValidator):\n    """数据库配置验证器"""\n\n    def __init__(self):\n        super().__init__("DatabaseConfigValidator", "验证数据库配置")\n\n    def validate(self, config: Dict[str, Any]) -> ValidationResult:\n        """验证数据库配置"""\n        result = ValidationResult(True)\n\n        db_config = config.get('database', {})\n        if not db_config:\n            result.add_error("缺少database配置", ValidationSeverity.ERROR)\n            return result\n\n        # 检查必需字段\n        required_fields = ['host', 'port', 'database']\n        for field in required_fields:\n            if field not in db_config:\n                result.add_error(f"数据库配置缺少必需字段: {field}", ValidationSeverity.ERROR)\n\n        # 验证端口\n        if 'port' in db_config:\n            port = db_config['port']\n            if not isinstance(port, int) or not (1024 <= port <= 65535):\n                result.add_error("数据库端口必须是1024-65535之间的整数", ValidationSeverity.ERROR)\n\n        # 验证连接池设置\n        pool_config = db_config.get('pool', {})\n        if pool_config:\n            if 'min_size' in pool_config and 'max_size' in pool_config:\n                min_size = pool_config['min_size']\n                max_size = pool_config['max_size']\n                if min_size > max_size:\n                    result.add_error("连接池最小大小不能大于最大大小", ValidationSeverity.ERROR)\n\n        return result\n\n    def validate_database_config(self, config: Dict[str, Any]) -> ValidationResult:\n        """验证数据库配置（兼容性方法）"""\n        return self.validate(config)\n\nclass LoggingConfigValidator(BaseConfigValidator):\n    """日志配置验证器"""\n\n    VALID_LOG_LEVELS = ['DEBUG', 'INFO', 'WARNING', 'ERROR', 'CRITICAL']\n\n    def __init__(self):\n        super().__init__("LoggingConfigValidator", "验证日志配置")\n\n    def validate(self, config: Dict[str, Any]) -> ValidationResult:\n        """验证日志配置"""\n        result = ValidationResult(True)\n\n        logging_config = config.get('logging', {})\n        if not logging_config:\n            result.add_warning("缺少logging配置")\n            return result\n\n        # 验证日志级别\n        log_level = logging_config.get('level', 'INFO').upper()\n        if log_level not in self.VALID_LOG_LEVELS:\n            result.add_error(f"无效的日志级别: {log_level}，应为: {', '.join(self.VALID_LOG_LEVELS)}",\n                           ValidationSeverity.ERROR)\n\n        # 验证日志文件配置\n        if 'file' in logging_config:\n            file_config = logging_config['file']\n            if 'path' not in file_config:\n                result.add_error("日志文件配置缺少path字段", ValidationSeverity.ERROR)\n\n            # 验证日志轮转大小\n            if 'max_size' in file_config:\n                max_size = file_config['max_size']\n                if isinstance(max_size, str):\n                    # 解析大小字符串 (如 "10MB", "1GB")\n                    size_match = re.match(r'^(\d+)([KMGT]?B?)$', max_size.upper())\n                    if not size_match:\n                        result.add_error(f"无效的日志文件大小格式: {max_size}", ValidationSeverity.ERROR)\n\n        return result\n\nclass NetworkConfigValidator(BaseConfigValidator):\n    """网络配置验证器"""\n\n    def __init__(self):\n        super().__init__("NetworkConfigValidator", "验证网络配置")\n\n    def validate(self, config: Dict[str, Any]) -> ValidationResult:\n        """验证网络配置"""\n        result = ValidationResult(True)\n\n        network_config = config.get('network', {})\n        if not network_config:\n            result.add_warning("缺少network配置")\n            return result\n\n        # 验证主机配置\n        if 'host' in network_config:\n            host = network_config['host']\n            if host not in ['localhost', '127.0.0.1', '0.0.0.0'] and not self._is_valid_ip(host):\n                result.add_warning(f"主机地址 {host} 可能不是有效的IP地址")\n\n        # 验证端口配置\n        if 'port' in network_config:\n            port = network_config['port']\n            if not isinstance(port, int) or not (1 <= port <= 65535):\n                result.add_error("端口必须是1-65535之间的整数", ValidationSeverity.ERROR)\n\n        # 验证SSL配置\n        ssl_config = network_config.get('ssl', {})\n        if ssl_config.get('enabled', False):\n            required_ssl_fields = ['cert_file', 'key_file']\n            for field in required_ssl_fields:\n                if field not in ssl_config:\n                    result.add_error(f"SSL启用时必须配置{field}", ValidationSeverity.ERROR)\n\n        return result\n\n    def _is_valid_ip(self, ip: str) -> bool:\n        """检查是否为有效IP地址"""\n        import ipaddress\n        try:\n            ipaddress.ip_address(ip)\n            return True\n        except ValueError:\n            return False\n\n# ==================== 验证器组合类 ====================\n\nclass ConfigValidators:\n    """多策略组合校验器 (兼容原有接口)"""\n\n    def __init__(self, validators: List[IConfigValidator]):\n        self.validators = validators\n\n    def validate(self, config: Dict[str, Any]) -> Tuple[bool, Optional[Dict[str, Any]]]:\n        """验证配置 (兼容原有接口)"""\n        all_valid = True\n        all_errors = {}\n        all_warnings = {}\n\n        for validator in self.validators:\n            try:\n                result = validator.validate(config)\n                if not result.is_valid:\n                    all_valid = False\n                    all_errors[validator.name] = result.errors\n\n                if result.warnings:\n                    all_warnings[validator.name] = result.warnings\n\n            except Exception as e:\n                all_valid = False\n                all_errors[validator.name] = [str(e)]\n\n        combined_result = {\n            'is_valid': all_valid,\n            'errors': all_errors,\n            'warnings': all_warnings\n        }\n\n        return all_valid, (combined_result if not all_valid or all_warnings else None)\n\n# ==================== 便捷验证函数 ====================\n\ndef validate_trading_hours(config: Dict[str, Any]) -> bool:\n    """验证交易时段配置 (兼容原有接口)"""\n    validator = TradingHoursValidator()\n    result = validator.validate(config)\n    return result.is_valid\n\ndef validate_database_config(config: Dict[str, Any]) -> bool:\n    """验证数据库配置 (兼容原有接口)"""\n    validator = DatabaseConfigValidator()\n    result = validator.validate(config)\n    return result.is_valid\n\ndef validate_logging_config(config: Dict[str, Any]) -> bool:\n    """验证日志配置 (兼容原有接口)"""\n    validator = LoggingConfigValidator()\n    result = validator.validate(config)\n    return result.is_valid\n\ndef validate_network_config(config: Dict[str, Any]) -> bool:\n    """验证网络配置 (兼容原有接口)"""\n    validator = NetworkConfigValidator()\n    result = validator.validate(config)\n    return result.is_valid\n\n# ==================== 验证器工厂 ====================\n\nclass UnifiedValidatorFactory:\n    """统一验证器工厂"""\n\n    def __init__(self):\n        self._validator_classes: Dict[str, type] = {}\n        self._validator_instances: Dict[str, IConfigValidator] = {}\n        self._register_default_validators()\n\n    def _register_default_validators(self):\n        """注册默认验证器"""\n        self.register_validator("trading_hours", TradingHoursValidator)\n        self.register_validator("database", DatabaseConfigValidator)\n        self.register_validator("logging", LoggingConfigValidator)\n        self.register_validator("network", NetworkConfigValidator)\n\n    def register_validator(self, name: str, validator_class: type) -> None:\n        """注册验证器"""\n        if not issubclass(validator_class, IConfigValidator):\n            raise ValueError(f"验证器类必须实现IConfigValidator接口")\n        self._validator_classes[name] = validator_class\n\n    def create_validator(self, name: str, **kwargs) -> IConfigValidator:\n        """创建验证器实例"""\n        if name not in self._validator_classes:\n            raise ValueError(f"未知的验证器类型: {name}")\n\n        validator_class = self._validator_classes[name]\n        return validator_class(**kwargs)\n\n    def get_available_validators(self) -> List[str]:\n        """获取所有可用验证器"""\n        return list(self._validator_classes.keys())\n\n    def create_validator_suite(self, validator_names: List[str]) -> ConfigValidators:\n        """创建验证器套件"""\n        validators = []\n        for name in validator_names:\n            if name in self._validator_classes:\n                validators.append(self.create_validator(name))\n\n        return ConfigValidators(validators)\n\n# ==================== 全局验证器工厂实例 ====================\n\n_global_validator_factory: Optional[UnifiedValidatorFactory] = None\n\ndef get_validator_factory() -> UnifiedValidatorFactory:\n    """获取全局验证器工厂实例"""\n    global _global_validator_factory\n    if _global_validator_factory is None:\n        _global_validator_factory = UnifiedValidatorFactory()\n    return _global_validator_factory\n\ndef reset_validator_factory():\n    """重置全局验证器工厂实例"""\n    global _global_validator_factory\n    _global_validator_factory = None\n\n# ==================== 向后兼容类 ====================\n\nclass ConfigValidator(BaseConfigValidator):\n    """配置验证器（向后兼容简单接口）"""\n\n    def __init__(self):\n        super().__init__("ConfigValidator", "简单配置验证器")\n        self.rules: Dict[str, Callable] = {}\n\n    def validate(self, config: Dict[str, Any]) -> bool:\n        """验证配置（兼容原有接口）"""\n        for field_path, rule in self.rules.items():\n            try:\n                value = self._get_nested_value(config, field_path)\n                if value is not None and not rule(value):\n                    return False\n            except (KeyError, Exception):\n                continue\n        return True\n\n    def add_validation_rule(self, field_path: str, rule: Callable) -> None:\n        """添加验证规则"""\n        self.rules[field_path] = rule\n\n    def _get_nested_value(self, config: Dict[str, Any], field_path: str) -> Any:\n        """获取嵌套字典中的值"""\n        keys = field_path.split('.')\n        current = config\n\n        for key in keys:\n            if isinstance(current, dict) and key in current:\n                current = current[key]\n            else:\n                raise KeyError(f"Field {field_path} not found")\n\n        return current\n\n# ==================== 便捷函数 ====================\n\ndef create_validator(name: str, **kwargs) -> IConfigValidator:\n    """创建验证器 (便捷函数)"""\n    factory = get_validator_factory()\n    return factory.create_validator(name, **kwargs)\n\ndef create_validator_suite(validator_names: List[str]) -> ConfigValidators:\n    """创建验证器套件 (便捷函数)"""\n    factory = get_validator_factory()\n    return factory.create_validator_suite(validator_names)\n\ndef validate_config_with_suite(config: Dict[str, Any], validator_names: List[str]) -> Tuple[bool, Optional[Dict[str, Any]]]:\n    """使用验证器套件验证配置 (便捷函数)"""\n    suite = create_validator_suite(validator_names)\n    return suite.validate(config)\n