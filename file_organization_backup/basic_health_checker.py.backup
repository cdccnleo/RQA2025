"""\n基础设施层 - 日志系统组件\n\nbasic_health_checker 模块\n\n日志系统相关的文件\n提供日志系统相关的功能实现。\n"""\n\n#!/usr/bin/env python3\nfrom .health_result import HealthCheckResult, ServiceHealthProfile, CheckType\nfrom .health_status import HealthStatus\nfrom abc import ABC, abstractmethod\nfrom collections import defaultdict\nfrom datetime import datetime\nfrom typing import Dict, Any, Optional, Callable\nimport logging\nimport time\n\n# -*- coding: utf-8 -*-\n"""\n基础健康检查器实现\n\n提供基本的健康检查功能，遵循统一接口规范。\n"""\n\nlogger = logging.getLogger(__name__)\n\nclass IHealthChecker(ABC):\n    """健康检查器接口"""\n\n    @abstractmethod\n    def check_health(self, service_name: str):\n        """检查服务健康状态"""\n        pass\n\n    @abstractmethod\n    def register_service(self, service_name: str, check_func: Callable) -> None:\n        """注册服务"""\n        pass\n\n    @abstractmethod\n    def unregister_service(self, service_name: str) -> None:\n        """注销服务"""\n        pass\n\nclass BasicHealthChecker(IHealthChecker):\n\n    """基础健康检查器"""\n\n    def __init__(self, config: Optional[Dict[str, Any]] = None):\n\n        """\n        初始化基础健康检查器\n\n        Args:\n            config: 配置字典\n        """\n        self.config = config or {}\n        self._services: Dict[str, ServiceHealthProfile] = {}\n        self._checkers: Dict[str, Callable] = {}\n        self._monitoring = False\n        self._check_interval = self.config.get('check_interval', 30)\n\n        # 默认配置\n        self._default_config = {\n            'check_interval': 30,\n            'timeout': 10,\n            'retry_count': 3\n        }\n\n        # 合并配置\n        merged_config = self._default_config.copy()\n        merged_config.update(self.config)\n        self.config = merged_config\n\n    def register_service(self, name: str, check_func: Callable) -> None:\n    """文档字符串"""\n\n        """\n        注册服务健康检查函数\n\n        Args:\n            name: 服务名称\n            check_func: 检查函数\n        """\n        if not callable(check_func):\n            raise ValueError(f"检查函数必须是可调用对象: {check_func}")\n\n        self._checkers[name] = check_func\n\n        # 创建服务健康档案\n        if name not in self._services:\n            self._services[name] = ServiceHealthProfile(\n                service_name=name,\n                current_status=HealthStatus.UNKNOWN,\n                last_check=datetime.now()\n            )\n\n        logger.info(f"已注册服务健康检查: {name}")\n\n    def check_service(self, name: str, timeout: int = 5) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        检查特定服务健康状态\n\n        Args:\n            name: 服务名称\n            timeout: 超时时间（秒）\n\n        Returns:\n            健康检查结果字典\n        """\n        if name not in self._checkers:\n            return {\n                'status': HealthStatus.UNKNOWN.value,\n                'error': f'服务未注册: {name}',\n                'timestamp': datetime.now().isoformat()\n            }\n\n        start_time = time.time()\n        try:\n            # 执行检查函数\n            result = self._checkers[name]()\n            response_time = time.time() - start_time\n\n            # 创建检查结果\n            check_result = HealthCheckResult(\n                service_name=name,\n                check_type=CheckType.AVAILABILITY,\n                status=HealthStatus.UP if result else HealthStatus.DOWN,\n                timestamp=datetime.now(),\n                response_time=response_time,\n                details={'result': result}\n            )\n\n            # 更新服务健康档案\n            if name in self._services:\n                self._services[name].add_check_result(check_result)\n\n            return {\n                'status': check_result.status.value,\n                'response_time': response_time,\n                'timestamp': check_result.timestamp.isoformat(),\n                'details': check_result.details\n            }\n\n        except Exception as e:\n            response_time = time.time() - start_time\n            error_msg = str(e)\n\n            # 创建错误检查结果\n            check_result = HealthCheckResult(\n                service_name=name,\n                check_type=CheckType.AVAILABILITY,\n                status=HealthStatus.DOWN,\n                timestamp=datetime.now(),\n                response_time=response_time,\n                details={},\n                error_message=error_msg\n            )\n\n            # 更新服务健康档案\n            if name in self._services:\n                self._services[name].add_check_result(check_result)\n\n            logger.error(f"服务健康检查失败: {name}, 错误: {error_msg}")\n\n            return {\n                'status': HealthStatus.DOWN.value,\n                'error': error_msg,\n                'response_time': response_time,\n                'timestamp': datetime.now().isoformat()\n            }\n\n    def check_health(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        执行整体健康检查\n\n        Returns:\n            整体健康状态字典\n        """\n        overall_status = HealthStatus.UP\n        service_results = {}\n\n        for service_name in self._checkers:\n            try:\n                result = self.check_service(service_name)\n                service_results[service_name] = result\n\n                # 更新整体状态\n                if result.get('status') == HealthStatus.DOWN.value:\n                    overall_status = HealthStatus.DOWN\n                elif result.get('status') == HealthStatus.DEGRADED.value and overall_status == HealthStatus.UP:\n                    overall_status = HealthStatus.DEGRADED\n\n            except Exception as e:\n                logger.error(f"检查服务 {service_name} 时发生异常: {e}")\n                service_results[service_name] = {\n                    'status': HealthStatus.DOWN.value,\n                    'error': str(e),\n                    'timestamp': datetime.now().isoformat()\n                }\n\n                overall_status = HealthStatus.DOWN\n\n        return {\n            'overall_status': overall_status.value,\n            'timestamp': datetime.now().isoformat(),\n            'total_services': len(self._checkers),\n            'services': service_results\n        }\n\n    def get_status(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取健康检查状态摘要\n\n        Returns:\n            状态摘要字典\n        """\n        healthy_count = 0\n        degraded_count = 0\n        down_count = 0\n        unknown_count = 0\n\n        for profile in self._services.values():\n            if profile.current_status == HealthStatus.UP:\n                healthy_count += 1\n            elif profile.current_status == HealthStatus.DEGRADED:\n                degraded_count += 1\n            elif profile.current_status == HealthStatus.DOWN:\n                down_count += 1\n            else:\n                unknown_count += 1\n\n        return {\n            'total_services': len(self._services),\n            'healthy_services': healthy_count,\n            'degraded_services': degraded_count,\n            'down_services': down_count,\n            'unknown_services': unknown_count,\n            'overall_health': self._calculate_overall_health(),\n            'last_check': datetime.now().isoformat()\n        }\n\n    def start_monitoring(self) -> None:\n    """文档字符串"""\n\n        """启动健康监控"""\n        if self._monitoring:\n            logger.warning("健康监控已在运行中")\n            return\n\n        self._monitoring = True\n        logger.info("健康监控已启动")\n\n    def stop_monitoring(self) -> None:\n    """文档字符串"""\n\n        """停止健康监控"""\n        if not self._monitoring:\n            logger.warning("健康监控未在运行")\n            return\n\n        self._monitoring = False\n        logger.info("健康监控已停止")\n\n    def is_monitoring(self) -> bool:\n    """文档字符串"""\n\n        """检查是否正在监控"""\n        return self._monitoring\n\n    def _calculate_overall_health(self) -> str:\n    """文档字符串"""\n\n        """计算整体健康状态"""\n        if not self._services:\n            return "UNKNOWN"\n\n        down_services = sum(1 for p in self._services.values() if p.current_status == HealthStatus.DOWN)\n        total_services = len(self._services)\n\n        if down_services == 0:\n            return "HEALTHY"\n        elif down_services < total_services * 0.5:\n            return "DEGRADED"\n        else:\n            return "UNHEALTHY"\n