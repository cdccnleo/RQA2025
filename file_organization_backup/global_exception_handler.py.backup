"""\n基础设施层 - 全局异常处理组件\n\n提供全局异常捕获、处理和恢复机制，确保系统稳定性。\n"""\n\nfrom enum import Enum\nfrom typing import Dict, Any, Optional, Callable, List, Type\nimport logging\nimport os\nimport sys\nimport threading\nimport time\n\nfrom dataclasses import dataclass, field\nimport traceback\n\nlogger = logging.getLogger(__name__)\n\nclass ExceptionSeverity(Enum):\n    """异常严重程度"""\n\n    LOW = "low"\n    MEDIUM = "medium"\n    HIGH = "high"\n    CRITICAL = "critical"\n\nclass ExceptionCategory(Enum):\n    """异常分类"""\n\n    SYSTEM = "system"\n    NETWORK = "network"\n    DATABASE = "database"\n    BUSINESS = "business"\n    SECURITY = "security"\n    RESOURCE = "resource"\n    EXTERNAL = "external"\n\n@dataclass\nclass ExceptionContext:\n    """异常上下文"""\n\n    exception: Exception\n    category: ExceptionCategory\n    severity: ExceptionSeverity\n    module: str\n    function: str\n    line_number: int\n    thread_id: int\n    process_id: int\n    timestamp: float = field(default_factory=time.time)\n    stack_trace: str = ""\n    additional_data: Dict[str, Any] = field(default_factory=dict)\n\n@dataclass\nclass ExceptionHandlingResult:\n    """异常处理结果"""\n\n    handled: bool = False\n    recovered: bool = False\n    retry_count: int = 0\n    fallback_used: bool = False\n    processing_time: float = 0.0\n    error_message: Optional[str] = None\n    recovery_action: str = ""\n    next_steps: List[str] = field(default_factory=list)\n\nclass GlobalExceptionHandler:\n    """全局异常处理器"""\n\n    def __init__(self):\n        self.handlers: Dict[ExceptionCategory, List[Callable]] = {}\n        self.recovery_strategies: Dict[ExceptionCategory, List[Callable]] = {}\n        self.exception_stats = {\n            'total_exceptions': 0,\n            'handled_exceptions': 0,\n            'recovered_exceptions': 0,\n            'unhandled_exceptions': 0,\n            'by_category': {},\n            'by_severity': {}\n        }\n        self._lock = threading.Lock()\n\n        self._register_default_handlers()\n\n    def _register_default_handlers(self):\n        """注册默认异常处理器"""\n\n        # 系统异常处理器\n        self.register_handler(ExceptionCategory.SYSTEM, self._handle_system_exception)\n\n        # 网络异常处理器\n        self.register_handler(ExceptionCategory.NETWORK, self._handle_network_exception)\n\n        # 数据库异常处理器\n        self.register_handler(ExceptionCategory.DATABASE, self._handle_database_exception)\n\n        # 业务异常处理器\n        self.register_handler(ExceptionCategory.BUSINESS, self._handle_business_exception)\n\n        # 安全异常处理器\n        self.register_handler(ExceptionCategory.SECURITY, self._handle_security_exception)\n\n        # 资源异常处理器\n        self.register_handler(ExceptionCategory.RESOURCE, self._handle_resource_exception)\n\n        # 外部服务异常处理器\n        self.register_handler(ExceptionCategory.EXTERNAL, self._handle_external_exception)\n\n    def register_handler(self, category: ExceptionCategory, handler: Callable):\n        """注册异常处理器"""\n        with self._lock:\n            if category not in self.handlers:\n                self.handlers[category] = []\n            self.handlers[category].append(handler)\n\n    def register_recovery_strategy(self, category: ExceptionCategory, strategy: Callable):\n        """注册恢复策略"""\n        with self._lock:\n            if category not in self.recovery_strategies:\n                self.recovery_strategies[category] = []\n            self.recovery_strategies[category].append(strategy)\n\n    def handle_exception(self, exception: Exception, context: Dict[str, Any] = None) -> ExceptionHandlingResult:\n        """处理异常"""\n        start_time = time.perf_counter()  # 使用更高精度的计时器\n        self.exception_stats['total_exceptions'] += 1\n\n        # 创建异常上下文\n        exc_context = self._create_exception_context(exception, context or {})\n\n        # 更新统计信息\n        self._update_exception_stats(exc_context)\n\n        # 查找并执行处理器\n        result = self._execute_handlers(exc_context)\n\n        # 如果未处理，尝试恢复策略\n        if not result.handled:\n            result = self._execute_recovery_strategies(exc_context)\n\n        result.processing_time = time.perf_counter() - start_time\n\n        # 记录处理结果\n        self._log_exception_result(exc_context, result)\n\n        return result\n\n    def _create_exception_context(self, exception: Exception, context: Dict[str, Any]) -> ExceptionContext:\n        """创建异常上下文"""\n        # 获取堆栈跟踪信息\n        exc_type, exc_value, exc_traceback = sys.exc_info()\n        stack_trace = ''.join(traceback.format_exception(exc_type, exc_value, exc_traceback))\n\n        # 获取调用信息\n        frame = traceback.extract_tb(exc_traceback)[-1] if exc_traceback else None\n\n        return ExceptionContext(\n            exception=exception,\n            category=self._classify_exception(exception),\n            severity=self._assess_severity(exception),\n            module=frame.filename if frame else "unknown",\n            function=frame.name if frame else "unknown",\n            line_number=frame.lineno if frame else 0,\n            thread_id=threading.get_ident(),\n            process_id=os.getpid(),\n            stack_trace=stack_trace,\n            additional_data=context\n        )\n\n    def _classify_exception(self, exception: Exception) -> ExceptionCategory:\n        """分类异常"""\n        exc_type = type(exception).__name__\n\n        # 网络相关异常\n        if exc_type in ['ConnectionError', 'TimeoutError', 'URLError', 'HTTPError']:\n            return ExceptionCategory.NETWORK\n\n        # 数据库相关异常\n        if 'database' in str(exception).lower() or exc_type in ['OperationalError', 'IntegrityError']:\n            return ExceptionCategory.DATABASE\n\n        # 安全相关异常\n        if 'permission' in str(exception).lower() or 'auth' in str(exception).lower():\n            return ExceptionCategory.SECURITY\n\n        # 资源相关异常\n        if 'memory' in str(exception).lower() or 'disk' in str(exception).lower():\n            return ExceptionCategory.RESOURCE\n\n        # 业务逻辑异常\n        if hasattr(exception, 'business_error') or 'business' in str(exception).lower():\n            return ExceptionCategory.BUSINESS\n\n        # 系统异常\n        return ExceptionCategory.SYSTEM\n\n    def _assess_severity(self, exception: Exception) -> ExceptionSeverity:\n        """评估异常严重程度"""\n        exc_type = type(exception).__name__\n\n        # 严重异常\n        if exc_type in ['SystemExit', 'KeyboardInterrupt', 'MemoryError']:\n            return ExceptionSeverity.CRITICAL\n\n        # 高严重程度异常\n        if exc_type in ['ConnectionError', 'OperationalError', 'PermissionError']:\n            return ExceptionSeverity.HIGH\n\n        # 中等严重程度异常\n        if exc_type in ['ValueError', 'TypeError', 'KeyError']:\n            return ExceptionSeverity.MEDIUM\n\n        # 低严重程度异常\n        return ExceptionSeverity.LOW\n\n    def _execute_handlers(self, context: ExceptionContext) -> ExceptionHandlingResult:\n        """执行异常处理器"""\n        handlers = self.handlers.get(context.category, [])\n\n        for handler in handlers:\n            try:\n                result = handler(context)\n                if result.handled:\n                    self.exception_stats['handled_exceptions'] += 1\n                    return result\n            except Exception as e:\n                logger.error(f"Exception handler failed: {e}")\n\n        return ExceptionHandlingResult(\n            handled=False,\n            error_message=f"No handler available for {context.category.value}"\n        )\n\n    def _execute_recovery_strategies(self, context: ExceptionContext) -> ExceptionHandlingResult:\n        """执行恢复策略"""\n        strategies = self.recovery_strategies.get(context.category, [])\n\n        for strategy in strategies:\n            try:\n                result = strategy(context)\n                if result.recovered:\n                    self.exception_stats['recovered_exceptions'] += 1\n                    return result\n            except Exception as e:\n                logger.error(f"Recovery strategy failed: {e}")\n\n        self.exception_stats['unhandled_exceptions'] += 1\n        return ExceptionHandlingResult(\n            handled=False,\n            recovered=False,\n            error_message=f"No recovery strategy available for {context.category.value}"\n        )\n\n    def _update_exception_stats(self, context: ExceptionContext):\n        """更新异常统计信息"""\n        # 按类别统计\n        category = context.category.value\n        if category not in self.exception_stats['by_category']:\n            self.exception_stats['by_category'][category] = 0\n        self.exception_stats['by_category'][category] += 1\n\n        # 按严重程度统计\n        severity = context.severity.value\n        if severity not in self.exception_stats['by_severity']:\n            self.exception_stats['by_severity'][severity] = 0\n        self.exception_stats['by_severity'][severity] += 1\n\n    def _log_exception_result(self, context: ExceptionContext, result: ExceptionHandlingResult):\n        """记录异常处理结果"""\n        log_level = logging.ERROR\n        if result.handled and result.recovered:\n            log_level = logging.INFO\n        elif result.handled:\n            log_level = logging.WARNING\n\n        logger.log(log_level, f"Exception handled: {context.exception.__class__.__name__} "\n                  f"[Category: {context.category.value}, Severity: {context.severity.value}] "\n                  f"[Handled: {result.handled}, Recovered: {result.recovered}]")\n\n    # 默认异常处理器实现\n    def _handle_system_exception(self, context: ExceptionContext) -> ExceptionHandlingResult:\n        """处理系统异常"""\n        return ExceptionHandlingResult(\n            handled=True,\n            recovery_action="system_restart",\n            next_steps=["Log system state", "Restart affected services", "Monitor system health"]\n        )\n\n    def _handle_network_exception(self, context: ExceptionContext) -> ExceptionHandlingResult:\n        """处理网络异常"""\n        return ExceptionHandlingResult(\n            handled=True,\n            recovered=True,\n            retry_count=3,\n            recovery_action="retry_with_backoff",\n            next_steps=["Check network connectivity", "Retry with exponential backoff", "Switch to backup endpoint"]\n        )\n\n    def _handle_database_exception(self, context: ExceptionContext) -> ExceptionHandlingResult:\n        """处理数据库异常"""\n        return ExceptionHandlingResult(\n            handled=True,\n            recovered=True,\n            recovery_action="connection_pool_refresh",\n            next_steps=["Refresh connection pool", "Check database health", "Switch to backup database"]\n        )\n\n    def _handle_business_exception(self, context: ExceptionContext) -> ExceptionHandlingResult:\n        """处理业务异常"""\n        return ExceptionHandlingResult(\n            handled=True,\n            recovery_action="business_fallback",\n            next_steps=["Apply business rules", "Use fallback logic", "Notify business stakeholders"]\n        )\n\n    def _handle_security_exception(self, context: ExceptionContext) -> ExceptionHandlingResult:\n        """处理安全异常"""\n        return ExceptionHandlingResult(\n            handled=True,\n            recovery_action="security_lockdown",\n            next_steps=["Log security event", "Lock affected resources", "Alert security team"]\n        )\n\n    def _handle_resource_exception(self, context: ExceptionContext) -> ExceptionHandlingResult:\n        """处理资源异常"""\n        return ExceptionHandlingResult(\n            handled=True,\n            recovered=True,\n            recovery_action="resource_cleanup",\n            next_steps=["Free up resources", "Scale up if needed", "Monitor resource usage"]\n        )\n\n    def _handle_external_exception(self, context: ExceptionContext) -> ExceptionHandlingResult:\n        """处理外部服务异常"""\n        return ExceptionHandlingResult(\n            handled=True,\n            fallback_used=True,\n            recovery_action="external_service_fallback",\n            next_steps=["Switch to cached data", "Use local processing", "Queue for later retry"]\n        )\n\n    def get_stats(self) -> Dict[str, Any]:\n        """获取统计信息"""\n        return self.exception_stats.copy()\n\n    def reset_stats(self):\n        """重置统计信息"""\n        self.exception_stats = {\n            'total_exceptions': 0,\n            'handled_exceptions': 0,\n            'recovered_exceptions': 0,\n            'unhandled_exceptions': 0,\n            'by_category': {},\n            'by_severity': {}\n        }\n\n# 全局异常处理器实例\n_global_exception_handler = None\n\ndef get_global_exception_handler() -> GlobalExceptionHandler:\n    """获取全局异常处理器实例"""\n    global _global_exception_handler\n    if _global_exception_handler is None:\n        _global_exception_handler = GlobalExceptionHandler()\n    return _global_exception_handler\n\ndef handle_global_exception(exception: Exception, context: Dict[str, Any] = None) -> ExceptionHandlingResult:\n    """全局异常处理函数"""\n    handler = get_global_exception_handler()\n    return handler.handle_exception(exception, context)\n\ndef setup_global_exception_handling():\n    """设置全局异常处理"""\n    def global_exception_hook(exc_type, exc_value, exc_traceback):\n        """全局异常钩子"""\n        if issubclass(exc_type, KeyboardInterrupt):\n            # 忽略用户中断\n            return\n\n        # 创建异常上下文\n        context = {\n            'global_hook': True,\n            'unhandled_exception': True\n        }\n\n        # 处理异常\n        result = handle_global_exception(exc_value, context)\n\n        # 记录未处理的异常\n        if not result.handled:\n            logger.critical(f"Unhandled exception: {exc_value}", exc_info=(exc_type, exc_value, exc_traceback))\n\n    # 设置全局异常钩子\n    sys.excepthook = global_exception_hook\n\n    logger.info("Global exception handling setup completed")\n\n# 装饰器用于自动异常处理\ndef exception_handler(category: ExceptionCategory = ExceptionCategory.SYSTEM,\n    """文档字符串"""\n                     enable_recovery: bool = True):\n    """异常处理装饰器"""\n    def decorator(func: Callable):\n    """文档字符串"""\n        def wrapper(*args, **kwargs):\n            try:\n                return func(*args, **kwargs)\n            except Exception as e:\n                context = {\n                    'function_name': func.__name__,\n                    'module_name': func.__module__,\n                    'args_count': len(args),\n                    'kwargs_keys': list(kwargs.keys())\n                }\n\n                result = handle_global_exception(e, context)\n\n                if result.recovered and enable_recovery:\n                    logger.info(f"Exception recovered for {func.__name__}: {result.recovery_action}")\n                    return result.result_data if hasattr(result, 'result_data') else None\n\n                # 如果无法恢复，重新抛出异常\n                raise e\n\n        return wrapper\n    return decorator\n\n# 初始化全局异常处理\nsetup_global_exception_handling()\n