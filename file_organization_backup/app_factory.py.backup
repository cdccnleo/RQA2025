"""\n基础设施层 - 日志系统组件\n\napp_factory 模块\n\n日志系统相关的文件\n提供日志系统相关的功能实现。\n"""\n\nimport time\n\nfrom fastapi import FastAPI, HTTPException\nfrom fastapi.responses import JSONResponse\n\nfrom src.infrastructure.health.health_check import HealthCheck\n\n# 跨层级导入：infrastructure层组件\nfrom ..interfaces import IHealthDependency\nfrom ..core.health_dependency import default_health_dependency\nfrom .application_monitor import ApplicationMonitor\n\n# Import or define stub classes for ResourceManager and GPUManager\ntry:\n    from src.infrastructure.init_infrastructure import ResourceManager, GPUManager\nexcept ImportError:\n\n    class ResourceManager:\n\n        pass\n\n    class GPUManager:\n\n        pass\n# 跨层级导入：infrastructure层组件\n# 跨层级导入：infrastructure层组件\n# 跨层级导入：infrastructure层组件\nimport logging\n\n# 跨层级导入：infrastructure层组件\n# 跨层级导入：infrastructure层组件\n# 跨层级导入：infrastructure层组件\nfrom .data_api import router as data_router\nfrom .websocket_api import router as websocket_router\n\nlogger = logging.getLogger(__name__)\n\ndef create_app(config: dict = None, dependency: IHealthDependency = None) -> FastAPI:\n    """文档字符串"""\n\n    """创建FastAPI应用实例"""\n\n    # 初始化应用\n    app = FastAPI(\n        title="RQA2025量化平台",\n        description="A股量化交易系统API",\n        version="1.0.0"\n    )\n\n    # 使用依赖注入或默认依赖\n    if dependency is None:\n        dependency = default_health_dependency\n\n    # 加载配置通过依赖注入\n    if config:\n        for key, value in config.items():\n            # 这里可以扩展依赖接口以支持配置更新\n            pass\n\n    # 初始化健康检查\n    health_check = HealthCheck()\n\n    # 添加核心依赖检查\n\n    def check_database():\n    """文档字符串"""\n\n        # 实际项目中替换为真实数据库检查\n        return {"status": "ok", "tables": 42}\n\n    def check_cache():\n    """文档字符串"""\n\n        # 实际项目中替换为真实缓存检查\n        return {"status": "ok", "items": 100}\n\n    health_check.add_dependency_check("database", check_database)\n    health_check.add_dependency_check("cache", check_cache)\n\n    # 初始化资源监控API\n    resource_api = ResourceAPI(\n        resource_manager=ResourceManager(),\n        gpu_manager=GPUManager()\n    )\n\n    # 初始化错误处理器\n    error_handler = ErrorHandler()\n\n    # 初始化应用监控\n    app.state.monitor = ApplicationMonitor(\n        app_name="rqa2025_api",\n        influx_config=config_manager.get("monitoring.influxdb")\n    )\n\n    # 添加根路由\n\n    @app.get("/")\n    async def root():\n        return {"message": "RQA2025 API"}\n\n    # 添加健康检查路由\n    @app.get("/health")\n    async def health():\n        try:\n            checks = app.state.monitor.run_health_checks()\n            return {"status": "healthy", "checks": checks}\n        except Exception as e:\n            return {"status": "unhealthy", "error": str(e)}\n\n    # 添加指标路由\n    @app.get("/metrics")\n    async def metrics():\n        try:\n            metrics = app.state.monitor.get_metrics()\n            return metrics\n        except Exception as e:\n            raise HTTPException(status_code=500, detail=str(e))\n\n    # 添加路由\n    app.include_router(health_check.router, prefix="/api / v1")\n    app.include_router(resource_api.router, prefix="/api / v1")\n    app.include_router(data_router, prefix="/api / v1")\n    app.include_router(websocket_router)\n\n    # 添加中间件\n    @app.middleware("http")\n    async def monitor_requests(request, call_next):\n        start_time = time.time()\n\n        try:\n            response = await call_next(request)\n            process_time = time.time() - start_time\n\n            # 记录请求指标\n            app.state.monitor.record_metric(\n                "request_duration",\n                process_time,\n                tags={"method": request.method, "path": request.url.path}\n            )\n\n            return response\n\n        except Exception as e:\n            process_time = time.time() - start_time\n\n            # 记录错误\n            error_handler.handle(e, context={\n                "method": request.method,\n                "path": request.url.path,\n                "duration": process_time\n            })\n            # 记录错误指标\n            app.state.monitor.record_metric(\n                "request_error",\n                1,\n                tags={"method": request.method, "path": request.url.path}\n            )\n\n            return JSONResponse(\n                status_code=500,\n                content={"error": str(e)}\n            )\n\n    logger.info("Application initialized successfully")\n    return app\n