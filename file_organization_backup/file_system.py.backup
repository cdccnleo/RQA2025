"""\n基础设施层 - 工具组件组件\n\nfile_system 模块\n\n通用工具组件\n提供工具组件相关的功能实现。\n"""\n\n#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\nfrom pathlib import Path\nfrom typing import Dict, Optional\nimport glob\nimport json\nimport os\n\nfrom .core import StorageAdapter\n\nclass FileSystemAdapter(StorageAdapter):\n\n    """本地文件系统存储适配器"""\n\n    def __init__(self, base_path: str = "data / storage"):\n\n        self.base_path = Path(base_path)\n        os.makedirs(self.base_path, exist_ok=True)\n\n    def write(self, path: str, data: Dict) -> bool:\n    """文档字符串"""\n\n        """写入数据到文件系统"""\n        full_path = Path(self.base_path) / path\n        full_path = full_path.with_suffix('.json')\n        full_path.parent.mkdir(parents=True, exist_ok=True)\n\n        try:\n            with open(str(full_path), 'w', encoding='utf - 8') as f:\n                json.dump(data, f, indent=2, ensure_ascii=False)\n            return True\n        except (IOError, TypeError):\n            return False\n\n    def read(self, path: str) -> Optional[Dict]:\n    """文档字符串"""\n\n        """从文件系统读取数据"""\n        full_path = Path(self.base_path) / path\n        full_path = full_path.with_suffix('.json')\n\n        if not full_path.exists():\n            return None\n\n        try:\n            with open(str(full_path), 'r', encoding='utf - 8') as f:\n                return json.load(f)\n        except (IOError, json.JSONDecodeError):\n            return None\n\n    def delete(self, path: str) -> bool:\n    """文档字符串"""\n\n        """删除文件"""\n        full_path = Path(self.base_path) / path\n        full_path = full_path.with_suffix('.json')\n        try:\n            os.remove(str(full_path))\n            return True\n        except FileNotFoundError:\n            return False\n\nclass AShareFileSystemAdapter(FileSystemAdapter):\n\n    """A股专用文件存储适配器"""\n\n    def __init__(self, base_path: str = "data / storage"):\n\n        super().__init__(base_path)\n\n    def format_path(self, symbol: str, date: str) -> str:\n    """文档字符串"""\n\n        """格式化文件路径"""\n        return f"stock/{symbol}/{date}.parquet"\n\n    def batch_write(self, batch_data: Dict[str, Dict[str, Dict]]) -> bool:\n    """文档字符串"""\n\n        """批量写入数据"""\n        for symbol, date_dict in batch_data.items():\n            for date, data in date_dict.items():\n                path = self.format_path(symbol, date)\n                self.write(path, data)\n        return True\n\n    def get_latest_data(self, symbol: str) -> Optional[str]:\n    """文档字符串"""\n\n        """获取最新数据文件路径"""\n        pattern = Path(self.base_path) / f"stock/{symbol}/*.parquet"\n        files = list(glob.glob(str(pattern)))\n        if not files:\n            return None\n        return max(files)\n