from .base_security import SecurityLevel\nfrom abc import ABC\nfrom typing import Dict, Any, Optional\nimport hashlib\nimport re\nimport secrets\n\n"""\n基础设施层 - 安全管理组件\n\nsecurity_utils 模块\n\n安全管理相关的文件\n提供安全管理相关的功能实现。\n"""\n\n#!/usr/bin/env python3\n    # -*- coding: utf-8 -*-\n"""\n安全工具类\n提供通用的安全功能，包括密码验证、输入清理等\n"""\n\nclass SecurityUtils:\n\n    """安全工具类"""\n\n    # 密码强度正则表达式\n    PASSWORD_PATTERNS = {\n        'length': r'^.{8,}$',\n        'uppercase': r'[A-Z]',\n        'lowercase': r'[a-z]',\n        'digit': r'\d',\n        'special': r'[!@#$%^&*()_+\-=\[\]{};\':"\\|,.<>\/?]'\n    }\n\n    # 敏感数据模式\n    SENSITIVE_PATTERNS = {\n        'email': r'\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b',\n        'phone': r'\b\d{3}[-.]?\d{3}[-.]?\d{4}\b',\n        'credit_card': r'\b\d{4}[-\s]?\d{4}[-\s]?\d{4}[-\s]?\d{4}\b',\n        'ssn': r'\b\d{3}-\d{2}-\d{4}\b',\n        'ip_address': r'\b(?:\d{1,3}\.){3}\d{1,3}\b'\n    }\n\n    @staticmethod\n\n    def validate_password_strength(password: str) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        验证密码强度\n\n        Args:\n            password: 待验证的密码\n\n        Returns:\n            包含验证结果的字典\n        """\n        if not password:\n            return {\n                'valid': False,\n                'score': 0,\n                'issues': ['密码不能为空'],\n                'level': SecurityLevel.LOW\n            }\n\n        issues = []\n        score = 0\n\n        # 长度检查\n        if len(password) >= 8:\n            score += 1\n        else:\n            issues.append('密码长度至少8位')\n\n        # 包含大写字母\n        if re.search(SecurityUtils.PASSWORD_PATTERNS['uppercase'], password):\n            score += 1\n        else:\n            issues.append('密码应包含大写字母')\n\n        # 包含小写字母\n        if re.search(SecurityUtils.PASSWORD_PATTERNS['lowercase'], password):\n            score += 1\n        else:\n            issues.append('密码应包含小写字母')\n\n        # 包含数字\n        if re.search(SecurityUtils.PASSWORD_PATTERNS['digit'], password):\n            score += 1\n        else:\n            issues.append('密码应包含数字')\n\n        # 包含特殊字符\n        if re.search(SecurityUtils.PASSWORD_PATTERNS['special'], password):\n            score += 1\n        else:\n            issues.append('密码应包含特殊字符')\n\n        # 确定安全级别\n        if score >= 4:\n            level = SecurityLevel.HIGH\n        elif score >= 3:\n            level = SecurityLevel.MEDIUM\n        else:\n            level = SecurityLevel.LOW\n\n        return {\n            'valid': score >= 3,\n            'score': score,\n            'max_score': 5,\n            'issues': issues,\n            'level': level\n        }\n\n    @staticmethod\n\n    def generate_secure_password(length: int = 12,\n    """文档字符串"""\n                                include_special: bool = True):\n        """\n        生成安全密码\n\n        Args:\n            length: 密码长度\n            include_special: 是否包含特殊字符\n\n        Returns:\n            生成的密码\n        """\n        if length < 8:\n            length = 8\n\n        # 字符集\n        chars = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789'\n        if include_special:\n            chars += '!@#$%^&*()_+-=[]{}|;:,.<>?'\n\n        # 确保至少包含每种字符类型\n        password = [\n            secrets.choice('abcdefghijklmnopqrstuvwxyz'),  # 小写\n            secrets.choice('ABCDEFGHIJKLMNOPQRSTUVWXYZ'),  # 大写\n            secrets.choice('0123456789'),                  # 数字\n        ]\n\n        if include_special:\n            password.append(secrets.choice('!@#$%^&*()_+-=[]{}|;:,.<>?'))\n\n        # 填充剩余长度\n        remaining_length = length - len(password)\n        password.extend(secrets.choice(chars) for _ in range(remaining_length))\n\n        # 打乱顺序\n        password_list = list(password)\n        secrets.SystemRandom().shuffle(password_list)\n\n        return ''.join(password_list)\n\n    @staticmethod\n\n    def sanitize_input(input_data: str,\n    """文档字符串"""\n                      remove_sensitive: bool = True,\n                      max_length: Optional[int] = None):\n        """\n        清理输入数据\n\n        Args:\n            input_data: 输入数据\n            remove_sensitive: 是否移除敏感信息\n            max_length: 最大长度限制\n\n        Returns:\n            清理后的数据\n        """\n        if not isinstance(input_data, str):\n            return str(input_data)\n\n        # 移除敏感信息\n        if remove_sensitive:\n            for pattern_name, pattern in SecurityUtils.SENSITIVE_PATTERNS.items():\n                input_data = re.sub(pattern, f'[REDACTED_{pattern_name.upper()}]', input_data)\n\n        # 移除HTML标签\n        input_data = re.sub(r'<[^>]+>', '', input_data)\n\n        # 移除SQL注入相关字符\n        sql_patterns = [\n            r'(\b)(union|select|insert|update|delete|drop|create|alter)(\b)',\n            r'(\b)(and|or|not)(\b)',\n            r'(\b)(where|from|into|values)(\b)',\n            r'(\b)(exec|execute|declare|cast|convert)(\b)'\n        ]\n\n        for pattern in sql_patterns:\n            input_data = re.sub(pattern, r'\1[REDACTED_SQL]\3', input_data, flags=re.IGNORECASE)\n\n        # 长度限制\n        if max_length and len(input_data) > max_length:\n            input_data = input_data[:max_length] + '...'\n\n        return input_data.strip()\n\n    @staticmethod\n\n    def calculate_hash(data: str, algorithm: str = 'sha256') -> str:\n    """文档字符串"""\n\n        """\n        计算数据的哈希值\n\n        Args:\n            data: 待哈希的数据\n            algorithm: 哈希算法\n\n        Returns:\n            哈希值\n        """\n        if not data:\n            return ''\n\n        try:\n            if algorithm.lower() == 'md5':\n                return hashlib.md5(data.encode()).hexdigest()\n            elif algorithm.lower() == 'sha1':\n                return hashlib.sha1(data.encode()).hexdigest()\n            elif algorithm.lower() == 'sha256':\n                return hashlib.sha256(data.encode()).hexdigest()\n            elif algorithm.lower() == 'sha512':\n                return hashlib.sha512(data.encode()).hexdigest()\n            else:\n                # 默认使用SHA256\n                return hashlib.sha256(data.encode()).hexdigest()\n        except Exception:\n            return ''\n\n    @staticmethod\n\n    def is_sensitive_data(data: str) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        检测数据是否包含敏感信息\n\n        Args:\n            data: 待检测的数据\n\n        Returns:\n            检测结果\n        """\n        if not isinstance(data, str):\n            return {'is_sensitive': False, 'types': []}\n\n        detected_types = []\n\n        for pattern_name, pattern in SecurityUtils.SENSITIVE_PATTERNS.items():\n            if re.search(pattern, data):\n                detected_types.append(pattern_name)\n\n        return {\n            'is_sensitive': len(detected_types) > 0,\n            'types': detected_types,\n            'count': len(detected_types)\n        }\n\n    @staticmethod\n\n    def generate_api_key(length: int = 32) -> str:\n    """文档字符串"""\n\n        """\n        生成API密钥\n\n        Args:\n            length: 密钥长度\n\n        Returns:\n            生成的API密钥\n        """\n        if length < 16:\n            length = 16\n\n        # 使用安全的随机字符生成\n        chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789'\n        return ''.join(secrets.choice(chars) for _ in range(length))\n\n    @staticmethod\n\n    def generate_jwt_secret(length: int = 32) -> str:\n    """文档字符串"""\n\n        """\n        生成JWT密钥\n\n        Args:\n            length: 密钥长度\n\n        Returns:\n            生成的JWT密钥\n        """\n        if length < 16:\n            length = 16\n\n        # 使用安全的随机字符生成\n        chars = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789'\n        return ''.join(secrets.choice(chars) for _ in range(length))\n\n    @staticmethod\n\n    def hash_password(password: str, salt: str) -> str:\n    """文档字符串"""\n\n        """\n        哈希密码\n\n        Args:\n            password: 密码\n            salt: 盐值\n\n        Returns:\n            哈希后的密码\n        """\n        if not password or not salt:\n            return ''\n\n        try:\n            # 使用SHA256哈希密码 + 值\n            return hashlib.sha256((password + salt).encode()).hexdigest()\n        except Exception:\n            return ''\n\n    @staticmethod\n\n    def verify_password(password: str, salt: str, hashed: str) -> bool:\n    """文档字符串"""\n\n        """\n        验证密码\n\n        Args:\n            password: 密码\n            salt: 盐值\n            hashed: 哈希值\n\n        Returns:\n            验证结果\n        """\n        if not password or not salt or not hashed:\n            return False\n\n        try:\n            return SecurityUtils.hash_password(password, salt) == hashed\n        except Exception:\n            return False\n\n    @staticmethod\n\n    def generate_otp(length: int = 6, alphabet: str = "0123456789") -> str:\n    """文档字符串"""\n\n        """\n        生成一次性密码\n\n        Args:\n            length: OTP长度\n            alphabet: 字符集\n\n        Returns:\n            生成的OTP\n        """\n        if length < 4:\n            length = 4\n\n        if not alphabet:\n            alphabet = "0123456789"\n\n        return ''.join(secrets.choice(alphabet) for _ in range(length))\n\n    @staticmethod\n\n    def generate_secure_filename(original_filename: str) -> str:\n    """文档字符串"""\n\n        """\n        生成安全的文件名\n\n        Args:\n            original_filename: 原始文件名\n\n        Returns:\n            安全的文件名\n        """\n        if not original_filename:\n            return f"file_{secrets.token_hex(8)}"\n\n        # 移除或替换不安全字符\n        safe_filename = re.sub(r'[<>:"/\\|?*]', '_', original_filename)\n\n        # 移除多余的空格和点\n        safe_filename = re.sub(r'\s+', '_', safe_filename)\n        safe_filename = re.sub(r'\.+', '.', safe_filename)\n\n        # 确保不以点开头或结尾\n        safe_filename = safe_filename.strip('._')\n\n        # 如果文件名为空，生成随机文件名\n        if not safe_filename:\n            safe_filename = f"file_{secrets.token_hex(8)}"\n\n        return safe_filename\n\n    @staticmethod\n\n    def generate_uuid(prefix: str = "", suffix: str = "") -> str:\n    """文档字符串"""\n\n        """\n        生成UUID\n\n        Args:\n            prefix: 前缀\n            suffix: 后缀\n\n        Returns:\n            生成的UUID\n        """\n        import uuid\n\n        uuid_value = str(uuid.uuid4())\n\n        if prefix:\n            uuid_value = f"{prefix}_{uuid_value}"\n\n        if suffix:\n            uuid_value = f"{uuid_value}_{suffix}"\n\n        return uuid_value\n