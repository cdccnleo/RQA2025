"""\n高级日志记录优化系统\n\n提供高性能、异步、智能的日志处理能力，包括：\n- 异步日志写入\n- 智能日志过滤和采样\n- 性能监控和优化\n- 分布式日志追踪\n- 日志压缩和归档\n"""\n\nfrom concurrent.futures import ThreadPoolExecutor\nfrom datetime import datetime\nfrom enum import Enum\nfrom pathlib import Path\nfrom typing import Dict, List, Any, Optional, Callable, Union\nimport asyncio\nimport gzip\nimport json\nimport logging\nimport os\nimport queue\nimport re\nimport shutil\nimport threading\nimport time\n\nfrom dataclasses import dataclass, field\n\nclass LogPriority(Enum):\n    """日志优先级"""\n\n    LOW = 1\n    NORMAL = 2\n    HIGH = 3\n    CRITICAL = 4\n\nclass LogCompression(Enum):\n    """日志压缩类型"""\n\n    NONE = "none"\n    GZIP = "gzip"\n    LZ4 = "lz4"\n\n@dataclass\nclass LogEntry:\n    """日志条目"""\n\n    timestamp: float\n    level: str\n    message: str\n    component: str\n    thread_id: int\n    process_id: int\n    priority: LogPriority = LogPriority.NORMAL\n    metadata: Dict[str, Any] = field(default_factory=dict)\n    compressed: bool = False\n\n    def to_dict(self) -> Dict[str, Any]:\n        """转换为字典"""\n        return {\n            'timestamp': self.timestamp,\n            'timestamp_iso': datetime.fromtimestamp(self.timestamp).isoformat(),\n            'level': self.level,\n            'message': self.message,\n            'component': self.component,\n            'thread_id': self.thread_id,\n            'process_id': self.process_id,\n            'priority': self.priority.value,\n            'metadata': self.metadata,\n            'compressed': self.compressed\n        }\n\n    def to_json(self) -> str:\n        """转换为JSON字符串"""\n        return json.dumps(self.to_dict(), ensure_ascii=False)\n\nclass LogEntryPool:\n    """日志条目对象池（内存优化）"""\n\n    def __init__(self, max_size: int = 1000):\n        self.pool = []\n        self.max_size = max_size\n        self.created_count = 0\n        self.reused_count = 0\n\n    def get_entry(self, timestamp: float, level: str, message: str,\n    """文档字符串"""\n                  component: str, thread_id: int, process_id: int,\n                  priority: LogPriority = LogPriority.NORMAL,\n                  metadata: Dict[str, Any] = None) -> LogEntry:\n        """从池中获取或创建日志条目"""\n        if self.pool:\n            # 重用现有对象\n            entry = self.pool.pop()\n            self.reused_count += 1\n\n            # 重置对象属性\n            entry.timestamp = timestamp\n            entry.level = level\n            entry.message = message\n            entry.component = component\n            entry.thread_id = thread_id\n            entry.process_id = process_id\n            entry.priority = priority\n            entry.metadata = metadata or {}\n            entry.compressed = False\n        else:\n            # 创建新对象\n            entry = LogEntry(\n                timestamp=timestamp,\n                level=level,\n                message=message,\n                component=component,\n                thread_id=thread_id,\n                process_id=process_id,\n                priority=priority,\n                metadata=metadata or {}\n            )\n            self.created_count += 1\n\n        return entry\n\n    def return_entry(self, entry: LogEntry):\n        """将日志条目返回到池中"""\n        if len(self.pool) < self.max_size:\n            # 清空可能的大对象引用\n            entry.metadata = {}\n            entry.message = ""\n            self.pool.append(entry)\n\n    def get_stats(self) -> Dict[str, int]:\n        """获取池统计信息"""\n        return {\n            'pool_size': len(self.pool),\n            'max_size': self.max_size,\n            'created_count': self.created_count,\n            'reused_count': self.reused_count,\n            'reuse_rate': self.reused_count / max(self.created_count, 1)\n        }\n\nclass SmartLogFilter:\n    """智能日志过滤器"""\n\n    def __init__(self):\n        self.filters: List[Callable] = []\n        self.sample_rates: Dict[str, float] = {}\n        self.suppression_rules: Dict[str, float] = {}  # 消息模式 -> 抑制时间\n\n    def add_filter(self, filter_func: Callable[[LogEntry], bool]):\n        """添加过滤器"""\n        self.filters.append(filter_func)\n\n    def set_sample_rate(self, component: str, rate: float):\n        """设置采样率 (0.0-1.0)"""\n        self.sample_rates[component] = max(0.0, min(1.0, rate))\n\n    def should_log(self, entry: LogEntry) -> bool:\n        """判断是否应该记录日志"""\n        # 应用过滤器\n        for filter_func in self.filters:\n            if not filter_func(entry):\n                return False\n\n        # 应用采样\n        sample_rate = self.sample_rates.get(entry.component, 1.0)\n        if sample_rate < 1.0:\n            import random\n            if random.random() > sample_rate:\n                return False\n\n        # 应用抑制规则（优化：预先获取时间戳）\n        current_time = time.time()\n        for pattern, suppress_time in self.suppression_rules.items():\n            if re.search(pattern, entry.message):\n                # 检查是否在抑制时间内\n                last_suppress = getattr(self, f'_suppress_{pattern}', 0)\n                if current_time - last_suppress < suppress_time:\n                    return False\n                setattr(self, f'_suppress_{pattern}', current_time)\n\n        return True\n\nclass AsyncLogWriter:\n    """异步日志写入器"""\n\n    def __init__(self, max_queue_size: int = 10000, num_workers: int = 2):\n        self.log_queue = queue.Queue(maxsize=max_queue_size)\n        self.executor = ThreadPoolExecutor(max_workers=num_workers)\n        self.running = False\n        self.workers: List[threading.Thread] = []\n\n        # 性能统计\n        self.stats = {\n            'queued_logs': 0,\n            'processed_logs': 0,\n            'dropped_logs': 0,\n            'avg_processing_time': 0.0\n        }\n\n    def start(self):\n        """启动异步写入器"""\n        self.running = True\n        for i in range(self.executor._max_workers):\n            worker = threading.Thread(\n                target=self._worker_loop,\n                name=f"LogWriter-{i}",\n                daemon=True\n            )\n            worker.start()\n            self.workers.append(worker)\n\n    def stop(self):\n        """停止异步写入器"""\n        self.running = False\n        self.executor.shutdown(wait=True)\n\n    def enqueue_log(self, entry: LogEntry, handler: Callable[[LogEntry], None]):\n        """将日志加入队列"""\n        try:\n            self.log_queue.put((entry, handler), timeout=0.1)\n            self.stats['queued_logs'] += 1\n        except queue.Full:\n            self.stats['dropped_logs'] += 1\n\n    def _worker_loop(self):\n        """工作线程循环"""\n        while self.running:\n            try:\n                entry, handler = self.log_queue.get(timeout=1.0)\n                start_time = time.time()\n\n                # 处理日志\n                handler(entry)\n\n                # 更新统计\n                processing_time = time.time() - start_time\n                self.stats['processed_logs'] += 1\n                self.stats['avg_processing_time'] = (\n                    self.stats['avg_processing_time'] * (self.stats['processed_logs'] - 1) +\n                    processing_time\n                ) / self.stats['processed_logs']\n\n                self.log_queue.task_done()\n\n            except queue.Empty:\n                continue\n            except Exception as e:\n                # 记录处理错误\n                print(f"Log processing error: {e}")\n\n    def get_stats(self) -> Dict[str, Any]:\n        """获取统计信息"""\n        return self.stats.copy()\n\nclass LogCompressor:\n    """日志压缩器"""\n\n    def __init__(self, compression: LogCompression = LogCompression.GZIP):\n        self.compression = compression\n\n    def compress_log(self, log_data: str) -> bytes:\n        """压缩日志数据"""\n        if self.compression == LogCompression.GZIP:\n            return gzip.compress(log_data.encode('utf-8'))\n        elif self.compression == LogCompression.NONE:\n            return log_data.encode('utf-8')\n        else:\n            # 默认使用GZIP\n            return gzip.compress(log_data.encode('utf-8'))\n\n    def decompress_log(self, compressed_data: bytes) -> str:\n        """解压日志数据"""\n        if self.compression == LogCompression.GZIP:\n            return gzip.decompress(compressed_data).decode('utf-8')\n        elif self.compression == LogCompression.NONE:\n            return compressed_data.decode('utf-8')\n        else:\n            return gzip.decompress(compressed_data).decode('utf-8')\n\nclass LogArchiver:\n    """日志归档器"""\n\n    def __init__(self, archive_dir: str = "logs/archive"):\n        self.archive_dir = Path(archive_dir)\n        self.archive_dir.mkdir(parents=True, exist_ok=True)\n\n    def archive_logs(self, log_files: List[str], compression: LogCompression = LogCompression.GZIP):\n        """归档日志文件"""\n        compressor = LogCompressor(compression)\n        archived_files = []\n\n        for log_file in log_files:\n            log_path = Path(log_file)\n            if not log_path.exists():\n                continue\n\n            # 读取日志内容\n            with open(log_path, 'r', encoding='utf-8') as f:\n                log_content = f.read()\n\n            # 压缩并保存\n            compressed_data = compressor.compress_log(log_content)\n            archive_name = f"{log_path.stem}_{int(time.time())}{log_path.suffix}.gz"\n            archive_path = self.archive_dir / archive_name\n\n            with open(archive_path, 'wb') as f:\n                f.write(compressed_data)\n\n            # 删除原始文件\n            log_path.unlink()\n\n            archived_files.append(str(archive_path))\n\n        return archived_files\n\n    def cleanup_old_archives(self, days_to_keep: int = 30):\n        """清理旧的归档文件"""\n        cutoff_time = time.time() - (days_to_keep * 24 * 60 * 60)\n        removed_files = []\n\n        for archive_file in self.archive_dir.glob("*.gz"):\n            if archive_file.stat().st_mtime < cutoff_time:\n                archive_file.unlink()\n                removed_files.append(str(archive_file))\n\n        return removed_files\n\nclass PerformanceMonitor:\n    """性能监控器"""\n\n    def __init__(self):\n        self.metrics = {\n            'log_write_time': [],\n            'queue_wait_time': [],\n            'compression_time': [],\n            'memory_usage': []\n        }\n        self.max_metrics = 1000  # 保留最近的1000个指标\n\n    def record_metric(self, metric_name: str, value: float):\n        """记录性能指标"""\n        if metric_name not in self.metrics:\n            self.metrics[metric_name] = []\n\n        self.metrics[metric_name].append((time.time(), value))\n\n        # 限制指标数量\n        if len(self.metrics[metric_name]) > self.max_metrics:\n            self.metrics[metric_name] = self.metrics[metric_name][-self.max_metrics:]\n\n    def get_average(self, metric_name: str, time_window: float = 300) -> Optional[float]:\n        """获取时间窗口内的平均值"""\n        if metric_name not in self.metrics:\n            return None\n\n        current_time = time.time()\n        recent_metrics = [\n            value for timestamp, value in self.metrics[metric_name]\n            if current_time - timestamp <= time_window\n        ]\n\n        return sum(recent_metrics) / len(recent_metrics) if recent_metrics else None\n\n    def get_percentile(self, metric_name: str, percentile: float = 95.0) -> Optional[float]:\n        """获取百分位数"""\n        if metric_name not in self.metrics:\n            return None\n\n        values = [value for _, value in self.metrics[metric_name]]\n        if not values:\n            return None\n\n        values.sort()\n        index = int(len(values) * percentile / 100)\n        return values[min(index, len(values) - 1)]\n\nclass AdvancedLogger:\n    """高级日志记录器"""\n\n    def __init__(self,\n                 name: str,\n                 log_dir: str = "logs",\n                 enable_async: bool = True,\n                 enable_compression: bool = True,\n                 enable_archiving: bool = True):\n\n        self.name = name\n        self.log_dir = Path(log_dir)\n        self.log_dir.mkdir(parents=True, exist_ok=True)\n\n        # 组件初始化\n        self.filter = SmartLogFilter()\n        self.performance_monitor = PerformanceMonitor()\n\n        if enable_async:\n            self.async_writer = AsyncLogWriter()\n            self.async_writer.start()\n        else:\n            self.async_writer = None\n\n        self.compressor = LogCompressor(LogCompression.GZIP if enable_compression else LogCompression.NONE)\n        self.archiver = LogArchiver(str(self.log_dir / "archive")) if enable_archiving else None\n\n        # 日志文件\n        self.current_log_file = self.log_dir / f"{name}_{datetime.now().strftime('%Y%m%d')}.log"\n\n        # 统计信息\n        self.stats = {\n            'total_logs': 0,\n            'filtered_logs': 0,\n            'compressed_logs': 0,\n            'archived_files': 0\n        }\n\n        # 日志级别映射（用于性能优化）\n        self._level_map = {\n            'DEBUG': 10,\n            'INFO': 20,\n            'WARNING': 30,\n            'ERROR': 40,\n            'CRITICAL': 50\n        }\n        self._min_level = 20  # 默认INFO级别\n\n        # 对象池（内存优化）\n        self._log_entry_pool = LogEntryPool(max_size=500)\n\n        # 字符串缓存（性能优化）\n        self._string_cache = {}\n        self._max_cache_size = 1000\n\n    def _get_level_value(self, level: str) -> int:\n        """获取日志级别的数值（用于性能优化）"""\n        return self._level_map.get(level.upper(), 20)\n\n    def log(self, level: str, message: str, component: str = "unknown",\n    """文档字符串"""\n            priority: LogPriority = LogPriority.NORMAL, **metadata):\n        """记录日志"""\n        # 快速预检查：避免在不需要记录的级别进行计算\n        if hasattr(self, '_min_level') and self._get_level_value(level) < self._min_level:\n            return\n\n        # 优化：只调用一次time.time()\n        current_time = time.time()\n        start_time = current_time\n\n        # 预先获取线程和进程ID，避免重复调用\n        thread_id = threading.get_ident()\n        process_id = os.getpid()\n\n        # 从对象池获取日志条目（内存优化）\n        entry = self._log_entry_pool.get_entry(\n            timestamp=current_time,\n            level=level,\n            message=message,\n            component=component,\n            thread_id=thread_id,\n            process_id=process_id,\n            priority=priority,\n            metadata=metadata\n        )\n\n        # 应用智能过滤\n        if not self.filter.should_log(entry):\n            self.stats['filtered_logs'] += 1\n            return\n\n        self.stats['total_logs'] += 1\n\n        # 异步或同步处理\n        if self.async_writer:\n            self.async_writer.enqueue_log(entry, self._write_log_entry)\n        else:\n            self._write_log_entry(entry)\n\n        # 记录性能指标（使用已有的时间戳优化性能）\n        processing_time = time.time() - current_time  # 使用current_time而不是start_time\n        self.performance_monitor.record_metric('log_write_time', processing_time)\n\n        # 定期清理缓存（每1000次日志记录清理一次）\n        if hasattr(self, '_log_count'):\n            self._log_count += 1\n        else:\n            self._log_count = 1\n\n        if self._log_count % 1000 == 0:\n            self.cleanup_cache()\n\n    def _write_log_entry(self, entry: LogEntry):\n        """写入日志条目"""\n        try:\n            # 格式化日志\n            log_line = self._format_log_entry(entry)\n\n            # 压缩日志（如果启用）\n            if self.compressor.compression != LogCompression.NONE:\n                compressed_data = self.compressor.compress_log(log_line)\n                entry.compressed = True\n                self.stats['compressed_logs'] += 1\n                log_line = compressed_data.decode('latin-1')  # 二进制数据转字符串\n\n            # 写入文件\n            with open(self.current_log_file, 'a', encoding='utf-8') as f:\n                f.write(log_line + '\n')\n\n            # 检查是否需要归档\n            if self.archiver and self._should_archive():\n                self._archive_current_logs()\n\n        except Exception as e:\n            # 记录写入错误\n            print(f"Log write error: {e}")\n        finally:\n            # 将日志条目返回到对象池（内存优化）\n            self._log_entry_pool.return_entry(entry)\n\n    def _format_log_entry(self, entry: LogEntry) -> str:\n        """格式化日志条目（优化版本）"""\n        # 优化：预格式化时间戳，避免重复计算\n        dt = datetime.fromtimestamp(entry.timestamp)\n        timestamp = dt.strftime('%Y-%m-%d %H:%M:%S.') + f"{dt.microsecond // 1000:03d}"\n\n        # 使用字符串缓存优化格式化（性能优化）\n        cache_key = f"{entry.level}:{entry.component}:{entry.thread_id}:{entry.process_id}"\n\n        def format_log():\n    """文档字符串"""\n            # 优化：使用更高效的字符串构建方式\n            parts = [\n                "[",\n                timestamp,\n                "] [",\n                entry.level,\n                "] [",\n                entry.component,\n                "] [T",\n                str(entry.thread_id),\n                "] [P",\n                str(entry.process_id),\n                "] ",\n                entry.message\n            ]\n\n            # 优化：条件性添加metadata，避免不必要的JSON序列化\n            if entry.metadata:\n                metadata_json = json.dumps(entry.metadata, ensure_ascii=False, separators=(',', ':'))\n                parts.extend([" | ", metadata_json])\n\n            return "".join(parts)\n\n        return self._get_cached_string(cache_key, format_log)\n\n    def _should_archive(self) -> bool:\n        """判断是否需要归档"""\n        # 简单的归档策略：文件大小超过10MB\n        return self.current_log_file.exists() and self.current_log_file.stat().st_size > 10 * 1024 * 1024\n\n    def _archive_current_logs(self):\n        """归档当前日志"""\n        try:\n            archived = self.archiver.archive_logs([str(self.current_log_file)])\n            if archived:\n                self.stats['archived_files'] += len(archived)\n                # 创建新的日志文件\n                self.current_log_file = self.log_dir / f"{self.name}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.log"\n        except Exception as e:\n            print(f"Archive error: {e}")\n\n    def get_stats(self) -> Dict[str, Any]:\n        """获取统计信息"""\n        stats = self.stats.copy()\n        if self.async_writer:\n            stats.update(self.async_writer.get_stats())\n        return stats\n\n    def get_performance_metrics(self) -> Dict[str, Any]:\n        """获取性能指标"""\n        return {\n            'avg_log_write_time': self.performance_monitor.get_average('log_write_time'),\n            'p95_log_write_time': self.performance_monitor.get_percentile('log_write_time', 95),\n            'p99_log_write_time': self.performance_monitor.get_percentile('log_write_time', 99)\n        }\n\n    def cleanup(self):\n        """清理资源"""\n        # 清理字符串缓存\n        self.cleanup_cache()\n\n        if self.async_writer:\n            self.async_writer.stop()\n\n        if self.archiver:\n            # 清理30天前的归档文件\n            removed = self.archiver.cleanup_old_archives(30)\n            print(f"Cleaned up {len(removed)} old archive files")\n\n    def set_min_level(self, level: str):\n        """设置最小日志级别（性能优化）"""\n        self._min_level = self._get_level_value(level)\n\n    def cleanup_cache(self):\n        """清理字符串缓存，防止内存泄漏"""\n        cache_size = len(self._string_cache)\n        if cache_size > self._max_cache_size * 0.8:  # 当缓存达到80%容量时清理\n            # 清理一半的缓存项\n            items_to_remove = cache_size // 2\n            cache_items = list(self._string_cache.items())\n\n            # 按访问频率排序（如果有的话），否则随机清理\n            for i in range(items_to_remove):\n                if cache_items:\n                    key, _ = cache_items.pop(0)\n                    del self._string_cache[key]\n\n            print(f"🧹 Cleaned up {items_to_remove} items from string cache")\n\n    def _get_cached_string(self, key: str, generator_func) -> str:\n        """获取缓存的字符串（性能优化）"""\n        if key in self._string_cache:\n            return self._string_cache[key]\n\n        # 生成新字符串\n        result = generator_func()\n\n        # 缓存字符串（限制缓存大小）\n        if len(self._string_cache) < self._max_cache_size:\n            self._string_cache[key] = result\n\n        return result\n\n# 全局日志记录器实例\n_global_advanced_logger = None\n\ndef get_advanced_logger(name: str = "advanced_logger") -> AdvancedLogger:\n    """获取高级日志记录器实例"""\n    global _global_advanced_logger\n    if _global_advanced_logger is None:\n        _global_advanced_logger = AdvancedLogger(name)\n    return _global_advanced_logger\n\ndef setup_advanced_logging():\n    """设置高级日志记录"""\n    logger = get_advanced_logger()\n\n    # 配置智能过滤\n    logger.filter.set_sample_rate("debug_component", 0.1)  # 10%的调试日志\n    logger.filter.set_sample_rate("verbose_component", 0.5)  # 50%的详细日志\n\n    # 添加过滤器：过滤掉低优先级的调试信息\n    def debug_filter(entry: LogEntry) -> bool:\n    """文档字符串"""\n        if entry.level.lower() == "debug" and entry.priority == LogPriority.LOW:\n            return False\n        return True\n\n    logger.filter.add_filter(debug_filter)\n\n    print("Advanced logging system initialized")\n\n# 日志记录装饰器\ndef log_performance(operation_name: str):\n    """性能日志装饰器"""\n    def decorator(func: Callable):\n    """文档字符串"""\n        def wrapper(*args, **kwargs):\n            start_time = time.time()\n            logger = get_advanced_logger()\n\n            try:\n                result = func(*args, **kwargs)\n                execution_time = time.time() - start_time\n\n                logger.log(\n                    "INFO",\n                    f"Operation completed: {operation_name}",\n                    component="performance",\n                    execution_time=execution_time,\n                    success=True\n                )\n\n                return result\n\n            except Exception as e:\n                execution_time = time.time() - start_time\n\n                logger.log(\n                    "ERROR",\n                    f"Operation failed: {operation_name}",\n                    component="performance",\n                    execution_time=execution_time,\n                    error=str(e),\n                    success=False\n                )\n\n                raise\n\n        return wrapper\n\nif __name__ == "__main__":\n    # 初始化高级日志系统\n    setup_advanced_logging()\n\n    # 获取日志记录器\n    logger = get_advanced_logger("test_logger")\n\n    # 测试日志记录\n    logger.log("INFO", "Advanced logging system test", component="test", priority=LogPriority.HIGH)\n    logger.log("DEBUG", "Debug message", component="debug_component", priority=LogPriority.LOW)\n    logger.log("WARNING", "Warning message", component="test", priority=LogPriority.NORMAL)\n\n    # 显示统计信息\n    print("Logger stats:", logger.get_stats())\n    print("Performance metrics:", logger.get_performance_metrics())\n\n    # 清理资源\n    logger.cleanup()\n