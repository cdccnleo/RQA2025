"""\n增强监控体系\n提供全面的系统监控、性能分析和健康检查功能\n"""\nfrom collections import deque\nfrom datetime import datetime, timedelta\nfrom typing import Dict, List, Any, Optional, Callable\nimport gc\nimport json\nimport logging\nimport os\nimport threading\nimport time\n\nimport GPUtil\nimport cpuinfo\nimport netifaces\nimport platform\nimport psutil\nimport tracemalloc\n\nlogger = logging.getLogger(__name__)\n\nclass SystemMetricsCollector:\n\n    """\nenhanced_monitoring - 健康检查\n\n职责说明：\n负责系统健康状态监控、自我诊断和健康报告\n\n核心职责：\n- 系统健康检查\n- 组件状态监控\n- 性能指标收集\n- 健康状态报告\n- 自我诊断功能\n- 健康告警机制\n\n相关接口：\n- IHealthComponent\n- IHealthChecker\n- IHealthMonitor\n""" """系统指标收集器"""\n\n    def __init__(self, history_size: int = 1000):\n\n        self.history_size = history_size\n        self.metrics_history = deque(maxlen=history_size)\n\n        # CPU指标历史\n        self.cpu_history = deque(maxlen=history_size)\n        self.memory_history = deque(maxlen=history_size)\n        self.disk_history = deque(maxlen=history_size)\n        self.network_history = deque(maxlen=history_size)\n        self.gpu_history = deque(maxlen=history_size)\n\n        # 性能计数器\n        self.performance_counters = {\n            'api_calls': 0,\n            'cache_hits': 0,\n            'cache_misses': 0,\n            'db_connections': 0,\n            'errors': 0,\n            'warnings': 0\n        }\n\n        self.is_collecting = False\n        self.collector_thread = None\n\n    def start_collection(self, interval: float = 1.0):\n    """文档字符串"""\n\n        """开始指标收集"""\n        if self.is_collecting:\n            return\n\n        self.is_collecting = True\n        self.collector_thread = threading.Thread(\n            target=self._collection_worker,\n            args=(interval,),\n            daemon=True\n        )\n\n        self.collector_thread.start()\n        logger.info(".1f" % interval)\n\n    def stop_collection(self):\n    """文档字符串"""\n\n        """停止指标收集"""\n        self.is_collecting = False\n        if self.collector_thread and self.collector_thread.is_alive():\n            self.collector_thread.join(timeout=2.0)\n        logger.info("系统指标收集已停止")\n\n    def _collection_worker(self, interval: float):\n    """文档字符串"""\n\n        """指标收集工作线程"""\n        while self.is_collecting:\n            try:\n                metrics = self.collect_current_metrics()\n                self.metrics_history.append(metrics)\n                # 使用较短的sleep间隔，以便快速响应停止信号\n                for _ in range(int(interval)):\n                    if not self._running:\n                        break\n                    time.sleep(1)\n                if not self._running:\n                    break\n            except Exception as e:\n                logger.error(f"指标收集错误: {e}")\n                # 异常时使用较短的sleep间隔\n                for _ in range(5):\n                    if not self._running:\n                        break\n                    time.sleep(1)\n                if not self._running:\n                    break\n\n    def collect_current_metrics(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """收集当前系统指标"""\n        try:\n            # CPU指标\n            cpu_percent = psutil.cpu_percent(interval=0.1)\n            cpu_freq = psutil.cpu_freq()\n            cpu_count = psutil.cpu_count()\n            cpu_count_logical = psutil.cpu_count(logical=True)\n\n            # 内存指标\n            memory = psutil.virtual_memory()\n            swap = psutil.swap_memory()\n\n            # 磁盘指标\n            disk_usage = psutil.disk_usage('/')\n            disk_io = psutil.disk_io_counters()\n\n            # 网络指标\n            network_io = psutil.net_io_counters()\n\n            # 进程信息\n            process = psutil.Process()\n            process_memory = process.memory_info()\n            process_cpu = process.cpu_percent()\n\n            # GPU指标（如果可用）\n            gpu_info = {}\n            try:\n                gpus = GPUtil.getGPUs()\n                for i, gpu in enumerate(gpus):\n                    gpu_info[f'gpu_{i}'] = {\n                        'name': gpu.name,\n                        'load': gpu.load * 100,\n                        'memory_used': gpu.memoryUsed,\n                        'memory_total': gpu.memoryTotal,\n                        'memory_free': gpu.memoryFree,\n                        'temperature': gpu.temperature\n                    }\n\n            except:\n                gpu_info = {}\n\n            metrics = {\n                'timestamp': datetime.now().isoformat(),\n                'cpu': {\n                    'percent': cpu_percent,\n                    'frequency_current': cpu_freq.current if cpu_freq else 0,\n                    'frequency_max': cpu_freq.max if cpu_freq else 0,\n                    'count_physical': cpu_count,\n                    'count_logical': cpu_count_logical\n                },\n                'memory': {\n                    'total': memory.total,\n                    'available': memory.available,\n                    'percent': memory.percent,\n                    'used': memory.used,\n                    'free': memory.free,\n                    'swap_total': swap.total,\n                    'swap_used': swap.used,\n                    'swap_percent': swap.percent\n                },\n                'disk': {\n                    'total': disk_usage.total,\n                    'used': disk_usage.used,\n                    'free': disk_usage.free,\n                    'percent': disk_usage.percent,\n                    'read_count': disk_io.read_count if disk_io else 0,\n                    'write_count': disk_io.write_count if disk_io else 0,\n                    'read_bytes': disk_io.read_bytes if disk_io else 0,\n                    'write_bytes': disk_io.write_bytes if disk_io else 0\n                },\n                'network': {\n                    'bytes_sent': network_io.bytes_sent if network_io else 0,\n                    'bytes_recv': network_io.bytes_recv if network_io else 0,\n                    'packets_sent': network_io.packets_sent if network_io else 0,\n                    'packets_recv': network_io.packets_recv if network_io else 0\n                },\n                'process': {\n                    'memory_rss': process_memory.rss,\n                    'memory_vms': process_memory.vms,\n                    'memory_percent': process.memory_percent(),\n                    'cpu_percent': process_cpu,\n                    'threads': process.num_threads(),\n                    'open_files': len(process.open_files()) if process.open_files() else 0\n                },\n                'gpu': gpu_info,\n                'performance_counters': self.performance_counters.copy(),\n                'system_info': {\n                    'platform': platform.platform(),\n                    'python_version': platform.python_version(),\n                    'cpu_info': cpuinfo.get_cpu_info().get('brand_raw', 'Unknown'),\n                    'hostname': platform.node()\n                }\n            }\n\n            # 更新历史记录\n            self.cpu_history.append(metrics['cpu'])\n            self.memory_history.append(metrics['memory'])\n            self.disk_history.append(metrics['disk'])\n            self.network_history.append(metrics['network'])\n            self.gpu_history.append(metrics['gpu'])\n\n            return metrics\n\n        except Exception as e:\n            logger.error(f"收集指标时出错: {e}")\n            return {}\n\n    def get_latest_metrics(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取最新指标"""\n        if self.metrics_history:\n            return self.metrics_history[-1]\n        return {}\n\n    def get_metrics_summary(self, time_window: int = 60) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取指标摘要"""\n        if not self.metrics_history:\n            return {}\n\n        # 获取最近N秒的数据\n        recent_metrics = list(self.metrics_history)[-time_window:]\n\n        if not recent_metrics:\n            return {}\n\n        # 计算CPU统计\n        cpu_percents = [m['cpu']['percent'] for m in recent_metrics]\n        cpu_summary = {\n            'current': cpu_percents[-1] if cpu_percents else 0,\n            'average': sum(cpu_percents) / len(cpu_percents),\n            'max': max(cpu_percents) if cpu_percents else 0,\n            'min': min(cpu_percents) if cpu_percents else 0\n        }\n\n        # 计算内存统计\n        memory_percents = [m['memory']['percent'] for m in recent_metrics]\n        memory_summary = {\n            'current': memory_percents[-1] if memory_percents else 0,\n            'average': sum(memory_percents) / len(memory_percents),\n            'max': max(memory_percents) if memory_percents else 0,\n            'min': min(memory_percents) if memory_percents else 0\n        }\n\n        return {\n            'cpu': cpu_summary,\n            'memory': memory_summary,\n            'sample_count': len(recent_metrics),\n            'time_window_seconds': time_window\n        }\n\n    def increment_counter(self, counter_name: str, value: int = 1):\n    """文档字符串"""\n\n        """增加性能计数器"""\n        if counter_name in self.performance_counters:\n            self.performance_counters[counter_name] += value\n\n    def reset_counters(self):\n    """文档字符串"""\n\n        """重置性能计数器"""\n        for key in self.performance_counters:\n            self.performance_counters[key] = 0\n\nclass HealthChecker:\n\n    """健康检查器"""\n\n    def __init__(self, metrics_collector: SystemMetricsCollector):\n\n        self.metrics_collector = metrics_collector\n        self.health_checks = []\n        self.last_check_time = None\n        self.health_status = "unknown"\n\n        # 默认健康检查\n        self._register_default_checks()\n\n    def _register_default_checks(self):\n    """文档字符串"""\n\n        """注册默认健康检查"""\n        self.register_health_check("cpu_usage", self._check_cpu_usage)\n        self.register_health_check("memory_usage", self._check_memory_usage)\n        self.register_health_check("disk_usage", self._check_disk_usage)\n        self.register_health_check("process_health", self._check_process_health)\n\n    def register_health_check(self, name: str, check_func: Callable):\n    """文档字符串"""\n\n        """注册健康检查"""\n        self.health_checks.append({\n            'name': name,\n            'function': check_func\n        })\n\n    def _check_cpu_usage(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """检查CPU使用率"""\n        metrics = self.metrics_collector.get_latest_metrics()\n        if not metrics:\n            return {'status': 'unknown', 'message': 'No metrics available'}\n\n        cpu_percent = metrics['cpu']['percent']\n\n        if cpu_percent > 90:\n            return {\n                'status': 'critical',\n                'message': '.1f',\n                'value': cpu_percent\n            }\n\n        elif cpu_percent > 70:\n            return {\n                'status': 'warning',\n                'message': '.1f',\n                'value': cpu_percent\n            }\n\n        else:\n            return {\n                'status': 'healthy',\n                'message': '.1f',\n                'value': cpu_percent\n            }\n\n    def _check_memory_usage(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """检查内存使用率"""\n        metrics = self.metrics_collector.get_latest_metrics()\n        if not metrics:\n            return {'status': 'unknown', 'message': 'No metrics available'}\n\n        memory_percent = metrics['memory']['percent']\n\n        if memory_percent > 90:\n            return {\n                'status': 'critical',\n                'message': '.1f',\n                'value': memory_percent\n            }\n\n        elif memory_percent > 75:\n            return {\n                'status': 'warning',\n                'message': '.1f',\n                'value': memory_percent\n            }\n\n        else:\n            return {\n                'status': 'healthy',\n                'message': '.1f',\n                'value': memory_percent\n            }\n\n    def _check_disk_usage(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """检查磁盘使用率"""\n        metrics = self.metrics_collector.get_latest_metrics()\n        if not metrics:\n            return {'status': 'unknown', 'message': 'No metrics available'}\n\n        disk_percent = metrics['disk']['percent']\n\n        if disk_percent > 95:\n            return {\n                'status': 'critical',\n                'message': '.1f',\n                'value': disk_percent\n            }\n\n        elif disk_percent > 85:\n            return {\n                'status': 'warning',\n                'message': '.1f',\n                'value': disk_percent\n            }\n\n        else:\n            return {\n                'status': 'healthy',\n                'message': '.1f',\n                'value': disk_percent\n            }\n\n    def _check_process_health(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """检查进程健康状态"""\n        try:\n            process = psutil.Process()\n            if process.is_running():\n                return {\n                    'status': 'healthy',\n                    'message': 'Process is running normally',\n                    'value': process.status()\n                }\n\n            else:\n                return {\n                    'status': 'critical',\n                    'message': 'Process is not running',\n                    'value': 'stopped'\n                }\n\n        except psutil.NoSuchProcess:\n            return {\n                'status': 'critical',\n                'message': 'Process does not exist',\n                'value': 'not_found'\n            }\n\n    def perform_health_check(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """执行健康检查"""\n        self.last_check_time = datetime.now()\n\n        results = {}\n        overall_status = 'healthy'\n\n        for check in self.health_checks:\n            try:\n                result = check['function']()\n                results[check['name']] = result\n\n                # 更新整体状态\n                if result['status'] == 'critical':\n                    overall_status = 'critical'\n                elif result['status'] == 'warning' and overall_status == 'healthy':\n                    overall_status = 'warning'\n\n            except Exception as e:\n                results[check['name']] = {\n                    'status': 'error',\n                    'message': f'Health check failed: {e}',\n                    'value': None\n                }\n\n                overall_status = 'error'\n\n        health_result = {\n            'timestamp': self.last_check_time.isoformat(),\n            'overall_status': overall_status,\n            'checks': results\n        }\n\n        self.health_status = overall_status\n        return health_result\n\n    def get_health_status(self) -> str:\n    """文档字符串"""\n\n        """获取当前健康状态"""\n        return self.health_status\n\nclass PerformanceMonitor:\n\n    """性能监控器"""\n\n    def __init__(self):\n\n        self.tracemalloc_started = False\n        self.performance_data = {}\n        self.alerts = []\n\n    def start_memory_tracing(self):\n    """文档字符串"""\n\n        """开始内存追踪"""\n        if not self.tracemalloc_started:\n            tracemalloc.start()\n            self.tracemalloc_started = True\n            logger.info("内存追踪已启动")\n\n    def stop_memory_tracing(self):\n    """文档字符串"""\n\n        """停止内存追踪"""\n        if self.tracemalloc_started:\n            tracemalloc.stop()\n            self.tracemalloc_started = False\n            logger.info("内存追踪已停止")\n\n    def get_memory_snapshot(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取内存快照"""\n        if not self.tracemalloc_started:\n            return {'error': 'Memory tracing not started'}\n\n        try:\n            snapshot = tracemalloc.take_snapshot()\n            top_stats = snapshot.statistics('lineno')[:10]\n\n            return {\n                'total_blocks': len(snapshot.traces),\n                'total_memory_mb': sum(stat.size for stat in top_stats) / 1024 / 1024,\n                'top_allocations': [\n                    {\n                        'file': stat.traceback.format()[-1] if stat.traceback else 'unknown',\n                        'line': stat.size,\n                        'count': stat.count\n                    }\n                    for stat in top_stats\n                ]\n            }\n        except Exception as e:\n            return {'error': f'Failed to get memory snapshot: {e}'}\n\n    def profile_function(self, func: Callable, *args, **kwargs) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """分析函数性能"""\n        import cProfile\n        import pstats\n        import io\n\n        pr = cProfile.Profile()\n        pr.enable()\n\n        start_time = time.time()\n        result = func(*args, **kwargs)\n        end_time = time.time()\n\n        pr.disable()\n\n        s = io.StringIO()\n        sortby = 'cumulative'\n        ps = pstats.Stats(pr, stream=s).sort_stats(sortby)\n        ps.print_stats()\n\n        return {\n            'execution_time': end_time - start_time,\n            'profile_output': s.getvalue(),\n            'function_result': result\n        }\n\n    def add_alert(self, alert_type: str, message: str, severity: str = 'info'):\n    """文档字符串"""\n\n        """添加告警"""\n        alert = {\n            'timestamp': datetime.now().isoformat(),\n            'type': alert_type,\n            'message': message,\n            'severity': severity\n        }\n\n        self.alerts.append(alert)\n        logger.warning(f"性能告警 [{severity.upper()}]: {message}")\n\n    def get_recent_alerts(self, hours: int = 24) -> List[Dict[str, Any]]:\n    """文档字符串"""\n\n        """获取最近的告警"""\n        cutoff_time = datetime.now() - timedelta(hours=hours)\n        return [\n            alert for alert in self.alerts\n            if datetime.fromisoformat(alert['timestamp']) > cutoff_time\n        ]\n\nclass EnhancedMonitoringSystem:\n\n    """增强监控系统"""\n\n    def __init__(self):\n\n        self.metrics_collector = SystemMetricsCollector()\n        self.health_checker = HealthChecker(self.metrics_collector)\n        self.performance_monitor = PerformanceMonitor()\n\n        self.is_monitoring = False\n        self.monitoring_thread = None\n        self._stop_event = threading.Event()  # 添加停止事件\n        self._running = True\n\n        # 监控配置\n        self.config = {\n            'metrics_collection_interval': 1.0,  # 1秒\n            'health_check_interval': 30.0,      # 30秒\n            'alert_check_interval': 60.0,       # 60秒\n            'enable_memory_tracing': False\n        }\n\n    def start_monitoring(self):\n    """文档字符串"""\n\n        """启动监控系统"""\n        if self.is_monitoring:\n            return\n\n        self.is_monitoring = True\n\n        # 启动内存追踪（如果启用）\n        if self.config['enable_memory_tracing']:\n            self.performance_monitor.start_memory_tracing()\n\n        # 启动指标收集\n        self.metrics_collector.start_collection(self.config['metrics_collection_interval'])\n\n        # 启动监控线程\n        self.monitoring_thread = threading.Thread(\n            target=self._monitoring_worker,\n            daemon=True\n        )\n\n        self.monitoring_thread.start()\n\n        logger.info("增强监控系统已启动")\n\n    def stop_monitoring(self):\n    """文档字符串"""\n\n        """停止监控系统"""\n        if not self.is_monitoring:\n            return\n\n        self.is_monitoring = False\n        self._running = False\n        self._stop_event.set()  # 设置停止事件\n\n        # 停止各项监控\n        self.metrics_collector.stop_collection()\n        self.performance_monitor.stop_memory_tracing()\n\n        if self.monitoring_thread and self.monitoring_thread.is_alive():\n            self.monitoring_thread.join(timeout=5.0)\n\n        self._stop_event.clear()  # 清理停止事件\n\n        logger.info("增强监控系统已停止")\n\n    def _monitoring_worker(self):\n    """文档字符串"""\n\n        """监控工作线程"""\n        last_health_check = 0\n        last_alert_check = 0\n\n        while self.is_monitoring:\n            try:\n                current_time = time.time()\n\n                # 定期健康检查\n                if current_time - last_health_check >= self.config['health_check_interval']:\n                    health_result = self.health_checker.perform_health_check()\n                    self._process_health_result(health_result)\n                    last_health_check = current_time\n\n                # 定期告警检查\n                if current_time - last_alert_check >= self.config['alert_check_interval']:\n                    self._check_performance_alerts()\n                    last_alert_check = current_time\n\n                # 使用事件等待，实现可中断的等待\n                interrupted = self._stop_event.wait(timeout=1.0)\n                if interrupted or not self._running:\n                    break\n\n            except Exception as e:\n                logger.error(f"监控工作线程错误: {e}")\n                # 异常时使用较短的等待时间\n                if not self._running:\n                    break\n\n    def _process_health_result(self, health_result: Dict[str, Any]):\n    """文档字符串"""\n\n        """处理健康检查结果"""\n        if health_result['overall_status'] != 'healthy':\n            # 生成告警\n            for check_name, check_result in health_result['checks'].items():\n                if check_result['status'] != 'healthy':\n                    self.performance_monitor.add_alert(\n                        alert_type='health_check',\n                        message=f"{check_name}: {check_result['message']}",\n                        severity=check_result['status']\n                    )\n\n    def _check_performance_alerts(self):\n    """文档字符串"""\n\n        """检查性能告警"""\n        metrics_summary = self.metrics_collector.get_metrics_summary()\n\n        if not metrics_summary:\n            return\n\n        # CPU使用率告警\n        cpu_avg = metrics_summary['cpu']['average']\n        if cpu_avg > 80:\n            self.performance_monitor.add_alert(\n                'high_cpu_usage',\n                f'CPU usage is {cpu_avg:.1f}%',\n                'warning'\n            )\n\n        # 内存使用率告警\n        memory_avg = metrics_summary['memory']['average']\n        if memory_avg > 85:\n            self.performance_monitor.add_alert(\n                'high_memory_usage',\n                f'Memory usage is {memory_avg:.1f}%',\n                'warning'\n            )\n\n    def get_system_status(self) -> Dict[str, Any]:\n        """获取系统状态"""\n        return {\n            'timestamp': datetime.now().isoformat(),\n            'is_monitoring': self.is_monitoring,\n            'latest_metrics': self.metrics_collector.get_latest_metrics(),\n            'metrics_summary': self.metrics_collector.get_metrics_summary(),\n            'health_status': self.health_checker.get_health_status(),\n            'recent_alerts': self.performance_monitor.get_recent_alerts(),\n            'memory_snapshot': self.performance_monitor.get_memory_snapshot() if self.config['enable_memory_tracing'] else None\n        }\n\n    def configure(self, **kwargs):\n    """文档字符串"""\n\n        """配置监控系统"""\n        self.config.update(kwargs)\n\n        # 重新启动监控以应用新配置\n        if self.is_monitoring:\n            self.stop_monitoring()\n            self.start_monitoring()\n\n# 全局监控系统实例\n# Global enhanced monitoring instance - only created when needed\n# 全局增强监控实例 - 仅在需要时创建\n_enhanced_monitoring = None\n\ndef get_enhanced_monitoring() -> EnhancedMonitoringSystem:\n    """获取全局增强监控实例"""\n    global _enhanced_monitoring\n    if _enhanced_monitoring is None:\n        _enhanced_monitoring = EnhancedMonitoringSystem()\n    return _enhanced_monitoring\n\n# For backward compatibility\nenhanced_monitoring = None\n\n# 便捷函数\n\ndef start_system_monitoring():\n    """文档字符串"""\n\n    """启动系统监控"""\n    enhanced_monitoring.start_monitoring()\n\ndef stop_system_monitoring():\n    """文档字符串"""\n\n    """停止系统监控"""\n    enhanced_monitoring.stop_monitoring()\n\ndef get_system_status():\n    """文档字符串"""\n\n    """获取系统状态"""\n    return enhanced_monitoring.get_system_status()\n\ndef increment_performance_counter(counter_name: str, value: int = 1):\n    """文档字符串"""\n\n    """增加性能计数器"""\n    enhanced_monitoring.metrics_collector.increment_counter(counter_name, value)\n