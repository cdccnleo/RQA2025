"""\n配置结果类\n统一配置操作的返回格式\n"""\n\nfrom typing import Any, Optional, Dict\n\nfrom dataclasses import dataclass\n\n@dataclass\n\nclass ConfigResult:\n\n    """配置操作结果"\n\n    属性:\n        success: 操作是否成功\n        data: 操作返回的数据\n        error: 错误信息\n        metadata: 额外的元数据\n    """\n    success: bool\n    data: Optional[Any] = None\n    error: Optional[str] = None\n    metadata: Optional[Dict] = None\n\n    @classmethod\n\n    def success_result(cls, data: Any = None, metadata: Optional[Dict] = None) -> 'ConfigResult':\n    """文档字符串"""\n\n        """创建成功结果"""\n        return cls(success=True, data=data, metadata=metadata)\n\n    @classmethod\n\n    def error_result(cls, error: str, metadata: Optional[Dict] = None) -> 'ConfigResult':\n    """文档字符串"""\n\n        """创建错误结果"""\n        # 将整个metadata作为data\n        return cls(success=False, error=error, data=metadata, metadata=metadata)\n\n    def __bool__(self) -> bool:\n\n        """支持布尔判断"""\n        return self.success\n\n    def get_data(self, default: Any = None) -> Any:\n    """文档字符串"""\n\n        """获取数据，支持默认值"""\n        return self.data if self.data is not None else default\n