#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n引擎层结构化日志格式化器\n提供JSON格式的结构化日志输出\n"""\n\nfrom enum import Enum\nfrom typing import Dict, Any, Optional\nimport json\nimport logging\nimport sys\nimport time\n\nfrom dataclasses import dataclass, field\n\nclass StructuredFormatter(logging.Formatter):\n\n    """结构化日志格式化器"""\n\n    def __init__(self, include_timestamp: bool = True,\n\n                 include_level: bool = True,\n                 include_logger: bool = True,\n                 include_location: bool = True):\n        """初始化结构化格式化器\n\n        Args:\n            include_timestamp: 是否包含时间戳\n            include_level: 是否包含日志级别\n            include_logger: 是否包含日志记录器名称\n            include_location: 是否包含位置信息\n        """\n        super().__init__()\n        self.include_timestamp = include_timestamp\n        self.include_level = include_level\n        logger = logging.getLogger(__name__)\n        self.include_location = include_location\n\n    def format(self, record: logging.LogRecord) -> str:\n    """文档字符串"""\n\n        """格式化日志记录"""\n        try:\n            # 创建结构化日志条目\n            log_entry = self._create_log_entry(record)\n\n            # 转换为JSON格式\n            return json.dumps(log_entry, ensure_ascii=False, default=str)\n\n        except Exception as e:\n            # 如果结构化格式化失败，回退到简单格式\n            return f"结构化日志格式化失败: {e} - {record.getMessage()}"\n\n    def _create_log_entry(self, record: logging.LogRecord) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """创建日志条目"""\n        log_entry = {}\n\n        # 基本字段\n        if self.include_timestamp:\n            log_entry['timestamp'] = time.time()\n            log_entry['timestamp_iso'] = time.strftime('%Y-%m-%dT % H:%M:%S',\n                                                       time.localtime(record.created))\n\n        if self.include_level:\n            log_entry['level'] = record.levelname\n\n        if self.include_logger:\n            log_entry['logger'] = record.name\n\n        # 消息内容\n        log_entry['message'] = record.getMessage()\n\n        # 位置信息\n        if self.include_location:\n            log_entry['location'] = {\n                'filename': record.filename,\n                'lineno': record.lineno,\n                'funcName': record.funcName,\n                'module': record.module\n            }\n\n        # 异常信息\n        if record.exc_info:\n            log_entry['exception'] = {\n                'type': record.exc_info[0].__name__ if record.exc_info[0] else None,\n                'message': str(record.exc_info[1]) if record.exc_info[1] else None,\n                'traceback': self.formatException(record.exc_info)\n            }\n\n        # 额外字段\n        if hasattr(record, 'correlation_id'):\n            log_entry['correlation_id'] = record.correlation_id\n\n        if hasattr(record, 'user_id'):\n            log_entry['user_id'] = record.user_id\n\n        if hasattr(record, 'session_id'):\n            log_entry['session_id'] = record.session_id\n\n        if hasattr(record, 'component'):\n            log_entry['component'] = record.component\n\n        if hasattr(record, 'operation'):\n            log_entry['operation'] = record.operation\n\n        if hasattr(record, 'business_type'):\n            log_entry['business_type'] = record.business_type\n\n        if hasattr(record, 'performance_metrics'):\n            log_entry['performance_metrics'] = record.performance_metrics\n\n        if hasattr(record, 'security_event'):\n            log_entry['security_event'] = record.security_event\n\n        # 自定义字段\n        if hasattr(record, 'metadata'):\n            log_entry['metadata'] = record.metadata\n\n        # 处理所有动态额外字段\n        for attr_name in dir(record):\n            if not attr_name.startswith('_') and attr_name not in [\n                'name', 'msg', 'args', 'levelname', 'levelno', 'pathname', 'filename',\n                'module', 'lineno', 'funcName', 'created', 'msecs', 'relativeCreated',\n                'thread', 'threadName', 'processName', 'process', 'getMessage',\n                'exc_info', 'exc_text', 'stack_info', 'timestamp', 'timestamp_iso',\n                'logger', 'message', 'location', 'exception', 'correlation_id',\n                'user_id', 'session_id', 'component', 'operation', 'business_type',\n                'performance_metrics', 'security_event', 'metadata'\n            ]:\n                try:\n                    value = getattr(record, attr_name)\n                    if value is not None:\n                        log_entry[attr_name] = value\n                except Exception:\n                    pass\n\n        return log_entry\n\n    def formatException(self, exc_info) -> str:\n    """文档字符串"""\n\n        """格式化异常信息"""\n        import traceback\n        return ''.join(traceback.format_exception(*exc_info))\n