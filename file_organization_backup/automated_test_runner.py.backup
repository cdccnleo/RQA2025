"""\n自动化测试运行器\n集成测试优化器和框架集成器，提供自动化测试流水线\n"""\n\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\nfrom enum import Enum\nfrom typing import Dict, Any, List, Optional, Callable\nimport logging\nimport threading\nimport time\n\nfrom dataclasses import dataclass\n\nfrom .test_optimizer import TestMode, get_test_optimizer\nfrom .framework_integrator import get_framework_integrator\n\nlogger = logging.getLogger(__name__)\n\nclass TestExecutionStatus(Enum):\n\n    """测试执行状态"""\n    PENDING = "pending"\n    RUNNING = "running"\n    PASSED = "passed"\n    FAILED = "failed"\n    SKIPPED = "skipped"\n    TIMEOUT = "timeout"\n\n@dataclass\n\nclass TestResult:\n\n    """测试结果"""\n    test_name: str\n    test_mode: TestMode\n    status: TestExecutionStatus\n    execution_time: float\n    start_time: float\n    end_time: float\n    error_message: Optional[str] = None\n    performance_metrics: Optional[Dict[str, Any]] = None\n    metadata: Optional[Dict[str, Any]] = None\n\n@dataclass\n\nclass TestSuiteConfig:\n\n    """测试套件配置"""\n    name: str\n    test_mode: TestMode = TestMode.UNIT\n    max_workers: int = 4\n    timeout: int = 300\n    retry_count: int = 1\n    parallel_execution: bool = True\n    performance_monitoring: bool = True\n    cleanup_on_failure: bool = True\n\nclass AutomatedTestRunner:\n\n    """自动化测试运行器"""\n\n    def __init__(self, config: TestSuiteConfig):\n\n        self.config = config\n        self.test_optimizer = get_test_optimizer()\n        self.framework_integrator = get_framework_integrator()\n        self.test_results: List[TestResult] = []\n        self._execution_lock = threading.Lock()\n        self._stop_event = threading.Event()\n\n    def add_test(self, test_name: str, test_func: Callable,\n    """文档字符串"""\n\n                 test_mode: Optional[TestMode] = None, **kwargs):\n        """添加测试到队列"""\n        mode = test_mode or self.config.test_mode\n\n        # 确保测试函数存储在元数据中\n        metadata = kwargs.copy()\n        metadata['test_func'] = test_func\n\n        with self._execution_lock:\n            self.test_results.append(TestResult(\n                test_name=test_name,\n                test_mode=mode,\n                status=TestExecutionStatus.PENDING,\n                execution_time=0.0,\n                start_time=0.0,\n                end_time=0.0,\n                metadata=metadata\n            ))\n\n        logger.info(f"测试已添加到队列: {test_name} (模式: {mode.value})")\n\n    def run_tests(self) -> List[TestResult]:\n    """文档字符串"""\n\n        """运行所有测试"""\n        if not self.test_results:\n            logger.warning("没有测试需要运行")\n            return []\n\n        logger.info(f"开始运行测试套件: {self.config.name}")\n        logger.info(f"测试数量: {len(self.test_results)}")\n        logger.info(f"测试模式: {self.config.test_mode.value}")\n        logger.info(f"最大工作线程: {self.config.max_workers}")\n\n        # 设置测试环境\n        self._setup_test_environment()\n\n        try:\n            if self.config.parallel_execution:\n                self._run_tests_parallel()\n            else:\n                self._run_tests_sequential()\n        finally:\n            # 清理测试环境\n            self._cleanup_test_environment()\n\n        # 生成测试报告\n        self._generate_test_report()\n\n        return self.test_results\n\n    def _setup_test_environment(self) -> None:\n    """文档字符串"""\n\n        """设置测试环境"""\n        logger.info("设置测试环境...")\n\n        # 应用测试优化\n        self.test_optimizer.apply_optimizations()\n\n        # 设置框架集成器环境\n        self.framework_integrator.setup_test_environment(self.config.test_mode)\n\n        logger.info("测试环境设置完成")\n\n    def _cleanup_test_environment(self) -> None:\n    """文档字符串"""\n\n        """清理测试环境"""\n        logger.info("清理测试环境...")\n\n        # 恢复测试优化\n        self.test_optimizer.restore_optimizations()\n\n        # 清理框架集成器环境\n        self.framework_integrator.cleanup_test_environment()\n\n        logger.info("测试环境清理完成")\n\n    def _run_tests_sequential(self) -> None:\n    """文档字符串"""\n\n        """顺序运行测试"""\n        logger.info("使用顺序执行模式")\n\n        for i, test_result in enumerate(self.test_results):\n            if self._stop_event.is_set():\n                logger.info("测试执行被中断")\n                break\n\n            logger.info(f"运行测试 {i + 1}/{len(self.test_results)}: {test_result.test_name}")\n            self._execute_single_test(test_result)\n\n    def _run_tests_parallel(self) -> None:\n    """文档字符串"""\n\n        """并行运行测试"""\n        logger.info("使用并行执行模式")\n\n        with ThreadPoolExecutor(max_workers=self.config.max_workers) as executor:\n            # 提交所有测试任务\n            future_to_test = {}\n        for test_result in self.test_results:\n            if test_result.status == TestExecutionStatus.PENDING:\n                future = executor.submit(self._execute_single_test, test_result)\n                future_to_test[future] = test_result\n\n            # 等待所有任务完成\n            for future in as_completed(future_to_test):\n                test_result = future_to_test[future]\n                try:\n                    # 任务已完成，结果已更新\n                    pass\n                except Exception as e:\n                    logger.error(f"测试执行异常: {test_result.test_name}, 错误: {e}")\n                    test_result.status = TestExecutionStatus.FAILED\n                    test_result.error_message = str(e)\n\n    def _execute_single_test(self, test_result: TestResult) -> None:\n    """文档字符串"""\n\n        """执行单个测试"""\n        if test_result.status != TestExecutionStatus.PENDING:\n            return\n\n        test_result.status = TestExecutionStatus.RUNNING\n        test_result.start_time = time.time()\n\n        try:\n            logger.info(f"开始执行测试: {test_result.test_name}")\n\n            # 获取测试函数\n            test_func = test_result.metadata.get('test_func')\n            if not test_func:\n                raise ValueError(f"测试函数未找到: {test_result.test_name}")\n\n            # 执行测试\n            if self.config.performance_monitoring:\n                # 使用性能监控\n                result = self.framework_integrator.run_optimized_performance_test(\n                    test_result.test_name,\n                    test_func,\n                    test_result.test_mode,\n                    **{k: v for k, v in test_result.metadata.items() if k != 'test_func'}\n                )\n                test_result.performance_metrics = result.get('performance_metrics')\n            else:\n                # 直接执行\n                start_time = time.time()\n                test_func(**{k: v for k, v in test_result.metadata.items() if k != 'test_func'})\n                execution_time = time.time() - start_time\n                result = {'execution_time': execution_time}\n\n            # 更新测试结果\n            test_result.end_time = time.time()\n            test_result.execution_time = test_result.end_time - test_result.start_time\n            test_result.status = TestExecutionStatus.PASSED\n\n            logger.info(f"测试执行成功: {test_result.test_name}, 耗时: {test_result.execution_time:.3f}s")\n\n        except Exception as e:\n            test_result.end_time = time.time()\n            test_result.execution_time = test_result.end_time - test_result.start_time\n            test_result.status = TestExecutionStatus.FAILED\n            test_result.error_message = str(e)\n\n            logger.error(f"测试执行失败: {test_result.test_name}, 错误: {e}")\n\n        if self.config.cleanup_on_failure:\n            logger.info("执行失败清理...")\n            self._cleanup_on_failure()\n\n    def _cleanup_on_failure(self) -> None:\n    """文档字符串"""\n\n        """失败时的清理操作"""\n        try:\n            # 清理后台线程\n            self.test_optimizer.thread_manager.shutdown_all_threads(timeout=5)\n\n            # 恢复环境配置\n            self.test_optimizer.restore_optimizations()\n\n            logger.info("失败清理完成")\n        except Exception as e:\n            logger.error(f"失败清理异常: {e}")\n\n    def _generate_test_report(self) -> None:\n    """文档字符串"""\n\n        """生成测试报告"""\n        total_tests = len(self.test_results)\n        passed_tests = len([r for r in self.test_results if r.status == TestExecutionStatus.PASSED])\n        failed_tests = len([r for r in self.test_results if r.status == TestExecutionStatus.FAILED])\n        skipped_tests = len([r for r in self.test_results if r.status == TestExecutionStatus.SKIPPED])\n\n        total_time = sum(r.execution_time for r in self.test_results)\n        avg_time = total_time / total_tests if total_tests > 0 else 0\n\n        logger.info("=" * 60)\n        logger.info("测试执行报告")\n        logger.info("=" * 60)\n        logger.info(f"测试套件: {self.config.name}")\n        logger.info(f"总测试数: {total_tests}")\n        logger.info(f"通过: {passed_tests}")\n        logger.info(f"失败: {failed_tests}")\n        logger.info(f"跳过: {skipped_tests}")\n        logger.info(f"成功率: {passed_tests / total_tests * 100:.1f}%" if total_tests > 0 else "0%")\n        logger.info(f"总执行时间: {total_time:.3f}s")\n        logger.info(f"平均执行时间: {avg_time:.3f}s")\n        logger.info("=" * 60)\n\n        # 失败的测试详情\n        if failed_tests > 0:\n            logger.info("失败的测试:")\n        for result in self.test_results:\n            if result.status == TestExecutionStatus.FAILED:\n                logger.error(f"  - {result.test_name}: {result.error_message}")\n\n    def stop_execution(self) -> None:\n    """文档字符串"""\n\n        """停止测试执行"""\n        logger.info("收到停止信号，正在停止测试执行...")\n        self._stop_event.set()\n\n    def get_execution_status(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取执行状态"""\n        total = len(self.test_results)\n        running = len([r for r in self.test_results if r.status == TestExecutionStatus.RUNNING])\n        completed = len([r for r in self.test_results if r.status in [TestExecutionStatus.PASSED, TestExecutionStatus.FAILED]])\n\n        return {\n            'total_tests': total,\n            'running_tests': running,\n            'completed_tests': completed,\n            'pending_tests': total - running - completed,\n            'stop_requested': self._stop_event.is_set(),\n            'config': {\n                'name': self.config.name,\n                'test_mode': self.config.test_mode.value,\n                'max_workers': self.config.max_workers,\n                'parallel_execution': self.config.parallel_execution\n            }\n        }\n\n    def clear_results(self) -> None:\n    """文档字符串"""\n\n        """清空测试结果"""\n        with self._execution_lock:\n            self.test_results.clear()\n        logger.info("测试结果已清空")\n\n# 便捷函数\n\ndef create_test_suite(name: str, test_mode: TestMode = TestMode.UNIT, **kwargs) -> AutomatedTestRunner:\n    """文档字符串"""\n\n    """创建测试套件"""\n    config = TestSuiteConfig(name=name, test_mode=test_mode, **kwargs)\n    return AutomatedTestRunner(config)\n\ndef run_test_suite(name: str, tests: List[tuple], test_mode: TestMode = TestMode.UNIT, **kwargs) -> List[TestResult]:\n    """文档字符串"""\n\n    """快速运行测试套件"""\n    runner = create_test_suite(name, test_mode, **kwargs)\n\n    # 添加测试\n    for test_name, test_func, *args in tests:\n        test_kwargs = {}\n        if args:\n            test_kwargs = args[0] if isinstance(args[0], dict) else {}\n        # 不要在这里添加test_func，add_test方法会自动处理\n        runner.add_test(test_name, test_func, test_mode, **test_kwargs)\n\n    # 运行测试\n    return runner.run_tests()\n\ndef run_performance_tests(tests: List[tuple], **kwargs) -> List[TestResult]:\n    """文档字符串"""\n\n    """运行性能测试套件"""\n    return run_test_suite("性能测试套件", tests, TestMode.PERFORMANCE, **kwargs)\n\ndef run_integration_tests(tests: List[tuple], **kwargs) -> List[TestResult]:\n    """文档字符串"""\n\n    """运行集成测试套件"""\n    return run_test_suite("集成测试套件", tests, TestMode.INTEGRATION, **kwargs)\n\ndef run_stress_tests(tests: List[tuple], **kwargs) -> List[TestResult]:\n    """文档字符串"""\n\n    """运行压力测试套件"""\n    return run_test_suite("压力测试套件", tests, TestMode.STRESS, **kwargs)\n