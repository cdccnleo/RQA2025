"""\n错误处理模块\n提供统一的错误处理和异常管理功能\n"""\n\nfrom enum import Enum\nfrom typing import Dict, Any, Optional, Callable, List\nimport logging\nimport sys\nimport time\nimport uuid\n\nfrom dataclasses import dataclass\nimport traceback\n\nclass ErrorSeverity(Enum):\n\n    LOW = "low"\n    MEDIUM = "medium"\n    HIGH = "high"\n    CRITICAL = "critical"\n\nclass ErrorType(Enum):\n\n    VALIDATION = "validation"\n    CONNECTION = "connection"\n    TIMEOUT = "timeout"\n    PERMISSION = "permission"\n    RESOURCE = "resource"\n    SYSTEM = "system"\n    BUSINESS = "business"\n    UNKNOWN = "unknown"\n\n@dataclass\n\nclass ErrorInfo:\n\n    error_type: ErrorType\n    severity: ErrorSeverity\n    message: str\n    details: Optional[Dict[str, Any]] = None\n    stack_trace: Optional[str] = None\n    context: Optional[Dict[str, Any]] = None\n    event_id: Optional[str] = None\n\nclass ErrorHandler:\n\n    def __init__(self, performance_mode: bool = False, max_history: int = 1000):\n\n        self.logger = logging.getLogger(__name__)\n        self.error_handlers: Dict[ErrorType, Callable] = {}\n        self.global_error_handler: Optional[Callable] = None\n        self.error_count = 0\n        self.error_history: List[ErrorInfo] = []\n        self.performance_mode = performance_mode\n        self.max_history = max_history\n\n    def register_error_handler(self, error_type: ErrorType, handler: Callable):\n    """文档字符串"""\n\n        self.error_handlers[error_type] = handler\n        self.logger.info(f"注册错误处理器: {error_type.value}")\n\n    def register_global_error_handler(self, handler: Callable):\n    """文档字符串"""\n\n        self.global_error_handler = handler\n        self.logger.info("注册全局错误处理器")\n\n    def handle_error(self, error: Exception, context: Optional[Dict[str, Any]] = None) -> ErrorInfo:\n    """文档字符串"""\n\n        if not self.performance_mode:\n            self.logger.info(f"处理错误: {type(error).__name__} - {error}")\n\n        self.error_count += 1\n\n        # 确定错误类型和严重程度\n        error_type = self._classify_error(error)\n        severity = self._determine_severity(error, error_type)\n\n        # 创建错误信息（性能模式下减少开销）\n        if self.performance_mode:\n            error_info = ErrorInfo(\n                error_type=error_type,\n                severity=severity,\n                message=str(error),\n                details=None,  # 性能模式下不提取详细信息\n                stack_trace=None,  # 性能模式下不生成堆栈跟踪\n                context=context,\n                event_id=str(uuid.uuid4())\n            )\n        else:\n            error_info = ErrorInfo(\n                error_type=error_type,\n                severity=severity,\n                message=str(error),\n                details=self._extract_error_details(error),\n                stack_trace=traceback.format_exc(),\n                context=context,\n                event_id=str(uuid.uuid4())\n            )\n\n        # 记录错误（性能模式下减少日志）\n        if not self.performance_mode:\n            self.logger.warning(f"错误 [{error_type.value}] [{severity.value}]: {error}")\n            self.logger.info(f"错误类型: {error_type.value}")\n            self.logger.info(f"严重程度: {severity.value}")\n\n        # 调用相应的错误处理器\n        self._call_error_handler(error_info)\n\n        # 添加到历史记录（性能模式下限制历史记录大小）\n        if len(self.error_history) >= self.max_history:\n            self.error_history.pop(0)  # 移除最旧的记录\n        self.error_history.append(error_info)\n\n        return error_info\n\n    def handle_errors_batch(self, errors: List[Exception], context: Optional[Dict[str, Any]] = None) -> List[ErrorInfo]:\n    """文档字符串"""\n\n        if not errors:\n            return []\n\n        # 启用性能模式进行批量处理\n        original_performance_mode = self.performance_mode\n        self.performance_mode = True\n\n        try:\n            results = []\n            for error in errors:\n                result = self.handle_error(error, context)\n                results.append(result)\n            return results\n        finally:\n            # 恢复原始性能模式设置\n            self.performance_mode = original_performance_mode\n\n    def _classify_error(self, error: Exception) -> ErrorType:\n    """文档字符串"""\n\n        error_name = type(error).__name__.lower()\n\n        if any(keyword in error_name for keyword in ['validation', 'value', 'type']):\n            return ErrorType.VALIDATION\n        elif 'timeout' in error_name:\n            return ErrorType.TIMEOUT  # 超时错误优先判断\n        elif any(keyword in error_name for keyword in ['connection', 'network']):\n            return ErrorType.CONNECTION\n        elif any(keyword in error_name for keyword in ['permission', 'access', 'auth']):\n            return ErrorType.PERMISSION\n        elif any(keyword in error_name for keyword in ['resource', 'memory', 'disk']):\n            return ErrorType.RESOURCE\n        elif any(keyword in error_name for keyword in ['system', 'os', 'platform']):\n            return ErrorType.SYSTEM\n        elif any(keyword in error_name for keyword in ['business', 'logic', 'domain']):\n            return ErrorType.BUSINESS\n        else:\n            return ErrorType.UNKNOWN\n\n    def _determine_severity(self, error: Exception, error_type: ErrorType) -> ErrorSeverity:\n    """文档字符串"""\n\n        # 根据错误类型和消息内容判断严重程度\n        error_msg = str(error).lower()\n\n        if error_type == ErrorType.CONNECTION:\n            return ErrorSeverity.HIGH\n        elif error_type == ErrorType.RESOURCE:\n            return ErrorSeverity.HIGH  # 资源错误通常是高严重程度\n        elif error_type == ErrorType.VALIDATION:\n            return ErrorSeverity.MEDIUM  # 验证错误通常是中等严重程度\n        elif error_type == ErrorType.PERMISSION:\n            return ErrorSeverity.HIGH    # 权限错误通常是高严重程度\n        elif error_type == ErrorType.TIMEOUT:\n            return ErrorSeverity.MEDIUM  # 超时错误通常是中等严重程度\n        elif error_type == ErrorType.SYSTEM:\n            return ErrorSeverity.CRITICAL  # 系统错误通常是严重级别\n        elif error_type == ErrorType.BUSINESS:\n            return ErrorSeverity.MEDIUM  # 业务错误通常是中等严重程度\n        elif error_type == ErrorType.UNKNOWN:\n            return ErrorSeverity.MEDIUM  # 未知错误通常是中等严重程度\n        elif 'critical' in error_msg or 'fatal' in error_msg:\n            return ErrorSeverity.CRITICAL\n        elif 'error' in error_msg:\n            return ErrorSeverity.HIGH\n        elif 'warning' in error_msg:\n            return ErrorSeverity.MEDIUM\n        else:\n            return ErrorSeverity.LOW\n\n    def _extract_error_details(self, error: Exception) -> Dict[str, Any]:\n    """文档字符串"""\n\n        details = {\n            'error_type': type(error).__name__,\n            'error_module': getattr(error, '__module__', 'unknown'),\n            'error_args': getattr(error, 'args', ()),\n        }\n\n        # 添加特定错误类型的额外信息\n        if hasattr(error, 'code'):\n            details['error_code'] = error.code\n        if hasattr(error, 'filename'):\n            details['filename'] = error.filename\n        if hasattr(error, 'lineno'):\n            details['lineno'] = error.lineno\n\n        return details\n\n    def _log_error(self, error_info: ErrorInfo):\n    """文档字符串"""\n\n        log_level = {\n            ErrorSeverity.LOW: logging.DEBUG,\n            ErrorSeverity.MEDIUM: logging.WARNING,\n            ErrorSeverity.HIGH: logging.ERROR,\n            ErrorSeverity.CRITICAL: logging.CRITICAL\n        }\n\n        self.logger.log(log_level.get(error_info.severity, logging.ERROR),\n                        f"错误 [{error_info.error_type.value}] [{error_info.severity.value}]: {error_info.message}",\n                        extra={'error_info': error_info})\n\n    def _call_error_handler(self, error_info: ErrorInfo):\n    """文档字符串"""\n\n        # 调用特定类型的错误处理器\n        if error_info.error_type in self.error_handlers:\n            try:\n                self.error_handlers[error_info.error_type](error_info)\n            except Exception as e:\n                self.logger.error(f"错误处理器执行失败: {e}")\n\n        # 调用全局错误处理器\n        if self.global_error_handler:\n            try:\n                self.global_error_handler(error_info)\n            except Exception as e:\n                self.logger.error(f"全局错误处理器执行失败: {e}")\n\n    def get_error_statistics(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        stats = {\n            'total_errors': self.error_count,\n            'error_count': self.error_count,  # 添加error_count字段\n            'error_types': {},\n            'severity_distribution': {},\n            'recent_errors': []\n        }\n\n        # 统计错误类型分布\n        for error_info in self.error_history:\n            error_type = error_info.error_type.value\n            stats['error_types'][error_type] = stats['error_types'].get(error_type, 0) + 1\n\n            severity = error_info.severity.value\n            stats['severity_distribution'][severity] = stats['severity_distribution'].get(severity, 0) + 1\n\n        # 最近10个错误\n        stats['recent_errors'] = [\n            {\n                'type': e.error_type.value,\n                'severity': e.severity.value,\n                'message': e.message,\n                'timestamp': getattr(e, 'timestamp', None)\n            }\n            for e in self.error_history[-10:]\n        ]\n\n        return stats\n\n    def clear_error_history(self):\n    """文档字符串"""\n\n        self.error_history.clear()\n        self.error_count = 0\n        self.logger.info("错误历史已清空")\n\n    def is_healthy(self) -> bool:\n    """文档字符串"""\n\n        # 如果最近有太多严重错误，认为系统不健康\n        recent_critical_errors = sum(\n            1 for e in self.error_history[-100:]\n            if e.severity == ErrorSeverity.CRITICAL\n        )\n        # 如果错误总数过多，也认为系统不健康:\n        if self.error_count > 50:\n            return False\n\n        return recent_critical_errors < 5\n\n# 全局错误处理器实例\nerror_handler = ErrorHandler()\n\ndef handle_exception(func):\n    """文档字符串"""\n\n    def wrapper(*args, **kwargs):\n    """文档字符串"""\n\n        try:\n            return func(*args, **kwargs)\n        except Exception as e:\n            error_handler.handle_error(e, {\n                'function': func.__name__,\n                'args': args,\n                'kwargs': kwargs\n            })\n\n            return None  # 失败时返回None\n    return wrapper\n\ndef safe_execute(func: Callable, *args, **kwargs) -> Optional[Any]:\n    """文档字符串"""\n\n    try:\n        return func(*args, **kwargs)\n    except Exception as e:\n        error_handler.handle_error(e, {\n            'function': func.__name__,\n            'args': args,\n            'kwargs': kwargs\n        })\n\n        return None\n