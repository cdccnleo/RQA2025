"""\n重试处理器模块\n\n提供智能重试策略、指数退避算法和熔断器模式，用于提高分布式组件的可靠性。\n"""\n\nfrom enum import Enum\nfrom functools import wraps\nfrom typing import Callable, Any, Optional, Dict, List\nimport logging\nimport random\nimport threading\nimport time\n\nfrom dataclasses import dataclass\n\nlogger = logging.getLogger(__name__)\n\nclass RetryStrategy(Enum):\n\n    """重试策略枚举"""\n    FIXED = "fixed"\n    EXPONENTIAL = "exponential"\n    LINEAR = "linear"\n    RANDOM = "random"\n\nclass CircuitState(Enum):\n\n    """熔断器状态枚举"""\n    CLOSED = "closed"         # 关闭状态（正常）\n    OPEN = "open"             # 开启状态（熔断）\n    HALF_OPEN = "half_open"   # 半开状态（试探）\n\n@dataclass\nclass RetryConfig:\n\n    """重试配置"""\n    max_attempts: int = 3\n    base_delay: float = 1.0\n    max_delay: float = 60.0\n    strategy: RetryStrategy = RetryStrategy.EXPONENTIAL\n    jitter: bool = True\n    backoff_factor: float = 2.0\n\n@dataclass\nclass CircuitBreakerConfig:\n\n    """熔断器配置"""\n    failure_threshold: int = 5\n    recovery_timeout: float = 60.0\n    expected_exception: type = Exception\n    monitor_interval: float = 1.0\n\nclass RetryHandler:\n\n    """重试处理器"""\n\n    def __init__(self, config: RetryConfig):\n\n        self.config = config\n        self._lock = threading.Lock()\n\n    def calculate_delay(self, attempt: int) -> float:\n    """文档字符串"""\n\n        """计算重试延迟时间"""\n        if attempt <= 0:\n            return 0.0\n\n        if self.config.strategy == RetryStrategy.FIXED:\n            delay = self.config.base_delay\n        elif self.config.strategy == RetryStrategy.EXPONENTIAL:\n            delay = self.config.base_delay * (self.config.backoff_factor ** (attempt - 1))\n        elif self.config.strategy == RetryStrategy.LINEAR:\n            delay = self.config.base_delay * attempt\n        elif self.config.strategy == RetryStrategy.RANDOM:\n            delay = random.uniform(0, self.config.base_delay * attempt)\n        else:\n            delay = self.config.base_delay\n\n        # 添加抖动\n        if self.config.jitter:\n            jitter = delay * 0.1 * random.uniform(-1, 1)\n            delay += jitter\n\n        # 限制最大延迟\n        return min(delay, self.config.max_delay)\n\n    def retry(self, func: Callable, *args, **kwargs) -> Any:\n    """文档字符串"""\n\n        """执行带重试的函数调用"""\n        last_exception = None\n\n        for attempt in range(1, self.config.max_attempts + 1):\n            try:\n                return func(*args, **kwargs)\n            except Exception as e:\n                last_exception = e\n                logger.warning(f"第{attempt}次尝试失败: {e}")\n\n                if attempt < self.config.max_attempts:\n                    delay = self.calculate_delay(attempt)\n                    logger.info(f"等待{delay:.2f}秒后进行第{attempt + 1}次重试")\n                    time.sleep(delay)\n                else:\n                    logger.error(f"所有{self.config.max_attempts}次尝试都失败了")\n\n        raise last_exception\n\nclass CircuitBreaker:\n\n    """熔断器实现"""\n\n    def __init__(self, config: CircuitBreakerConfig):\n\n        self.config = config\n        self.state = CircuitState.CLOSED\n        self.failure_count = 0\n        self.last_failure_time = 0\n        self.last_state_change = time.time()\n        self._lock = threading.Lock()\n        self._running = True\n        self._stop_event = threading.Event()  # 添加停止事件\n\n        # 启动监控线程\n        self._monitor_thread = threading.Thread(target=self._monitor, daemon=True)\n        self._monitor_thread.start()\n\n    def stop(self):\n    """文档字符串"""\n\n        """停止监控线程 - 增强版"""\n        logger = logging.getLogger(__name__)\n\n        if self._monitor_thread is not None:\n            logger.info("正在停止熔断器监控线程...")\n\n            # Phase 1: 立即设置停止标志\n            self._running = False\n\n            # Phase 2: 多次设置停止事件，确保线程能立即检测到\n            if hasattr(self, '_stop_event'):\n                for _ in range(5):\n                    self._stop_event.set()\n                    time.sleep(0.001)  # 短暂延迟确保信号被处理\n\n            # Phase 3: 等待线程结束，采用渐进式超时策略\n            wait_intervals = [0.1, 0.2, 0.5, 1.0]  # 总共1.8秒\n\n            for i, interval in enumerate(wait_intervals):\n                self._monitor_thread.join(timeout=interval)\n                if not self._monitor_thread.is_alive():\n                    logger.info(f"✅ 熔断器监控线程在 {sum(wait_intervals[:i + 1]):.1f} 秒后停止")\n                    break\n                logger.debug(f"等待熔断器监控线程停止... (已等待 {sum(wait_intervals[:i + 1]):.1f}s)")\n            # Phase 4: 检查线程是否仍在运行\n            if self._monitor_thread.is_alive():\n                logger.warning("⚠️ 熔断器监控线程未能及时停止，可能需要强制清理")\n                # 尝试更激进的停止策略\n                self._force_stop_monitor_thread()\n            else:\n                logger.info("✅ 熔断器监控线程已成功停止")\n\n            # Phase 5: 清理资源\n        if hasattr(self, '_stop_event'):\n            self._stop_event.clear()\n\n    def _force_stop_monitor_thread(self):\n    """文档字符串"""\n\n        """强制停止监控线程（最后的手段）"""\n        logger = logging.getLogger(__name__)\n\n        try:\n            logger.warning("正在执行熔断器强制线程停止...")\n\n            # 设置所有可能的停止标志\n            for attr in ['_running', '_stop', '_stopped', 'running']:\n                if hasattr(self, attr):\n                    try:\n                        setattr(self, attr, False)\n                        logger.debug(f"设置 {attr} = False")\n                    except Exception as e:\n                        logger.debug(f"无法设置 {attr}: {e}")\n\n            # 最后一次等待\n            self._monitor_thread.join(timeout=1.0)\n\n            if self._monitor_thread.is_alive():\n                logger.error("❌ 熔断器监控线程强制停止失败")\n            else:\n                logger.info("✅ 熔断器监控线程通过强制手段停止")\n\n        except Exception as e:\n            logger.error(f"强制停止熔断器监控线程时出错: {e}")\n\n    def _monitor(self):\n    """文档字符串"""\n\n        """监控线程，定期检查熔断器状态"""\n        while self._running:\n            try:\n                # 在每次循环开始时立即检查运行状态\n                if not self._running:\n                    break\n\n                # 使用事件等待，实现可中断的等待\n                interrupted = self._stop_event.wait(timeout=self.config.monitor_interval)\n\n                # 等待结束后立即检查运行状态\n                if not self._running or interrupted:\n                    break\n\n                # 执行任务前再次检查运行状态\n                if not self._running:\n                    break\n\n                self._check_state()\n\n            except Exception as e:\n                logger.error(f"熔断器监控异常: {e}")\n                # 异常时立即检查运行状态\n                if not self._running:\n                    break\n\n    def _check_state(self):\n    """文档字符串"""\n\n        """检查并更新熔断器状态"""\n        with self._lock:\n            current_time = time.time()\n\n            if self.state == CircuitState.OPEN:\n                # 检查是否应该进入半开状态\n                if current_time - self.last_failure_time >= self.config.recovery_timeout:\n                    self.state = CircuitState.HALF_OPEN\n                    self.last_state_change = current_time\n                    logger.info("熔断器状态: OPEN -> HALF_OPEN")\n\n            elif self.state == CircuitState.HALF_OPEN:\n                # 半开状态下的成功应该关闭熔断器\n                if self.failure_count == 0:\n                    self.state = CircuitState.CLOSED\n                    self.last_state_change = current_time\n                    logger.info("熔断器状态: HALF_OPEN -> CLOSED")\n\n    def call(self, func: Callable, *args, **kwargs) -> Any:\n    """文档字符串"""\n\n        """通过熔断器调用函数"""\n        with self._lock:\n            if self.state == CircuitState.OPEN:\n                raise Exception("熔断器处于开启状态，拒绝调用")\n\n            if self.state == CircuitState.HALF_OPEN:\n                # 半开状态下只允许少量请求通过\n                if self.failure_count > 0:\n                    raise Exception("熔断器处于半开状态，拒绝调用")\n\n        try:\n            result = func(*args, **kwargs)\n            self._on_success()\n            return result\n        except Exception as e:\n            self._on_failure(e)\n            raise\n\n    def _on_success(self):\n    """文档字符串"""\n\n        """成功回调"""\n        with self._lock:\n            if self.state == CircuitState.HALF_OPEN:\n                self.failure_count = 0\n                logger.info("半开状态下调用成功")\n\n    def _on_failure(self, exception: Exception):\n    """文档字符串"""\n\n        """失败回调"""\n        with self._lock:\n            self.failure_count += 1\n            self.last_failure_time = time.time()\n\n            if self.state == CircuitState.CLOSED:\n                if self.failure_count >= self.config.failure_threshold:\n                    self.state = CircuitState.OPEN\n                    self.last_state_change = time.time()\n                    logger.warning(f"熔断器状态: CLOSED -> OPEN (失败次数: {self.failure_count})")\n\n            elif self.state == CircuitState.HALF_OPEN:\n                self.state = CircuitState.OPEN\n                self.last_state_change = time.time()\n                logger.warning(f"熔断器状态: HALF_OPEN -> OPEN")\n\n    def get_state(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取熔断器状态信息"""\n        with self._lock:\n            return {\n                "state": self.state.value,\n                "failure_count": self.failure_count,\n                "last_failure_time": self.last_failure_time,\n                "last_state_change": self.last_state_change,\n                "config": {\n                    "failure_threshold": self.config.failure_threshold,\n                    "recovery_timeout": self.config.recovery_timeout\n                }\n            }\n\nclass ResilienceManager:\n\n    """弹性管理器，整合重试和熔断器"""\n\n    def __init__(self, retry_config: RetryConfig = None, circuit_config: CircuitBreakerConfig = None):\n\n        self.retry_config = retry_config or RetryConfig()\n        self.circuit_config = circuit_config or CircuitBreakerConfig()\n\n        self.retry_handler = RetryHandler(self.retry_config)\n        self.circuit_breaker = CircuitBreaker(self.circuit_config)\n\n    def resilient_call(self, func: Callable, *args, **kwargs) -> Any:\n    """文档字符串"""\n\n        """弹性调用，结合重试和熔断器"""\n\n        def circuit_wrapped_func():\n    """文档字符串"""\n\n            return self.circuit_breaker.call(func, *args, **kwargs)\n\n        return self.retry_handler.retry(circuit_wrapped_func)\n\n    def get_status(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取弹性管理器状态"""\n        return {\n            "retry_config": {\n                "max_attempts": self.retry_config.max_attempts,\n                "base_delay": self.retry_config.base_delay,\n                "strategy": self.retry_config.strategy.value\n            },\n            "circuit_breaker": self.circuit_breaker.get_state()\n        }\n\n    def stop(self):\n    """文档字符串"""\n\n        """停止所有组件"""\n        self.circuit_breaker.stop()\n\n    def resilient(func: Callable = None, *,\n    """文档字符串"""\n\n                  retry_config: RetryConfig = None,\n                  circuit_config: CircuitBreakerConfig = None):\n        """弹性装饰器"""\n\n        def decorator(f):\n    """文档字符串"""\n\n            @wraps(f)\n\n            def wrapper(*args, **kwargs):\n    """文档字符串"""\n\n                manager = ResilienceManager(retry_config, circuit_config)\n                return manager.resilient_call(f, *args, **kwargs)\n            return wrapper\n\n        if func is None:\n            return decorator\n        return decorator(func)\n\n# 预定义的配置\nDEFAULT_RETRY_CONFIG = RetryConfig(\n    max_attempts=3,\n    base_delay=1.0,\n    max_delay=30.0,\n    strategy=RetryStrategy.EXPONENTIAL,\n    jitter=True\n)\n\nDEFAULT_CIRCUIT_CONFIG = CircuitBreakerConfig(\n    failure_threshold=5,\n    recovery_timeout=60.0,\n    expected_exception=Exception\n)\n\n# 全局弹性管理器实例\n\ndefault_resilience_manager = ResilienceManager(DEFAULT_RETRY_CONFIG, DEFAULT_CIRCUIT_CONFIG)\n