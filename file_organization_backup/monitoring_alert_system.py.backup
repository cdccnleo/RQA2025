"""\n监控告警系统\n\n实现测试执行监控和异常告警功能，包括：\n- 实时监控测试执行状态\n- 异常检测和告警\n- 性能指标监控\n- 告警通知管理\n"""\n\nfrom collections import defaultdict, deque\nfrom datetime import datetime, timedelta\nfrom enum import Enum\nfrom typing import Dict, List, Optional, Callable, Any\nimport json\nimport logging\nimport smtplib\nimport threading\nimport time\n\nfrom dataclasses import dataclass, field\nfrom email.mime.multipart import MIMEMultipart\nfrom email.mime.text import MIMEText\nimport requests\n\nclass AlertLevel(Enum):\n\n    """Alert level enumeration"""\n\n    INFO = "info"\n    WARNING = "warning"\n    ERROR = "error"\n    CRITICAL = "critical"\n\nclass AlertType(Enum):\n\n    """Alert type enumeration"""\n    TEST_TIMEOUT = "test_timeout"\n    TEST_FAILURE = "test_failure"\n    PERFORMANCE_DEGRADATION = "performance_degradation"\n    SYSTEM_ERROR = "system_error"\n    RESOURCE_EXHAUSTION = "resource_exhaustion"\n    NETWORK_ISSUE = "network_issue"\n\nclass MonitoringEvent(Enum):\n\n    """Monitoring event type enumeration"""\n    TEST_STARTED = "test_started"\n    TEST_COMPLETED = "test_completed"\n    TEST_FAILED = "test_failed"\n    TEST_TIMEOUT = "test_timeout"\n    PERFORMANCE_THRESHOLD_EXCEEDED = "performance_threshold_exceeded"\n    SYSTEM_RESOURCE_LOW = "system_resource_low"\n    NETWORK_LATENCY_HIGH = "network_latency_high"\n\n@dataclass\n\nclass AlertRule:\n\n    """Alert rule dataclass"""\n    name: str\n    alert_type: AlertType\n    alert_level: AlertLevel\n    condition: str  # 条件表达式\n    threshold: float  # 阈值\n    enabled: bool = True\n    cooldown: int = 300  # 冷却时间(秒)\n    last_triggered: Optional[datetime] = None\n\n@dataclass\n\nclass Alert:\n\n    """Alert information dataclass"""\n    id: str\n    alert_type: AlertType\n    alert_level: AlertLevel\n    message: str\n    details: Dict[str, Any]\n    timestamp: datetime\n    source: str\n    resolved: bool = False\n    resolved_at: Optional[datetime] = None\n\n@dataclass\n\nclass PerformanceMetrics:\n\n    """Performance metrics dataclass"""\n    cpu_usage: float = 0.0\n    memory_usage: float = 0.0\n    disk_usage: float = 0.0\n    network_latency: float = 0.0\n    test_execution_time: float = 0.0\n    test_success_rate: float = 0.0\n    active_threads: int = 0\n    timestamp: datetime = field(default_factory=datetime.now)\n\n@dataclass\n\nclass TestExecutionInfo:\n\n    """Test execution information dataclass"""\n    test_id: str\n    test_name: str\n    start_time: datetime\n    end_time: Optional[datetime] = None\n    status: str = "running"\n    execution_time: Optional[float] = None\n    error_message: Optional[str] = None\n    performance_metrics: Optional[PerformanceMetrics] = None\n\nclass PerformanceMonitor:\n\n    """Performance monitor class"""\n\n    def __init__(self, update_interval: int = 5):\n\n        self.update_interval = update_interval\n        self.metrics_history: deque = deque(maxlen=1000)\n        self.current_metrics = PerformanceMetrics()\n        self.monitoring = False\n        self.monitor_thread: Optional[threading.Thread] = None\n        self._lock = threading.Lock()\n\n    def start_monitoring(self):\n    """文档字符串"""\n\n        """Start monitoring"""\n        if self.monitoring:\n            return\n\n        self.monitoring = True\n        self.monitor_thread = threading.Thread(target=self._monitor_loop, daemon=True)\n        self.monitor_thread.start()\n\n    def stop_monitoring(self):\n    """文档字符串"""\n\n        """Stop monitoring"""\n        self.monitoring = False\n        if self.monitor_thread:\n            self.monitor_thread.join()\n\n    def _monitor_loop(self):\n    """文档字符串"""\n\n        """Monitoring loop"""\n        while self.monitoring:\n            try:\n                self._collect_metrics()\n                time.sleep(self.update_interval)\n            except Exception as e:\n                logging.error(f"性能监控错误: {e}")\n\n    def _collect_metrics(self):\n    """文档字符串"""\n\n        """Collect performance metrics"""\n        # 这里应该实现实际的系统指标收集\n        # 目前使用模拟数据\n        import psutil\n\n        try:\n            cpu_percent = psutil.cpu_percent(interval=1)\n            memory = psutil.virtual_memory()\n            disk = psutil.disk_usage('/')\n\n            with self._lock:\n                self.current_metrics = PerformanceMetrics(\n                    cpu_usage=cpu_percent,\n                    memory_usage=memory.percent,\n                    disk_usage=disk.percent,\n                    network_latency=self._get_network_latency(),\n                    active_threads=threading.active_count(),\n                    timestamp=datetime.now()\n                )\n\n                self.metrics_history.append(self.current_metrics)\n\n        except ImportError:\n            # psutil不可用时使用模拟数据\n            with self._lock:\n                self.current_metrics = PerformanceMetrics(\n                    cpu_usage=time.time() % 100,\n                    memory_usage=50 + (time.time() % 30),\n                    disk_usage=60 + (time.time() % 20),\n                    network_latency=10 + (time.time() % 50),\n                    active_threads=threading.active_count(),\n                    timestamp=datetime.now()\n                )\n\n                self.metrics_history.append(self.current_metrics)\n\n    def _get_network_latency(self) -> float:\n    """文档字符串"""\n\n        """Get network latency"""\n        try:\n            start_time = time.time()\n            requests.get("http://www.baidu.com", timeout=5)\n            return (time.time() - start_time) * 1000\n        except:\n            return 100.0  # 默认延迟\n\n    def get_current_metrics(self) -> PerformanceMetrics:\n    """文档字符串"""\n\n        """Get current performance metrics"""\n        with self._lock:\n            return self.current_metrics\n\n    def get_metrics_history(self, minutes: int = 60) -> List[PerformanceMetrics]:\n    """文档字符串"""\n\n        """Get historical performance metrics"""\n        cutoff_time = datetime.now() - timedelta(minutes=minutes)\n        with self._lock:\n            return [m for m in self.metrics_history if m.timestamp > cutoff_time]\n\nclass AlertManager:\n\n    """Alert manager class"""\n\n    def __init__(self):\n\n        self.alert_rules: List[AlertRule] = []\n        self.active_alerts: Dict[str, Alert] = {}\n        self.alert_handlers: Dict[AlertType, List[Callable]] = defaultdict(list)\n        self._lock = threading.Lock()\n\n    def add_alert_rule(self, rule: AlertRule):\n    """文档字符串"""\n\n        """Add alert rule"""\n        with self._lock:\n            self.alert_rules.append(rule)\n\n    def remove_alert_rule(self, rule_name: str):\n    """文档字符串"""\n\n        """Remove alert rule"""\n        with self._lock:\n            self.alert_rules = [r for r in self.alert_rules if r.name != rule_name]\n\n    def register_alert_handler(self, alert_type: AlertType, handler: Callable):\n    """文档字符串"""\n\n        """Register alert handler"""\n        self.alert_handlers[alert_type].append(handler)\n\n    def check_alerts(self, metrics: PerformanceMetrics, test_info: Optional[TestExecutionInfo] = None):\n    """文档字符串"""\n\n        """Check alert conditions"""\n        with self._lock:\n            for rule in self.alert_rules:\n                if not rule.enabled:\n                    continue\n\n                # 检查冷却时间\n                if (rule.last_triggered and\n                    datetime.now() - rule.last_triggered < timedelta(seconds=rule.cooldown)):\n                    continue\n\n                # 检查告警条件\n                if self._evaluate_condition(rule, metrics, test_info):\n                    self._trigger_alert(rule, metrics, test_info)\n\n    def _evaluate_condition(self, rule: AlertRule, metrics: PerformanceMetrics,\n    """文档字符串"""\n\n                          test_info: Optional[TestExecutionInfo]):\n        """评估告警条件"""\n        try:\n            if rule.condition == "cpu_usage > threshold":\n                return metrics.cpu_usage > rule.threshold\n            elif rule.condition == "memory_usage > threshold":\n                return metrics.memory_usage > rule.threshold\n            elif rule.condition == "disk_usage > threshold":\n                return metrics.disk_usage > rule.threshold\n            elif rule.condition == "network_latency > threshold":\n                return metrics.network_latency > rule.threshold\n            elif rule.condition == "test_execution_time > threshold" and test_info:\n                return test_info.execution_time and test_info.execution_time > rule.threshold\n            elif rule.condition == "test_success_rate < threshold":\n                return metrics.test_success_rate < rule.threshold\n            return False\n        except Exception as e:\n            logging.error(f"告警条件评估错误: {e}")\n            return False\n\n    def _trigger_alert(self, rule: AlertRule, metrics: PerformanceMetrics,\n    """文档字符串"""\n\n                      test_info: Optional[TestExecutionInfo]):\n        """触发告警"""\n        alert_id = f"{rule.alert_type.value}_{int(time.time())}"\n\n        alert = Alert(\n            id=alert_id,\n            alert_type=rule.alert_type,\n            alert_level=rule.alert_level,\n            message=f"触发告警规则: {rule.name}",\n            details={\n                "rule_name": rule.name,\n                "condition": rule.condition,\n                "threshold": rule.threshold,\n                "current_value": self._get_current_value(rule, metrics, test_info),\n                "metrics": {\n                    "cpu_usage": metrics.cpu_usage,\n                    "memory_usage": metrics.memory_usage,\n                    "disk_usage": metrics.disk_usage,\n                    "network_latency": metrics.network_latency\n                }\n            },\n            timestamp=datetime.now(),\n            source="performance_monitor"\n        )\n\n        with self._lock:\n            self.active_alerts[alert_id] = alert\n            rule.last_triggered = datetime.now()\n\n        # 调用告警处理器（异步处理，避免阻塞）\n\n        def call_handlers():\n    """文档字符串"""\n\n            for handler in self.alert_handlers[rule.alert_type]:\n                try:\n                    handler(alert)\n                except Exception as e:\n                    logging.error(f"告警处理器错误: {e}")\n\n        # 在后台线程中调用处理器，避免阻塞主线程\n        handler_thread = threading.Thread(target=call_handlers, daemon=True)\n        handler_thread.start()\n\n    def _get_current_value(self, rule: AlertRule, metrics: PerformanceMetrics,\n    """文档字符串"""\n\n                          test_info: Optional[TestExecutionInfo]):\n        """获取当前值"""\n        if rule.condition == "cpu_usage > threshold":\n            return metrics.cpu_usage\n        elif rule.condition == "memory_usage > threshold":\n            return metrics.memory_usage\n        elif rule.condition == "disk_usage > threshold":\n            return metrics.disk_usage\n        elif rule.condition == "network_latency > threshold":\n            return metrics.network_latency\n        elif rule.condition == "test_execution_time > threshold" and test_info:\n            return test_info.execution_time or 0.0\n        elif rule.condition == "test_success_rate < threshold":\n            return metrics.test_success_rate\n        return 0.0\n\n    def resolve_alert(self, alert_id: str):\n    """文档字符串"""\n\n        """解决告警"""\n        with self._lock:\n            if alert_id in self.active_alerts:\n                self.active_alerts[alert_id].resolved = True\n                self.active_alerts[alert_id].resolved_at = datetime.now()\n\n    def get_active_alerts(self) -> List[Alert]:\n    """文档字符串"""\n\n        """获取活跃告警"""\n        with self._lock:\n            return list(self.active_alerts.values())\n\n    def get_alert_history(self, hours: int = 24) -> List[Alert]:\n    """文档字符串"""\n\n        """获取告警历史"""\n        cutoff_time = datetime.now() - timedelta(hours=hours)\n        with self._lock:\n            return [a for a in self.active_alerts.values() if a.timestamp > cutoff_time]\n\nclass NotificationManager:\n\n    """Notification manager class"""\n\n    def __init__(self):\n\n        self.notification_channels: Dict[str, Callable] = {}\n        self.notification_config: Dict[str, Dict] = {}\n\n    def register_channel(self, name: str, handler: Callable, config: Dict = None):\n    """文档字符串"""\n\n        """注册通知通道"""\n        self.notification_channels[name] = handler\n        if config:\n            self.notification_config[name] = config\n\n    def send_notification(self, alert: Alert, channels: List[str] = None):\n    """文档字符串"""\n\n        """发送通知"""\n        if not channels:\n            channels = list(self.notification_channels.keys())\n\n        for channel in channels:\n            if channel in self.notification_channels:\n                try:\n                    self.notification_channels[channel](alert, self.notification_config.get(channel, {}))\n                except Exception as e:\n                    logging.error(f"通知发送失败 {channel}: {e}")\n\n    def send_email_notification(self, alert: Alert, config: Dict):\n    """文档字符串"""\n\n        """发送邮件通知"""\n        try:\n            msg = MIMEMultipart()\n            msg['From'] = config.get('from_email', 'noreply@example.com')\n            msg['To'] = config.get('to_email', 'admin@example.com')\n\n            msg['Subject'] = f"测试监控告警: {alert.alert_level.value.upper()}"\n\n            body = f"""\n            告警详情:\n            - 级别: {alert.alert_level.value}\n            - 类型: {alert.alert_type.value}\n            - 消息: {alert.message}\n            - 时间: {alert.timestamp}\n            - 详情: {json.dumps(alert.details, indent=2, ensure_ascii=False)}\n            """\n\n            msg.attach(MIMEText(body, 'plain', 'utf-8'))\n\n            # 发送邮件\n            server = smtplib.SMTP(config.get('smtp_server', 'localhost'))\n            if config.get('use_tls', False):\n                server.starttls()\n            if config.get('username') and config.get('password'):\n                server.login(config['username'], config['password'])\n            server.send_message(msg)\n            server.quit()\n\n            logging.info(f"邮件通知发送成功: {alert.id}")\n\n        except Exception as e:\n            logging.error(f"邮件通知发送失败: {e}")\n\n    def send_webhook_notification(self, alert: Alert, config: Dict):\n    """文档字符串"""\n\n        """发送Webhook通知"""\n        try:\n            webhook_url = config.get('webhook_url')\n            if not webhook_url:\n                return\n\n            payload = {\n                "alert_id": alert.id,\n                "level": alert.alert_level.value,\n                "type": alert.alert_type.value,\n                "message": alert.message,\n                "timestamp": alert.timestamp.isoformat(),\n                "details": alert.details\n            }\n\n            response = requests.post(\n                webhook_url,\n                json=payload,\n                headers={'Content-Type': 'application/json'},\n                timeout=10\n            )\n\n            if response.status_code == 200:\n                logging.info(f"Webhook通知发送成功: {alert.id}")\n            else:\n                logging.warning(f"Webhook通知发送失败: {response.status_code}")\n\n        except Exception as e:\n            logging.error(f"Webhook通知发送失败: {e}")\n\nclass TestExecutionMonitor:\n\n    """Test execution monitor class"""\n\n    def __init__(self):\n\n        self.active_tests: Dict[str, TestExecutionInfo] = {}\n        self.test_history: List[TestExecutionInfo] = []\n        self.monitoring = False\n        self.monitor_thread: Optional[threading.Thread] = None\n        self._lock = threading.Lock()\n\n    def start_monitoring(self):\n    """文档字符串"""\n\n        """Start monitoring"""\n        if self.monitoring:\n            return\n\n        self.monitoring = True\n        self.monitor_thread = threading.Thread(target=self._monitor_loop, daemon=True)\n        self.monitor_thread.start()\n\n    def stop_monitoring(self):\n    """文档字符串"""\n\n        """Stop monitoring"""\n        self.monitoring = False\n        if self.monitor_thread:\n            self.monitor_thread.join()\n\n    def _monitor_loop(self):\n    """文档字符串"""\n\n        """Monitoring loop"""\n        while self.monitoring:\n            try:\n                self._check_test_timeouts()\n                time.sleep(1)\n            except Exception as e:\n                logging.error(f"测试监控错误: {e}")\n\n    def _check_test_timeouts(self):\n    """文档字符串"""\n\n        """Check test timeouts"""\n        current_time = datetime.now()\n        timeout_tests = []\n\n        with self._lock:\n            for test_id, test_info in self.active_tests.items():\n                if test_info.status == "running":\n                    # 检查是否超时 (默认5分钟)\n                    if (current_time - test_info.start_time).total_seconds() > 300:\n                        test_info.status = "timeout"\n                        test_info.end_time = current_time\n                        test_info.error_message = "测试执行超时"\n                        timeout_tests.append(test_id)\n\n        # 处理超时测试\n        for test_id in timeout_tests:\n            self._handle_test_timeout(test_id)\n\n    def _handle_test_timeout(self, test_id: str):\n    """文档字符串"""\n\n        """处理测试超时"""\n        logging.warning(f"测试超时: {test_id}")\n        # 这里可以触发告警或执行其他处理逻辑\n\n    def register_test(self, test_id: str, test_name: str) -> str:\n    """文档字符串"""\n\n        """注册测试"""\n        test_info = TestExecutionInfo(\n            test_id=test_id,\n            test_name=test_name,\n            start_time=datetime.now()\n        )\n\n        with self._lock:\n            self.active_tests[test_id] = test_info\n\n        return test_id\n\n    def update_test_status(self, test_id: str, status: str,\n    """文档字符串"""\n\n                          execution_time: Optional[float] = None,\n                          error_message: Optional[str] = None):\n        """Update test status"""\n        with self._lock:\n            if test_id in self.active_tests:\n                test_info = self.active_tests[test_id]\n                test_info.status = status\n                test_info.end_time = datetime.now()\n                test_info.execution_time = execution_time\n                test_info.error_message = error_message\n\n                # 移动到历史记录\n                self.test_history.append(test_info)\n                del self.active_tests[test_id]\n\n    def get_active_tests(self) -> List[TestExecutionInfo]:\n    """文档字符串"""\n\n        """获取活跃测试"""\n        with self._lock:\n            return list(self.active_tests.values())\n\n    def get_test_history(self, hours: int = 24) -> List[TestExecutionInfo]:\n    """文档字符串"""\n\n        """获取测试历史"""\n        cutoff_time = datetime.now() - timedelta(hours=hours)\n        with self._lock:\n            return [t for t in self.test_history if t.start_time > cutoff_time]\n\nclass MonitoringAlertSystem:\n\n    """Monitoring alert system main class"""\n\n    def __init__(self):\n\n        self.performance_monitor = PerformanceMonitor()\n        self.alert_manager = AlertManager()\n        self.notification_manager = NotificationManager()\n        self.test_monitor = TestExecutionMonitor()\n        self.running = False\n\n        # 注册默认通知通道\n        self._setup_default_channels()\n\n        # 注册默认告警规则\n        self._setup_default_rules()\n\n    def _setup_default_channels(self):\n    """文档字符串"""\n\n        """设置默认通知通道"""\n        self.notification_manager.register_channel(\n            "email",\n            self.notification_manager.send_email_notification,\n            {\n                "from_email": "monitor@example.com",\n                "to_email": "admin@example.com",\n                "smtp_server": "localhost",\n                "use_tls": False\n            }\n        )\n\n        self.notification_manager.register_channel(\n            "webhook",\n            self.notification_manager.send_webhook_notification,\n            {\n                "webhook_url": "http://localhost:8080/webhook"\n            }\n        )\n\n    def _setup_default_rules(self):\n    """文档字符串"""\n\n        """设置默认告警规则"""\n\n        default_rules = [\n            AlertRule("CPU使用率过高", AlertType.SYSTEM_ERROR, AlertLevel.WARNING,\n                     "cpu_usage > threshold", 80.0),\n            AlertRule("内存使用率过高", AlertType.RESOURCE_EXHAUSTION, AlertLevel.WARNING,\n                     "memory_usage > threshold", 85.0),\n            AlertRule("磁盘使用率过高", AlertType.RESOURCE_EXHAUSTION, AlertLevel.WARNING,\n                     "disk_usage > threshold", 90.0),\n            AlertRule("网络延迟过高", AlertType.NETWORK_ISSUE, AlertLevel.WARNING,\n                     "network_latency > threshold", 100.0),\n            AlertRule("测试执行超时", AlertType.TEST_TIMEOUT, AlertLevel.ERROR,\n                     "test_execution_time > threshold", 300.0),\n            AlertRule("测试成功率过低", AlertType.TEST_FAILURE, AlertLevel.CRITICAL,\n                     "test_success_rate < threshold", 80.0)\n        ]\n\n        for rule in default_rules:\n            self.alert_manager.add_alert_rule(rule)\n\n    def start(self):\n    """文档字符串"""\n\n        """Start monitoring alert system"""\n        if self.running:\n            return\n\n        try:\n            # 启动性能监控\n            self.performance_monitor.start_monitoring()\n\n            # 启动测试监控\n            self.test_monitor.start_monitoring()\n\n            # 启动告警检查循环\n            self._start_alert_check_loop()\n\n            self.running = True\n            logging.info("监控告警系统启动成功")\n\n        except Exception as e:\n            logging.error(f"监控告警系统启动失败: {e}")\n            raise\n\n    def stop(self):\n    """文档字符串"""\n\n        """Stop monitoring alert system"""\n        if not self.running:\n            return\n\n        try:\n            self.performance_monitor.stop_monitoring()\n            self.test_monitor.stop_monitoring()\n            self.running = False\n            logging.info("监控告警系统已停止")\n\n        except Exception as e:\n            logging.error(f"监控告警系统停止失败: {e}")\n\n    def _start_alert_check_loop(self):\n    """文档字符串"""\n\n        """启动告警检查循环"""\n\n        def alert_check_loop():\n    """文档字符串"""\n\n            while self.running:\n                try:\n                    # 获取当前性能指标\n                    metrics = self.performance_monitor.get_current_metrics()\n\n                    # 检查告警条件\n                    self.alert_manager.check_alerts(metrics)\n\n                    time.sleep(10)  # 每10秒检查一次\n\n                except Exception as e:\n                    logging.error(f"告警检查错误: {e}")\n                    time.sleep(30)  # 出错时等待30秒\n\n        alert_thread = threading.Thread(target=alert_check_loop, daemon=True)\n        alert_thread.start()\n\n    def register_test(self, test_id: str, test_name: str) -> str:\n    """文档字符串"""\n\n        """Register test to monitoring system"""\n        return self.test_monitor.register_test(test_id, test_name)\n\n    def update_test_status(self, test_id: str, status: str,\n    """文档字符串"""\n\n                          execution_time: Optional[float] = None,\n                          error_message: Optional[str] = None):\n        """Update test status"""\n        self.test_monitor.update_test_status(test_id, status, execution_time, error_message)\n\n    def add_custom_alert_rule(self, rule: AlertRule):\n    """文档字符串"""\n\n        """Add custom alert rule"""\n        self.alert_manager.add_alert_rule(rule)\n\n    def get_system_status(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """Get system status"""\n        return {\n            "running": self.running,\n            "performance_metrics": self.performance_monitor.get_current_metrics(),\n            "active_tests": len(self.test_monitor.get_active_tests()),\n            "active_alerts": len(self.alert_manager.get_active_alerts()),\n            "test_history_count": len(self.test_monitor.test_history)\n        }\n\n    def get_performance_report(self, minutes: int = 60) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """Get performance report"""\n        metrics_history = self.performance_monitor.get_metrics_history(minutes)\n\n        if not metrics_history:\n            return {}\n\n        # 计算统计信息\n        cpu_usage = [m.cpu_usage for m in metrics_history]\n        memory_usage = [m.memory_usage for m in metrics_history]\n        network_latency = [m.network_latency for m in metrics_history]\n\n        return {\n            "time_range_minutes": minutes,\n            "metrics_count": len(metrics_history),\n            "cpu_usage": {\n                "current": cpu_usage[-1] if cpu_usage else 0,\n                "average": sum(cpu_usage) / len(cpu_usage) if cpu_usage else 0,\n                "max": max(cpu_usage) if cpu_usage else 0,\n                "min": min(cpu_usage) if cpu_usage else 0\n            },\n            "memory_usage": {\n                "current": memory_usage[-1] if memory_usage else 0,\n                "average": sum(memory_usage) / len(memory_usage) if memory_usage else 0,\n                "max": max(memory_usage) if memory_usage else 0,\n                "min": min(memory_usage) if memory_usage else 0\n            },\n            "network_latency": {\n                "current": network_latency[-1] if network_latency else 0,\n                "average": sum(network_latency) / len(network_latency) if network_latency else 0,\n                "max": max(network_latency) if network_latency else 0,\n                "min": min(network_latency) if network_latency else 0\n            }\n        }\n\n# 便捷函数\n\ndef create_monitoring_system() -> MonitoringAlertSystem:\n    """文档字符串"""\n\n    """创建监控告警系统实例"""\n    return MonitoringAlertSystem()\n\ndef start_monitoring() -> MonitoringAlertSystem:\n    """文档字符串"""\n\n    """启动监控告警系统"""\n    system = create_monitoring_system()\n    system.start()\n    return system\n\ndef get_system_status(system: MonitoringAlertSystem) -> Dict[str, Any]:\n    """文档字符串"""\n\n    """获取系统状态"""\n    return system.get_system_status()\n\ndef get_performance_report(system: MonitoringAlertSystem, minutes: int = 60) -> Dict[str, Any]:\n    """文档字符串"""\n\n    """Get performance report"""\n    return system.get_performance_report(minutes)\n