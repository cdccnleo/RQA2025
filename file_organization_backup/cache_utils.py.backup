"""\n缓存工具类 - 重构优化版本\n抽象重复的公共功能，消除代码重复，提高代码质量\n\n重构内容:\n✅ 保留 PredictionCache - 模型预测缓存装饰器\n✅ 新增通用缓存工具类 - 消除重复的公共功能\n✅ 抽象命中率计算逻辑\n✅ 抽象过期检查逻辑\n✅ 抽象统计信息收集逻辑\n✅ 抽象线程安全锁管理\n✅ 抽象性能监控工具\n\n核心特性:\n🔥 通用工具函数 - 消除重复的工具代码\n🔥 性能监控工具 - 统一的性能指标收集\n🔥 线程安全工具 - 标准化的锁管理\n🔥 数据验证工具 - 通用的数据校验功能\n🔥 缓存操作工具 - 常用的缓存操作辅助函数\n🔥 模型预测缓存 - 专用的ML缓存装饰器\n"""\n\nfrom collections import defaultdict\nfrom datetime import datetime, timedelta\nfrom typing import Callable, Any, Dict, List, Optional, Union\nimport functools\nimport gzip\nimport hashlib\nimport json\nimport logging\nimport pickle\nimport threading\nimport time\n\nimport pandas as pd\n\nlogger = logging.getLogger(__name__)\n\nclass PredictionCache:\n\n    """\n    模型预测缓存装饰器\n\n    特性：\n    - 基于特征哈希的缓存键\n    - 可配置的缓存过期时间\n    - 缓存命中率监控\n    """\n\n    def __init__(self, max_size: int = 1000, ttl_seconds: int = 3600):\n\n        self.cache = {}\n        self.max_size = max_size\n        self.ttl_seconds = ttl_seconds\n        self.hits = 0\n        self.misses = 0\n\n    def _make_key(self, *args, **kwargs) -> str:\n    """文档字符串"""\n\n        """生成基于特征数据的缓存键"""\n        data = kwargs.get('features') if 'features' in kwargs else args[0]\n        if isinstance(data, pd.DataFrame):\n            data = data.to_dict()\n        return hashlib.md5(pickle.dumps(data)).hexdigest()\n\n    def __call__(self, func: Callable) -> Callable:\n\n        @functools.wraps(func)\n\n        def wrapper(*args, **kwargs):\n    """文档字符串"""\n\n            key = self._make_key(*args, **kwargs)\n\n            # 检查缓存\n            if key in self.cache:\n                entry = self.cache[key]\n                if time.time() - entry['timestamp'] < self.ttl_seconds:\n                    self.hits += 1\n                    return entry['prediction']\n\n            # 缓存未命中，调用原始函数\n            result = func(*args, **kwargs)\n            self.misses += 1\n\n            # 更新缓存\n            if len(self.cache) >= self.max_size:\n                self.cache.pop(next(iter(self.cache)))\n            self.cache[key] = {\n                'prediction': result,\n                'timestamp': time.time()\n            }\n\n            return result\n\n        return wrapper\n\n    @property\n\n    def hit_rate(self) -> float:\n    """文档字符串"""\n\n        """计算缓存命中率"""\n        total = self.hits + self.misses\n        return self.hits / total if total > 0 else 0.0\n\ndef model_cache(max_size: int = 1000, ttl_seconds: int = 3600) -> Callable:\n    """文档字符串"""\n\n    """\n    模型预测缓存装饰器工厂函数\n\n    Args:\n        max_size: 最大缓存条目数\n        ttl_seconds: 缓存有效期(秒)\n    """\n    cache = PredictionCache(max_size, ttl_seconds)\n    return cache\n\ndef generate_cache_key(*args, **kwargs) -> str:\n    """\n    生成缓存键\n\n    Args:\n        *args: 位置参数\n        **kwargs: 关键字参数\n\n    Returns:\n        str: 缓存键\n    """\n    # 将参数转换为可哈希的字符串\n    key_data = {\n        'args': args,\n        'kwargs': kwargs\n    }\n\n    # 对于复杂对象，使用其字符串表示\n    try:\n        key_str = json.dumps(key_data, sort_keys=True, default=str)\n    except (TypeError, ValueError):\n        key_str = str(key_data)\n\n    # 使用MD5生成固定长度的键\n    return hashlib.md5(key_str.encode('utf-8')).hexdigest()\n\ndef calculate_ttl(base_ttl: int, access_count: int = 0, hit_rate: float = 0.0) -> int:\n    """\n    计算动态TTL\n\n    Args:\n        base_ttl: 基础TTL\n        access_count: 访问次数\n        hit_rate: 命中率\n\n    Returns:\n        int: 计算后的TTL\n    """\n    # 根据访问频率调整TTL\n    if access_count > 100:\n        # 高频访问，增加TTL\n        multiplier = 1.5\n    elif access_count > 50:\n        # 中等访问，保持TTL\n        multiplier = 1.0\n    else:\n        # 低频访问，减少TTL\n        multiplier = 0.8\n\n    # 根据命中率调整TTL\n    if hit_rate > 0.8:\n        # 高命中率，进一步增加TTL\n        multiplier *= 1.2\n    elif hit_rate < 0.3:\n        # 低命中率，减少TTL\n        multiplier *= 0.7\n\n    return int(base_ttl * multiplier)\n\ndef compress_data(data: Any) -> bytes:\n    """\n    压缩数据\n\n    Args:\n        data: 要压缩的数据\n\n    Returns:\n        bytes: 压缩后的数据\n    """\n    # 序列化数据\n    if isinstance(data, (dict, list, tuple)):\n        data_str = json.dumps(data, default=str)\n    else:\n        data_str = str(data)\n\n    # 压缩数据\n    return gzip.compress(data_str.encode('utf-8'))\n\ndef decompress_data(compressed_data: bytes) -> Any:\n    """\n    解压数据\n\n    Args:\n        compressed_data: 压缩的数据\n\n    Returns:\n        Any: 解压后的数据\n    """\n    try:\n        # 解压数据\n        decompressed = gzip.decompress(compressed_data).decode('utf-8')\n\n        # 尝试解析为JSON\n        try:\n            return json.loads(decompressed)\n        except (json.JSONDecodeError, ValueError):\n            return decompressed\n    except Exception:\n        # 如果解压失败，返回原始数据\n        return compressed_data\n\n# ==================== 通用缓存工具类 ====================\n\nclass PerformanceMonitor:\n    """性能监控器"""\n\n    def __init__(self):\n        self._lock = threading.RLock()\n        self.metrics: Dict[str, Dict[str, Any]] = defaultdict(dict)\n        self.start_times: Dict[str, float] = {}\n\n    def start_operation(self, operation_id: str) -> None:\n        """开始操作计时"""\n        # 优化：减少锁持有时间，只在真正需要同步时持有锁\n        current_time = time.time()\n        with self._lock:\n            self.start_times[operation_id] = current_time\n\n    def end_operation(self, operation_id: str) -> float:\n        """结束操作计时并返回耗时"""\n        # 优化：减少锁持有时间\n        current_time = time.time()\n        with self._lock:\n            if operation_id in self.start_times:\n                start_time = self.start_times[operation_id]\n                del self.start_times[operation_id]\n                return current_time - start_time\n            return 0.0\n\n    def record_metric(self, name: str, value: Any, tags: Optional[Dict[str, Any]] = None) -> None:\n        """记录指标"""\n        with self._lock:\n            self.metrics[name]['value'] = value\n            self.metrics[name]['timestamp'] = datetime.now()\n            if tags:\n                self.metrics[name]['tags'] = tags\n\n    def get_metric(self, name: str) -> Optional[Dict[str, Any]]:\n        """获取指标"""\n        with self._lock:\n            return self.metrics.get(name)\n\n    def get_all_metrics(self) -> Dict[str, Dict[str, Any]]:\n        """获取所有指标"""\n        with self._lock:\n            return dict(self.metrics)\n\n    def reset_metrics(self) -> None:\n        """重置所有指标"""\n        with self._lock:\n            self.metrics.clear()\n            self.start_times.clear()\n\nclass CacheStatistics:\n    """缓存统计工具类"""\n\n    def __init__(self):\n        self._lock = threading.RLock()\n        self.hits = 0\n        self.misses = 0\n        self.total_requests = 0\n        self.evictions = 0\n        self.sets = 0\n        self.deletes = 0\n        self.errors = 0\n\n    def record_hit(self) -> None:\n        """记录命中"""\n        # 使用原子操作避免锁竞争（对于简单的计数器）\n        self.hits += 1\n        self.total_requests += 1\n\n    def record_miss(self) -> None:\n        """记录未命中"""\n        # 使用原子操作避免锁竞争（对于简单的计数器）\n        self.misses += 1\n        self.total_requests += 1\n\n    def record_set(self) -> None:\n        """记录设置操作"""\n        # 使用原子操作避免锁竞争（对于简单的计数器）\n        self.sets += 1\n\n    def record_delete(self) -> None:\n        """记录删除操作"""\n        # 使用原子操作避免锁竞争（对于简单的计数器）\n        self.deletes += 1\n\n    def record_eviction(self) -> None:\n        """记录驱逐"""\n        # 使用原子操作避免锁竞争（对于简单的计数器）\n        self.evictions += 1\n\n    def record_error(self) -> None:\n        """记录错误"""\n        # 使用原子操作避免锁竞争（对于简单的计数器）\n        self.errors += 1\n\n    def get_hit_rate(self) -> float:\n        """计算命中率"""\n        with self._lock:\n            return self.hits / max(self.total_requests, 1)\n\n    def get_miss_rate(self) -> float:\n        """计算未命中率"""\n        with self._lock:\n            return self.misses / max(self.total_requests, 1)\n\n    def get_stats(self) -> Dict[str, Any]:\n        """获取完整统计信息"""\n        with self._lock:\n            return {\n                'hits': self.hits,\n                'misses': self.misses,\n                'total_requests': self.total_requests,\n                'hit_rate': self.get_hit_rate(),\n                'miss_rate': self.get_miss_rate(),\n                'evictions': self.evictions,\n                'sets': self.sets,\n                'deletes': self.deletes,\n                'errors': self.errors,\n                'timestamp': datetime.now().isoformat()\n            }\n\n    def reset(self) -> None:\n        """重置统计信息"""\n        with self._lock:\n            self.hits = 0\n            self.misses = 0\n            self.total_requests = 0\n            self.evictions = 0\n            self.sets = 0\n            self.deletes = 0\n            self.errors = 0\n\nclass TimeUtils:\n    """时间工具类"""\n\n    @staticmethod\n    def get_current_timestamp() -> float:\n        """获取当前时间戳"""\n        return time.time()\n\n    @staticmethod\n    def is_expired(creation_time: float, ttl: int) -> bool:\n        """检查是否过期"""\n        if ttl <= 0:\n            return False\n        return time.time() - creation_time > ttl\n\n    @staticmethod\n    def calculate_remaining_ttl(creation_time: float, ttl: int) -> int:\n        """计算剩余TTL"""\n        if ttl <= 0:\n            return 0\n        elapsed = time.time() - creation_time\n        remaining = ttl - elapsed\n        return max(0, int(remaining))\n\n    @staticmethod\n    def format_timestamp(timestamp: float) -> str:\n        """格式化时间戳"""\n        return datetime.fromtimestamp(timestamp).isoformat()\n\nclass ExpirationManager:\n    """过期管理器"""\n\n    def __init__(self):\n        self._lock = threading.RLock()\n        self.expiration_times: Dict[str, float] = {}\n        self.ttl_settings: Dict[str, int] = {}\n\n    def set_expiration(self, key: str, ttl: int) -> None:\n        """设置过期时间"""\n        with self._lock:\n            self.ttl_settings[key] = ttl\n            self.expiration_times[key] = time.time() + ttl\n\n    def is_expired(self, key: str) -> bool:\n        """检查是否过期"""\n        with self._lock:\n            if key not in self.expiration_times:\n                return False\n            return time.time() > self.expiration_times[key]\n\n    def get_remaining_ttl(self, key: str) -> int:\n        """获取剩余TTL"""\n        with self._lock:\n            if key not in self.expiration_times:\n                return 0\n            return TimeUtils.calculate_remaining_ttl(\n                self.expiration_times[key] - self.ttl_settings.get(key, 0),\n                self.ttl_settings.get(key, 0)\n            )\n\n    def cleanup_expired(self, keys: List[str]) -> List[str]:\n        """清理过期的键"""\n        expired_keys = []\n        for key in keys:\n            if self.is_expired(key):\n                expired_keys.append(key)\n        return expired_keys\n\n    def clear_expiration(self, key: str) -> None:\n        """清除过期设置"""\n        with self._lock:\n            if key in self.expiration_times:\n                del self.expiration_times[key]\n            if key in self.ttl_settings:\n                del self.ttl_settings[key]\n\nclass ThreadSafetyManager:\n    """线程安全管理器"""\n\n    def __init__(self):\n        self._lock = threading.RLock()\n        self._condition = threading.Condition(self._lock)\n        self._active_operations = 0\n\n    def acquire_lock(self) -> None:\n        """获取锁"""\n        self._lock.acquire()\n\n    def release_lock(self) -> None:\n        """释放锁"""\n        self._lock.release()\n\n    def __enter__(self):\n        """上下文管理器入口"""\n        self.acquire_lock()\n        return self\n\n    def __exit__(self, exc_type, exc_val, exc_tb):\n        """上下文管理器出口"""\n        self.release_lock()\n\n    def execute_with_lock(self, func: Callable, *args, **kwargs) -> Any:\n        """在锁保护下执行函数"""\n        with self:\n            return func(*args, **kwargs)\n\n    def wait_for_condition(self, condition_func: Callable, timeout: float = 5.0) -> bool:\n        """等待条件满足"""\n        return self._condition.wait_for(condition_func, timeout)\n\n    def notify_all(self) -> None:\n        """通知所有等待线程"""\n        self._condition.notify_all()\n\nclass DataValidator:\n    """数据验证器"""\n\n    @staticmethod\n    def validate_key(key: str) -> bool:\n        """验证键的合法性"""\n        if not isinstance(key, str):\n            return False\n        if not key.strip():\n            return False\n        if len(key) > 250:  # Redis键长度限制\n            return False\n        # 检查是否包含非法字符\n        invalid_chars = ['\x00', '\r', '\n']\n        for char in invalid_chars:\n            if char in key:\n                return False\n        return True\n\n    @staticmethod\n    def validate_value(value: Any) -> bool:\n        """验证值的合法性"""\n        # 检查值是否可以序列化\n        try:\n            pickle.dumps(value)\n            return True\n        except (TypeError, pickle.PicklingError):\n            return False\n\n    @staticmethod\n    def validate_ttl(ttl: int) -> bool:\n        """验证TTL的合法性"""\n        return isinstance(ttl, int) and ttl >= 0\n\n    @staticmethod\n    def sanitize_key(key: str) -> str:\n        """清理键"""\n        # 移除首尾空白字符\n        key = key.strip()\n        # 替换非法字符\n        key = key.replace('\x00', '').replace('\r', '').replace('\n', '')\n        return key\n\nclass CacheOperations:\n    """缓存操作工具类"""\n\n    @staticmethod\n    def generate_cache_key(*args, **kwargs) -> str:\n        """生成缓存键"""\n        # 将所有参数组合成字符串\n        key_parts = [str(arg) for arg in args]\n        if kwargs:\n            sorted_kwargs = sorted(kwargs.items())\n            key_parts.extend([f"{k}:{v}" for k, v in sorted_kwargs])\n\n        key_string = "|".join(key_parts)\n\n        # 生成哈希\n        return hashlib.md5(key_string.encode()).hexdigest()\n\n    @staticmethod\n    def batch_get(cache_dict: Dict[str, Any], keys: List[str]) -> Dict[str, Any]:\n        """批量获取缓存值"""\n        result = {}\n        for key in keys:\n            if key in cache_dict:\n                result[key] = cache_dict[key]\n        return result\n\n    @staticmethod\n    def batch_set(cache_dict: Dict[str, Any], data: Dict[str, Any]) -> None:\n        """批量设置缓存值"""\n        cache_dict.update(data)\n\n    @staticmethod\n    def batch_delete(cache_dict: Dict[str, Any], keys: List[str]) -> int:\n        """批量删除缓存值"""\n        deleted_count = 0\n        for key in keys:\n            if key in cache_dict:\n                del cache_dict[key]\n                deleted_count += 1\n        return deleted_count\n\n    @staticmethod\n    def cleanup_by_pattern(cache_dict: Dict[str, Any], pattern: str) -> int:\n        """按模式清理缓存"""\n        import re\n        try:\n            regex = re.compile(pattern)\n            keys_to_delete = [key for key in cache_dict.keys() if regex.match(key)]\n            return CacheOperations.batch_delete(cache_dict, keys_to_delete)\n        except re.error:\n            logger.error(f"无效的正则表达式: {pattern}")\n            return 0\n\n# ==================== 全局实例 ====================\n\n# 创建全局实例以供复用\nperformance_monitor = PerformanceMonitor()\ncache_statistics = CacheStatistics()\nexpiration_manager = ExpirationManager()\nthread_safety_manager = ThreadSafetyManager()\n\n# ==================== 便捷函数 ====================\n\ndef get_performance_monitor() -> PerformanceMonitor:\n    """获取性能监控器实例"""\n    return performance_monitor\n\ndef get_cache_statistics() -> CacheStatistics:\n    """获取缓存统计器实例"""\n    return cache_statistics\n\ndef get_expiration_manager() -> ExpirationManager:\n    """获取过期管理器实例"""\n    return expiration_manager\n\ndef get_thread_safety_manager() -> ThreadSafetyManager:\n    """获取线程安全管理器实例"""\n    return thread_safety_manager\n\ndef calculate_hit_rate(hits: int, total_requests: int) -> float:\n    """计算命中率（便捷函数）"""\n    return hits / max(total_requests, 1)\n\ndef is_expired(creation_time: float, ttl: int) -> bool:\n    """检查是否过期（便捷函数）"""\n    return TimeUtils.is_expired(creation_time, ttl)\n\ndef with_lock(func: Callable) -> Callable:\n    """装饰器：在锁保护下执行函数"""\n    def wrapper(*args, **kwargs):\n    """文档字符串"""\n        with thread_safety_manager:\n            return func(*args, **kwargs)\n    return wrapper\n\ndef measure_performance(operation_name: str) -> Callable:\n    """装饰器：测量函数性能"""\n    def decorator(func: Callable) -> Callable:\n    """文档字符串"""\n        def wrapper(*args, **kwargs):\n            performance_monitor.start_operation(operation_name)\n            try:\n                result = func(*args, **kwargs)\n                elapsed = performance_monitor.end_operation(operation_name)\n                performance_monitor.record_metric(\n                    f"{operation_name}_duration",\n                    elapsed,\n                    {"operation": operation_name}\n                )\n                return result\n            except Exception as e:\n                performance_monitor.end_operation(operation_name)\n                raise e\n        return wrapper\n    return decorator\n