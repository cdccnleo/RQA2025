"""
health_result 模块

提供 health_result 相关功能
"""


from .health_status import HealthStatus\nfrom datetime import datetime\nfrom enum import Enum\nfrom typing import Dict, Any, Optional, List, Callable\nimport time\n\nfrom dataclasses import dataclass, field\n\n"""\n基础设施层 - 健康检查组件\n\nhealth_result 模块\n\n健康检查相关的文件\n提供健康检查相关的功能实现。\n"""\n\n#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n统一健康检查结果和服务健康档案数据模型\n\n遵循基础设施层架构设计，提供标准化的数据结构。\n"""\n\nclass CheckType(Enum):\n\n    """检查类型枚举"""\n    AVAILABILITY = "availability"    # 可用性检查\n    PERFORMANCE = "performance"      # 性能检查\n    FUNCTIONALITY = "functionality"  # 功能性检查\n    RESOURCE = "resource"            # 资源检查\n    SYSTEM = "system"                # 系统检查\n\n@dataclass\n\nclass HealthCheckResult:\n\n    """统一健康检查结果"""\n    service_name: str\n    check_type: CheckType\n    status: HealthStatus\n    timestamp: datetime\n    response_time: float\n    details: Dict[str, Any] = field(default_factory=dict)\n    error_message: Optional[str] = None\n\n    def __post_init__(self):\n\n        """后初始化处理"""\n        if isinstance(self.status, str):\n            self.status = HealthStatus.from_string(self.status)\n\n        if isinstance(self.check_type, str):\n            try:\n                self.check_type = CheckType(self.check_type)\n            except ValueError:\n                self.check_type = CheckType.AVAILABILITY\n\n@dataclass\n\nclass ServiceHealthProfile:\n\n    """服务健康档案"""\n    service_name: str\n    current_status: HealthStatus\n    last_check: datetime\n    check_history: List[HealthCheckResult] = field(default_factory=list)\n    total_checks: int = 0\n    successful_checks: int = 0\n    failed_checks: int = 0\n    consecutive_failures: int = 0\n    check_function: Optional[Callable] = None\n\n    def __post_init__(self):\n\n        """后初始化处理"""\n        if isinstance(self.current_status, str):\n            self.current_status = HealthStatus.from_string(self.current_status)\n\n        # 计算统计信息\n        self._update_statistics()\n\n    def add_check_result(self, result: HealthCheckResult) -> None:\n    """文档字符串"""\n\n        """添加检查结果"""\n        self.check_history.append(result)\n        self.last_check = result.timestamp\n        self.current_status = result.status\n\n        # 限制历史记录数量\n        if len(self.check_history) > 100:\n            self.check_history = self.check_history[-50:]\n\n        self._update_statistics()\n\n    def _update_statistics(self) -> None:\n    """文档字符串"""\n\n        """更新统计信息"""\n        self.total_checks = len(self.check_history)\n        self.successful_checks = len([r for r in self.check_history if r.status.is_healthy()])\n        self.failed_checks = len([r for r in self.check_history if not r.status.is_healthy()])\n\n    def get_success_rate(self) -> float:\n    """文档字符串"""\n\n        """获取成功率"""\n        if self.total_checks == 0:\n            return 0.0\n        return self.successful_checks / self.total_checks\n\n    def get_average_response_time(self) -> float:\n    """文档字符串"""\n\n        """获取平均响应时间"""\n        if not self.check_history:\n            return 0.0\n\n        total_time = sum(r.response_time for r in self.check_history)\n        return total_time / len(self.check_history)\n