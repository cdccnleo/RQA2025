"""\n基础设施层 - 日志系统组件\n\nmonitor_factory 模块\n\n日志系统相关的文件\n提供日志系统相关的功能实现。\n"""\n\n#!/usr/bin/env python3\nfrom .exceptions import MonitorError  # type: ignore\nfrom .core.monitor import UnifiedMonitor  # type: ignore\n# 修复深层相对导入 - 使用绝对导入\ntry:\n    from src.infrastructure.interfaces.unified_interfaces import IMonitor, IMonitorFactory\nexcept ImportError:\n    # 如果接口不存在，使用本地定义\n    from abc import ABC, abstractmethod\n    from typing import Any, Dict, Optional\n\n    class IMonitor(ABC):\n        @abstractmethod\n        def record_metric(self, name: str, value: Any, tags: Optional[Dict[str, str]] = None) -> None:\n    """文档字符串"""\n            pass\n\n    class IMonitorFactory(ABC):\n        @abstractmethod\n        def create_monitor(self, monitor_type: str, **kwargs) -> IMonitor:\n    """文档字符串"""\n            pass\nimport time\nfrom enum import Enum\nfrom abc import ABC, abstractmethod\nfrom typing import Dict, Any, Optional, Type\nimport logging\n# -*- coding: utf-8 -*-\n"""\nmonitor_factory - 日志系统\n\n职责说明：\n负责系统日志记录、日志格式化、日志存储和日志分析\n\n核心职责：\n- 日志记录和格式化\n- 日志级别管理\n- 日志存储和轮转\n- 日志分析和监控\n- 日志搜索和过滤\n- 日志性能优化\n\n相关接口：\n- ILoggingComponent\n- ILogger\n- ILogHandler\n""" """\n监控器工厂 - 解决重复代码问题\n\n提供统一的监控器创建接口，支持多种监控器类型：\n- 统一监控器\n- 性能监控器\n- 业务监控器\n- 系统监控器\n- 应用监控器\n"""\n\n\nclass MonitorType(Enum):\n\n    """监控器类型"""\n    UNIFIED = "unified"\n    PERFORMANCE = "performance"\n    BUSINESS = "business"\n    SYSTEM = "system"\n    APPLICATION = "application"\n\n\nclass MonitorFactory(IMonitorFactory):\n\n    """监控器工厂实现"""\n\n\n    def __init__(self):\n\n        self._monitors: Dict[str, Type[IMonitor]] = {}\n        self._monitor_instances: Dict[str, IMonitor] = {}  # 存储监控器实例\n        self._logger = logging.getLogger(__name__)\n\n        # 注册默认监控器类型\n        self._register_default_monitors()\n\n\n    def _register_default_monitors(self):\n    """文档字符串"""\n\n        """注册默认的监控器类型"""\n        try:\n            # 导入所需的监控器类\n            from .performance_optimized_monitor import PerformanceOptimizedMonitor  # type: ignore\n            from .business_metrics_monitor import BusinessMetricsMonitor  # type: ignore\n            from .automation_monitor import AutomationMonitor  # type: ignore\n            from .prometheus_monitor import PrometheusMonitor  # type: ignore\n            from .system_monitor import SystemMonitor  # type: ignore\n            from .application_monitor import ApplicationMonitor  # type: ignore\n\n            # 注册统一监控器\n            self.register_monitor(MonitorType.UNIFIED.value, UnifiedMonitor)\n\n            # 注册性能优化监控器\n            self.register_monitor(MonitorType.PERFORMANCE.value, PerformanceOptimizedMonitor)\n\n            # 注册业务指标监控器\n            self.register_monitor(MonitorType.BUSINESS.value, BusinessMetricsMonitor)\n\n            # 注册系统监控器\n            self.register_monitor(MonitorType.SYSTEM.value, SystemMonitor)\n\n            # 注册应用监控器\n            self.register_monitor(MonitorType.APPLICATION.value, ApplicationMonitor)\n\n            # 注册自动化监控器\n            self.register_monitor("automation", AutomationMonitor)\n\n            # 注册Prometheus监控器\n            self.register_monitor("prometheus", PrometheusMonitor)\n\n        except ImportError as e:\n            self._logger.warning(f"注册默认监控器失败，某些监控器类型不可用: {e}")\n            # 注册可用的监控器\n        try:\n            self.register_monitor(MonitorType.PERFORMANCE.value, PerformanceOptimizedMonitor)\n        except ImportError:\n            pass\n\n        try:\n            self.register_monitor(MonitorType.SYSTEM.value, SystemMonitor)\n        except ImportError:\n            pass\n\n        try:\n            self.register_monitor("automation", AutomationMonitor)\n        except ImportError:\n            pass\n\n        try:\n            self.register_monitor("prometheus", PrometheusMonitor)\n        except ImportError:\n            pass\n\n        try:\n            self.register_monitor(MonitorType.UNIFIED.value, UnifiedMonitor)\n        except ImportError:\n            pass\n\n        try:\n            self.register_monitor(MonitorType.BUSINESS.value, BusinessMetricsMonitor)\n        except ImportError:\n            pass\n\n\n    def create_monitor(self, monitor_type: str, **kwargs) -> IMonitor:\n    """文档字符串"""\n\n        """\n        创建监控器\n\n        Args:\n            monitor_type: 监控器类型\n            **kwargs: 初始化参数\n\n        Returns:\n            监控器实例\n\n        Raises:\n            MonitorError: 当监控器类型不存在时\n        """\n        if monitor_type not in self._monitors:\n            available = list(self._monitors.keys())\n            raise MonitorError(f"未知的监控器类型: {monitor_type}，可用类型: {available}")\n\n        try:\n            monitor_class = self._monitors[monitor_type]\n            monitor = monitor_class(**kwargs)\n            self._logger.info(f"成功创建监控器: {monitor_type}")\n            return monitor\n        except Exception as e:\n            self._logger.error(f"创建监控器失败: {monitor_type}, 错误: {str(e)}")\n            raise MonitorError(f"创建监控器失败: {str(e)}")\n\n\n    def register_monitor(self, name: str, monitor_class: Type[IMonitor]) -> None:\n    """文档字符串"""\n\n        """\n        注册监控器类型\n\n        Args:\n            name: 监控器名称\n            monitor_class: 监控器类\n        """\n        if not issubclass(monitor_class, IMonitor):\n            raise MonitorError(f"监控器类必须实现 IMonitor 接口: {monitor_class}")\n\n        self._monitors[name] = monitor_class\n        self._logger.info(f"注册监控器: {name}")\n\n\n    def get_available_monitors(self) -> Dict[str, Type[IMonitor]]:\n    """文档字符串"""\n\n        """\n        获取可用的监控器类型\n\n        Returns:\n            可用监控器类型字典\n        """\n        return self._monitors.copy()\n\n\n    def get_monitor(self, name: str) -> IMonitor:\n    """文档字符串"""\n\n        """\n        获取指定的监控器实例（单例模式）\n\n        Args:\n            name: 监控器名称\n\n        Returns:\n            监控器实例\n\n        Raises:\n            ValueError: 当监控器类型不存在时\n        """\n        monitor_class = self._monitors.get(name)\n        if monitor_class is None:\n            raise ValueError(f"Unknown monitor type: {name}")\n\n        # 如果实例已存在，返回现有实例\n        if name in self._monitor_instances:\n            return self._monitor_instances[name]\n\n        try:\n            # 创建新实例并缓存\n            instance = monitor_class()\n            self._monitor_instances[name] = instance\n            self._logger.info(f"创建新的监控器实例: {name}")\n            return instance\n        except Exception as e:\n            self._logger.error(f"创建监控器实例失败: {e}")\n            raise ValueError(f"Failed to create monitor instance: {e}")\n\n\nclass SystemMonitor(UnifiedMonitor):\n\n    """系统监控器"""\n\n\n    def __init__(self, **kwargs):\n\n        super().__init__(**kwargs)\n        self._system_metrics = {}\n\n\n    def record_metric(self, name: str, value: float, tags: Optional[Dict[str, str]] = None) -> None:\n    """文档字符串"""\n\n        """记录系统指标"""\n        if name not in self._system_metrics:\n            self._system_metrics[name] = []\n\n        metric_data = {\n            'value': value,\n            'timestamp': time.time(),\n            'tags': tags or {}\n        }\n\n        self._system_metrics[name].append(metric_data)\n\n\n    def get_metrics(self, name: str, time_range: Optional[tuple] = None) -> list:\n    """文档字符串"""\n\n        """获取系统指标"""\n        if name not in self._system_metrics:\n            return []\n\n        metrics = self._system_metrics[name]\n        if time_range:\n            start_time, end_time = time_range\n            metrics = [m for m in metrics if start_time <= m['timestamp'] <= end_time]\n\n        return metrics\n\n\nclass ApplicationMonitor(UnifiedMonitor):\n\n    """应用监控器"""\n\n\n    def __init__(self, **kwargs):\n\n        super().__init__(**kwargs)\n        self._app_metrics = {}\n\n\n    def record_metric(self, name: str, value: float, tags: Optional[Dict[str, str]] = None) -> None:\n    """文档字符串"""\n\n        """记录应用指标"""\n        if name not in self._app_metrics:\n            self._app_metrics[name] = []\n\n        metric_data = {\n            'value': value,\n            'timestamp': time.time(),\n            'tags': tags or {}\n        }\n\n        self._app_metrics[name].append(metric_data)\n\n\n    def get_metrics(self, name: str, time_range: Optional[tuple] = None) -> list:\n    """文档字符串"""\n\n        """获取应用指标"""\n        if name not in self._app_metrics:\n            return []\n\n        metrics = self._app_metrics[name]\n        if time_range:\n            start_time, end_time = time_range\n            metrics = [m for m in metrics if start_time <= m['timestamp'] <= end_time]\n\n        return metrics\n\n\ndef get_monitor_factory() -> MonitorFactory:\n    """文档字符串"""\n\n    """获取监控器工厂实例"""\n    return MonitorFactory()\n\n\ndef create_monitor(monitor_type: str = "unified", **kwargs) -> IMonitor:\n    """文档字符串"""\n\n    """\n    创建监控器的便捷函数\n\n    Args:\n        monitor_type: 监控器类型\n        **kwargs: 初始化参数\n\n    Returns:\n        监控器实例\n    """\n    factory = get_monitor_factory()\n    return factory.create_monitor(monitor_type, **kwargs)\n\n\ndef register_monitor(name: str, monitor_class: Type[IMonitor]) -> None:\n    """文档字符串"""\n\n    """\n    注册监控器类型的便捷函数\n\n    Args:\n        name: 监控器名称\n        monitor_class: 监控器类\n    """\n    factory = get_monitor_factory()\n    factory.register_monitor(name, monitor_class)\n