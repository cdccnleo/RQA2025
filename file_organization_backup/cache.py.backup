#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\n"""\n基础设施层 - 缓存接口定义\n\n统一缓存相关的接口定义，消除重复和不一致性\n"""\n\nfrom abc import ABC, abstractmethod\nfrom enum import Enum\nfrom typing import Any, Dict, List, Optional, Union, Protocol\n\nclass CacheType(Enum):\n    """缓存类型枚举"""\n\n    MEMORY = "memory"\n    REDIS = "redis"\n    DISK = "disk"\n    HYBRID = "hybrid"\n    DISTRIBUTED = "distributed"\n    MULTI_LEVEL = "multi_level"\n\nclass CacheStrategy(Enum):\n    """缓存策略枚举"""\n\n    LRU = "lru"\n    LFU = "lfu"\n    FIFO = "fifo"\n    RANDOM = "random"\n    TTL = "ttl"\n\nclass ICacheComponent(ABC):\n    """缓存组件基础接口"""\n\n    @abstractmethod\n    def get(self, key: str) -> Optional[Any]:\n        """获取缓存项"""\n        pass\n\n    @abstractmethod\n    def set(self, key: str, value: Any, ttl: Optional[int] = None) -> bool:\n        """设置缓存项"""\n        pass\n\n    @abstractmethod\n    def delete(self, key: str) -> bool:\n        """删除缓存项"""\n        pass\n\n    @abstractmethod\n    def exists(self, key: str) -> bool:\n        """检查缓存项是否存在"""\n        pass\n\n    @abstractmethod\n    def clear(self) -> bool:\n        """清空缓存"""\n        pass\n\n    @abstractmethod\n    def size(self) -> int:\n        """获取缓存大小"""\n        pass\n\nclass ICacheManager(ABC):\n    """缓存管理器接口"""\n\n    @abstractmethod\n    def get_cache(self, name: str) -> Optional[ICacheComponent]:\n        """获取指定名称的缓存实例"""\n        pass\n\n    @abstractmethod\n    def create_cache(self, name: str, cache_type: CacheType,\n    """文档字符串"""\n                    config: Dict[str, Any]) -> ICacheComponent:\n        """创建缓存实例"""\n        pass\n\n    @abstractmethod\n    def delete_cache(self, name: str) -> bool:\n        """删除缓存实例"""\n        pass\n\n    @abstractmethod\n    def list_caches(self) -> List[str]:\n        """列出所有缓存实例"""\n        pass\n\n    @abstractmethod\n    def get_stats(self) -> Dict[str, Any]:\n        """获取缓存统计信息"""\n        pass\n\nclass ICacheFactory(ABC):\n    """缓存工厂接口"""\n\n    @abstractmethod\n    def create_cache(self, cache_type: CacheType,\n    """文档字符串"""\n                    config: Dict[str, Any]) -> ICacheComponent:\n        """创建指定类型的缓存"""\n        pass\n\n    @abstractmethod\n    def get_supported_types(self) -> List[CacheType]:\n        """获取支持的缓存类型"""\n        pass\n\nclass ICacheStrategy(ABC):\n    """缓存策略接口"""\n\n    @abstractmethod\n    def should_evict(self, cache: ICacheComponent,\n    """文档字符串"""\n                    key: str, access_count: int) -> bool:\n        """判断是否应该驱逐缓存项"""\n        pass\n\n    @abstractmethod\n    def on_access(self, cache: ICacheComponent, key: str) -> None:\n        """缓存访问时的回调"""\n        pass\n\n    @abstractmethod\n    def on_evict(self, cache: ICacheComponent, key: str) -> None:\n        """缓存驱逐时的回调"""\n        pass\n\nclass ICacheSerializer(ABC):\n    """缓存序列化接口"""\n\n    @abstractmethod\n    def serialize(self, obj: Any) -> bytes:\n        """序列化对象"""\n        pass\n\n    @abstractmethod\n    def deserialize(self, data: bytes) -> Any:\n        """反序列化对象"""\n        pass\n\nclass ICacheStorage(ABC):\n    """缓存存储接口"""\n\n    @abstractmethod\n    def store(self, key: str, data: bytes,\n    """文档字符串"""\n             ttl: Optional[int] = None) -> bool:\n        """存储数据"""\n        pass\n\n    @abstractmethod\n    def retrieve(self, key: str) -> Optional[bytes]:\n        """检索数据"""\n        pass\n\n    @abstractmethod\n    def remove(self, key: str) -> bool:\n        """删除数据"""\n        pass\n\n    @abstractmethod\n    def cleanup_expired(self) -> int:\n        """清理过期数据，返回清理数量"""\n        pass\n\nclass ICacheMonitor(ABC):\n    """缓存监控接口"""\n\n    @abstractmethod\n    def record_hit(self, key: str) -> None:\n        """记录缓存命中"""\n        pass\n\n    @abstractmethod\n    def record_miss(self, key: str) -> None:\n        """记录缓存未命中"""\n        pass\n\n    @abstractmethod\n    def record_eviction(self, key: str) -> None:\n        """记录缓存驱逐"""\n        pass\n\n    @abstractmethod\n    def get_metrics(self) -> Dict[str, Any]:\n        """获取监控指标"""\n        pass\n\nclass CacheConfig:\n    """缓存配置类"""\n\n    def __init__(self,\n                 cache_type: CacheType = CacheType.MEMORY,\n                 max_size: int = 1000,\n                 ttl: Optional[int] = None,\n                 strategy: CacheStrategy = CacheStrategy.LRU,\n                 enable_monitoring: bool = True,\n                 **kwargs):\n        self.cache_type = cache_type\n        self.max_size = max_size\n        self.ttl = ttl\n        self.strategy = strategy\n        self.enable_monitoring = enable_monitoring\n        self.extra_config = kwargs\n\n# 向后兼容的别名\nICache = ICacheComponent\nCacheManager = ICacheManager\nCacheFactory = ICacheFactory\n