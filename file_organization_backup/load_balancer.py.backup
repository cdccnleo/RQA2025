import logging\n\n"""\n负载均衡器\n提供多种负载均衡策略，支持健康检查和故障转移\n"""\n\nimport time\nimport random\nfrom typing import List, Dict, Optional, Any\nfrom enum import Enum\nfrom dataclasses import dataclass\nfrom .exceptions import LoadBalancerError\n\nlogger = logging.getLogger(__name__)\n\nclass LoadBalancingStrategy(Enum):\n    """负载均衡策略"""\n    ROUND_ROBIN = "round_robin"      # 轮询\n    LEAST_CONNECTIONS = "least_connections"  # 最少连接\n    WEIGHTED_ROUND_ROBIN = "weighted_round_robin"  # 加权轮询\n    RANDOM = "random"                # 随机\n    IP_HASH = "ip_hash"              # IP哈希\n\n@dataclass\nclass Endpoint:\n    """端点信息"""\n    url: str\n    weight: int = 1\n    max_connections: int = 100\n    current_connections: int = 0\n    health_check_url: Optional[str] = None\n    is_healthy: bool = True\n    last_health_check: float = 0.0\n    response_time: float = 0.0\n    error_count: int = 0\n    max_errors: int = 3\n\nclass LoadBalancer:\n\n    """负载均衡器"""\n\n    def __init__(self, strategy: LoadBalancingStrategy = LoadBalancingStrategy.ROUND_ROBIN,\n                 health_check_interval: float = 30.0,\n                 health_check_timeout: float = 5.0):\n        """\n        初始化负载均衡器\n\n        Args:\n            strategy: 负载均衡策略\n            health_check_interval: 健康检查间隔\n            health_check_timeout: 健康检查超时时间\n        """\n        self.strategy = strategy\n        self.health_check_interval = health_check_interval\n        self.health_check_timeout = health_check_timeout\n\n        # 端点管理\n        self.endpoints: List[Endpoint] = []\n        self.current_index = 0\n\n        # 统计信息\n        self.stats = {\n            'total_requests': 0,\n            'successful_requests': 0,\n            'failed_requests': 0,\n            'health_checks': 0,\n            'endpoint_failures': 0\n        }\n\n        # 启动健康检查线程\n        self._start_health_check_thread()\n\n    def add_endpoint(self, url: str,\n    """文档字符串"""\n                     weight: int = 1,\n                     max_connections: int = 100,\n                     health_check_url: Optional[str] = None):\n        """\n        添加端点\n\n        Args:\n            url: 端点URL\n            weight: 权重\n            max_connections: 最大连接数\n            health_check_url: 健康检查URL\n        """\n        endpoint = Endpoint(\n            url=url,\n            weight=weight,\n            max_connections=max_connections,\n            health_check_url=health_check_url or url\n        )\n\n        self.endpoints.append(endpoint)\n        logger.info(f"添加端点: {url} (权重: {weight})")\n\n    def remove_endpoint(self, url: str) -> bool:\n        """\n        移除端点\n\n        Args:\n            url: 端点URL\n\n        Returns:\n            bool: 是否成功移除\n        """\n        for i, endpoint in enumerate(self.endpoints):\n            if endpoint.url == url:\n                del self.endpoints[i]\n                logger.info(f"移除端点: {url}")\n                return True\n        return False\n\n    def get_endpoint(self, client_ip: Optional[str] = None) -> Optional[Endpoint]:\n    """文档字符串"""\n\n        """\n        获取端点\n\n        Args:\n            client_ip: 客户端IP（用于IP哈希策略）\n\n        Returns:\n            Endpoint: 选中的端点\n\n        Raises:\n            LoadBalancerError: 没有可用端点\n        """\n        if not self.endpoints:\n            raise LoadBalancerError("没有可用的端点")\n\n        # 过滤健康的端点\n        healthy_endpoints = [ep for ep in self.endpoints if ep.is_healthy]\n        if not healthy_endpoints:\n            raise LoadBalancerError("没有健康的端点")\n\n        self.stats['total_requests'] += 1\n\n        # 根据策略选择端点\n        if self.strategy == LoadBalancingStrategy.ROUND_ROBIN:\n            selected = self._round_robin_select(healthy_endpoints)\n        elif self.strategy == LoadBalancingStrategy.LEAST_CONNECTIONS:\n            selected = self._least_connections_select(healthy_endpoints)\n        elif self.strategy == LoadBalancingStrategy.WEIGHTED_ROUND_ROBIN:\n            selected = self._weighted_round_robin_select(healthy_endpoints)\n        elif self.strategy == LoadBalancingStrategy.RANDOM:\n            selected = self._random_select(healthy_endpoints)\n        elif self.strategy == LoadBalancingStrategy.IP_HASH:\n            selected = self._ip_hash_select(healthy_endpoints, client_ip)\n        else:\n            selected = healthy_endpoints[0]\n\n        # 更新连接数\n        selected.current_connections += 1\n        return selected\n\n    def release_endpoint(self, endpoint: Endpoint) -> None:\n    """文档字符串"""\n\n        """\n        释放端点连接\n\n        Args:\n            endpoint: 端点对象\n        """\n        if endpoint.current_connections > 0:\n            endpoint.current_connections -= 1\n\n    def mark_endpoint_error(self, endpoint: Endpoint) -> None:\n    """文档字符串"""\n\n        """\n        标记端点错误\n\n        Args:\n            endpoint: 端点对象\n        """\n        endpoint.error_count += 1\n        self.stats['failed_requests'] += 1\n\n        if endpoint.error_count >= endpoint.max_errors:\n            endpoint.is_healthy = False\n            self.stats['endpoint_failures'] += 1\n            logger.warning(f"端点标记为不健康: {endpoint.url}")\n\n    def mark_endpoint_success(self, endpoint: Endpoint) -> None:\n    """文档字符串"""\n\n        """\n        标记端点成功\n\n        Args:\n            endpoint: 端点对象\n        """\n        endpoint.error_count = 0\n        self.stats['successful_requests'] += 1\n\n        if not endpoint.is_healthy:\n            endpoint.is_healthy = True\n            logger.info(f"端点恢复健康: {endpoint.url}")\n\n    def get_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        获取负载均衡器统计信息\n\n        Returns:\n            Dict: 统计信息\n        """\n        stats = self.stats.copy()\n        stats['endpoints'] = {\n            'total': len(self.endpoints),\n            'healthy': len([ep for ep in self.endpoints if ep.is_healthy]),\n            'unhealthy': len([ep for ep in self.endpoints if not ep.is_healthy])\n        }\n\n        return stats\n\n    def _round_robin_select(self, endpoints: List[Endpoint]) -> Endpoint:\n    """文档字符串"""\n\n        """轮询选择"""\n        selected = endpoints[self.current_index % len(endpoints)]\n        self.current_index += 1\n        return selected\n\n    def _least_connections_select(self, endpoints: List[Endpoint]) -> Endpoint:\n    """文档字符串"""\n\n        """最少连接选择"""\n        return min(endpoints, key=lambda ep: ep.current_connections)\n\n    def _weighted_round_robin_select(self, endpoints: List[Endpoint]) -> Endpoint:\n    """文档字符串"""\n\n        """加权轮询选择"""\n        total_weight = sum(ep.weight for ep in endpoints)\n        if total_weight == 0:\n            return endpoints[0]\n\n        # 简单的加权轮询实现\n        current_weight = 0\n        for endpoint in endpoints:\n            current_weight += endpoint.weight\n            if self.current_index < current_weight:\n                self.current_index += 1\n                return endpoint\n\n        # 重置索引\n        self.current_index = 0\n        return endpoints[0]\n\n    def _random_select(self, endpoints: List[Endpoint]) -> Endpoint:\n    """文档字符串"""\n\n        """随机选择"""\n        return random.choice(endpoints)\n\n    def _ip_hash_select(self, endpoints: List[Endpoint], client_ip: Optional[str]) -> Endpoint:\n    """文档字符串"""\n\n        """IP哈希选择"""\n        if not client_ip:\n            return endpoints[0]\n\n        hash_value = hash(client_ip)\n        index = hash_value % len(endpoints)\n        return endpoints[index]\n\n    def _start_health_check_thread(self) -> None:\n    """文档字符串"""\n\n        """启动健康检查线程"""\n        import threading\n\n        def health_check_worker():\n    """文档字符串"""\n            while True:\n                try:\n                    time.sleep(self.health_check_interval)\n                    self._perform_health_checks()\n                except Exception as e:\n                    logger.error(f"健康检查异常: {e}")\n\n        health_check_thread = threading.Thread(target=health_check_worker, daemon=True)\n        health_check_thread.start()\n\n    def _perform_health_checks(self) -> None:\n    """文档字符串"""\n\n        """执行健康检查"""\n        for endpoint in self.endpoints:\n            try:\n                # 模拟健康检查\n                response_time = random.uniform(0.1, 2.0)  # 模拟响应时间\n                endpoint.response_time = response_time\n                endpoint.last_health_check = time.time()\n\n                # 模拟健康状态\n                is_healthy = random.random() > 0.1  # 90% 概率健康\n                if endpoint.is_healthy != is_healthy:\n                    endpoint.is_healthy = is_healthy\n                    if is_healthy:\n                        logger.info(f"端点恢复健康: {endpoint.url}")\n                    else:\n                        logger.warning(f"端点不健康: {endpoint.url}")\n\n                self.stats['health_checks'] += 1\n\n            except Exception as e:\n                logger.error(f"健康检查失败 {endpoint.url}: {e}")\n                endpoint.is_healthy = False\n