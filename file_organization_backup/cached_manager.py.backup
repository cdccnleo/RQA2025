"""\n基础设施层 - 缓存系统组件\n\ncached_manager 模块\n\n缓存系统相关的文件\n提供缓存系统相关的功能实现。\n"""\n\n#!/usr/bin/env python3\n# 修复深层相对导入 - 使用条件导入避免循环依赖\ntry:\n    from src.infrastructure.config.core.unified_manager import UnifiedConfigManager\n    from src.infrastructure.config.core.unified_interface import (\n    IConfigManagerComponent as IConfigManager\n)\nexcept ImportError:\n    # 如果导入失败，使用占位符类\n    class UnifiedConfigManager:\n        def __init__(self, config_path=None):\n            self.config_path = config_path\n\n    class IConfigManagerComponent:\n        pass\n\n    IConfigManager = IConfigManagerComponent\nfrom typing import Dict, Any, Optional\nimport logging\nimport time\n\n\nclass CachedConfigManager(UnifiedConfigManager):\n\n    """缓存配置管理器"""\n\n\n    def __init__(self, config_path: Optional[str] = None, cache_ttl: int = 3600):\n\n        """\n        初始化缓存配置管理器\n\n        Args:\n            config_path: 配置文件路径\n            cache_ttl: 缓存过期时间（秒）\n        """\n        self.cache_ttl = cache_ttl\n        self._cache = {}\n        self._cache_timestamps = {}\n        self._logger = logging.getLogger(__name__)\n        super().__init__(config_path)\n\n\n    def _is_cache_valid(self, key: str) -> bool:\n    """文档字符串"""\n\n        """检查缓存是否有效"""\n        if key not in self._cache:\n            return False\n\n        timestamp = self._cache_timestamps.get(key, 0)\n        return time.time() - timestamp < self.cache_ttl\n\n\n    def _update_cache(self, key: str, value: Any):\n    """文档字符串"""\n\n        """更新缓存"""\n        self._cache[key] = value\n        self._cache_timestamps[key] = time.time()\n\n    def _get_cached_config(self, key: str) -> Any:\n    """文档字符串"""\n\n        """获取缓存的配置（测试兼容方法）"""\n        try:\n            if self._is_cache_valid(key):\n                return self._cache[key]\n\n            # 使用_get_config_from_source方法获取数据\n            value = self._get_config_from_source(key)\n            if value is not None:\n                self._update_cache(key, value)\n            return value\n\n        except Exception as e:\n            self._logger.error(f"获取缓存配置失败: {key}, 错误: {e}")\n            return None\n\n    def _get_config_from_source(self, key: str) -> Any:\n    """文档字符串"""\n\n        """从源获取配置（测试兼容方法）"""\n        try:\n            if hasattr(super(), 'get_config'):\n                return super().get_config(key)\n            else:\n                return None\n        except Exception as e:\n            self._logger.error(f"从源获取配置失败: {key}, 错误: {e}")\n            return None\n\n    def _invalidate_cache(self, key: str):\n    """文档字符串"""\n\n        """失效缓存（测试兼容方法）"""\n        if key in self._cache:\n            del self._cache[key]\n        if key in self._cache_timestamps:\n            del self._cache_timestamps[key]\n        # CachedConfigManager不使用expiry_times，跳过\n\n    def _clear_cache(self):\n    """文档字符串"""\n\n        """清空缓存（测试兼容方法）"""\n        self._cache.clear()\n        self._cache_timestamps.clear()\n        if hasattr(self, 'expiry_times'):\n            self.expiry_times.clear()\n\n    def _get_cache_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取缓存统计信息（测试兼容方法）"""\n        return {\n            'total_entries': len(self._cache),\n            'cache_ttl': self.cache_ttl,\n            'hit_rate': 0.0,  # 可以实现命中率统计\n            'last_cleanup': time.time()\n        }\n\n    def _clear_expired_cache(self):\n    """文档字符串"""\n\n        """清理过期缓存（测试兼容方法）"""\n        current_time = time.time()\n        expired_keys = []\n\n        for key, timestamp in self._cache_timestamps.items():\n            if current_time - timestamp > self.cache_ttl:\n                expired_keys.append(key)\n\n        for key in expired_keys:\n            self._invalidate_cache(key)\n\n\n    def get_config(self, key: str, default: Any = None) -> Any:\n    """文档字符串"""\n\n        """获取配置（带缓存）"""\n        try:\n            # 检查缓存\n            if self._is_cache_valid(key):\n                self._logger.debug(f"从缓存获取配置: {key}")\n                return self._cache[key]\n\n            # 从父类获取\n            value = super().get_config(key, default)\n\n            # 更新缓存\n            if value is not None:\n                self._update_cache(key, value)\n                self._logger.debug(f"更新缓存配置: {key}")\n\n            return value\n\n        except Exception as e:\n            self._logger.error(f"获取缓存配置失败: {key}, 错误: {e}")\n            return default\n\n\n    def set_config(self, key: str, value: Any) -> bool:\n    """文档字符串"""\n\n        """设置配置（同时更新缓存）"""\n        try:\n            # 调用父类方法\n            result = super().set_config(key, value)\n\n            if result:\n                # 更新缓存\n                self._update_cache(key, value)\n                self._logger.debug(f"设置配置并更新缓存: {key}")\n\n            return result\n\n        except Exception as e:\n            self._logger.error(f"设置缓存配置失败: {key}, 错误: {e}")\n            return False\n\n\n    def clear_cache(self) -> None:\n    """文档字符串"""\n\n        """清除缓存"""\n        self._cache.clear()\n        self._cache_timestamps.clear()\n        self._logger.info("配置缓存已清除")\n\n\n    def get_cache_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取缓存统计信息"""\n        current_time = time.time()\n        valid_cache_count = 0\n        expired_cache_count = 0\n\n        for key, timestamp in self._cache_timestamps.items():\n            if current_time - timestamp < self.cache_ttl:\n                valid_cache_count += 1\n            else:\n                expired_cache_count += 1\n\n        return {\n            'total_cached_keys': len(self._cache),\n            'valid_cache_count': valid_cache_count,\n            'expired_cache_count': expired_cache_count,\n            'cache_ttl': self.cache_ttl,\n            'cache_hit_rate': valid_cache_count / max(len(self._cache), 1)\n        }\n\n\n    def refresh_cache(self, key: Optional[str] = None) -> bool:\n    """文档字符串"""\n\n        """刷新缓存"""\n        try:\n            if key is None:\n                # 刷新所有缓存\n                for cached_key in list(self._cache.keys()):\n                    value = super().get_config(cached_key)\n                    if value is not None:\n                        self._update_cache(cached_key, value)\n                self._logger.info("所有配置缓存已刷新")\n            else:\n                # 刷新指定键的缓存\n                value = super().get_config(key)\n                if value is not None:\n                    self._update_cache(key, value)\n                    self._logger.info(f"配置缓存已刷新: {key}")\n                else:\n                    # 如果配置不存在，从缓存中移除\n                    self._cache.pop(key, None)\n                    self._cache_timestamps.pop(key, None)\n                    self._logger.info(f"配置已从缓存中移除: {key}")\n\n            return True\n\n        except Exception as e:\n            self._logger.error(f"刷新缓存失败: {e}")\n            return False\n\n\n    def set_cache_ttl(self, new_ttl: int) -> bool:\n    """文档字符串"""\n\n        """设置缓存TTL"""\n        try:\n            if new_ttl <= 0:\n                raise ValueError("缓存TTL必须大于0")\n\n            self.cache_ttl = new_ttl\n            self._logger.info(f"缓存TTL已更新: {new_ttl}秒")\n            return True\n\n        except Exception as e:\n            self._logger.error(f"设置缓存TTL失败: {e}")\n            return False\n\n    # 确保实现所有IConfigManager接口方法\n\n    def has_config(self, key: str) -> bool:\n    """文档字符串"""\n\n        """检查配置是否存在"""\n        return super().has_config(key)\n\n\n    def delete_config(self, key: str) -> bool:\n    """文档字符串"""\n\n        """删除配置"""\n        result = super().delete_config(key)\n        if result:\n            # 同时从缓存中移除\n            self._cache.pop(key, None)\n            self._cache_timestamps.pop(key, None)\n        return result\n\n\n    def get_all_configs(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取所有配置"""\n        return super().get_all_configs()\n\n\n    def update_configs(self, configs: Dict[str, Any]) -> bool:\n    """文档字符串"""\n\n        """批量更新配置"""\n        result = super().update_configs(configs)\n        if result:\n            # 更新缓存\n            for key, value in configs.items():\n                self._update_cache(key, value)\n        return result\n