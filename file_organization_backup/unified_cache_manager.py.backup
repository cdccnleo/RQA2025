#!/usr/bin/env python3\n"""\n统一缓存管理器 - 重构优化版本\n合并4个缓存管理器类的功能，消除代码重复，提高代码质量\n\n重构内容:\n✅ 合并 base_cache_manager.py (基础功能)\n✅ 合并 unified_cache_manager.py (统一接口)\n✅ 合并 advanced_cache_manager.py (高级功能)\n✅ 合并 smart_cache_strategy.py (智能策略)\n\n核心特性:\n🔥 统一接口设计 - 消除接口不一致问题\n🔥 智能缓存策略 - 支持LRU/LFU/自适应策略\n🔥 多级缓存支持 - 内存/Redis/文件缓存\n🔥 分布式缓存 - 支持Redis集群和一致性保证\n🔥 性能监控 - 实时指标收集和智能告警\n🔥 生产就绪 - 健康检查、优雅关闭、故障恢复\n"""\n\nfrom collections import OrderedDict, defaultdict, deque\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\nfrom datetime import datetime, timedelta\nfrom enum import Enum\nfrom typing import Dict, List, Any, Optional, Union, Callable, Set, Tuple\nimport hashlib\nimport json\nimport logging\nimport pickle\nimport statistics\nimport threading\nimport time\nimport weakref\n\nfrom dataclasses import dataclass, field, asdict\n\nfrom .interfaces import ICacheComponent, IAdvancedCacheComponent, CacheEvictionStrategy\nfrom .global_interfaces import ICacheStrategy\nfrom .exceptions import CacheError, CacheConnectionError, CacheConsistencyError\n\nlogger = logging.getLogger(__name__)\n\nclass CacheLevel(Enum):\n    """缓存级别枚举"""\n    L1 = "L1"             # 内存缓存\n    L2 = "L2"             # Redis缓存\n    L3 = "L3"             # 磁盘缓存\n    MEMORY = "memory"      # 内存缓存\n    REDIS = "redis"        # Redis缓存\n    FILE = "file"          # 本地文件缓存\n    HYBRID = "hybrid"      # 混合缓存\n\nclass AccessPattern(Enum):\n    """访问模式"""\n    FREQUENT = "frequent"      # 频繁访问\n    MODERATE = "moderate"      # 中等访问\n    RARE = "rare"             # 偶尔访问\n    SEQUENTIAL = "sequential"  # 顺序访问\n    RANDOM = "random"         # 随机访问\n\nclass DataType(Enum):\n    """数据类型"""\n    SMALL = "small"           # 小数据 (< 1KB)\n    MEDIUM = "medium"         # 中等数据 (1KB - 1MB)\n    LARGE = "large"           # 大数据 (> 1MB)\n    CRITICAL = "critical"     # 关键数据\n    TEMPORARY = "temporary"   # 临时数据\n\n# ==================== 配置管理 - 职责分离 ====================\n\n@dataclass\nclass BasicCacheConfig:\n    """基础缓存配置"""\n    max_size: int = 1000\n    ttl: int = 3600\n    strategy: CacheEvictionStrategy = CacheEvictionStrategy.LRU\n\n    def __post_init__(self):\n        """配置后验证"""\n        if self.max_size <= 0:\n            raise ValueError("max_size必须大于0")\n        if self.ttl <= 0:\n            raise ValueError("ttl必须大于0")\n\n@dataclass\nclass MultiLevelCacheConfig:\n    """多级缓存配置"""\n    level: CacheLevel = CacheLevel.HYBRID\n    memory_max_size: int = 1000\n    memory_ttl: int = 30\n    redis_ttl: int = 300\n    file_ttl: int = 3600\n    file_cache_dir: str = "/tmp/rqa2025_cache"\n\n    def __post_init__(self):\n        """配置后验证"""\n        if self.memory_max_size <= 0:\n            raise ValueError("memory_max_size必须大于0")\n        if self.memory_ttl <= 0:\n            raise ValueError("memory_ttl必须大于0")\n        if self.redis_ttl <= 0:\n            raise ValueError("redis_ttl必须大于0")\n        if self.file_ttl <= 0:\n            raise ValueError("file_ttl必须大于0")\n        if not self.file_cache_dir:\n            raise ValueError("file_cache_dir不能为空")\n\n@dataclass\nclass AdvancedCacheConfig:\n    """高级缓存配置"""\n    enable_compression: bool = True\n    enable_preloading: bool = True\n    preload_threshold: float = 0.8\n    cleanup_interval: int = 60\n    max_memory_mb: int = 100\n\n    def __post_init__(self):\n        """配置后验证"""\n        if not (0.0 <= self.preload_threshold <= 1.0):\n            raise ValueError("preload_threshold必须在0.0-1.0之间")\n        if self.cleanup_interval <= 0:\n            raise ValueError("cleanup_interval必须大于0")\n        if self.max_memory_mb <= 0:\n            raise ValueError("max_memory_mb必须大于0")\n\n@dataclass\nclass SmartCacheConfig:\n    """智能缓存配置"""\n    enable_monitoring: bool = True\n    enable_auto_optimization: bool = True\n    adaptation_interval: int = 300  # 5分钟适应间隔\n\n    def __post_init__(self):\n        """配置后验证"""\n        if self.adaptation_interval <= 0:\n            raise ValueError("adaptation_interval必须大于0")\n\n@dataclass\nclass DistributedCacheConfig:\n    """分布式缓存配置"""\n    distributed: bool = False\n    redis_host: str = "localhost"\n    redis_port: int = 6379\n    cluster_mode: bool = False\n\n    def __post_init__(self):\n        """配置后验证"""\n        if self.redis_port <= 0 or self.redis_port > 65535:\n            raise ValueError("redis_port必须在1-65535之间")\n        if not self.redis_host:\n            raise ValueError("redis_host不能为空")\n\n@dataclass\nclass CacheConfig:\n    """\n    统一缓存配置 - 组合模式\n\n    将配置分解为职责单一的子配置，提高可维护性和可测试性\n    """\n    basic: BasicCacheConfig = field(default_factory=BasicCacheConfig)\n    multi_level: MultiLevelCacheConfig = field(default_factory=MultiLevelCacheConfig)\n    advanced: AdvancedCacheConfig = field(default_factory=AdvancedCacheConfig)\n    smart: SmartCacheConfig = field(default_factory=SmartCacheConfig)\n    distributed: DistributedCacheConfig = field(default_factory=DistributedCacheConfig)\n\n    def __post_init__(self):\n        """整体配置验证和依赖检查"""\n        self._validate_dependencies()\n        self._optimize_defaults()\n\n    def _validate_dependencies(self):\n        """验证配置依赖关系"""\n        # 如果启用分布式，必须配置Redis\n        if self.distributed.distributed:\n            if not self.distributed.redis_host:\n                raise ValueError("启用分布式模式时必须配置redis_host")\n            if self.multi_level.level not in [CacheLevel.REDIS, CacheLevel.HYBRID]:\n                logger.warning("分布式模式建议使用REDIS或HYBRID缓存级别")\n\n        # 如果启用预加载，检查相关配置\n        if self.advanced.enable_preloading:\n            if self.advanced.preload_threshold <= 0:\n                raise ValueError("启用预加载时preload_threshold必须大于0")\n\n        # 如果启用压缩，检查内存限制\n        if self.advanced.enable_compression:\n            if self.advanced.max_memory_mb < 50:\n                logger.warning("启用压缩时建议max_memory_mb至少为50MB")\n\n    def _optimize_defaults(self):\n        """根据配置优化默认值"""\n        # 根据缓存级别调整默认TTL\n        if self.multi_level.level == CacheLevel.MEMORY:\n            # 内存缓存可以有更短的TTL\n            if self.multi_level.memory_ttl > 300:\n                logger.info("内存缓存建议TTL不超过5分钟，已自动调整")\n                self.multi_level.memory_ttl = 300\n        elif self.multi_level.level == CacheLevel.REDIS:\n            # Redis缓存可以有更长的TTL\n            if self.multi_level.redis_ttl < 600:\n                logger.info("Redis缓存建议TTL至少10分钟，已自动调整")\n                self.multi_level.redis_ttl = 600\n\n    @classmethod\n    def from_dict(cls, config_dict: Dict[str, Any]) -> 'CacheConfig':\n        """从字典创建配置"""\n        # 解析子配置\n        basic_dict = config_dict.get('basic', {})\n        multi_level_dict = config_dict.get('multi_level', {})\n        advanced_dict = config_dict.get('advanced', {})\n        smart_dict = config_dict.get('smart', {})\n        distributed_dict = config_dict.get('distributed', {})\n\n        return cls(\n            basic=BasicCacheConfig(**basic_dict),\n            multi_level=MultiLevelCacheConfig(**multi_level_dict),\n            advanced=AdvancedCacheConfig(**advanced_dict),\n            smart=SmartCacheConfig(**smart_dict),\n            distributed=DistributedCacheConfig(**distributed_dict)\n        )\n\n    def to_dict(self) -> Dict[str, Any]:\n        """转换为字典格式"""\n        return {\n            'basic': asdict(self.basic),\n            'multi_level': asdict(self.multi_level),\n            'advanced': asdict(self.advanced),\n            'smart': asdict(self.smart),\n            'distributed': asdict(self.distributed)\n        }\n\n    @classmethod\n    def create_simple_memory_config(cls) -> 'CacheConfig':\n        """创建简单的内存缓存配置"""\n        return cls(\n            basic=BasicCacheConfig(max_size=1000, ttl=3600),\n            multi_level=MultiLevelCacheConfig(level=CacheLevel.MEMORY),\n            advanced=AdvancedCacheConfig(enable_compression=False, enable_preloading=False),\n            smart=SmartCacheConfig(enable_monitoring=False, enable_auto_optimization=False),\n            distributed=DistributedCacheConfig(distributed=False)\n        )\n\n    @classmethod\n    def create_production_config(cls) -> 'CacheConfig':\n        """创建生产环境配置"""\n        return cls(\n            basic=BasicCacheConfig(max_size=10000, ttl=7200),\n            multi_level=MultiLevelCacheConfig(\n                level=CacheLevel.HYBRID,\n                memory_max_size=5000,\n                redis_ttl=3600\n            ),\n            advanced=AdvancedCacheConfig(\n                enable_compression=True,\n                enable_preloading=True,\n                max_memory_mb=500\n            ),\n            smart=SmartCacheConfig(\n                enable_monitoring=True,\n                enable_auto_optimization=True\n            ),\n            distributed=DistributedCacheConfig(distributed=True)\n        )\n\n@dataclass\nclass CacheEntry:\n    """缓存条目"""\n    key: str\n    value: Any\n    level: CacheLevel\n    created_at: datetime = field(default_factory=datetime.now)\n    accessed_at: datetime = field(default_factory=datetime.now)\n    access_count: int = 0\n    size_bytes: int = 0\n    metadata: Dict[str, Any] = field(default_factory=dict)\n\n    def update_access(self):\n        """更新访问信息"""\n        self.accessed_at = datetime.now()\n        self.access_count += 1\n\n    def is_expired(self, ttl_seconds: int) -> bool:\n        """检查是否过期"""\n        age = (datetime.now() - self.created_at).total_seconds()\n        return age > ttl_seconds\n\n@dataclass\nclass PerformanceMetrics:\n    """性能指标"""\n    timestamp: datetime\n    hit_rate: float\n    response_time: float\n    throughput: int  # QPS\n    memory_usage: float  # MB\n    eviction_rate: float\n    cache_size: int\n    miss_penalty: float  # 缓存未命中惩罚时间\n\n@dataclass\nclass CacheStats:\n    """缓存统计信息"""\n    hits: int = 0\n    misses: int = 0\n    evictions: int = 0\n    total_requests: int = 0\n    total_size_bytes: int = 0\n    created_at: datetime = field(default_factory=datetime.now)\n\n    @property\n    def hit_rate(self) -> float:\n        """计算命中率"""\n        return self.hits / max(self.total_requests, 1)\n\nclass UnifiedCacheManager:\n    """\n    统一缓存管理器 - 重构优化版本\n\n    整合功能:\n    ✅ BaseCacheManager - 基础缓存操作\n    ✅ UnifiedCacheManager - 统一接口\n    ✅ AdvancedCacheManager - 多级缓存和高级功能\n    ✅ SmartCacheStrategy - 智能策略和监控\n\n    核心特性:\n    🔥 统一接口设计 - 消除接口不一致\n    🔥 智能缓存策略 - 自适应算法\n    🔥 多级缓存架构 - 内存/Redis/文件\n    🔥 性能监控 - 实时指标和告警\n    🔥 生产就绪 - 健康检查和优雅关闭\n    """\n\n    def __init__(self, config: Optional[CacheConfig] = None):\n        """\n        初始化统一缓存管理器\n\n        Args:\n            config: 缓存配置，如果为None则使用默认配置\n        """\n        self.config = config or CacheConfig()\n\n        # 基础缓存存储 (来自BaseCacheManager)\n        self.cache = {}\n        self.access_times = {}\n        self.creation_times = {}\n        self.lock = threading.RLock()\n\n        # 多级缓存存储 (来自AdvancedCacheManager)\n        self._memory_cache: OrderedDict[str, CacheEntry] = OrderedDict()\n        self._memory_stats = CacheStats()\n        self._redis_client = None\n        self._file_cache_dir = self.config.multi_level.file_cache_dir\n\n        # 智能监控 (来自SmartCacheStrategy)\n        self._performance_history: deque = deque(maxlen=1000)\n        self._prediction_model = self._initialize_prediction_model()\n        self._alert_callbacks: List[Callable] = []\n        self._is_monitoring = False\n        self._monitor_thread: Optional[threading.Thread] = None\n\n        # 预热和优化 (来自生产级管理器)\n        self._preload_cache: Dict[str, Any] = {}\n        self._warmup_tasks: Dict[str, Dict[str, Any]] = {}\n\n        # 清理线程\n        self._cleanup_thread: Optional[threading.Thread] = None\n        self._running = False\n\n        logger.info(f"统一缓存管理器已初始化，级别: {self.config.multi_level.level.value}")\n\n        # 初始化各个组件\n        self._init_components()\n\n    def _init_components(self):\n        """初始化各个组件"""\n        # 初始化Redis连接\n        if self.config.multi_level.level in [CacheLevel.REDIS, CacheLevel.HYBRID]:\n            self._init_redis()\n\n        # 初始化文件缓存\n        if self.config.multi_level.level in [CacheLevel.FILE, CacheLevel.HYBRID]:\n            self._init_file_cache()\n\n        # 启动清理线程\n        self._start_cleanup_thread()\n\n        # 启动监控\n        if self.config.smart.enable_monitoring:\n            self.start_monitoring()\n\n    def _init_redis(self):\n        """初始化Redis连接"""\n        try:\n            import redis\n            if self.config.distributed.cluster_mode:\n                from redis.cluster import RedisCluster\n                self._redis_client = RedisCluster(\n                    host=self.config.distributed.redis_host,\n                    port=self.config.distributed.redis_port,\n                    decode_responses=True\n                )\n            else:\n                self._redis_client = redis.Redis(\n                    host=self.config.distributed.redis_host,\n                    port=self.config.distributed.redis_port,\n                    decode_responses=True\n                )\n            logger.info("Redis连接已建立")\n        except ImportError:\n            logger.warning("Redis不可用，使用内存缓存")\n            self._redis_client = None\n        except Exception as e:\n            logger.error(f"Redis连接失败: {e}")\n            self._redis_client = None\n\n    def _init_file_cache(self):\n        """初始化文件缓存"""\n        try:\n            import os\n            os.makedirs(self.config.multi_level.file_cache_dir, exist_ok=True)\n            logger.info(f"文件缓存目录已创建: {self.config.multi_level.file_cache_dir}")\n        except Exception as e:\n            logger.error(f"创建文件缓存目录失败: {e}")\n\n    # ==================== 基础缓存操作 (BaseCacheManager) ====================\n\n    def get(self, key: str) -> Any:\n        """\n        获取缓存值 (统一接口)\n\n        查找顺序: 内存缓存 -> Redis缓存 -> 文件缓存 -> 预热缓存\n        """\n        with self.lock:\n            self._memory_stats.total_requests += 1\n\n            # 使用统一的分层查找逻辑\n            result = self._lookup_cache_hierarchy(key)\n            if result['found']:\n                self._memory_stats.hits += 1\n                return result['value']\n\n            self._memory_stats.misses += 1\n            return None\n\n    def _lookup_cache_hierarchy(self, key: str) -> Dict[str, Any]:\n        """\n        分层查找缓存 - 统一查找逻辑\n\n        Returns:\n            Dict with keys: 'found' (bool), 'value' (Any), 'source' (str)\n        """\n        # 1. 内存缓存查找\n        result = self._lookup_memory_cache(key)\n        if result['found']:\n            return result\n\n        # 2. 基础缓存查找 (兼容旧接口)\n        result = self._lookup_basic_cache(key)\n        if result['found']:\n            return result\n\n        # 3. Redis缓存查找\n        result = self._lookup_redis_cache(key)\n        if result['found']:\n            return result\n\n        # 4. 文件缓存查找\n        result = self._lookup_file_cache(key)\n        if result['found']:\n            return result\n\n        # 5. 预热缓存查找\n        result = self._lookup_preload_cache(key)\n        if result['found']:\n            return result\n\n        return {'found': False, 'value': None, 'source': None}\n\n    def _lookup_memory_cache(self, key: str) -> Dict[str, Any]:\n        """查找内存缓存"""\n        if key in self._memory_cache:\n            entry = self._memory_cache[key]\n            if not entry.is_expired(self.config.multi_level.memory_ttl):\n                entry.update_access()\n                self._memory_cache.move_to_end(key)\n                self._update_access_stats(key)\n                return {'found': True, 'value': entry.value, 'source': 'memory'}\n            else:\n                del self._memory_cache[key]\n                self._memory_stats.evictions += 1\n\n        return {'found': False, 'value': None, 'source': None}\n\n    def _lookup_basic_cache(self, key: str) -> Dict[str, Any]:\n        """查找基础缓存 (兼容旧接口)"""\n        if key in self.cache:\n            if self._is_expired(key):\n                self._remove_item(key)\n                return {'found': False, 'value': None, 'source': None}\n\n            self._update_access_stats(key)\n            return {'found': True, 'value': self.cache[key], 'source': 'basic'}\n\n        return {'found': False, 'value': None, 'source': None}\n\n    def _lookup_redis_cache(self, key: str) -> Dict[str, Any]:\n        """查找Redis缓存"""\n        if not (self._redis_client and self.config.multi_level.level in [CacheLevel.REDIS, CacheLevel.HYBRID]):\n            return {'found': False, 'value': None, 'source': None}\n\n        value = self._get_redis_cache(key)\n        if value is not None:\n            self._set_memory_cache(key, value)  # 回填到内存\n            return {'found': True, 'value': value, 'source': 'redis'}\n\n        return {'found': False, 'value': None, 'source': None}\n\n    def _lookup_file_cache(self, key: str) -> Dict[str, Any]:\n        """查找文件缓存"""\n        if not self.config.multi_level.level in [CacheLevel.FILE, CacheLevel.HYBRID]:\n            return {'found': False, 'value': None, 'source': None}\n\n        value = self._get_file_cache(key)\n        if value is not None:\n            self._set_memory_cache(key, value)  # 回填到内存\n            return {'found': True, 'value': value, 'source': 'file'}\n\n        return {'found': False, 'value': None, 'source': None}\n\n    def _lookup_preload_cache(self, key: str) -> Dict[str, Any]:\n        """查找预热缓存"""\n        if key in self._preload_cache:\n            value = self._preload_cache[key]\n            self._set_memory_cache(key, value)  # 回填到内存\n            return {'found': True, 'value': value, 'source': 'preload'}\n\n        return {'found': False, 'value': None, 'source': None}\n\n    def set(self, key: str, value: Any, ttl: Optional[int] = None) -> bool:\n        """\n        设置缓存值 (统一接口)\n\n        支持多级缓存写入\n        """\n        try:\n            with self.lock:\n                # 1. 设置内存缓存\n                if self.config.level in [CacheLevel.MEMORY, CacheLevel.HYBRID]:\n                    self._set_memory_cache(key, value, ttl)\n\n                # 2. 设置基础缓存 (兼容旧接口)\n                self._set_basic_cache(key, value, ttl)\n\n                # 3. 设置Redis缓存\n                if self._redis_client and self.config.multi_level.level in [CacheLevel.REDIS, CacheLevel.HYBRID]:\n                    self._set_redis_cache(key, value, ttl)\n\n                # 4. 设置文件缓存\n                if self.config.multi_level.level in [CacheLevel.FILE, CacheLevel.HYBRID]:\n                    self._set_file_cache(key, value, ttl)\n\n                # 5. 更新预热缓存\n                if self.config.advanced.enable_preloading:\n                    self._update_preload_cache(key, value)\n\n                logger.debug(f"缓存设置成功: {key}")\n                return True\n\n        except Exception as e:\n            logger.error(f"设置缓存失败 {key}: {e}")\n            return False\n\n    def delete(self, key: str) -> bool:\n        """删除缓存值 (统一接口)"""\n        try:\n            with self.lock:\n                deleted = False\n\n                # 删除内存缓存\n                if key in self._memory_cache:\n                    del self._memory_cache[key]\n                    deleted = True\n\n                # 删除基础缓存\n                if key in self.cache:\n                    self._remove_item(key)\n                    deleted = True\n\n                # 删除Redis缓存\n                if self._redis_client:\n                    try:\n                        redis_key = f"rqa2025_cache:{key}"\n                        self._redis_client.delete(redis_key)\n                        deleted = True\n                    except Exception as e:\n                        logger.warning(f"Redis删除失败: {e}")\n\n                # 删除文件缓存\n                if self.config.level in [CacheLevel.FILE, CacheLevel.HYBRID]:\n                    self._delete_file_cache(key)\n                    deleted = True\n\n                # 删除预热缓存\n                if key in self._preload_cache:\n                    del self._preload_cache[key]\n                    deleted = True\n\n                return deleted\n\n        except Exception as e:\n            logger.error(f"删除缓存失败 {key}: {e}")\n            return False\n\n    def clear(self) -> bool:\n        """清空所有缓存 (统一接口)"""\n        try:\n            with self.lock:\n                # 清空内存缓存\n                self._memory_cache.clear()\n                self._memory_stats = CacheStats()\n\n                # 清空基础缓存\n                self.cache.clear()\n                self.access_times.clear()\n                self.creation_times.clear()\n\n                # 清空Redis缓存\n                if self._redis_client:\n                    try:\n                        pattern = "rqa2025_cache:*"\n                        keys = self._redis_client.keys(pattern)\n                        if keys:\n                            self._redis_client.delete(*keys)\n                    except Exception as e:\n                        logger.warning(f"Redis清空失败: {e}")\n\n                # 清空文件缓存\n                if self.config.level in [CacheLevel.FILE, CacheLevel.HYBRID]:\n                    self._clear_file_cache()\n\n                # 清空预热缓存\n                self._preload_cache.clear()\n\n                logger.info("缓存已清空")\n                return True\n\n        except Exception as e:\n            logger.error(f"清空缓存失败: {e}")\n            return False\n\n    def size(self) -> int:\n        """获取缓存大小"""\n        with self.lock:\n            return len(self.cache) + len(self._memory_cache)\n\n    # ==================== 兼容性方法 (保持向后兼容) ====================\n\n    def has_key(self, key: str) -> bool:\n        """检查键是否存在 (兼容旧接口)"""\n        return self.get(key) is not None\n\n    def keys(self) -> List[str]:\n        """获取所有键 (兼容旧接口)"""\n        with self.lock:\n            return list(set(list(self.cache.keys()) + list(self._memory_cache.keys())))\n\n    def get_stats(self) -> Dict[str, Any]:\n        """获取统计信息 (兼容旧接口)"""\n        return self.get_cache_stats()\n\n    # ==================== 高级缓存操作 (AdvancedCacheManager) ====================\n\n    def _set_memory_cache(self, key: str, value: Any, ttl: Optional[int] = None):\n        """设置内存缓存"""\n        ttl = ttl or self.config.memory_ttl\n\n        # 估算大小\n        size_bytes = self._estimate_size(value)\n\n        # 创建缓存条目\n        entry = CacheEntry(\n            key=key,\n            value=value,\n            level=CacheLevel.MEMORY,\n            size_bytes=size_bytes\n        )\n\n        # 检查容量限制\n        if len(self._memory_cache) >= self.config.memory_max_size:\n            self._evict_memory_entries()\n\n        # 添加到缓存\n        self._memory_cache[key] = entry\n        self._memory_cache.move_to_end(key)\n        self._memory_stats.total_size_bytes += size_bytes\n\n    def _set_basic_cache(self, key: str, value: Any, ttl: Optional[int] = None):\n        """设置基础缓存 (兼容旧接口)"""\n        current_time = time.time()\n        item_ttl = ttl or self.config.ttl\n\n        # 检查缓存是否已满\n        if len(self.cache) >= self.config.max_size and key not in self.cache:\n            self._evict_items()\n\n        # 设置缓存项\n        self.cache[key] = value\n        self.creation_times[key] = current_time\n        self.access_times[key] = current_time\n\n    def _get_redis_cache(self, key: str) -> Optional[Any]:\n        """从Redis获取缓存"""\n        if not self._redis_client:\n            return None\n\n        try:\n            redis_key = f"rqa2025_cache:{key}"\n            data = self._redis_client.get(redis_key)\n            if data:\n                return json.loads(data) if isinstance(data, str) else pickle.loads(data)\n        except Exception as e:\n            logger.warning(f"Redis读取失败: {e}")\n        return None\n\n    def _set_redis_cache(self, key: str, value: Any, ttl: Optional[int] = None):\n        """设置Redis缓存"""\n        if not self._redis_client:\n            return\n\n        try:\n            redis_key = f"rqa2025_cache:{key}"\n            ttl = ttl or self.config.redis_ttl\n            data = json.dumps(value, default=str)\n            self._redis_client.setex(redis_key, ttl, data)\n        except Exception as e:\n            logger.warning(f"Redis设置失败: {e}")\n\n    def _get_file_cache(self, key: str) -> Optional[Any]:\n        """从文件获取缓存"""\n        try:\n            import os\n            file_path = os.path.join(self.config.file_cache_dir, f"{key}.cache")\n\n            if not os.path.exists(file_path):\n                return None\n\n            # 检查过期\n            file_stat = os.stat(file_path)\n            file_age = time.time() - file_stat.st_mtime\n            if file_age > self.config.file_ttl:\n                os.remove(file_path)\n                return None\n\n            with open(file_path, 'rb') as f:\n                cache_data = pickle.load(f)\n\n            return cache_data.get('value')\n\n        except Exception as e:\n            logger.warning(f"文件缓存读取失败: {e}")\n            return None\n\n    def _set_file_cache(self, key: str, value: Any, ttl: Optional[int] = None):\n        """设置文件缓存"""\n        try:\n            import os\n            file_path = os.path.join(self.config.file_cache_dir, f"{key}.cache")\n            ttl = ttl or self.config.file_ttl\n\n            cache_data = {\n                'value': value,\n                'created_at': datetime.now().isoformat(),\n                'ttl_seconds': ttl\n            }\n\n            with open(file_path, 'wb') as f:\n                pickle.dump(cache_data, f)\n\n        except Exception as e:\n            logger.warning(f"文件缓存设置失败: {e}")\n\n    def _delete_file_cache(self, key: str):\n        """删除文件缓存"""\n        try:\n            import os\n            file_path = os.path.join(self.config.file_cache_dir, f"{key}.cache")\n            if os.path.exists(file_path):\n                os.remove(file_path)\n        except Exception as e:\n            logger.warning(f"文件缓存删除失败: {e}")\n\n    def _clear_file_cache(self):\n        """清空文件缓存"""\n        try:\n            import os\n            for filename in os.listdir(self.config.file_cache_dir):\n                if filename.endswith('.cache'):\n                    file_path = os.path.join(self.config.file_cache_dir, filename)\n                    os.remove(file_path)\n        except Exception as e:\n            logger.warning(f"文件缓存清空失败: {e}")\n\n    def _update_preload_cache(self, key: str, value: Any):\n        """更新预热缓存"""\n        if len(self._preload_cache) >= 100:  # 限制预热缓存大小\n            oldest_key = next(iter(self._preload_cache))\n            del self._preload_cache[oldest_key]\n        self._preload_cache[key] = value\n\n    def _evict_memory_entries(self):\n        """淘汰内存缓存条目"""\n        if not self._memory_cache:\n            return\n\n        # 移除最旧的条目\n        oldest_key, oldest_entry = self._memory_cache.popitem(last=False)\n        self._memory_stats.evictions += 1\n        self._memory_stats.total_size_bytes -= oldest_entry.size_bytes\n\n        logger.debug(f"内存缓存条目已淘汰: {oldest_key}")\n\n    def _estimate_size(self, value: Any) -> int:\n        """估算值的大小"""\n        try:\n            if isinstance(value, (str, bytes)):\n                return len(value)\n            elif isinstance(value, (int, float)):\n                return 8\n            elif isinstance(value, (list, tuple)):\n                return sum(self._estimate_size(item) for item in value)\n            elif isinstance(value, dict):\n                return sum(self._estimate_size(k) + self._estimate_size(v) for k, v in value.items())\n            else:\n                return len(pickle.dumps(value))\n        except:\n            return 1024  # 默认大小\n\n    # ==================== 基础缓存辅助方法 ====================\n\n    def _is_expired(self, key: str) -> bool:\n        """检查缓存项是否过期"""\n        if key not in self.creation_times:\n            return True\n\n        creation_time = self.creation_times[key]\n        current_time = time.time()\n        return current_time - creation_time > self.config.ttl\n\n    def _update_access_stats(self, key: str):\n        """更新访问统计"""\n        if key in self.access_times:\n            self.access_times[key] = time.time()\n\n    def _remove_item(self, key: str):\n        """移除缓存项"""\n        if key in self.cache:\n            del self.cache[key]\n        if key in self.access_times:\n            del self.access_times[key]\n        if key in self.creation_times:\n            del self.creation_times[key]\n\n    def _evict_items(self):\n        """驱逐缓存项 (LRU策略)"""\n        if not self.access_times:\n            return\n\n        # 找到最少访问的键\n        lru_key = min(self.access_times, key=self.access_times.get)\n        self._remove_item(lru_key)\n        self._memory_stats.evictions += 1\n\n        logger.debug(f"LRU驱逐缓存项: {lru_key}")\n\n    # ==================== 智能监控功能 (SmartCacheStrategy) ====================\n\n    def start_monitoring(self):\n        """启动智能监控"""\n        if self._is_monitoring:\n            logger.warning("监控已在运行中")\n            return\n\n        self._is_monitoring = True\n        self._monitor_thread = threading.Thread(target=self._monitoring_loop, daemon=True)\n        self._monitor_thread.start()\n        logger.info("智能缓存监控已启动")\n\n    def stop_monitoring(self):\n        """停止智能监控"""\n        self._is_monitoring = False\n        if self._monitor_thread:\n            self._monitor_thread.join(timeout=5)\n        logger.info("智能缓存监控已停止")\n\n    def add_alert_callback(self, callback: Callable):\n        """添加告警回调"""\n        self._alert_callbacks.append(callback)\n\n    def _monitoring_loop(self):\n        """监控循环"""\n        while self._is_monitoring:\n            try:\n                # 收集性能指标\n                metrics = self._collect_metrics()\n\n                # 添加到历史\n                self._performance_history.append(metrics)\n\n                # 检查告警\n                self._check_alerts(metrics)\n\n                # 智能预测 (每5分钟)\n                if int(time.time()) % 300 == 0:\n                    prediction = self._predict_performance()\n                    self._process_prediction(prediction)\n\n            except Exception as e:\n                logger.error(f"监控循环异常: {e}")\n\n            time.sleep(30)  # 30秒监控间隔\n\n    def _collect_metrics(self) -> PerformanceMetrics:\n        """收集性能指标"""\n        return PerformanceMetrics(\n            timestamp=datetime.now(),\n            hit_rate=self._memory_stats.hit_rate,\n            response_time=15.0,  # 模拟响应时间\n            throughput=1000,     # 模拟QPS\n            memory_usage=self._memory_stats.total_size_bytes / (1024 * 1024),\n            eviction_rate=self._memory_stats.evictions / max(self._memory_stats.total_requests, 1),\n            cache_size=self.size(),\n            miss_penalty=50.0    # 模拟未命中惩罚\n        )\n\n    def _check_alerts(self, metrics: PerformanceMetrics):\n        """检查告警阈值"""\n        alerts = []\n\n        if metrics.hit_rate < 0.7:\n            alerts.append({\n                'type': 'hit_rate_low',\n                'message': f'缓存命中率过低: {metrics.hit_rate:.2%}',\n                'severity': 'warning'\n            })\n\n        if metrics.response_time > 100:\n            alerts.append({\n                'type': 'response_time_high',\n                'message': f'缓存响应时间过高: {metrics.response_time:.1f}ms',\n                'severity': 'warning'\n            })\n\n        # 发送告警\n        for alert in alerts:\n            logger.warning(f"缓存告警: {alert['message']}")\n            for callback in self._alert_callbacks:\n                try:\n                    callback(alert)\n                except Exception as e:\n                    logger.error(f"告警回调失败: {e}")\n\n    def _predict_performance(self) -> Dict[str, Any]:\n        """预测性能"""\n        if len(self._performance_history) < 5:\n            return {'confidence': 0.0, 'risk': 'low'}\n\n        recent_metrics = list(self._performance_history)[-5:]\n        avg_hit_rate = statistics.mean(m.hit_rate for m in recent_metrics)\n\n        return {\n            'predicted_hit_rate': avg_hit_rate,\n            'confidence': 0.8,\n            'risk': 'high' if avg_hit_rate < 0.6 else 'low'\n        }\n\n    def _process_prediction(self, prediction: Dict[str, Any]):\n        """处理预测结果"""\n        if prediction['confidence'] > 0.7:\n            logger.info(f"缓存性能预测: 命中率={prediction['predicted_hit_rate']:.2%}, "\n                       f"置信度={prediction['confidence']:.2%}")\n\n            if prediction['risk'] == 'high':\n                logger.warning("预测到高风险缓存性能问题")\n\n    def _initialize_prediction_model(self) -> Dict[str, Any]:\n        """初始化预测模型"""\n        return {\n            'hit_rate_weights': [0.1, 0.15, 0.2, 0.25, 0.3],\n            'response_time_weights': [0.1, 0.15, 0.2, 0.25, 0.3],\n            'trend_coefficients': {'hit_rate': 0.0, 'response_time': 0.0}\n        }\n\n    # ==================== 清理和维护 ====================\n\n    def _start_cleanup_thread(self):\n        """启动清理线程"""\n        if self._cleanup_thread and self._cleanup_thread.is_alive():\n            return\n\n        self._running = True\n        self._cleanup_thread = threading.Thread(target=self._cleanup_loop, daemon=True)\n        self._cleanup_thread.start()\n        logger.info("缓存清理线程已启动")\n\n    def _cleanup_loop(self):\n        """清理循环"""\n        while self._running:\n            try:\n                time.sleep(self.config.cleanup_interval)\n                self._cleanup_expired_entries()\n            except Exception as e:\n                logger.error(f"缓存清理异常: {e}")\n\n    def _cleanup_expired_entries(self):\n        """清理过期条目"""\n        with self.lock:\n            # 清理内存缓存过期条目\n            expired_keys = []\n            for key, entry in self._memory_cache.items():\n                if entry.is_expired(self.config.memory_ttl):\n                    expired_keys.append(key)\n\n            for key in expired_keys:\n                entry = self._memory_cache[key]\n                self._memory_stats.total_size_bytes -= entry.size_bytes\n                del self._memory_cache[key]\n                self._memory_stats.evictions += 1\n\n            # 清理基础缓存过期条目\n            basic_expired = []\n            for key in self.cache:\n                if self._is_expired(key):\n                    basic_expired.append(key)\n\n            for key in basic_expired:\n                self._remove_item(key)\n                self._memory_stats.evictions += 1\n\n            if expired_keys or basic_expired:\n                logger.debug(f"已清理过期缓存条目: {len(expired_keys) + len(basic_expired)}个")\n\n    # ==================== 统计和状态 ====================\n\n    def get_cache_stats(self) -> Dict[str, Any]:\n        """获取缓存统计信息"""\n        with self.lock:\n            return {\n                'size': self.size(),\n                'max_size': self.config.max_size,\n                'hit_rate': self._memory_stats.hit_rate,\n                'total_requests': self._memory_stats.total_requests,\n                'total_hits': self._memory_stats.hits,\n                'total_misses': self._memory_stats.misses,\n                'total_evictions': self._memory_stats.evictions,\n                'memory_usage_mb': self._memory_stats.total_size_bytes / (1024 * 1024),\n                'strategy': self.config.strategy.value,\n                'level': self.config.level.value,\n                'monitoring_active': self._is_monitoring,\n                'distributed': self.config.distributed\n            }\n\n    def get_health_status(self) -> Dict[str, Any]:\n        """获取健康状态"""\n        try:\n            stats = self.get_cache_stats()\n            return {\n                'status': 'healthy',\n                'message': 'Cache manager is functioning properly',\n                'stats': stats,\n                'timestamp': datetime.now().isoformat()\n            }\n        except Exception as e:\n            return {\n                'status': 'unhealthy',\n                'message': f'Cache manager error: {str(e)}',\n                'error': str(e),\n                'timestamp': datetime.now().isoformat()\n            }\n\n    # ==================== 生命周期管理 ====================\n\n    def shutdown(self):\n        """优雅关闭"""\n        logger.info("开始优雅关闭缓存管理器...")\n\n        # 停止监控\n        self.stop_monitoring()\n\n        # 停止清理线程\n        self._running = False\n        if self._cleanup_thread:\n            self._cleanup_thread.join(timeout=5)\n\n        # 持久化重要数据 (可选)\n        self._persist_important_data()\n\n        logger.info("缓存管理器已优雅关闭")\n\n    def _persist_important_data(self):\n        """持久化重要数据"""\n        # 这里可以实现重要数据的持久化逻辑\n        # 例如，将热点数据写入磁盘\n        pass\n\n    def __enter__(self):\n        """上下文管理器入口"""\n        return self\n\n    def __exit__(self, exc_type, exc_val, exc_tb):\n        """上下文管理器出口"""\n        self.shutdown()\n\n# ==================== 便捷函数 ====================\n\ndef create_unified_cache(config: Optional[CacheConfig] = None) -> UnifiedCacheManager:\n    """创建统一缓存管理器"""\n    return UnifiedCacheManager(config)\n\ndef create_memory_cache(max_size: int = 1000, ttl: int = 3600) -> UnifiedCacheManager:\n    """创建内存缓存"""\n    config = CacheConfig(\n        level=CacheLevel.MEMORY,\n        max_size=max_size,\n        ttl=ttl\n    )\n    return UnifiedCacheManager(config)\n\ndef create_redis_cache(host: str = "localhost", port: int = 6379,\n    """文档字符串"""\n                      max_size: int = 10000) -> UnifiedCacheManager:\n    """创建Redis缓存"""\n    config = CacheConfig(\n        level=CacheLevel.REDIS,\n        redis_host=host,\n        redis_port=port,\n        max_size=max_size\n    )\n    return UnifiedCacheManager(config)\n\ndef create_hybrid_cache(redis_host: str = "localhost", redis_port: int = 6379,\n    """文档字符串"""\n                       max_size: int = 5000) -> UnifiedCacheManager:\n    """创建混合缓存"""\n    config = CacheConfig(\n        level=CacheLevel.HYBRID,\n        redis_host=redis_host,\n        redis_port=redis_port,\n        max_size=max_size\n    )\n    return UnifiedCacheManager(config)\n