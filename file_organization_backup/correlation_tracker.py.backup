import logging\n\n#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n引擎层关联追踪器\n提供请求追踪和关联ID管理功能\n"""\n\nimport time\nimport threading\nimport uuid\nfrom typing import Dict, Any, Optional, List, Callable\nfrom dataclasses import dataclass, field\nfrom enum import Enum\nfrom contextlib import contextmanager\n\nfrom .core_logger import EngineLogger, LogLevel, LogCategory\n\nclass CorrelationType(Enum):\n\n    """关联类型"""\n    REQUEST = "request"\n    SESSION = "session"\n    USER = "user"\n    BUSINESS = "business"\n    SYSTEM = "system"\n\n@dataclass\n\nclass CorrelationContext:\n\n    """关联上下文"""\n    correlation_id: str\n    correlation_type: CorrelationType\n    parent_id: Optional[str] = None\n    user_id: str = ""\n    session_id: str = ""\n    component: str = ""\n    operation: str = ""\n    start_time: float = field(default_factory=time.time)\n    end_time: Optional[float] = None\n    metadata: Dict[str, Any] = field(default_factory=dict)\n\nclass CorrelationTracker:\n\n    """关联追踪器"""\n\n    def __init__(self, logger: EngineLogger, config: Dict[str, Any] = None):\n\n        """初始化关联追踪器\n\n        Args:\n            logger: 引擎日志记录器\n            config: 配置字典\n        """\n        logger = logging.getLogger(__name__)\n        self.config = config or {}\n\n        # 关联上下文存储\n        self._correlation_contexts = {}\n        self._context_lock = threading.RLock()\n\n        # 线程本地存储\n        self._thread_local = threading.local()\n\n        # 关联统计\n        self._correlation_stats = {\n            'total_correlations': 0,\n            'active_correlations': 0,\n            'correlations_by_type': {},\n            'correlations_by_component': {}\n        }\n\n        # 超时配置\n        self._timeout = self.config.get('timeout', 3600)  # 1小时\n        self._cleanup_interval = self.config.get('cleanup_interval', 300)  # 5分钟\n\n        # 启动清理线程\n        self._cleanup_thread = None\n        self._stop_cleanup = False\n        self._start_cleanup_thread()\n\n    def stop(self):\n    """文档字符串"""\n\n        """停止关联追踪器，清理所有资源"""\n        self.logger.info("正在停止关联追踪器...")\n\n        # 设置停止标志\n        self._stop_cleanup = True\n\n        # 等待清理线程结束\n        if self._cleanup_thread and self._cleanup_thread.is_alive():\n            self._cleanup_thread.join(timeout=5.0)\n        if self._cleanup_thread.is_alive():\n            self.logger.warning("关联追踪器清理线程未能及时停止")\n\n        # 清空关联上下文\n        with self._context_lock:\n            self._correlation_contexts.clear()\n            self._correlation_stats = {\n                'total_correlations': 0,\n                'active_correlations': 0,\n                'correlations_by_type': {},\n                'correlations_by_component': {}\n            }\n\n        self.logger.info("关联追踪器已停止")\n\n    def __del__(self):\n\n        """析构函数，确保资源被清理"""\n        try:\n            self.stop()\n        except Exception:\n            pass  # 忽略析构时的异常\n\n    def _start_cleanup_thread(self):\n    """文档字符串"""\n\n        """启动清理线程"""\n\n        def cleanup_worker():\n    """文档字符串"""\n\n            while not self._stop_cleanup:\n                try:\n                    # 使用可中断的睡眠机制\n                    for _ in range(self._cleanup_interval):\n                        if self._stop_cleanup:\n                            break\n                        time.sleep(1)\n                    if not self._stop_cleanup:\n                        self._cleanup_expired_correlations()\n                except Exception as e:\n                    self.logger.error(f"关联追踪清理失败: {e}", exception=e)\n\n        self._cleanup_thread = threading.Thread(target=cleanup_worker, daemon=True)\n        self._cleanup_thread.start()\n\n    def create_correlation(self, correlation_type: CorrelationType,\n    """文档字符串"""\n\n                           user_id: str = "", session_id: str = "",\n                           component: str = "", operation: str = "",\n                           parent_id: Optional[str] = None,\n                           **kwargs) -> str:\n        """创建关联ID"""\n        try:\n            # 生成关联ID\n            correlation_id = str(uuid.uuid4())\n\n            # 创建关联上下文\n            context = CorrelationContext(\n                correlation_id=correlation_id,\n                correlation_type=correlation_type,\n                parent_id=parent_id,\n                user_id=user_id,\n                session_id=session_id,\n                component=component,\n                operation=operation,\n                metadata=kwargs\n            )\n\n            # 存储上下文\n            with self._context_lock:\n                self._correlation_contexts[correlation_id] = context\n                self._correlation_stats['total_correlations'] += 1\n                self._correlation_stats['active_correlations'] += 1\n\n                # 按类型统计\n                type_str = correlation_type.value\n                if type_str not in self._correlation_stats['correlations_by_type']:\n                    self._correlation_stats['correlations_by_type'][type_str] = 0\n                self._correlation_stats['correlations_by_type'][type_str] += 1\n\n                # 按组件统计\n                if component:\n                    if component not in self._correlation_stats['correlations_by_component']:\n                        self._correlation_stats['correlations_by_component'][component] = 0\n                    self._correlation_stats['correlations_by_component'][component] += 1\n\n            # 设置线程本地关联ID\n            self._set_thread_correlation_id(correlation_id)\n\n            # 记录关联创建\n            self.logger.info(\n                f"创建关联: {correlation_id} - {correlation_type.value}",\n                component=component,\n                operation=operation,\n                correlation_id=correlation_id,\n                correlation_type=correlation_type.value,\n                user_id=user_id,\n                session_id=session_id,\n                parent_id=parent_id,\n                **kwargs\n            )\n\n            return correlation_id\n\n        except Exception as e:\n            self.logger.error(f"创建关联失败: {e}", exception=e)\n            return ""\n\n    def get_correlation_context(self, correlation_id: str) -> Optional[CorrelationContext]:\n    """文档字符串"""\n\n        """获取关联上下文"""\n        with self._context_lock:\n            return self._correlation_contexts.get(correlation_id)\n\n    def update_correlation(self, correlation_id: str, **kwargs):\n    """文档字符串"""\n\n        """更新关联上下文"""\n        with self._context_lock:\n            if correlation_id in self._correlation_contexts:\n                context = self._correlation_contexts[correlation_id]\n                context.metadata.update(kwargs)\n\n    def end_correlation(self, correlation_id: str, status: str = "success", **kwargs):\n    """文档字符串"""\n\n        """结束关联"""\n        try:\n            with self._context_lock:\n                if correlation_id in self._correlation_contexts:\n                    context = self._correlation_contexts[correlation_id]\n                    context.end_time = time.time()\n                    context.metadata.update(kwargs)\n                    context.metadata['status'] = status\n\n                    self._correlation_stats['active_correlations'] -= 1\n\n                    # 记录关联结束\n                    duration = context.end_time - context.start_time\n                    self.logger.info(\n                        f"结束关联: {correlation_id} - 状态: {status} - 耗时: {duration:.3f}s",\n                        component=context.component,\n                        operation=context.operation,\n                        correlation_id=correlation_id,\n                        correlation_type=context.correlation_type.value,\n                        status=status,\n                        duration=duration,\n                        **kwargs\n                    )\n\n                    # 清理线程本地存储\n                    self._clear_thread_correlation_id()\n\n        except Exception as e:\n            self.logger.error(f"结束关联失败: {e}", exception=e)\n\n    def get_current_correlation_id(self) -> str:\n    """文档字符串"""\n\n        """获取当前关联ID"""\n        return getattr(self._thread_local, 'correlation_id', '')\n\n    def set_current_correlation_id(self, correlation_id: str):\n    """文档字符串"""\n\n        """设置当前关联ID"""\n        self._thread_local.correlation_id = correlation_id\n\n    def _set_thread_correlation_id(self, correlation_id: str):\n    """文档字符串"""\n\n        """设置线程本地关联ID"""\n        self._thread_local.correlation_id = correlation_id\n\n    def _clear_thread_correlation_id(self):\n    """文档字符串"""\n\n        """清理线程本地关联ID"""\n        if hasattr(self._thread_local, 'correlation_id'):\n            delattr(self._thread_local, 'correlation_id')\n\n    @contextmanager\n\n    def correlation_context(self, correlation_type: CorrelationType,\n    """文档字符串"""\n\n                            user_id: str = "", session_id: str = "",\n                            component: str = "", operation: str = "",\n                            parent_id: Optional[str] = None,\n                            **kwargs):\n        """关联上下文管理器"""\n        correlation_id = self.create_correlation(\n            correlation_type=correlation_type,\n            user_id=user_id,\n            session_id=session_id,\n            component=component,\n            operation=operation,\n            parent_id=parent_id,\n            **kwargs\n        )\n\n        try:\n            yield correlation_id\n        except Exception as e:\n            self.end_correlation(correlation_id, status="error", error=str(e))\n            raise\n        else:\n            self.end_correlation(correlation_id, status="success")\n\n    def get_correlation_chain(self, correlation_id: str) -> List[CorrelationContext]:\n    """文档字符串"""\n\n        """获取关联链"""\n        chain = []\n        current_id = correlation_id\n\n        while current_id:\n            context = self.get_correlation_context(current_id)\n            if context:\n                chain.append(context)\n                current_id = context.parent_id\n            else:\n                break\n\n        return list(reversed(chain))\n\n    def get_correlations_by_type(self, correlation_type: CorrelationType,\n    """文档字符串"""\n\n                                 time_range: float = None) -> List[CorrelationContext]:\n        """按类型获取关联"""\n        with self._context_lock:\n            contexts = [\n                context for context in self._correlation_contexts.values()\n                if context.correlation_type == correlation_type\n            ]\n\n            if time_range:\n                current_time = time.time()\n                contexts = [\n                    context for context in contexts\n                    if current_time - context.start_time <= time_range\n                ]\n\n            return contexts\n\n    def get_correlations_by_user(self, user_id: str,\n    """文档字符串"""\n\n                                 time_range: float = None) -> List[CorrelationContext]:\n        """按用户获取关联"""\n        with self._context_lock:\n            contexts = [\n                context for context in self._correlation_contexts.values()\n                if context.user_id == user_id\n            ]\n\n            if time_range:\n                current_time = time.time()\n                contexts = [\n                    context for context in contexts\n                    if current_time - context.start_time <= time_range\n                ]\n\n            return contexts\n\n    def get_correlation_summary(self, time_range: float = None) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取关联摘要"""\n        with self._context_lock:\n            contexts = list(self._correlation_contexts.values())\n\n            if time_range:\n                current_time = time.time()\n                contexts = [\n                    context for context in contexts\n                    if current_time - context.start_time <= time_range\n                ]\n\n            summary = {\n                'total_correlations': len(contexts),\n                'active_correlations': len([c for c in contexts if c.end_time is None]),\n                'correlations_by_type': {},\n                'correlations_by_component': {},\n                'correlations_by_status': {},\n                'avg_duration': 0.0,\n                'max_duration': 0.0,\n                'min_duration': float('inf')\n            }\n\n            total_duration = 0.0\n            completed_count = 0\n\n            for context in contexts:\n                # 按类型统计\n                type_str = context.correlation_type.value\n                if type_str not in summary['correlations_by_type']:\n                    summary['correlations_by_type'][type_str] = 0\n                summary['correlations_by_type'][type_str] += 1\n\n                # 按组件统计\n                if context.component:\n                    if context.component not in summary['correlations_by_component']:\n                        summary['correlations_by_component'][context.component] = 0\n                    summary['correlations_by_component'][context.component] += 1\n\n                # 按状态统计\n                status = context.metadata.get('status', 'unknown')\n                if status not in summary['correlations_by_status']:\n                    summary['correlations_by_status'][status] = 0\n                summary['correlations_by_status'][status] += 1\n\n                # 计算持续时间\n                if context.end_time:\n                    duration = context.end_time - context.start_time\n                    total_duration += duration\n                    completed_count += 1\n                    summary['max_duration'] = max(summary['max_duration'], duration)\n                    summary['min_duration'] = min(summary['min_duration'], duration)\n\n            if completed_count > 0:\n                summary['avg_duration'] = total_duration / completed_count\n\n            return summary\n\n    def _cleanup_expired_correlations(self):\n    """文档字符串"""\n\n        """清理过期的关联"""\n        current_time = time.time()\n        expired_ids = []\n\n        with self._context_lock:\n            for correlation_id, context in self._correlation_contexts.items():\n                if current_time - context.start_time > self._timeout:\n                    expired_ids.append(correlation_id)\n\n            for correlation_id in expired_ids:\n                del self._correlation_contexts[correlation_id]\n                self._correlation_stats['active_correlations'] -= 1\n\n        if expired_ids:\n            self.logger.info(f"清理了 {len(expired_ids)} 个过期关联")\n\n    def get_correlation_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取关联统计信息"""\n        with self._context_lock:\n            return self._correlation_stats.copy()\n\n    def clear_correlations(self, time_range: float = None):\n    """文档字符串"""\n\n        """清理关联"""\n        with self._context_lock:\n            if time_range:\n                current_time = time.time()\n                ids_to_remove = [\n                    correlation_id for correlation_id, context in self._correlation_contexts.items()\n                    if current_time - context.start_time > time_range\n                ]\n                for correlation_id in ids_to_remove:\n                    del self._correlation_contexts[correlation_id]\n                    self._correlation_stats['active_correlations'] -= 1\n            else:\n                self._correlation_contexts.clear()\n                self._correlation_stats['active_correlations'] = 0\n\n    def health_check(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """健康检查"""\n        try:\n            return {\n                'status': 'healthy',\n                'total_correlations': self._correlation_stats['total_correlations'],\n                'active_correlations': self._correlation_stats['active_correlations'],\n                'cached_contexts': len(self._correlation_contexts),\n                'timeout': self._timeout,\n                'cleanup_interval': self._cleanup_interval,\n                'correlation_stats': self.get_correlation_stats()\n            }\n        except Exception as e:\n            return {\n                'status': 'error',\n                'error': str(e)\n            }\n