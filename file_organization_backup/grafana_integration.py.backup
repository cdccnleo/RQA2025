"""
grafana_integration 模块

提供 grafana_integration 相关功能
"""


#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\nfrom datetime import datetime\nfrom typing import Dict, Any, List, Optional\nimport json\nimport logging\nimport os\n\nfrom dataclasses import dataclass, asdict\nimport requests\nimport yaml\n\nlogger = logging.getLogger(__name__)\n\n@dataclass\n\nclass GrafanaPanel:\n\n    """Grafana panel configuration"""\n    title: str\n    type: str  # graph, stat, table, heatmap\n    targets: List[Dict[str, Any]]\n    gridPos: Dict[str, int]  # x, y, w, h\n    options: Optional[Dict[str, Any]] = None\n\n@dataclass\n\nclass GrafanaDashboard:\n\n    """Grafana dashboard configuration"""\n    title: str\n    description: str\n    tags: List[str]\n    panels: List[GrafanaPanel]\n    variables: List[Dict[str, Any]]\n    refresh: str = "30s"\n    time: Optional[Dict[str, Any]] = None\n\nclass GrafanaIntegration:\n\n    """Grafana integration manager"""\n\n    def __init__(self, grafana_url: str, api_key: str, org_id: int = 1):\n\n        """\n        Initialize Grafana integration\n\n        Args:\n            grafana_url: Grafana server URL\n            api_key: Grafana API key\n            org_id: Organization ID\n        """\n        self.grafana_url = grafana_url.rstrip('/')\n        self.api_key = api_key\n        self.org_id = org_id\n        self.session = requests.Session()\n        self.session.headers.update({\n            'Authorization': f'Bearer {api_key}',\n            'Content - Type': 'application / json'\n        })\n\n        # Validate connection\n        self._test_connection()\n\n        logger.info(f"Grafana integration initialized for {grafana_url}")\n\n    def _test_connection(self) -> bool:\n    """文档字符串"""\n\n        """Test Grafana connection"""\n        try:\n            response = self.session.get(f"{self.grafana_url}/api / health")\n            if response.status_code == 200:\n                logger.info("Grafana connection successful")\n                return True\n            else:\n                logger.error(f"Grafana connection failed: {response.status_code}")\n                return False\n        except Exception as e:\n            logger.error(f"Grafana connection error: {e}")\n            return False\n\n    def create_health_monitoring_dashboard(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        Create health monitoring dashboard\n\n        Returns:\n            Dashboard configuration dictionary\n        """\n        dashboard = {\n            "dashboard": {\n                "title": "RQA2025 Health Monitoring",\n                "description": "Real - time monitoring of system health, performance metrics and alerts",\n                "tags": ["rqa2025", "health", "monitoring"],\n                "refresh": "30s",\n                "time": {\n                    "from": "now - 1h",\n                    "to": "now"\n                },\n                "panels": [\n                    {\n                        "title": "System Health Overview",\n                        "type": "stat",\n                        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},\n                        "targets": [\n                            {\n                                "expr": "rqa_health_status",\n                                "legendFormat": "{{service}} - {{check_type}}"\n                            }\n                        ],\n                        "options": {\n                            "colorMode": "value",\n                            "graphMode": "area",\n                            "justifyMode": "auto"\n                        }\n                    }\n                ],\n                "variables": [\n                    {\n                        "name": "service",\n                        "type": "query",\n                        "query": "label_values(rqa_health_status, service)",\n                        "label": "Service"\n                    },\n                    {\n                        "name": "check_type",\n                        "type": "query",\n                        "query": "label_values(rqa_health_status, check_type)",\n                        "label": "Check Type"\n                    }\n                ]\n            },\n            "folderId": 0,\n            "overwrite": True\n        }\n\n        return dashboard\n\n    def create_performance_dashboard(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """\n        Create performance monitoring dashboard\n\n        Returns:\n            Dashboard configuration dictionary\n        """\n        dashboard = {\n            "dashboard": {\n                "title": "RQA2025 Performance Monitoring",\n                "description": "System performance metrics and optimization suggestions",\n                "tags": ["rqa2025", "performance", "optimization"],\n                "refresh": "1m",\n                "panels": [\n                    {\n                        "title": "Key Performance Metrics Trend",\n                        "type": "graph",\n                        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},\n                        "targets": [\n                            {\n                                "expr": "rqa_performance_metric{metric=~\"response_time|cpu_usage|memory_usage\"}",\n                                "legendFormat": "{{metric}}"\n                            }\n                        ]\n                    }\n                ]\n            },\n            "folderId": 0,\n            "overwrite": True\n        }\n\n        return dashboard\n\n    def deploy_dashboard(self, dashboard_config: Dict[str, Any]) -> bool:\n    """文档字符串"""\n\n        """\n        Deploy dashboard to Grafana\n\n        Args:\n            dashboard_config: Dashboard configuration\n\n        Returns:\n            Whether deployment was successful\n        """\n        try:\n            url = f"{self.grafana_url}/api / dashboards / db"\n            response = self.session.post(url, json=dashboard_config)\n\n            if response.status_code == 200:\n                result = response.json()\n                logger.info(f"Dashboard deployed successfully: {result.get('url', '')}")\n                return True\n            else:\n                logger.error(f"Failed to deploy dashboard: {response.status_code} - {response.text}")\n                return False\n\n        except Exception as e:\n            logger.error(f"Dashboard deployment error: {e}")\n            return False\n\n    def deploy_all_dashboards(self) -> Dict[str, bool]:\n    """文档字符串"""\n\n        """\n        Deploy all predefined dashboards\n\n        Returns:\n            Deployment results dictionary\n        """\n        results = {}\n\n        # Deploy health monitoring dashboard\n        health_dashboard = self.create_health_monitoring_dashboard()\n        results['health_monitoring'] = self.deploy_dashboard(health_dashboard)\n\n        # Deploy performance monitoring dashboard\n        performance_dashboard = self.create_performance_dashboard()\n        results['performance_monitoring'] = self.deploy_dashboard(performance_dashboard)\n\n        return results\n\n    def export_dashboard_config(self, filepath: str) -> bool:\n    """文档字符串"""\n\n        """\n        Export dashboard configuration to file\n\n        Args:\n            filepath: Export file path\n\n        Returns:\n            Whether export was successful\n        """\n        try:\n            dashboards = {\n                'health_monitoring': self.create_health_monitoring_dashboard(),\n                'performance_monitoring': self.create_performance_dashboard()\n            }\n\n            with open(filepath, 'w', encoding='utf - 8') as f:\n                json.dump(dashboards, f, indent=2, ensure_ascii=False)\n\n            logger.info(f"Dashboard configurations exported to {filepath}")\n            return True\n\n        except Exception as e:\n            logger.error(f"Failed to export dashboard config: {e}")\n            return False\n\n    def get_dashboard_list(self) -> List[Dict[str, Any]]:\n    """文档字符串"""\n\n        """\n        Get existing dashboard list\n\n        Returns:\n            Dashboard list\n        """\n        try:\n            url = f"{self.grafana_url}/api / search"\n            response = self.session.get(url, params={'type': 'dash - db'})\n\n            if response.status_code == 200:\n                return response.json()\n            else:\n                logger.error(f"Failed to get dashboard list: {response.status_code}")\n                return []\n\n        except Exception as e:\n            logger.error(f"Error getting dashboard list: {e}")\n            return []\n\n    def delete_dashboard(self, dashboard_uid: str) -> bool:\n    """文档字符串"""\n\n        """\n        Delete dashboard\n\n        Args:\n            dashboard_uid: Dashboard UID\n\n        Returns:\n            Whether deletion was successful\n        """\n        try:\n            url = f"{self.grafana_url}/api / dashboards / uid/{dashboard_uid}"\n            response = self.session.delete(url)\n\n            if response.status_code == 200:\n                logger.info(f"Dashboard {dashboard_uid} deleted successfully")\n                return True\n            else:\n                logger.error(f"Failed to delete dashboard: {response.status_code}")\n                return False\n\n        except Exception as e:\n            logger.error(f"Error deleting dashboard: {e}")\n            return False\n\ndef get_grafana_integration(grafana_url: str, api_key: str, org_id: int = 1) -> GrafanaIntegration:\n    """文档字符串"""\n\n    """Get Grafana integration instance"""\n    return GrafanaIntegration(grafana_url, api_key, org_id)\n\ndef create_grafana_integration_from_config(config_path: str) -> Optional[GrafanaIntegration]:\n    """文档字符串"""\n\n    """Create Grafana integration from config file"""\n    try:\n        with open(config_path, 'r', encoding='utf - 8') as f:\n            config = yaml.safe_load(f)\n\n        grafana_config = config.get('grafana', {})\n        return GrafanaIntegration(\n            grafana_url=grafana_config['url'],\n            api_key=grafana_config['api_key'],\n            org_id=grafana_config.get('org_id', 1)\n        )\n    except Exception as e:\n        logger.error(f"Failed to create Grafana integration from config: {e}")\n        return None\n