"""\n边缘计算测试平台\n\n提供边缘节点的分布式测试支持，包括：\n- 边缘节点管理\n- 分布式测试执行\n- 边缘计算优化\n- 网络延迟模拟\n- 资源约束测试\n"""\n\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\nfrom enum import Enum\nfrom typing import Dict, List, Optional, Tuple, Any\nimport asyncio\nimport json\nimport logging\nimport socket\nimport subprocess\nimport threading\nimport time\n\nfrom dataclasses import dataclass, field\nfrom dataclasses_json import dataclass_json\nimport numpy as np\nimport psutil\nimport requests\n\n# 配置日志\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\nclass EdgeNodeType(Enum):\n\n    """\nedge_computing_test_platform - 配置管理\n\n职责说明：\n负责系统配置的统一管理、配置文件的读取、配置验证和配置分发\n\n核心职责：\n- 配置文件的读取和解析\n- 配置参数的验证\n- 配置的热重载\n- 配置的分发和同步\n- 环境变量管理\n- 配置加密和安全\n\n相关接口：\n- IConfigComponent\n- IConfigManager\n- IConfigValidator\n    边缘节点类型\n    IOT_DEVICE = "iot_device"           # IoT设备\n    EDGE_SERVER = "edge_server"         # 边缘服务器\n    MOBILE_DEVICE = "mobile_device"     # 移动设备\n    GATEWAY = "gateway"                 # 网关设备\n    FOG_NODE = "fog_node"              # 雾计算节点\n"""\n\nclass NodeStatus(Enum):\n\n    """节点状态"""\n    ONLINE = "online"                   # 在线\n    OFFLINE = "offline"                 # 离线\n    BUSY = "busy"                       # 忙碌\n    MAINTENANCE = "maintenance"         # 维护中\n    ERROR = "error"                     # 错误\n\nclass TestType(Enum):\n\n    """测试类型"""\n    LATENCY_TEST = "latency_test"       # 延迟测试\n    BANDWIDTH_TEST = "bandwidth_test"   # 带宽测试\n    COMPUTATION_TEST = "computation_test"  # 计算能力测试\n    MEMORY_TEST = "memory_test"         # 内存测试\n    STORAGE_TEST = "storage_test"       # 存储测试\n    NETWORK_TEST = "network_test"       # 网络测试\n\n@dataclass_json\n@dataclass\n\nclass EdgeNodeConfig:\n\n    """边缘节点配置"""\n    node_id: str\n    node_type: EdgeNodeType\n    host: str\n    port: int\n    username: str\n    password: str\n    capabilities: List[str] = field(default_factory=list)\n    resources: Dict[str, Any] = field(default_factory=dict)\n    location: Optional[str] = None\n    timezone: str = "UTC"\n\n@dataclass_json\n@dataclass\n\nclass EdgeNodeInfo:\n\n    """边缘节点信息"""\n    node_id: str\n    node_type: EdgeNodeType\n    status: NodeStatus\n    host: str\n    port: int\n    last_seen: float\n    capabilities: List[str]\n    resources: Dict[str, Any]\n    performance_metrics: Dict[str, float] = field(default_factory=dict)\n    network_metrics: Dict[str, float] = field(default_factory=dict)\n    location: Optional[str] = None\n    timezone: str = "UTC"\n\n@dataclass_json\n@dataclass\n\nclass TestResult:\n\n    """测试结果"""\n    test_id: str\n    node_id: str\n    test_type: TestType\n    status: str\n    start_time: float\n    end_time: float\n    duration: float\n    metrics: Dict[str, Any]\n    error_message: Optional[str] = None\n    raw_data: Optional[Dict[str, Any]] = None\n\n@dataclass_json\n@dataclass\n\nclass DistributedTestConfig:\n\n    """分布式测试配置"""\n    test_id: str\n    test_type: TestType\n    target_nodes: List[str]\n    test_parameters: Dict[str, Any]\n    execution_strategy: str = "parallel"  # parallel, sequential, adaptive\n    timeout: int = 300\n    retry_count: int = 3\n    data_size: int = 1024  # 测试数据大小(bytes)\n\nclass EdgeNodeManager:\n\n    """边缘节点管理器"""\n\n    def __init__(self):\n\n        self.nodes: Dict[str, EdgeNodeInfo] = {}\n        self._lock = threading.Lock()\n        self._health_check_thread = None\n        self._running = False\n\n    def add_node(self, config: EdgeNodeConfig) -> bool:\n    """文档字符串"""\n\n        """添加边缘节点"""\n        try:\n            with self._lock:\n                node_info = EdgeNodeInfo(\n                    node_id=config.node_id,\n                    node_type=config.node_type,\n                    status=NodeStatus.OFFLINE,\n                    host=config.host,\n                    port=config.port,\n                    last_seen=time.time(),\n                    capabilities=config.capabilities,\n                    resources=config.resources,\n                    location=config.location,\n                    timezone=config.timezone\n                )\n\n                self.nodes[config.node_id] = node_info\n                logger.info(f"添加边缘节点: {config.node_id}")\n                return True\n        except Exception as e:\n            logger.error(f"添加边缘节点失败: {e}")\n            return False\n\n    def remove_node(self, node_id: str) -> bool:\n    """文档字符串"""\n\n        """移除边缘节点"""\n        try:\n            with self._lock:\n                if node_id in self.nodes:\n                    del self.nodes[node_id]\n                    logger.info(f"移除边缘节点: {node_id}")\n                    return True\n                return False\n        except Exception as e:\n            logger.error(f"移除边缘节点失败: {e}")\n            return False\n\n    def get_node(self, node_id: str) -> Optional[EdgeNodeInfo]:\n    """文档字符串"""\n\n        """获取节点信息"""\n        with self._lock:\n            return self.nodes.get(node_id)\n\n    def get_all_nodes(self) -> List[EdgeNodeInfo]:\n    """文档字符串"""\n\n        """获取所有节点"""\n        with self._lock:\n            return list(self.nodes.values())\n\n    def get_available_nodes(self) -> List[EdgeNodeInfo]:\n    """文档字符串"""\n\n        """获取可用节点"""\n        with self._lock:\n            return [node for node in self.nodes.values()\n                    if node.status == NodeStatus.ONLINE]\n\n    def update_node_status(self, node_id: str, status: NodeStatus) -> bool:\n    """文档字符串"""\n\n        """更新节点状态"""\n        try:\n            with self._lock:\n                if node_id in self.nodes:\n                    self.nodes[node_id].status = status\n                    self.nodes[node_id].last_seen = time.time()\n                    return True\n                return False\n        except Exception as e:\n            logger.error(f"更新节点状态失败: {e}")\n            return False\n\n    def start_health_check(self, interval: int = 30):\n    """文档字符串"""\n\n        """启动健康检查"""\n        if self._running:\n            return\n\n        self._running = True\n        self._health_check_thread = threading.Thread(\n            target=self._health_check_loop,\n            args=(interval,),\n            daemon=True\n        )\n\n        self._health_check_thread.start()\n        logger.info("启动边缘节点健康检查")\n\n    def stop_health_check(self):\n    """文档字符串"""\n\n        """停止健康检查"""\n        self._running = False\n        if self._health_check_thread:\n            self._health_check_thread.join()\n        logger.info("停止边缘节点健康检查")\n\n    def _health_check_loop(self, interval: int):\n    """文档字符串"""\n\n        """健康检查循环"""\n        while self._running:\n            try:\n                self._check_all_nodes()\n                # 使用更短的睡眠间隔，以便更快响应停止信号\n                for _ in range(interval * 10):  # 将1秒分成10个0.1秒\n                    if not self._running:\n                        break\n                    time.sleep(0.1)\n            except Exception as e:\n                logger.error(f"健康检查错误: {e}")\n                if not self._running:\n                    break\n                time.sleep(0.1)\n\n    def _check_all_nodes(self):\n    """文档字符串"""\n\n        """检查所有节点"""\n        for node_id in list(self.nodes.keys()):\n            try:\n                self._check_single_node(node_id)\n            except Exception as e:\n                logger.error(f"检查节点 {node_id} 失败: {e}")\n\n    def _check_single_node(self, node_id: str):\n    """文档字符串"""\n\n        """检查单个节点"""\n        node = self.nodes[node_id]\n        try:\n            # 尝试连接节点\n            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n            sock.settimeout(5)\n            result = sock.connect_ex((node.host, node.port))\n            sock.close()\n\n            if result == 0:\n                self.update_node_status(node_id, NodeStatus.ONLINE)\n            else:\n                self.update_node_status(node_id, NodeStatus.OFFLINE)\n\n        except Exception:\n            self.update_node_status(node_id, NodeStatus.OFFLINE)\n\nclass EdgeTestExecutor:\n\n    """边缘测试执行器"""\n\n    def __init__(self, node_manager: EdgeNodeManager):\n\n        self.node_manager = node_manager\n        self._executor = ThreadPoolExecutor(max_workers=10)\n        self._test_results: Dict[str, TestResult] = {}\n        self._lock = threading.Lock()\n\n    def execute_test(self, config: DistributedTestConfig) -> List[TestResult]:\n    """文档字符串"""\n\n        """执行分布式测试"""\n        logger.info(f"开始执行分布式测试: {config.test_id}")\n\n        results = []\n        if config.execution_strategy == "parallel":\n            results = self._execute_parallel(config)\n        elif config.execution_strategy == "sequential":\n            results = self._execute_sequential(config)\n        elif config.execution_strategy == "adaptive":\n            results = self._execute_adaptive(config)\n\n        # 保存测试结果\n        with self._lock:\n            for result in results:\n                self._test_results[result.test_id] = result\n\n        return results\n\n    def _execute_parallel(self, config: DistributedTestConfig) -> List[TestResult]:\n    """文档字符串"""\n\n        """并行执行测试"""\n        futures = []\n        for node_id in config.target_nodes:\n            future = self._executor.submit(\n                self._execute_single_test,\n                node_id, config\n            )\n            futures.append(future)\n\n        results = []\n        for future in as_completed(futures, timeout=config.timeout):\n            try:\n                result = future.result()\n                results.append(result)\n            except Exception as e:\n                logger.error(f"并行测试执行失败: {e}")\n\n        return results\n\n    def _execute_sequential(self, config: DistributedTestConfig) -> List[TestResult]:\n    """文档字符串"""\n\n        """顺序执行测试"""\n        results = []\n        for node_id in config.target_nodes:\n            try:\n                result = self._execute_single_test(node_id, config)\n                results.append(result)\n            except Exception as e:\n                logger.error(f"顺序测试执行失败: {e}")\n\n        return results\n\n    def _execute_adaptive(self, config: DistributedTestConfig) -> List[TestResult]:\n    """文档字符串"""\n\n        """自适应执行测试"""\n        # 根据节点性能和网络状况动态调整执行策略\n        available_nodes = self.node_manager.get_available_nodes()\n        if len(available_nodes) < len(config.target_nodes) * 0.5:\n            # 如果可用节点少于50%，使用顺序执行\n            return self._execute_sequential(config)\n        else:\n            # 否则使用并行执行\n            return self._execute_parallel(config)\n\n    def _execute_single_test(self, node_id: str, config: DistributedTestConfig) -> TestResult:\n    """文档字符串"""\n\n        """执行单个测试"""\n        start_time = time.time()\n        test_id = f"{config.test_id}_{node_id}"\n\n        try:\n            if config.test_type == TestType.LATENCY_TEST:\n                metrics = self._run_latency_test(node_id, config)\n            elif config.test_type == TestType.BANDWIDTH_TEST:\n                metrics = self._run_bandwidth_test(node_id, config)\n            elif config.test_type == TestType.COMPUTATION_TEST:\n                metrics = self._run_computation_test(node_id, config)\n            elif config.test_type == TestType.MEMORY_TEST:\n                metrics = self._run_memory_test(node_id, config)\n            elif config.test_type == TestType.STORAGE_TEST:\n                metrics = self._run_storage_test(node_id, config)\n            elif config.test_type == TestType.NETWORK_TEST:\n                metrics = self._run_network_test(node_id, config)\n            else:\n                raise ValueError(f"不支持的测试类型: {config.test_type}")\n\n            end_time = time.time()\n            duration = end_time - start_time\n\n            return TestResult(\n                test_id=test_id,\n                node_id=node_id,\n                test_type=config.test_type,\n                status="passed",\n                start_time=start_time,\n                end_time=end_time,\n                duration=duration,\n                metrics=metrics\n            )\n\n        except Exception as e:\n            end_time = time.time()\n            duration = end_time - start_time\n\n            return TestResult(\n                test_id=test_id,\n                node_id=node_id,\n                test_type=config.test_type,\n                status="failed",\n                start_time=start_time,\n                end_time=end_time,\n                duration=duration,\n                metrics={},\n                error_message=str(e)\n            )\n\n    def _run_latency_test(self, node_id: str, config: DistributedTestConfig) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """运行延迟测试"""\n        node = self.node_manager.get_node(node_id)\n        if not node:\n            raise ValueError(f"节点不存在: {node_id}")\n\n        # 模拟网络延迟测试\n        latencies = []\n        for _ in range(10):\n            start = time.time()\n            # 模拟网络请求\n            time.sleep(0.01)  # 模拟网络延迟\n            end = time.time()\n            latencies.append((end - start) * 1000)  # 转换为毫秒\n\n        return {\n            "min_latency": min(latencies),\n            "max_latency": max(latencies),\n            "avg_latency": np.mean(latencies),\n            "std_latency": np.std(latencies),\n            "packet_loss": 0.0\n        }\n\n    def _run_bandwidth_test(self, node_id: str, config: DistributedTestConfig) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """运行带宽测试"""\n        data_size = config.data_size\n        start_time = time.time()\n\n        # 模拟数据传输\n        time.sleep(data_size / (1024 * 1024))  # 模拟基于数据大小的传输时间\n\n        end_time = time.time()\n        duration = end_time - start_time\n        bandwidth = data_size / duration / (1024 * 1024)  # MB / s\n\n        return {\n            "bandwidth_mbps": bandwidth,\n            "data_size_bytes": data_size,\n            "duration_seconds": duration,\n            "throughput": bandwidth\n        }\n\n    def _run_computation_test(self, node_id: str, config: DistributedTestConfig) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """运行计算能力测试"""\n        start_time = time.time()\n\n        # 执行计算密集型任务\n        result = 0\n        for i in range(1000000):\n            result += i * i\n\n        end_time = time.time()\n        duration = end_time - start_time\n\n        return {\n            "computation_time": duration,\n            "operations_per_second": 1000000 / duration,\n            "result": result\n        }\n\n    def _run_memory_test(self, node_id: str, config: DistributedTestConfig) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """运行内存测试"""\n        # 获取系统内存信息\n        memory = psutil.virtual_memory()\n\n        # 模拟内存压力测试\n        test_data = []\n        try:\n            for i in range(1000):\n                test_data.append([0] * 1000)\n                if i % 100 == 0:\n                    time.sleep(0.001)  # 避免阻塞\n        except MemoryError:\n            pass\n\n        return {\n            "total_memory_gb": memory.total / (1024 ** 3),\n            "available_memory_gb": memory.available / (1024 ** 3),\n            "memory_usage_percent": memory.percent,\n            "test_data_size": len(test_data)\n        }\n\n    def _run_storage_test(self, node_id: str, config: DistributedTestConfig) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """运行存储测试"""\n        # 获取磁盘信息\n        disk = psutil.disk_usage('/')\n\n        # 模拟文件I / O测试\n        start_time = time.time()\n        test_file = f"test_file_{node_id}.tmp"\n\n        try:\n            with open(test_file, 'w') as f:\n                f.write('0' * config.data_size)\n\n            with open(test_file, 'r') as f:\n                data = f.read()\n\n            import os\n            os.remove(test_file)\n\n            end_time = time.time()\n            duration = end_time - start_time\n\n            return {\n                "total_disk_gb": disk.total / (1024 ** 3),\n                "free_disk_gb": disk.free / (1024 ** 3),\n                "disk_usage_percent": (disk.used / disk.total) * 100,\n                "io_speed_mbps": (config.data_size * 2) / duration / (1024 * 1024)\n            }\n        except Exception as e:\n            return {\n                "error": str(e),\n                "total_disk_gb": disk.total / (1024 ** 3),\n                "free_disk_gb": disk.free / (1024 ** 3),\n                "disk_usage_percent": (disk.used / disk.total) * 100\n            }\n\n    def _run_network_test(self, node_id: str, config: DistributedTestConfig) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """运行网络测试"""\n        node = self.node_manager.get_node(node_id)\n        if not node:\n            raise ValueError(f"节点不存在: {node_id}")\n\n        # 模拟网络连接测试\n        start_time = time.time()\n\n        try:\n            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n            sock.settimeout(5)\n            result = sock.connect_ex((node.host, node.port))\n            sock.close()\n\n            end_time = time.time()\n            connection_time = end_time - start_time\n\n            return {\n                "connection_success": result == 0,\n                "connection_time": connection_time,\n                "host": node.host,\n                "port": node.port,\n                "status": "connected" if result == 0 else "failed"\n            }\n        except Exception as e:\n            return {\n                "connection_success": False,\n                "error": str(e),\n                "host": node.host,\n                "port": node.port,\n                "status": "error"\n            }\n\n    def get_test_result(self, test_id: str) -> Optional[TestResult]:\n    """文档字符串"""\n\n        """获取测试结果"""\n        with self._lock:\n            return self._test_results.get(test_id)\n\n    def get_all_results(self) -> List[TestResult]:\n    """文档字符串"""\n\n        """获取所有测试结果"""\n        with self._lock:\n            return list(self._test_results.values())\n\nclass EdgeComputingOptimizer:\n\n    """边缘计算优化器"""\n\n    def __init__(self, node_manager: EdgeNodeManager):\n\n        self.node_manager = node_manager\n        self._optimization_history: List[Dict[str, Any]] = []\n\n    def optimize_node_selection(self, test_type: TestType, \n    """文档字符串"""\n\n                              required_capabilities: List[str],\n                              min_nodes: int = 1):\n        """优化节点选择"""\n        available_nodes = self.node_manager.get_available_nodes()\n\n        # 过滤具备所需能力的节点\n        capable_nodes = [\n            node for node in available_nodes\n            if all(cap in node.capabilities for cap in required_capabilities)\n        ]\n\n        if len(capable_nodes) < min_nodes:\n            logger.warning(f"可用节点数量不足: 需要{min_nodes}个，可用{len(capable_nodes)}个")\n            return []\n\n        # 根据测试类型和节点性能进行排序\n        if test_type == TestType.LATENCY_TEST:\n            # 延迟测试优先选择延迟低的节点\n            sorted_nodes = sorted(capable_nodes,\n                                key=lambda x: x.performance_metrics.get('latency', float('inf')))\n        elif test_type == TestType.BANDWIDTH_TEST:\n            # 带宽测试优先选择带宽高的节点\n            sorted_nodes = sorted(capable_nodes,\n                                key=lambda x: -x.performance_metrics.get('bandwidth', 0))\n        elif test_type == TestType.COMPUTATION_TEST:\n            # 计算测试优先选择计算能力强的节点\n            sorted_nodes = sorted(capable_nodes,\n                                key=lambda x: -x.performance_metrics.get('cpu_power', 0))\n        else:\n            # 其他测试按综合性能排序\n            sorted_nodes = sorted(capable_nodes,\n                                key=lambda x: self._calculate_composite_score(x))\n\n        # 记录优化决策\n        optimization_record = {\n            "timestamp": time.time(),\n            "test_type": test_type.value,\n            "required_capabilities": required_capabilities,\n            "min_nodes": min_nodes,\n            "available_nodes": len(available_nodes),\n            "capable_nodes": len(capable_nodes),\n            "selected_nodes": [node.node_id for node in sorted_nodes[:min_nodes]],\n            "optimization_criteria": str(test_type)\n        }\n\n        self._optimization_history.append(optimization_record)\n\n        return [node.node_id for node in sorted_nodes[:min_nodes]]\n\n    def _calculate_composite_score(self, node: EdgeNodeInfo) -> float:\n    """文档字符串"""\n\n        """计算节点综合评分"""\n        score = 0.0\n\n        # CPU性能评分\n        cpu_score = node.performance_metrics.get('cpu_power', 0)\n        score += cpu_score * 0.3\n\n        # 内存评分\n        memory_score = node.performance_metrics.get('memory_score', 0)\n        score += memory_score * 0.2\n\n        # 网络评分\n        network_score = node.performance_metrics.get('network_score', 0)\n        score += network_score * 0.3\n\n        # 存储评分\n        storage_score = node.performance_metrics.get('storage_score', 0)\n        score += storage_score * 0.2\n\n        return score\n\n    def optimize_test_distribution(self, test_configs: List[DistributedTestConfig]) -> List[DistributedTestConfig]:\n    """文档字符串"""\n\n        """优化测试分布"""\n        optimized_configs = []\n\n        for config in test_configs:\n            # 根据测试类型优化节点选择\n            if config.test_type == TestType.LATENCY_TEST:\n                required_capabilities = ["low_latency", "network_stable"]\n            elif config.test_type == TestType.BANDWIDTH_TEST:\n                required_capabilities = ["high_bandwidth", "network_stable"]\n            elif config.test_type == TestType.COMPUTATION_TEST:\n                required_capabilities = ["high_computation", "memory_available"]\n            else:\n                required_capabilities = ["general_purpose"]\n\n            # 优化节点选择\n            optimal_nodes = self.optimize_node_selection(\n                config.test_type, required_capabilities, len(config.target_nodes))\n\n            if optimal_nodes:\n                # 创建优化后的配置\n                optimized_config = DistributedTestConfig(\n                    test_id=config.test_id,\n                    test_type=config.test_type,\n                    target_nodes=optimal_nodes,\n                    test_parameters=config.test_parameters,\n                    execution_strategy=config.execution_strategy,\n                    timeout=config.timeout,\n                    retry_count=config.retry_count,\n                    data_size=config.data_size\n                )\n\n                optimized_configs.append(optimized_config)\n            else:\n                # 如果无法优化，使用原始配置\n                optimized_configs.append(config)\n\n        return optimized_configs\n\n    def get_optimization_history(self) -> List[Dict[str, Any]]:\n    """文档字符串"""\n\n        """获取优化历史"""\n        return self._optimization_history.copy()\n\nclass EdgeComputingTestPlatform:\n\n    """边缘计算测试平台主类"""\n\n    def __init__(self):\n\n        self.node_manager = EdgeNodeManager()\n        self.test_executor = EdgeTestExecutor(self.node_manager)\n        self.optimizer = EdgeComputingOptimizer(self.node_manager)\n        self._running = False\n\n    def start_platform(self):\n    """文档字符串"""\n\n        """启动平台"""\n        if self._running:\n            return\n\n        self._running = True\n        self.node_manager.start_health_check()\n        logger.info("边缘计算测试平台已启动")\n\n    def stop_platform(self):\n    """文档字符串"""\n\n        """停止平台"""\n        if not self._running:\n            return\n\n        self._running = False\n        self.node_manager.stop_health_check()\n        logger.info("边缘计算测试平台已停止")\n\n    def add_edge_node(self, config: EdgeNodeConfig) -> bool:\n    """文档字符串"""\n\n        """添加边缘节点"""\n        return self.node_manager.add_node(config)\n\n    def remove_edge_node(self, node_id: str) -> bool:\n    """文档字符串"""\n\n        """移除边缘节点"""\n        return self.node_manager.remove_node(node_id)\n\n    def get_platform_status(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取平台状态"""\n        all_nodes = self.node_manager.get_all_nodes()\n        online_nodes = self.node_manager.get_available_nodes()\n\n        return {\n            "total_nodes": len(all_nodes),\n            "online_nodes": len(online_nodes),\n            "offline_nodes": len(all_nodes) - len(online_nodes),\n            "platform_status": "running" if self._running else "stopped",\n            "node_types": {\n                node_type.value: len([n for n in all_nodes if n.node_type == node_type])\n                for node_type in EdgeNodeType\n            }\n        }\n\n    def run_distributed_test(self, config: DistributedTestConfig) -> List[TestResult]:\n    """文档字符串"""\n\n        """运行分布式测试"""\n        # 优化测试配置\n        optimized_config = self.optimizer.optimize_test_distribution([config])[0]\n\n        # 执行测试\n        results = self.test_executor.execute_test(optimized_config)\n\n        return results\n\n    def run_optimized_tests(self, test_configs: List[DistributedTestConfig]) -> List[TestResult]:\n    """文档字符串"""\n\n        """运行优化的测试套件"""\n        # 优化测试分布\n        optimized_configs = self.optimizer.optimize_test_distribution(test_configs)\n\n        all_results = []\n        for config in optimized_configs:\n            results = self.test_executor.execute_test(config)\n            all_results.extend(results)\n\n        return all_results\n\n    def get_test_results(self, test_id: Optional[str] = None) -> List[TestResult]:\n    """文档字符串"""\n\n        """获取测试结果"""\n        if test_id:\n            result = self.test_executor.get_test_result(test_id)\n            return [result] if result else []\n        else:\n            return self.test_executor.get_all_results()\n\n    def get_optimization_history(self) -> List[Dict[str, Any]]:\n    """文档字符串"""\n\n        """获取优化历史"""\n        return self.optimizer.get_optimization_history()\n\n# 便捷函数\n\ndef create_edge_platform() -> EdgeComputingTestPlatform:\n    """文档字符串"""\n\n    """创建边缘计算测试平台"""\n    return EdgeComputingTestPlatform()\n\ndef add_test_edge_node(platform: EdgeComputingTestPlatform, \n    """文档字符串"""\n\n                      node_id: str,\n                      node_type: EdgeNodeType = EdgeNodeType.EDGE_SERVER,\n                      host: str = "localhost",\n                      port: int = 8080):\n    """添加测试边缘节点"""\n    config = EdgeNodeConfig(\n        node_id=node_id,\n        node_type=node_type,\n        host=host,\n        port=port,\n        username="test",\n        password="test",\n        capabilities=["general_purpose"],\n        resources={"cpu_cores": 4, "memory_gb": 8, "storage_gb": 100}\n    )\n    return platform.add_edge_node(config)\n\ndef run_edge_latency_test(platform: EdgeComputingTestPlatform, \n    """文档字符串"""\n\n                         node_ids: List[str]):\n    """运行边缘延迟测试"""\n    config = DistributedTestConfig(\n        test_id=f"latency_test_{int(time.time())}",\n        test_type=TestType.LATENCY_TEST,\n        target_nodes=node_ids,\n        test_parameters={"packet_count": 10, "timeout": 5},\n        execution_strategy="parallel"\n    )\n\n    return platform.run_distributed_test(config)\n