#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n基础设施层 - 异步异常处理机制\n处理asyncio相关的异常和错误恢复\n"""\n\nfrom enum import Enum\nfrom typing import Dict, Any, Optional, Callable, List, Union, Awaitable\nimport asyncio\nimport logging\nimport threading\nimport time\nimport weakref\n\nfrom dataclasses import dataclass, field\nimport traceback\n\nlogger = logging.getLogger(__name__)\n\nclass AsyncExceptionType(Enum):\n    """异步异常类型"""\n    TASK_CANCELLED = "task_cancelled"\n    TASK_TIMEOUT = "task_timeout"\n    TASK_EXCEPTION = "task_exception"\n    GATHER_EXCEPTION = "gather_exception"\n    QUEUE_FULL = "queue_full"\n    SEMAPHORE_TIMEOUT = "semaphore_timeout"\n    LOCK_TIMEOUT = "lock_timeout"\n\n@dataclass\nclass AsyncExceptionContext:\n    """异步异常上下文"""\n    exception: Exception\n    exception_type: AsyncExceptionType\n    task_name: str = ""\n    coroutine_name: str = ""\n    timestamp: float = None\n    task_id: str = ""\n    stack_trace: str = ""\n    metadata: Dict[str, Any] = field(default_factory=dict)\n\n    def __post_init__(self):\n        if self.timestamp is None:\n            self.timestamp = time.time()\n\n@dataclass\nclass AsyncRecoveryResult:\n    """异步恢复结果"""\n    recovered: bool\n    retry_count: int = 0\n    new_task: Optional[asyncio.Task] = None\n    recovery_time: float = 0.0\n    message: str = ""\n\nclass AsyncExceptionHandler:\n    """异步异常处理器"""\n\n    def __init__(self):\n        self.exception_handlers = {}\n        self.recovery_strategies = {}\n        self.task_monitor = {}\n        self.exception_stats = {}\n        self._shutdown_event = asyncio.Event()\n        self._monitoring_task: Optional[asyncio.Task] = None\n\n        # 初始化处理器\n        self._initialize_handlers()\n\n    def _initialize_handlers(self):\n        """初始化异常处理器"""\n        self.register_handler(AsyncExceptionType.TASK_CANCELLED, self._handle_task_cancelled)\n        self.register_handler(AsyncExceptionType.TASK_TIMEOUT, self._handle_task_timeout)\n        self.register_handler(AsyncExceptionType.TASK_EXCEPTION, self._handle_task_exception)\n        self.register_handler(AsyncExceptionType.GATHER_EXCEPTION, self._handle_gather_exception)\n        self.register_handler(AsyncExceptionType.QUEUE_FULL, self._handle_queue_full)\n        self.register_handler(AsyncExceptionType.SEMAPHORE_TIMEOUT, self._handle_semaphore_timeout)\n        self.register_handler(AsyncExceptionType.LOCK_TIMEOUT, self._handle_lock_timeout)\n\n    def register_handler(self, exception_type: AsyncExceptionType, handler: Callable):\n        """注册异常处理器"""\n        self.exception_handlers[exception_type] = handler\n\n    def register_recovery_strategy(self, exception_type: AsyncExceptionType, strategy: Callable):\n        """注册恢复策略"""\n        self.recovery_strategies[exception_type] = strategy\n\n    async def handle_async_exception(self, exception: Exception,\n                                   context: Dict[str, Any] = None) -> AsyncRecoveryResult:\n        """处理异步异常"""\n        context = context or {}\n\n        # 确定异常类型\n        exception_type = self._classify_async_exception(exception, context)\n\n        # 创建异常上下文\n        exc_context = AsyncExceptionContext(\n            exception=exception,\n            exception_type=exception_type,\n            task_name=context.get('task_name', ''),\n            coroutine_name=context.get('coroutine_name', ''),\n            task_id=context.get('task_id', ''),\n            stack_trace=traceback.format_exc(),\n            metadata=context\n        )\n\n        # 更新统计信息\n        self._update_exception_stats(exception_type)\n\n        # 获取处理器\n        handler = self.exception_handlers.get(exception_type)\n        if handler:\n            start_time = time.time()\n            try:\n                result = await handler(exc_context)\n                result.recovery_time = time.time() - start_time\n                return result\n            except Exception as e:\n                logger.error(f"异步异常处理器执行失败: {e}")\n                return AsyncRecoveryResult(\n                    recovered=False,\n                    message=f"处理器执行失败: {e}"\n                )\n\n        # 默认处理\n        return await self._default_async_exception_handling(exc_context)\n\n    def _classify_async_exception(self, exception: Exception,\n    """文档字符串"""\n                                context: Dict[str, Any]) -> AsyncExceptionType:\n        """分类异步异常"""\n        exc_type = type(exception).__name__\n\n        if exc_type == 'CancelledError':\n            return AsyncExceptionType.TASK_CANCELLED\n        elif exc_type == 'TimeoutError' or 'timeout' in str(exception).lower():\n            return AsyncExceptionType.TASK_TIMEOUT\n        elif exc_type == 'QueueFull':\n            return AsyncExceptionType.QUEUE_FULL\n        elif 'semaphore' in str(exception).lower():\n            return AsyncExceptionType.SEMAPHORE_TIMEOUT\n        elif 'lock' in str(exception).lower():\n            return AsyncExceptionType.LOCK_TIMEOUT\n        elif isinstance(exception, Exception):\n            # 检查是否是gather异常\n            if 'gather' in str(exception).lower():\n                return AsyncExceptionType.GATHER_EXCEPTION\n            else:\n                return AsyncExceptionType.TASK_EXCEPTION\n\n        return AsyncExceptionType.TASK_EXCEPTION\n\n    def _update_exception_stats(self, exception_type: AsyncExceptionType):\n        """更新异常统计"""\n        key = f"async_{exception_type.value}"\n        self.exception_stats[key] = self.exception_stats.get(key, 0) + 1\n\n    async def _handle_task_cancelled(self, context: AsyncExceptionContext) -> AsyncRecoveryResult:\n        """处理任务取消异常"""\n        logger.warning(f"异步任务被取消: {context.task_name}")\n\n        # 对于被取消的任务，通常不需要恢复\n        return AsyncRecoveryResult(\n            recovered=False,\n            message="任务已被取消，无需恢复"\n        )\n\n    async def _handle_task_timeout(self, context: AsyncExceptionContext) -> AsyncRecoveryResult:\n        """处理任务超时异常"""\n        logger.warning(f"异步任务超时: {context.task_name}")\n\n        # 尝试重试\n        return AsyncRecoveryResult(\n            recovered=True,\n            retry_count=1,\n            message="任务超时，正在重试"\n        )\n\n    async def _handle_task_exception(self, context: AsyncExceptionContext) -> AsyncRecoveryResult:\n        """处理任务执行异常"""\n        logger.error(f"异步任务执行异常: {context.task_name} - {context.exception}")\n\n        # 记录异常但不尝试恢复\n        return AsyncRecoveryResult(\n            recovered=False,\n            message=f"任务执行异常: {type(context.exception).__name__}"\n        )\n\n    async def _handle_gather_exception(self, context: AsyncExceptionContext) -> AsyncRecoveryResult:\n        """处理gather异常"""\n        logger.error(f"异步gather异常: {context.exception}")\n\n        # gather异常通常表示多个任务中有异常\n        return AsyncRecoveryResult(\n            recovered=False,\n            message="多个异步任务中出现异常"\n        )\n\n    async def _handle_queue_full(self, context: AsyncExceptionContext) -> AsyncRecoveryResult:\n        """处理队列满异常"""\n        logger.warning(f"异步队列已满: {context.task_name}")\n\n        # 等待一段时间后重试\n        await asyncio.sleep(0.1)\n\n        return AsyncRecoveryResult(\n            recovered=True,\n            retry_count=1,\n            message="队列已满，等待后重试"\n        )\n\n    async def _handle_semaphore_timeout(self, context: AsyncExceptionContext) -> AsyncRecoveryResult:\n        """处理信号量超时异常"""\n        logger.warning(f"信号量获取超时: {context.task_name}")\n\n        # 增加等待时间后重试\n        return AsyncRecoveryResult(\n            recovered=True,\n            retry_count=1,\n            message="信号量超时，增加等待时间后重试"\n        )\n\n    async def _handle_lock_timeout(self, context: AsyncExceptionContext) -> AsyncRecoveryResult:\n        """处理锁超时异常"""\n        logger.warning(f"锁获取超时: {context.task_name}")\n\n        # 锁超时通常需要等待\n        await asyncio.sleep(0.05)\n\n        return AsyncRecoveryResult(\n            recovered=True,\n            retry_count=1,\n            message="锁超时，等待后重试"\n        )\n\n    async def _default_async_exception_handling(self, context: AsyncExceptionContext) -> AsyncRecoveryResult:\n        """默认异步异常处理"""\n        logger.error(f"未处理的异步异常: {context.exception_type.value} - {context.exception}")\n\n        return AsyncRecoveryResult(\n            recovered=False,\n            message=f"异步异常: {type(context.exception).__name__}"\n        )\n\n    async def start_monitoring(self):\n        """启动异步任务监控"""\n        if self._monitoring_task is None:\n            self._monitoring_task = asyncio.create_task(self._monitoring_loop())\n\n    async def _monitoring_loop(self):\n        """监控循环"""\n        while not self._shutdown_event.is_set():\n            try:\n                await self._check_task_health()\n                await asyncio.sleep(30)  # 每30秒检查一次\n            except Exception as e:\n                logger.error(f"异步监控循环出错: {e}")\n                await asyncio.sleep(10)\n\n    async def _check_task_health(self):\n        """检查异步任务健康状态"""\n        # 这里可以添加任务健康检查逻辑\n        # 例如：检查长时间运行的任务、检查任务队列长度等\n\n        current_tasks = [task for task in asyncio.all_tasks() if not task.done()]\n        logger.debug(f"当前活跃异步任务数量: {len(current_tasks)}")\n\n        # 检查是否有异常的任务\n        for task in current_tasks:\n            if task.exception():\n                logger.error(f"发现异常异步任务: {task.get_name()} - {task.exception()}")\n\n    async def shutdown(self):\n        """关闭异步异常处理器"""\n        self._shutdown_event.set()\n\n        if self._monitoring_task and not self._monitoring_task.done():\n            self._monitoring_task.cancel()\n            try:\n                await self._monitoring_task\n            except asyncio.CancelledError:\n                pass\n\n    def get_exception_stats(self) -> Dict[str, int]:\n        """获取异常统计信息"""\n        return self.exception_stats.copy()\n\nclass AsyncTaskWrapper:\n    """异步任务包装器，提供异常处理"""\n\n    def __init__(self, exception_handler: Optional[AsyncExceptionHandler] = None):\n        self.exception_handler = exception_handler or AsyncExceptionHandler()\n        self.task_registry = {}\n\n    def wrap_coroutine(self, coro: Awaitable, task_name: str = "",\n    """文档字符串"""\n                      retry_count: int = 0, timeout: Optional[float] = None) -> Awaitable:\n        """包装协程函数，添加异常处理"""\n        async def wrapper(*args, **kwargs):\n            task_id = f"{task_name}_{id(coro)}_{time.time()}"\n\n            try:\n                # 设置超时\n                if timeout:\n                    return await asyncio.wait_for(\n                        self._execute_with_retry(coro, args, kwargs, retry_count, task_id),\n                        timeout=timeout\n                    )\n                else:\n                    return await self._execute_with_retry(coro, args, kwargs, retry_count, task_id)\n\n            except Exception as e:\n                # 处理异常\n                result = await self.exception_handler.handle_async_exception(\n                    e,\n                    {\n                        'task_name': task_name,\n                        'task_id': task_id,\n                        'coroutine_name': coro.__name__ if hasattr(coro, '__name__') else str(coro),\n                        'args': args,\n                        'kwargs': kwargs\n                    }\n                )\n\n                if result.recovered and result.retry_count < retry_count:\n                    # 如果可以恢复且未达到最大重试次数，重新执行\n                    logger.info(f"重试异步任务: {task_name} (尝试 {result.retry_count + 1}/{retry_count})")\n                    return await wrapper(*args, **kwargs)\n                else:\n                    # 无法恢复，重新抛出异常\n                    raise e\n\n        return wrapper\n\n    async def _execute_with_retry(self, coro: Awaitable, args: tuple,\n                                kwargs: dict, max_retries: int,\n                                task_id: str) -> Any:\n        """带重试的协程执行"""\n        last_exception = None\n\n        for attempt in range(max_retries + 1):\n            try:\n                if asyncio.iscoroutine(coro):\n                    return await coro\n                else:\n                    # 如果是协程函数，调用它\n                    return await coro(*args, **kwargs)\n            except Exception as e:\n                last_exception = e\n\n                if attempt < max_retries:\n                    # 计算退避时间\n                    backoff_time = min(0.1 * (2 ** attempt), 10)  # 最大10秒\n                    logger.warning(f"异步任务失败，重试中: {task_id} (尝试 {attempt + 1}/{max_retries + 1})")\n                    await asyncio.sleep(backoff_time)\n                else:\n                    logger.error(f"异步任务失败，已达到最大重试次数: {task_id}")\n                    raise last_exception\n\n        raise last_exception\n\n    async def create_task(self, coro: Awaitable, task_name: str = "",\n                         **kwargs) -> asyncio.Task:\n        """创建带异常处理的异步任务"""\n        wrapped_coro = self.wrap_coroutine(coro, task_name, **kwargs)\n        task = asyncio.create_task(wrapped_coro)\n\n        if task_name:\n            task.set_name(task_name)\n\n        # 注册任务\n        task_id = f"{task_name}_{id(task)}"\n        self.task_registry[task_id] = weakref.ref(task)\n\n        return task\n\n    async def gather_with_exception_handling(self, *coros: Awaitable,\n                                           task_name: str = "gather") -> List[Any]:\n        """带异常处理的gather操作"""\n        try:\n            return await asyncio.gather(*coros)\n        except Exception as e:\n            # 处理gather异常\n            await self.exception_handler.handle_async_exception(\n                e,\n                {\n                    'task_name': task_name,\n                    'coroutine_count': len(coros),\n                    'gather_operation': True\n                }\n            )\n            raise e\n\n# 装饰器\ndef async_exception_handler(retry_count: int = 0, timeout: Optional[float] = None):\n    """异步异常处理装饰器"""\n    def decorator(func):\n    """文档字符串"""\n        async def wrapper(*args, **kwargs):\n            handler = AsyncExceptionHandler()\n\n            try:\n                if timeout:\n                    return await asyncio.wait_for(func(*args, **kwargs), timeout=timeout)\n                else:\n                    return await func(*args, **kwargs)\n            except Exception as e:\n                result = await handler.handle_async_exception(\n                    e,\n                    {\n                        'function': func.__name__,\n                        'retry_count': retry_count,\n                        'timeout': timeout\n                    }\n                )\n\n                if result.recovered and retry_count > 0:\n                    # 简单的重试逻辑\n                    for i in range(retry_count):\n                        try:\n                            await asyncio.sleep(0.1 * (i + 1))\n                            return await func(*args, **kwargs)\n                        except Exception:\n                            continue\n\n                raise e\n\n        return wrapper\n    return decorator\n