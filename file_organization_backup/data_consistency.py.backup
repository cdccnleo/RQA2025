"""\n基础设施层 - 日志系统组件\n\ndata_consistency 模块\n\n日志系统相关的文件\n提供日志系统相关的功能实现。\n"""\n\n#!/usr / bin / env python\nfrom datetime import datetime, timedelta\nfrom enum import Enum\nfrom typing import Dict, List, Optional, Any, Tuple\nimport hashlib\nimport json\nimport logging\nimport threading\nimport time\n\nfrom dataclasses import dataclass\n\n# -*- coding: utf-8 -*-\n\n"""\n数据一致性保障机制\n实现InfluxDB + arquet混合存储的数据一致性保障\n"""\n\nlogger = logging.getLogger(__name__)\n\nclass ConsistencyLevel(Enum):\n\n    """数据一致性级别"""\n    EVENTUAL = "eventual"      # 最终一致性\n    STRONG = "strong"          # 强一致性\n    LINEARIZABLE = "linearizable"  # 线性一致性\n\nclass SyncStatus(Enum):\n\n    """同步状态"""\n    PENDING = "pending"\n    IN_PROGRESS = "in_progress"\n    COMPLETED = "completed"\n    FAILED = "failed"\n    ROLLBACK = "rollback"\n\n@dataclass\n\nclass DataSyncTask:\n\n    """数据同步任务"""\n    task_id: str\n    source: str\n    target: str\n    data_type: str\n    start_time: datetime\n    end_time: datetime\n    status: SyncStatus\n    retry_count: int = 0\n    max_retries: int = 3\n    error_message: Optional[str] = None\n    checksum: Optional[str] = None\n\nclass DataConsistencyManager:\n\n    """数据一致性管理器"""\n\n    def __init__(self, config: Dict[str, Any]):\n\n        """\n        初始化数据一致性管理器\n\n        Args:\n            config: 配置字典\n        """\n        self.config = config\n        self.consistency_level = ConsistencyLevel(config.get("consistency_level", "strong"))\n        self.sync_interval = config.get("sync_interval", 60)  # 秒\n        self.retry_delay = config.get("retry_delay", 5)  # 秒\n        self.max_retries = config.get("max_retries", 3)\n        self.checksum_algorithm = config.get("checksum_algorithm", "md5")\n\n        # 同步任务队列\n        self.sync_queue: List[DataSyncTask] = []\n        self.sync_lock = threading.RLock()\n\n        # 一致性检查结果缓存\n        self.consistency_cache: Dict[str, Dict] = {}\n        self.cache_ttl = config.get("cache_ttl", 300)  # 5分钟\n\n        # 启动同步监控线程\n        self._running = True\n        self._monitor_thread = threading.Thread(\n            target=self._monitor_sync_tasks,\n            daemon=True,\n            name="DataConsistencyMonitor"\n        )\n\n        self._monitor_thread.start()\n\n        logger.info("数据一致性管理器已启动")\n\n    def schedule_sync(self, source: str, target: str, data_type: str,\n    """文档字符串"""\n\n                      start_time: datetime, end_time: datetime):\n        """\n        调度数据同步任务\n\n        Args:\n            source: 源存储\n            target: 目标存储\n            data_type: 数据类型\n            start_time: 开始时间\n            end_time: 结束时间\n\n        Returns:\n            str: 任务ID\n        """\n        task_id = f"sync_{int(time.time())}_{hash(f'{source}_{target}_{data_type}')}"\n\n        task = DataSyncTask(\n            task_id=task_id,\n            source=source,\n            target=target,\n            data_type=data_type,\n            start_time=start_time,\n            end_time=end_time,\n            status=SyncStatus.PENDING\n        )\n\n        with self.sync_lock:\n            self.sync_queue.append(task)\n\n        logger.info(f"已调度同步任务: {task_id}")\n        return task_id\n\n    def check_consistency(self, storage_a: str, storage_b: str,\n    """文档字符串"""\n\n                          data_type: str, time_range: Tuple[datetime, datetime]):\n        """\n        检查两个存储之间的数据一致性\n\n        Args:\n            storage_a: 存储A\n            storage_b: 存储B\n            data_type: 数据类型\n            time_range: 时间范围\n\n        Returns:\n            Dict: 一致性检查结果\n        """\n        cache_key = f"{storage_a}_{storage_b}_{data_type}_{time_range[0]}_{time_range[1]}"\n\n        # 检查缓存\n        if cache_key in self.consistency_cache:\n            cached_result = self.consistency_cache[cache_key]\n            if time.time() - cached_result["timestamp"] < self.cache_ttl:\n                return cached_result["result"]\n\n        try:\n            # 获取两个存储的数据\n            data_a = self._get_data_from_storage(storage_a, data_type, time_range)\n            data_b = self._get_data_from_storage(storage_b, data_type, time_range)\n\n            # 计算校验和\n            checksum_a = self._calculate_checksum(data_a)\n            checksum_b = self._calculate_checksum(data_b)\n\n            # 比较数据\n            is_consistent = checksum_a == checksum_b\n            differences = self._find_differences(data_a, data_b)\n\n            result = {\n                "consistent": is_consistent,\n                "checksum_a": checksum_a,\n                "checksum_b": checksum_b,\n                "differences": differences,\n                "data_count_a": len(data_a) if data_a is not None else 0,\n                "data_count_b": len(data_b) if data_b is not None else 0,\n                "timestamp": time.time()\n            }\n\n            # 缓存结果\n            self.consistency_cache[cache_key] = {\n                "result": result,\n                "timestamp": time.time()\n            }\n\n            logger.info(f"一致性检查完成: {storage_a} vs {storage_b}, 一致: {is_consistent}")\n            return result\n\n        except Exception as e:\n            logger.error(f"一致性检查失败: {e}")\n            return {\n                "consistent": False,\n                "error": str(e),\n                "timestamp": time.time()\n            }\n\n    def rollback_data(self, storage: str, data_type: str,\n    """文档字符串"""\n\n                      target_time: datetime, backup_storage: str):\n        """\n        回滚数据到指定时间点\n\n        Args:\n            storage: 目标存储\n            data_type: 数据类型\n            target_time: 目标时间点\n            backup_storage: 备份存储\n\n        Returns:\n            bool: 回滚是否成功\n        """\n        try:\n            logger.info(f"开始回滚数据: {storage} -> {target_time}")\n\n            # 1. 创建当前状态快照\n            snapshot = self._create_snapshot(storage, data_type)\n\n            # 2. 从备份存储获取目标时间点的数据\n            backup_data = self._get_data_from_storage(\n                backup_storage, data_type,\n                (target_time - timedelta(hours=1), target_time + timedelta(hours=1))\n            )\n\n            if not backup_data:\n                logger.error(f"备份存储中未找到目标时间点的数据: {target_time}")\n                return False\n\n            # 3. 应用回滚\n            success = self._apply_rollback(storage, data_type, backup_data, target_time)\n\n            if success:\n                logger.info(f"数据回滚成功: {storage} -> {target_time}")\n                # 记录回滚操作\n                self._record_rollback_operation(storage, data_type, target_time, snapshot)\n            else:\n                logger.error(f"数据回滚失败: {storage} -> {target_time}")\n\n            return success\n\n        except Exception as e:\n            logger.error(f"回滚操作异常: {e}")\n            return False\n\n    def handle_archive_failure(self, task_id: str, error: Exception) -> bool:\n    """文档字符串"""\n\n        """\n        处理归档失败\n\n        Args:\n            task_id: 任务ID\n            error: 错误信息\n\n        Returns:\n            bool: 处理是否成功\n        """\n        try:\n            # 查找对应的同步任务\n            task = self._find_task_by_id(task_id)\n            if not task:\n                logger.error(f"未找到任务: {task_id}")\n                return False\n\n            # 更新任务状态\n            task.status = SyncStatus.FAILED\n            task.error_message = str(error)\n\n            # 根据错误类型选择处理策略\n            if self._is_retryable_error(error):\n                if task.retry_count < task.max_retries:\n                    task.retry_count += 1\n                    task.status = SyncStatus.PENDING\n                    logger.info(f"任务 {task_id} 将重试 (第 {task.retry_count} 次)")\n                    return True\n                else:\n                    logger.error(f"任务 {task_id} 重试次数已达上限")\n                    return self._handle_permanent_failure(task)\n            else:\n                logger.error(f"任务 {task_id} 遇到不可重试错误: {error}")\n                return self._handle_permanent_failure(task)\n\n        except Exception as e:\n            logger.error(f"处理归档失败时发生异常: {e}")\n            return False\n\n    def get_sync_status(self, task_id: str) -> Optional[Dict[str, Any]]:\n    """文档字符串"""\n\n        """\n        获取同步任务状态\n\n        Args:\n            task_id: 任务ID\n\n        Returns:\n            Dict: 任务状态信息\n        """\n        task = self._find_task_by_id(task_id)\n        if not task:\n            return None\n\n        return {\n            "task_id": task.task_id,\n            "source": task.source,\n            "target": task.target,\n            "data_type": task.data_type,\n            "status": task.status.value,\n            "start_time": task.start_time.isoformat(),\n            "end_time": task.end_time.isoformat(),\n            "retry_count": task.retry_count,\n            "error_message": task.error_message,\n            "checksum": task.checksum\n        }\n\n    def _monitor_sync_tasks(self):\n    """文档字符串"""\n\n        """监控同步任务的后台线程"""\n        while self._running:\n            try:\n                with self.sync_lock:\n                    pending_tasks = [task for task in self.sync_queue\n                                     if task.status == SyncStatus.PENDING]\n\n                for task in pending_tasks:\n                    self._execute_sync_task(task)\n\n                time.sleep(self.sync_interval)\n\n            except Exception as e:\n                logger.error(f"同步监控线程异常: {e}")\n                time.sleep(self.retry_delay)\n\n    def _execute_sync_task(self, task: DataSyncTask):\n    """文档字符串"""\n\n        """执行同步任务"""\n        try:\n            task.status = SyncStatus.IN_PROGRESS\n\n            # 执行数据同步\n            success = self._sync_data(task.source, task.target, task.data_type,\n                                      task.start_time, task.end_time)\n\n            if success:\n                task.status = SyncStatus.COMPLETED\n                task.checksum = self._calculate_checksum(\n                    self._get_data_from_storage(task.target, task.data_type,\n                                                (task.start_time, task.end_time))\n                )\n\n                logger.info(f"同步任务完成: {task.task_id}")\n            else:\n                task.status = SyncStatus.FAILED\n                task.error_message = "同步执行失败"\n                logger.error(f"同步任务失败: {task.task_id}")\n\n        except Exception as e:\n            task.status = SyncStatus.FAILED\n            task.error_message = str(e)\n            logger.error(f"同步任务异常: {task.task_id}, 错误: {e}")\n\n    def _sync_data(self, source: str, target: str, data_type: str,\n    """文档字符串"""\n\n                   start_time: datetime, end_time: datetime):\n        """执行数据同步"""\n        try:\n            # 从源存储获取数据\n            source_data = self._get_data_from_storage(source, data_type, (start_time, end_time))\n\n            if not source_data:\n                logger.warning(f"源存储中无数据: {source}")\n                return True  # 无数据也算成功\n\n            # 写入目标存储\n            success = self._write_data_to_storage(target, data_type, source_data)\n\n            if success:\n                # 验证同步结果\n                target_data = self._get_data_from_storage(target, data_type, (start_time, end_time))\n                source_checksum = self._calculate_checksum(source_data)\n                target_checksum = self._calculate_checksum(target_data)\n\n                return source_checksum == target_checksum\n\n            return False\n\n        except Exception as e:\n            logger.error(f"数据同步异常: {e}")\n            return False\n\n    def _get_data_from_storage(self, storage: str, data_type: str,\n    """文档字符串"""\n\n                               time_range: Tuple[datetime, datetime]):\n        """从存储获取数据"""\n        # 这里应该根据实际的存储接口实现\n        # 简化实现，实际项目中需要对接具体的存储系统\n        logger.debug(f"从存储 {storage} 获取 {data_type} 数据: {time_range}")\n        return []\n\n    def _write_data_to_storage(self, storage: str, data_type: str,\n    """文档字符串"""\n\n                               data: List[Dict]):\n        """写入数据到存储"""\n        # 这里应该根据实际的存储接口实现\n        # 简化实现，实际项目中需要对接具体的存储系统\n        logger.debug(f"写入 {len(data)} 条数据到存储 {storage}")\n        return True\n\n    def _calculate_checksum(self, data: Optional[List[Dict]]) -> str:\n    """文档字符串"""\n\n        """计算数据校验和"""\n        if not data:\n            return hashlib.md5(b"").hexdigest()\n\n        # 将数据序列化为JSON字符串\n        data_str = json.dumps(data, sort_keys=True, default=str)\n        return hashlib.md5(data_str.encode()).hexdigest()\n\n    def _find_differences(self, data_a: Optional[List[Dict]],\n    """文档字符串"""\n\n                          data_b: Optional[List[Dict]]):\n        """查找数据差异"""\n        differences = []\n\n        if data_a is None and data_b is None:\n            return differences\n        elif data_a is None:\n            differences.append({"type": "missing_in_a", "count": len(data_b)})\n            return differences\n        elif data_b is None:\n            differences.append({"type": "missing_in_b", "count": len(data_a)})\n            return differences\n\n        # 简化的差异比较，实际项目中需要更复杂的比较逻辑\n        if len(data_a) != len(data_b):\n            differences.append({\n                "type": "count_mismatch",\n                "count_a": len(data_a),\n                "count_b": len(data_b)\n            })\n\n        return differences\n\n    def _create_snapshot(self, storage: str, data_type: str) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """创建数据快照"""\n        snapshot = {\n            "storage": storage,\n            "data_type": data_type,\n            "timestamp": datetime.now().isoformat(),\n            "checksum": self._calculate_checksum(\n                self._get_data_from_storage(storage, data_type,\n                                            (datetime.now() - timedelta(hours=1), datetime.now()))\n            )\n        }\n\n        return snapshot\n\n    def _apply_rollback(self, storage: str, data_type: str,\n    """文档字符串"""\n\n                        backup_data: List[Dict], target_time: datetime):\n        """应用回滚操作"""\n        try:\n            # 这里应该实现具体的回滚逻辑\n            # 简化实现，实际项目中需要对接具体的存储系统\n            logger.info(f"应用回滚到 {storage}: {target_time}")\n            return True\n        except Exception as e:\n            logger.error(f"应用回滚失败: {e}")\n            return False\n\n    def _record_rollback_operation(self, storage: str, data_type: str,\n    """文档字符串"""\n\n                                   target_time: datetime, snapshot: Dict[str, Any]):\n        """记录回滚操作"""\n        rollback_record = {\n            "storage": storage,\n            "data_type": data_type,\n            "target_time": target_time.isoformat(),\n            "rollback_time": datetime.now().isoformat(),\n            "snapshot": snapshot\n        }\n        logger.info(f"回滚操作已记录: {rollback_record}")\n\n    def _find_task_by_id(self, task_id: str) -> Optional[DataSyncTask]:\n    """文档字符串"""\n\n        """根据任务ID查找任务"""\n        with self.sync_lock:\n            for task in self.sync_queue:\n                if task.task_id == task_id:\n                    return task\n            return None\n\n    def _is_retryable_error(self, error: Exception) -> bool:\n    """文档字符串"""\n\n        """判断错误是否可重试"""\n        retryable_errors = (\n            ConnectionError,\n            TimeoutError,\n            OSError\n        )\n\n        return isinstance(error, retryable_errors)\n\n    def _handle_permanent_failure(self, task: DataSyncTask) -> bool:\n    """文档字符串"""\n\n        """处理永久性失败"""\n        try:\n            logger.error(f"任务 {task.task_id} 遇到永久性失败: {task.error_message}")\n\n            # 发送告警\n            self._send_alert(f"数据同步永久失败: {task.task_id}")\n\n            # 记录失败日志\n            self._log_failure(task)\n\n            return False\n\n        except Exception as e:\n            logger.error(f"处理永久性失败时发生异常: {e}")\n            return False\n\n    def _send_alert(self, message: str):\n    """文档字符串"""\n\n        """发送告警"""\n        # 这里应该实现具体的告警逻辑\n        logger.critical(f"告警: {message}")\n\n    def _log_failure(self, task: DataSyncTask):\n    """文档字符串"""\n\n        """记录失败日志"""\n        failure_log = {\n            "task_id": task.task_id,\n            "source": task.source,\n            "target": task.target,\n            "data_type": task.data_type,\n            "error": task.error_message,\n            "timestamp": datetime.now().isoformat()\n        }\n\n        logger.error(f"同步失败记录: {failure_log}")\n\n    def shutdown(self):\n    """文档字符串"""\n\n        """关闭一致性管理器"""\n        self._running = False\n        if self._monitor_thread:\n            self._monitor_thread.join(timeout=5)\n        logger.info("数据一致性管理器已关闭")\n