"""\n日志关联查询接口\n支持采样日志与全量日志的关联机制\n"""\n\nfrom collections import defaultdict\nfrom datetime import datetime, timedelta\nfrom typing import Dict, Any, Optional, List, Set, Tuple\nimport json\nimport threading\nimport time\nimport uuid\n\nfrom dataclasses import dataclass, field\n\nfrom .log_sampler_plugin import LogEntry, BusinessLogType\n\n@dataclass\n\nclass CorrelationQuery:\n\n    """\n    log_correlation_plugin - 日志系统\n\n    职责说明：\n    负责系统日志记录、日志格式化、日志存储和日志分析\n\n    核心职责：\n    - 日志记录和格式化\n    - 日志级别管理\n    - 日志存储和轮转\n    - 日志分析和监控\n    - 日志搜索和过滤\n    - 日志性能优化\n\n    相关接口：\n    - ILoggingComponent\n    - ILogger\n    - ILogHandler\n    """ """关联查询条件"""\n    trace_id: Optional[str] = None\n    correlation_id: Optional[str] = None\n    business_type: Optional[BusinessLogType] = None\n    time_range: Optional[Tuple[datetime, datetime]] = None\n    log_level: Optional[str] = None\n    keywords: Optional[List[str]] = None\n\n@dataclass\n\nclass CorrelationResult:\n\n    """关联查询结果"""\n    query_id: str\n    timestamp: datetime = field(default_factory=datetime.now)\n    sampled_logs: List[LogEntry] = field(default_factory=list)\n    related_logs: List[LogEntry] = field(default_factory=list)\n    correlation_context: Dict[str, Any] = field(default_factory=dict)\n    trace_context: Dict[str, Any] = field(default_factory=dict)\n    statistics: Dict[str, Any] = field(default_factory=dict)\n\n    @property\n    def status(self) -> str:\n        """获取查询状态"""\n        if 'error' in self.statistics:\n            return 'error'\n        return 'success'\n\n    @property\n    def total_count(self) -> int:\n        """获取总数"""\n        return self.statistics.get('total_count', 0)\n\n    @property\n    def logs(self) -> List[LogEntry]:\n        """获取所有日志（sampled + related）"""\n        return self.sampled_logs + self.related_logs\n\nclass LogCorrelationPlugin:\n\n    """日志关联查询器"""\n\n    def __init__(self,\n\n                 max_query_history: int = 1000,\n                 query_timeout: int = 300):\n        """\n        初始化日志关联查询器\n\n        Args:\n            max_query_history: 最大查询历史数量\n            query_timeout: 查询超时时间(秒)\n        """\n        self.max_query_history = max_query_history\n        self.query_timeout = query_timeout\n\n        # 查询历史\n        self._query_history: Dict[str, CorrelationResult] = {}\n        self._query_timestamps: Dict[str, datetime] = {}\n\n        # 日志索引\n        self._trace_index: Dict[str, Set[str]] = defaultdict(set)\n        self._correlation_index: Dict[str, Set[str]] = defaultdict(set)\n        self._business_type_index: Dict[BusinessLogType, Set[str]] = defaultdict(set)\n        self._time_index: Dict[str, List[Tuple[datetime, str]]] = defaultdict(list)\n\n        # 线程安全\n        self._lock = threading.RLock()\n\n        # 清理定时器\n        self._cleanup_thread = None\n        self._start_cleanup_timer()\n\n    def correlate_logs(self, query: CorrelationQuery) -> CorrelationResult:\n    """文档字符串"""\n\n        """\n        关联查询日志\n        :param query: 查询条件\n        :return: 查询结果\n        """\n        with self._lock:\n            query_id = str(uuid.uuid4())\n            start_time = time.time()\n\n            try:\n                # 基于查询条件找到相关的日志ID\n                log_ids = self._find_matching_logs(query)\n\n                # 获取实际的日志条目（这里简化实现）\n                logs = []\n                for log_id in log_ids:\n                    # 简化实现：创建模拟日志条目\n                    log_entry = LogEntry(\n                        timestamp=datetime.now(),\n                        level="INFO",\n                        logger="test_logger",\n                        message=f"Log entry {log_id}",\n                        trace_id=query.trace_id if query.trace_id else "default_trace",\n                        correlation_id=query.correlation_id if query.correlation_id else "default_corr",\n                        business_type=query.business_type or BusinessLogType.TRADE\n                    )\n                    logs.append(log_entry)\n\n                result = CorrelationResult(\n                    query_id=query_id,\n                    timestamp=datetime.now(),\n                    sampled_logs=logs,  # 使用实际的字段名\n                    related_logs=[],\n                    correlation_context={},\n                    trace_context={},\n                    statistics={\n                        'total_count': len(logs),\n                        'execution_time': time.time() - start_time,\n                        'cache_hit': False\n                    }\n                )\n\n                # 保存查询历史\n                self._query_history[query_id] = result\n                self._query_timestamps[query_id] = datetime.now()\n\n                return result\n\n            except Exception as e:\n                return CorrelationResult(\n                    query_id=query_id,\n                    timestamp=datetime.now(),\n                    sampled_logs=[],\n                    related_logs=[],\n                    correlation_context={},\n                    trace_context={},\n                    statistics={\n                        'total_count': 0,\n                        'execution_time': time.time() - start_time,\n                        'cache_hit': False,\n                        'error': str(e)\n                    }\n                )\n\n    def _find_matching_logs(self, query: CorrelationQuery) -> List[str]:\n    """文档字符串"""\n\n        """\n        基于查询条件找到匹配的日志ID\n        :param query: 查询条件\n        :return: 匹配的日志ID列表\n        """\n        # 简化实现：返回模拟的日志ID\n        if query.trace_id:\n            return ["log_1", "log_2"]\n        elif query.correlation_id:\n            return ["log_3", "log_4"]\n        elif query.business_type:\n            return ["log_5", "log_6"]\n        else:\n            return ["log_default"]\n\n    def _start_cleanup_timer(self):\n    """文档字符串"""\n\n        """启动清理定时器"""\n        self._cleanup_thread = threading.Thread(target=self._cleanup_worker, daemon=True)\n        self._cleanup_thread.start()\n\n    def _cleanup_worker(self):\n    """文档字符串"""\n\n        """清理工作线程"""\n        while True:\n            try:\n                time.sleep(60)  # 每分钟清理一次\n                self._cleanup_expired_queries()\n            except Exception as e:\n                print(f"清理定时器异常: {e}")\n\n    def _cleanup_expired_queries(self):\n    """文档字符串"""\n\n        """清理过期的查询历史"""\n        now = datetime.now()\n        expired_queries = [\n            query_id for query_id, timestamp in self._query_timestamps.items()\n            if now - timestamp > timedelta(seconds=self.query_timeout)\n        ]\n\n        with self._lock:\n            for query_id in expired_queries:\n                if query_id in self._query_history:\n                    del self._query_history[query_id]\n                if query_id in self._query_timestamps:\n                    del self._query_timestamps[query_id]\n\n    def index_log_entry(self, log_entry: LogEntry):\n    """文档字符串"""\n\n        """索引日志条目"""\n        with self._lock:\n            log_id = str(uuid.uuid4())\n\n            # 跟踪ID索引\n            if log_entry.trace_id:\n                self._trace_index[log_entry.trace_id].add(log_id)\n\n            # 关联ID索引\n            if log_entry.correlation_id:\n                self._correlation_index[log_entry.correlation_id].add(log_id)\n\n            # 业务类型索引\n            if log_entry.business_type:\n                self._business_type_index[log_entry.business_type].add(log_id)\n\n            # 时间索引\n            date_key = log_entry.timestamp.strftime('%Y-%m-%d')\n            self._time_index[date_key].append((log_entry.timestamp, log_id))\n\n    def query_correlation(self, query: CorrelationQuery) -> CorrelationResult:\n    """文档字符串"""\n\n        """\n        执行关联查询\n\n        Args:\n            query: 查询条件\n\n        Returns:\n            CorrelationResult: 查询结果\n        """\n        query_id = str(uuid.uuid4())\n        now = datetime.now()\n\n        with self._lock:\n            # 记录查询时间戳\n            self._query_timestamps[query_id] = now\n\n            # 执行查询\n            sampled_logs = self._find_sampled_logs(query)\n            related_logs = self._find_related_logs(query)\n\n            # 构建结果\n            result = CorrelationResult(\n                query_id=query_id,\n                timestamp=now,\n                sampled_logs=sampled_logs,\n                related_logs=related_logs,\n                correlation_context=self._build_correlation_context(query),\n                trace_context=self._build_trace_context(query),\n                statistics=self._calculate_statistics(sampled_logs, related_logs)\n            )\n\n            # 保存查询历史\n            self._query_history[query_id] = result\n\n            # 清理过期查询\n            if len(self._query_history) > self.max_query_history:\n                self._cleanup_oldest_queries()\n\n            return result\n\n    def _find_sampled_logs(self, query: CorrelationQuery) -> List[LogEntry]:\n    """文档字符串"""\n\n        """查找采样日志"""\n        # 这里应该从实际的采样日志存储中查找\n        # 目前返回空列表，实际实现时需要连接采样日志存储\n        return []\n\n    def _find_related_logs(self, query: CorrelationQuery) -> List[LogEntry]:\n    """文档字符串"""\n\n        """查找关联日志"""\n        # 这里应该从全量日志存储中查找\n        # 目前返回空列表，实际实现时需要连接全量日志存储\n        return []\n\n    def _build_correlation_context(self, query: CorrelationQuery) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """构建关联上下文"""\n        context = {\n            'query_time': datetime.now().isoformat(),\n            'query_conditions': {\n                'trace_id': query.trace_id,\n                'correlation_id': query.correlation_id,\n                'business_type': query.business_type.value if query.business_type else None,\n                'time_range': [\n                    query.time_range[0].isoformat() if query.time_range else None,\n                    query.time_range[1].isoformat() if query.time_range else None\n                ],\n                'log_level': query.log_level,\n                'keywords': query.keywords\n            }\n        }\n\n        return context\n\n    def _build_trace_context(self, query: CorrelationQuery) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """构建追溯上下文"""\n        context = {\n            'trace_id': query.trace_id,\n            'correlation_id': query.correlation_id,\n            'business_type': query.business_type.value if query.business_type else None,\n            'query_time': datetime.now().isoformat()\n        }\n\n        return context\n\n    def _calculate_statistics(self, sampled_logs: List[LogEntry], related_logs: List[LogEntry]) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """计算统计信息"""\n        stats = {\n            'sampled_logs_count': len(sampled_logs),\n            'related_logs_count': len(related_logs),\n            'total_logs_count': len(sampled_logs) + len(related_logs),\n            'business_type_distribution': defaultdict(int),\n            'log_level_distribution': defaultdict(int),\n            'time_distribution': defaultdict(int)\n        }\n\n        # 统计业务类型分布\n        for log in sampled_logs + related_logs:\n            if log.business_type:\n                stats['business_type_distribution'][log.business_type.value] += 1\n                stats['log_level_distribution'][log.level] += 1\n\n            # 按小时统计\n            hour_key = log.timestamp.strftime('%Y-%m-%d %H:00')\n            stats['time_distribution'][hour_key] += 1\n\n        return dict(stats)\n\n    def _cleanup_oldest_queries(self):\n    """文档字符串"""\n\n        """清理最旧的查询"""\n        if len(self._query_history) <= self.max_query_history:\n            return\n\n        # 按时间戳排序，删除最旧的查询\n        sorted_queries = sorted(\n            self._query_timestamps.items(),\n            key=lambda x: x[1]\n        )\n\n        # 删除最旧的查询\n        to_delete = len(self._query_history) - self.max_query_history\n        for i in range(to_delete):\n            query_id = sorted_queries[i][0]\n            if query_id in self._query_history:\n                del self._query_history[query_id]\n            if query_id in self._query_timestamps:\n                del self._query_timestamps[query_id]\n\n    def get_query_history(self, limit: int = 100) -> List[CorrelationResult]:\n    """文档字符串"""\n\n        """获取查询历史"""\n        with self._lock:\n            sorted_queries = sorted(\n                self._query_history.values(),\n                key=lambda x: x.timestamp,\n                reverse=True\n            )\n\n            return sorted_queries[:limit]\n\n    def get_query_by_id(self, query_id: str) -> Optional[CorrelationResult]:\n    """文档字符串"""\n\n        """根据ID获取查询结果"""\n        with self._lock:\n            return self._query_history.get(query_id)\n\n    def search_by_trace_id(self, trace_id: str) -> List[LogEntry]:\n    """文档字符串"""\n\n        """根据跟踪ID搜索日志"""\n        with self._lock:\n            self._trace_index.get(trace_id, set())\n            # 这里应该从实际存储中获取日志条目\n            # 目前返回空列表\n            return []\n\n    def search_by_correlation_id(self, correlation_id: str) -> List[LogEntry]:\n    """文档字符串"""\n\n        """根据关联ID搜索日志"""\n        with self._lock:\n            self._correlation_index.get(correlation_id, set())\n            # 这里应该从实际存储中获取日志条目\n            # 目前返回空列表\n            return []\n\n    def search_by_business_type(self, business_type: BusinessLogType,\n    """文档字符串"""\n                                 time_range: Optional[Tuple[datetime, datetime]] = None):\n        """根据业务类型搜索日志"""\n        with self._lock:\n            log_ids = self._business_type_index.get(business_type, set())\n\n            if time_range:\n                # 过滤时间范围\n                start_time, end_time = time_range\n                filtered_ids = set()\n\n                for date_key in self._time_index:\n                    date_obj = datetime.strptime(date_key, '%Y-%m-%d')\n                    if start_time.date() <= date_obj.date() <= end_time.date():\n                        for timestamp, log_id in self._time_index[date_key]:\n                            if start_time <= timestamp <= end_time and log_id in log_ids:\n                                filtered_ids.add(log_id)\n\n                log_ids = filtered_ids\n\n            # 这里应该从实际存储中获取日志条目\n            # 目前返回空列表\n            return []\n\ndef get_statistics(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n    """获取统计信息"""\n    with self._lock:\n        return {\n            'query_history_count': len(self._query_history),\n            'trace_index_count': len(self._trace_index),\n            'correlation_index_count': len(self._correlation_index),\n            'business_type_index_count': len(self._business_type_index),\n            'time_index_count': len(self._time_index),\n            'max_query_history': self.max_query_history,\n            'query_timeout': self.query_timeout\n        }\n\ndef export_query_result(self, query_id: str, format: str = "json") -> str:\n    """文档字符串"""\n\n    """导出查询结果"""\n    result = self.get_query_by_id(query_id)\n    if not result:\n        return ""\n\n    if format.lower() == "json":\n        return json.dumps({\n            'query_id': result.query_id,\n            'timestamp': result.timestamp.isoformat(),\n            'sampled_logs_count': len(result.sampled_logs),\n            'related_logs_count': len(result.related_logs),\n            'correlation_context': result.correlation_context,\n            'trace_context': result.trace_context,\n            'statistics': result.statistics\n        })\n\n    elif format.lower() == "csv":\n        # CSV格式导出\n        lines = []\n        lines.append("timestamp,level,business_type,message,trace_id,correlation_id")\n\n        for log in result.sampled_logs + result.related_logs:\n            lines.append(f"{log.timestamp.isoformat()},{log.level},{log.business_type.value if log.business_type else ''},{log.message},{log.trace_id or ''},{log.correlation_id or ''}")\n\n        return "\n".join(lines)\n\n    return ""\n\ndef cleanup(self):\n    """文档字符串"""\n\n    """清理资源"""\n    self._cleanup_expired_queries()\n