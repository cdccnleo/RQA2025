"""\n基础设施层 - 日志系统组件\n\ncomprehensive_error_plugin 模块\n\n日志系统相关的文件\n提供日志系统相关的功能实现。\n"""\n\n#!/usr/bin/env python3\nfrom .unified_error_handler import ErrorLevel, ErrorType, ErrorInfo\nfrom .error_codes_utils import ErrorCode, ErrorCategory, get_error_code, get_error_info\nfrom collections import defaultdict, deque\nfrom datetime import datetime, timedelta\nfrom enum import Enum\nfrom typing import Dict, Any, Optional, List, Callable, Type, Union, Set\nimport json\nimport logging\nimport threading\nimport time\nimport uuid\nimport weakref\n\nfrom dataclasses import dataclass, field\nimport traceback\n\n# -*- coding: utf-8 -*-\n"""\n综合错误处理框架\n\n提供完整的错误处理解决方案，包括：\n- 错误分类和编码\n- 智能恢复策略\n- 错误关联分析\n- 性能影响跟踪\n- 自动告警和通知\n- 错误趋势分析\n"""\n\nclass ErrorSeverity(Enum):\n\n    """错误严重程度"""\n    DEBUG = "debug"\n    INFO = "info"\n    WARNING = "warning"\n    ERROR = "error"\n    CRITICAL = "critical"\n    FATAL = "fatal"\n\nclass RecoveryAction(Enum):\n\n    """恢复动作"""\n    RETRY = "retry"\n    FALLBACK = "fallback"\n    CLEANUP = "cleanup"\n    RESTART = "restart"\n    SKIP = "skip"\n    DENY = "deny"\n    STOP = "stop"\n    ESCALATE = "escalate"\n    NOTIFY = "notify"\n\n@dataclass\n\nclass PerformanceImpact:\n\n    """性能影响"""\n    response_time_increase: float = 0.0\n    memory_usage_increase: float = 0.0\n    cpu_usage_increase: float = 0.0\n    throughput_decrease: float = 0.0\n    error_rate_increase: float = 0.0\n\n@dataclass\n\nclass ComprehensiveErrorContext:\n\n    """综合错误上下文"""\n    error_id: str\n    timestamp: datetime\n    error_code: str\n    error_message: str\n    category: ErrorCategory\n    severity: ErrorSeverity\n    context_data: Dict[str, Any]\n    stack_trace: str\n    user_id: Optional[str] = None\n    session_id: Optional[str] = None\n    request_id: Optional[str] = None\n    correlation_id: Optional[str] = None\n    performance_impact: Optional[PerformanceImpact] = None\n    recovery_action: Optional[RecoveryAction] = None\n    recovery_success: Optional[bool] = None\n    recovery_time: Optional[float] = None\n\nclass IntelligentRecoveryManager:\n\n    """智能恢复管理器"""\n\n    def __init__(self):\n\n        self.recovery_strategies: Dict[ErrorCategory, Dict[ErrorSeverity, RecoveryAction]] = {}\n        self.custom_recovery_handlers: Dict[str, Callable] = {}\n        self.recovery_history: List[Dict[str, Any]] = []\n        self._lock = threading.RLock()\n        self._initialize_default_strategies()\n\n    def _initialize_default_strategies(self):\n    """文档字符串"""\n\n        """初始化默认恢复策略"""\n        # 系统错误策略\n        self.recovery_strategies[ErrorCategory.SYSTEM] = {\n            ErrorSeverity.CRITICAL: RecoveryAction.RESTART,\n            ErrorSeverity.ERROR: RecoveryAction.CLEANUP,\n            ErrorSeverity.WARNING: RecoveryAction.SKIP\n        }\n\n        # 数据库错误策略\n        self.recovery_strategies[ErrorCategory.DATABASE] = {\n            ErrorSeverity.CRITICAL: RecoveryAction.RESTART,\n            ErrorSeverity.ERROR: RecoveryAction.RETRY,\n            ErrorSeverity.WARNING: RecoveryAction.FALLBACK\n        }\n\n        # 网络错误策略\n        self.recovery_strategies[ErrorCategory.NETWORK] = {\n            ErrorSeverity.CRITICAL: RecoveryAction.ESCALATE,\n            ErrorSeverity.ERROR: RecoveryAction.RETRY,\n            ErrorSeverity.WARNING: RecoveryAction.SKIP\n        }\n\n    def determine_recovery_action(self, error_context: ComprehensiveErrorContext) -> RecoveryAction:\n    """文档字符串"""\n\n        """确定恢复动作"""\n        with self._lock:\n            # 检查自定义处理器\n            if error_context.error_code in self.custom_recovery_handlers:\n                return RecoveryAction.RETRY  # 简化处理\n\n            # 获取默认策略\n            category_strategies = self.recovery_strategies.get(error_context.category, {})\n            return category_strategies.get(error_context.severity, RecoveryAction.SKIP)\n\n    def execute_recovery(self, error_context: ComprehensiveErrorContext) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """执行恢复动作"""\n        start_time = time.time()\n        recovery_action = self.determine_recovery_action(error_context)\n\n        try:\n            result = self._execute_standard_recovery(recovery_action, error_context)\n            recovery_time = time.time() - start_time\n            result['recovery_time'] = recovery_time\n            result['success'] = True\n\n            # 记录恢复历史\n            self.recovery_history.append({\n                'error_id': error_context.error_id,\n                'recovery_action': recovery_action.value,\n                'recovery_time': recovery_time,\n                'success': True,\n                'timestamp': datetime.now()\n            })\n\n            return result\n\n        except Exception as e:\n            recovery_time = time.time() - start_time\n            result = {\n                'recovery_action': recovery_action.value,\n                'recovery_time': recovery_time,\n                'success': False,\n                'error': str(e)\n            }\n\n            return result\n\n    def _execute_standard_recovery(self, action: RecoveryAction,\n    """文档字符串"""\n\n                                   error_context: ComprehensiveErrorContext) -> Dict[str, Any]:\n        """执行标准恢复动作"""\n        if action == RecoveryAction.RETRY:\n            return {'action': 'retry', 'max_retries': 3, 'delay': 1.0}\n        elif action == RecoveryAction.FALLBACK:\n            return {'action': 'fallback', 'fallback_data': {}}\n        elif action == RecoveryAction.CLEANUP:\n            return {'action': 'cleanup', 'targets': ['memory', 'cache']}\n        elif action == RecoveryAction.RESTART:\n            return {'action': 'restart', 'component': 'unknown'}\n        elif action == RecoveryAction.SKIP:\n            return {'action': 'skip'}\n        elif action == RecoveryAction.DENY:\n            return {'action': 'deny'}\n        elif action == RecoveryAction.STOP:\n            return {'action': 'stop'}\n        elif action == RecoveryAction.ESCALATE:\n            return {'action': 'escalate', 'level': 'admin'}\n        elif action == RecoveryAction.NOTIFY:\n            return {'action': 'notify', 'recipients': ['admin']}\n        else:\n            return {'action': 'unknown'}\n\n    def get_recovery_statistics(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取恢复统计"""\n        with self._lock:\n            if not self.recovery_history:\n                return {}\n\n            total_recoveries = len(self.recovery_history)\n            successful_recoveries = len([r for r in self.recovery_history if r['success']])\n            success_rate = successful_recoveries / total_recoveries if total_recoveries > 0 else 0\n\n            avg_recovery_time = sum(r['recovery_time'] for r in self.recovery_history) / total_recoveries\n\n            return {\n                'total_recoveries': total_recoveries,\n                'successful_recoveries': successful_recoveries,\n                'success_rate': success_rate,\n                'avg_recovery_time': avg_recovery_time\n            }\n\nclass ComprehensiveErrorHandler:\n\n    """综合错误处理器"""\n\n    def __init__(self,\n\n                 config: Optional[Dict[str, Any]] = None,\n                 enable_intelligent_recovery: bool = True):\n\n        self.config = config or {}\n        self.enable_intelligent_recovery = enable_intelligent_recovery\n\n        # 初始化组件\n        self.recovery_manager = IntelligentRecoveryManager() if enable_intelligent_recovery else None\n\n        # 错误历史\n        self.error_history: List[ComprehensiveErrorContext] = []\n        self._lock = threading.RLock()\n\n        # 统计信息\n        self._error_count = 0\n        self._error_count_by_category: Dict[ErrorCategory, int] = defaultdict(int)\n        self._error_count_by_severity: Dict[ErrorSeverity, int] = defaultdict(int)\n\n        # 告警阈值\n        self.alert_thresholds = self.config.get('alert_thresholds', {\n            'critical_errors_per_minute': 5,\n            'error_rate_threshold': 0.1,\n            'recovery_failure_rate': 0.3\n        })\n\n    def handle_error(self, error: Exception, context: Optional[Dict[str, Any]] = None) -> ComprehensiveErrorContext:\n    """文档字符串"""\n\n        """处理错误"""\n        with self._lock:\n            # 生成错误ID\n            error_id = str(uuid.uuid4())\n\n            # 获取错误信息\n            error_code = get_error_code(error)\n            error_info = get_error_info(error)\n\n            # 确定错误类别和严重程度\n            category = error_info.category if error_info else ErrorCategory.SYSTEM\n            severity = self._determine_severity(error, error_info)\n\n            # 创建错误上下文\n            error_context = ComprehensiveErrorContext(\n                error_id=error_id,\n                timestamp=datetime.now(),\n                error_code=error_code,\n                error_message=str(error),\n                category=category,\n                severity=severity,\n                context_data=context or {},\n                stack_trace=self._get_stack_trace(error),\n                user_id=context.get('user_id') if context else None,\n                session_id=context.get('session_id') if context else None,\n                request_id=context.get('request_id') if context else None\n            )\n\n            # 分析性能影响\n            error_context.performance_impact = self._analyze_performance_impact(error_context)\n\n            # 执行智能恢复\n            if self.enable_intelligent_recovery and self.recovery_manager:\n                recovery_result = self.recovery_manager.execute_recovery(error_context)\n                error_context.recovery_action = RecoveryAction(recovery_result['action'])\n                error_context.recovery_success = recovery_result['success']\n                error_context.recovery_time = recovery_result['recovery_time']\n\n            # 添加到历史记录\n            self.error_history.append(error_context)\n\n            # 更新统计信息\n            self._update_statistics(error_context)\n\n            # 检查告警\n            self._check_alerts(error_context)\n\n            # 记录日志\n            self._log_error(error_context)\n\n            return error_context\n\n    def _determine_severity(self, error: Exception, error_info: Optional[ErrorCode]) -> ErrorSeverity:\n    """文档字符串"""\n\n        """确定错误严重程度"""\n        if error_info:\n            severity_map = {\n                'CRITICAL': ErrorSeverity.CRITICAL,\n                'ERROR': ErrorSeverity.ERROR,\n                'WARNING': ErrorSeverity.WARNING,\n                'INFO': ErrorSeverity.INFO\n            }\n\n            return severity_map.get(error_info.severity, ErrorSeverity.ERROR)\n\n        # 基于异常类型判断\n        if isinstance(error, (SystemError, OSError)):\n            return ErrorSeverity.CRITICAL\n        elif isinstance(error, (ValueError, TypeError)):\n            return ErrorSeverity.ERROR\n        elif isinstance(error, (Warning, UserWarning)):\n            return ErrorSeverity.WARNING\n        else:\n            return ErrorSeverity.ERROR\n\n    def _analyze_performance_impact(self, error_context: ComprehensiveErrorContext) -> PerformanceImpact:\n    """文档字符串"""\n\n        """分析性能影响"""\n        # 简化实现：基于错误类型和严重程度估算性能影响\n        impact = PerformanceImpact()\n\n        if error_context.severity == ErrorSeverity.CRITICAL:\n            impact.response_time_increase = 2.0\n            impact.memory_usage_increase = 15.0\n            impact.cpu_usage_increase = 20.0\n            impact.throughput_decrease = 30.0\n            impact.error_rate_increase = 25.0\n        elif error_context.severity == ErrorSeverity.ERROR:\n            impact.response_time_increase = 1.0\n            impact.memory_usage_increase = 8.0\n            impact.cpu_usage_increase = 10.0\n            impact.throughput_decrease = 15.0\n            impact.error_rate_increase = 10.0\n        elif error_context.severity == ErrorSeverity.WARNING:\n            impact.response_time_increase = 0.5\n            impact.memory_usage_increase = 3.0\n            impact.cpu_usage_increase = 5.0\n            impact.throughput_decrease = 5.0\n            impact.error_rate_increase = 2.0\n\n        return impact\n\n    def _get_stack_trace(self, error: Exception) -> str:\n    """文档字符串"""\n\n        """获取堆栈跟踪"""\n        return ''.join(traceback.format_exception(type(error), error, error.__traceback__))\n\n    def _update_statistics(self, error_context: ComprehensiveErrorContext) -> None:\n    """文档字符串"""\n\n        """更新统计信息"""\n        self._error_count += 1\n        self._error_count_by_category[error_context.category] += 1\n        self._error_count_by_severity[error_context.severity] += 1\n\n    def _check_alerts(self, error_context: ComprehensiveErrorContext) -> None:\n    """文档字符串"""\n\n        """检查告警"""\n        # 检查严重错误频率\n        recent_critical_errors = [\n            e for e in self.error_history[-100:]\n            if e.severity == ErrorSeverity.CRITICAL\n            and e.timestamp >= datetime.now() - timedelta(minutes=1)\n        ]\n\n        if len(recent_critical_errors) >= self.alert_thresholds['critical_errors_per_minute']:\n            self._trigger_alert("critical_error_rate_exceeded", error_context)\n\n    def _trigger_alert(self, alert_type: str, error_context: ComprehensiveErrorContext) -> None:\n    """文档字符串"""\n\n        """触发告警"""\n        alert_message = {\n            'alert_type': alert_type,\n            'error_id': error_context.error_id,\n            'error_code': error_context.error_code,\n            'severity': error_context.severity.value,\n            'timestamp': datetime.now().isoformat(),\n            'message': f"触发告警: {alert_type}"\n        }\n\n        logging.warning(f"ALERT: {json.dumps(alert_message, ensure_ascii=False)}")\n\n    def _log_error(self, error_context: ComprehensiveErrorContext) -> None:\n    """文档字符串"""\n\n        """记录错误日志"""\n        log_data = {\n            'error_id': error_context.error_id,\n            'error_code': error_context.error_code,\n            'category': error_context.category.value,\n            'severity': error_context.severity.value,\n            'message': error_context.error_message,\n            'timestamp': error_context.timestamp.isoformat(),\n            'recovery_action': error_context.recovery_action.value if error_context.recovery_action else None,\n            'recovery_success': error_context.recovery_success,\n            'recovery_time': error_context.recovery_time\n        }\n\n        if error_context.severity == ErrorSeverity.CRITICAL:\n            logging.critical(f"CRITICAL ERROR: {json.dumps(log_data, ensure_ascii=False)}")\n        elif error_context.severity == ErrorSeverity.ERROR:\n            logging.error(f"ERROR: {json.dumps(log_data, ensure_ascii=False)}")\n        elif error_context.severity == ErrorSeverity.WARNING:\n            logging.warning(f"WARNING: {json.dumps(log_data, ensure_ascii=False)}")\n        else:\n            logging.info(f"INFO: {json.dumps(log_data, ensure_ascii=False)}")\n\n    def get_error_statistics(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取错误统计"""\n        with self._lock:\n            return {\n                'total_errors': self._error_count,\n                'by_category': {cat.value: count for cat, count in self._error_count_by_category.items()},\n                'by_severity': {sev.value: count for sev, count in self._error_count_by_severity.items()},\n                'recent_errors': len([e for e in self.error_history if\n                                      e.timestamp >= datetime.now() - timedelta(hours=1)])\n            }\n\n    def get_recovery_statistics(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取恢复统计"""\n        if self.recovery_manager:\n            return self.recovery_manager.get_recovery_statistics()\n        return {}\n\n# 全局综合错误处理器实例\n_comprehensive_error_handler = None\n_comprehensive_error_handler_lock = threading.Lock()\n\ndef get_comprehensive_error_handler(config: Optional[Dict[str, Any]] = None) -> ComprehensiveErrorHandler:\n    """文档字符串"""\n\n    """获取全局综合错误处理器实例"""\n    global _comprehensive_error_handler\n    if _comprehensive_error_handler is None:\n        with _comprehensive_error_handler_lock:\n            if _comprehensive_error_handler is None:\n                _comprehensive_error_handler = ComprehensiveErrorHandler(config)\n    return _comprehensive_error_handler\n\ndef handle_comprehensive_error(error: Exception, context: Optional[Dict[str, Any]] = None) -> ComprehensiveErrorContext:\n    """文档字符串"""\n\n    """处理综合错误"""\n    handler = get_comprehensive_error_handler()\n    return handler.handle_error(error, context)\n\ndef comprehensive_error_handler(func: Callable) -> Callable:\n    """文档字符串"""\n\n    """综合错误处理装饰器"""\n\n    def wrapper(*args, **kwargs):\n    """文档字符串"""\n\n        try:\n            return func(*args, **kwargs)\n        except Exception as e:\n            context = {\n                'function': func.__name__,\n                'module': func.__module__,\n                'args': str(args),\n                'kwargs': str(kwargs)\n            }\n\n            handle_comprehensive_error(e, context)\n            raise\n    return wrapper\n