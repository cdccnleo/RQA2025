"""
WebSocket API路由模块
"""

from fastapi import APIRouter

# 创建WebSocket API路由器
router = APIRouter(prefix="/ws", tags=["WebSocket"])

@router.get("/")
async def websocket_info():
    """WebSocket信息"""
    return {"message": "WebSocket API端点", "status": "active"}

@router.get("/status")
async def websocket_status():
    """WebSocket状态"""
    return {"status": "healthy", "connections": 0}
