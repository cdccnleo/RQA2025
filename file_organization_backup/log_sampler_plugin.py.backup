import logging\n\n"""\n增强的日志采样系统\n支持关键业务日志强制采样和采样日志与全量日志的关联机制\n"""\n\nimport random\nimport time\nimport threading\nimport uuid\nfrom typing import Dict, Any, Optional, Callable, Union, List, Set\nfrom dataclasses import dataclass, field\nfrom enum import Enum\nfrom collections import deque, defaultdict\nfrom datetime import datetime, timedelta\n\nclass BusinessLogType(Enum):\n\n    """业务日志类型"""\n    ORDER = "order"                    # 订单相关\n    TRADE = "trade"                    # 交易相关\n    RISK = "risk"                      # 风控相关\n    ACCOUNT = "account"                # 账户相关\n    POSITION = "position"              # 持仓相关\n    SYSTEM = "system"                  # 系统相关\n    DEBUG = "debug"                    # 调试相关\n\nclass SamplingStrategyType(Enum):\n\n    """采样策略类型"""\n    FIXED_RATE = "fixed_rate"          # 固定比率采样\n    LEVEL_BASED = "level_based"        # 基于日志级别\n    BUSINESS_CRITICAL = "business_critical"  # 关键业务强制采样\n    KEYWORD_FILTER = "keyword_filter"  # 关键字过滤\n    COMBINED = "combined"              # 组合策略\n    DYNAMIC = "dynamic"                # 动态调整\n\n@dataclass\n\nclass SamplingRule:\n\n    """采样规则配置"""\n    strategy: SamplingStrategyType\n    rate: float = 1.0\n    level: Optional[str] = None\n    keywords: Optional[List[str]] = None\n    business_types: Optional[List[BusinessLogType]] = None\n    condition: Optional[Callable[[Dict], bool]] = None\n    force_sample: bool = False  # 强制采样标志\n\n@dataclass\n\nclass LogEntry:\n\n    """日志条目"""\n    timestamp: datetime\n    level: str\n    message: str\n    logger: str\n    business_type: Optional[BusinessLogType] = None\n    trace_id: Optional[str] = None\n    correlation_id: Optional[str] = None\n    extra: Dict[str, Any] = field(default_factory=dict)\n\nclass LogSamplerPlugin:\n\n    """增强版日志采样器"""\n\n    def __init__(self,\n\n                 base_rate: float = 1.0,\n                 min_rate: float = 0.01,\n                 max_rate: float = 1.0,\n                 load_window: int = 60):\n        """初始化采样器"""\n        self._base_rate = base_rate\n        self._min_rate = min_rate\n        self._max_rate = max_rate\n        self._load_window = load_window\n        self._current_rate = base_rate\n\n        self._rules: List[SamplingRule] = []\n        self._lock = threading.RLock()\n        self._load_history = deque(maxlen=load_window)\n        self._last_adjust_time = time.time()\n\n        # 关键业务日志强制采样配置\n        self._critical_business_types: Set[BusinessLogType] = {\n            BusinessLogType.ORDER,\n            BusinessLogType.TRADE,\n            BusinessLogType.RISK,\n            BusinessLogType.ACCOUNT\n        }\n\n        # 采样日志关联机制\n        self._sampled_logs: Dict[str, LogEntry] = {}\n        self._correlation_map: Dict[str, List[str]] = defaultdict(list)\n        self._trace_map: Dict[str, List[str]] = defaultdict(list)\n\n        # 默认规则\n        self._init_default_rules()\n\n    def _init_default_rules(self):\n    """文档字符串"""\n\n        """初始化默认采样规则"""\n        # 关键业务日志强制采样规则\n        self.add_rule(SamplingRule(\n            strategy=SamplingStrategyType.BUSINESS_CRITICAL,\n            rate=1.0,\n            business_types=list(self._critical_business_types),\n            force_sample=True\n        ))\n\n        # 基础采样规则\n        self.add_rule(SamplingRule(\n            strategy=SamplingStrategyType.FIXED_RATE,\n            rate=self._base_rate\n        ))\n\n    def configure(self, config: Dict[str, Any]):\n    """文档字符串"""\n\n        """配置采样器"""\n        with self._lock:\n            # 设置基础采样率\n            if 'default_rate' in config:\n                self._base_rate = max(self._min_rate, min(self._max_rate, config['default_rate']))\n                self._current_rate = self._base_rate\n\n            # 更新关键业务类型\n            if 'critical_business_types' in config:\n                self._critical_business_types = {\n                    BusinessLogType(t) for t in config['critical_business_types']\n                }\n\n            # 清除现有规则\n            self._rules.clear()\n\n            # 重新初始化默认规则\n            self._init_default_rules()\n\n            # 添加级别规则\n            if 'level_rates' in config:\n                for level, rate in config['level_rates'].items():\n                    self.add_rule(SamplingRule(\n                        strategy=SamplingStrategyType.LEVEL_BASED,\n                        level=level.upper(),\n                        rate=rate\n                    ))\n\n            # 添加交易时段规则\n            if 'trading_hours_rate' in config:\n                self.add_rule(SamplingRule(\n                    strategy=SamplingStrategyType.FIXED_RATE,\n                    rate=config['trading_hours_rate']\n                ))\n\n    def add_rule(self, rule: SamplingRule):\n    """文档字符串"""\n\n        """添加采样规则"""\n        with self._lock:\n            self._rules.append(rule)\n\n    def remove_rule(self, index: int):\n    """文档字符串"""\n\n        """移除采样规则"""\n        with self._lock:\n            if 0 <= index < len(self._rules):\n                self._rules.pop(index)\n\n    def clear_rules(self):\n    """文档字符串"""\n\n        """清除所有采样规则"""\n        with self._lock:\n            self._rules.clear()\n            self._init_default_rules()\n\n    def set_base_rate(self, rate: float):\n    """文档字符串"""\n\n        """设置基础采样率"""\n        with self._lock:\n            self._base_rate = max(self._min_rate, min(self._max_rate, rate))\n\n    def adjust_for_load(self, current_load: float):\n    """文档字符串"""\n\n        """根据系统负载调整采样率"""\n        now = time.time()\n        self._load_history.append((now, current_load))\n\n        # 计算平均负载\n        window_start = now - self._load_window\n        recent_loads = [load for ts, load in self._load_history if ts >= window_start]\n        if not recent_loads:\n            return\n\n        avg_load = sum(recent_loads) / len(recent_loads)\n\n        # 动态调整当前采样率\n        self._current_rate = self._calculate_dynamic_rate(avg_load)\n        self._last_adjust_time = now\n\n    def _calculate_dynamic_rate(self, load: float) -> float:\n    """文档字符串"""\n\n        """计算动态采样率"""\n        # 负载超过0.5时开始降低采样率\n        if load > 0.5:\n            # 使用二次曲线使采样率下降更快\n            scale = min(1.0, (load - 0.5) / 0.5)\n            adjusted_rate = self._base_rate - (self._base_rate - self._min_rate) * (scale ** 1.5)\n            return max(self._min_rate, min(self._max_rate, adjusted_rate))\n        return self._base_rate\n\n    def should_sample(self, record: Union[Dict, str, LogEntry]) -> bool:\n    """文档字符串"""\n\n        """判断是否采样当前日志记录"""\n        if not self._rules:\n            return True\n\n        # 处理简化输入(如直接传入日志级别字符串)\n        if isinstance(record, str):\n            record = {'level': record}\n        elif isinstance(record, LogEntry):\n            record = {\n                'level': record.level,\n                'message': record.message,\n                'logger': record.logger,\n                'business_type': record.business_type,\n                'trace_id': record.trace_id,\n                'correlation_id': record.correlation_id,\n                'extra': record.extra\n            }\n\n        with self._lock:\n            # 优先检查强制采样规则\n            for rule in self._rules:\n                if rule.force_sample and self._match_rule(rule, record):\n                    return True\n\n            # 检查其他规则\n            for rule in self._rules:\n                if self._match_rule(rule, record):\n                    return self._apply_sampling(rule, record)\n            return True\n\n    def _match_rule(self, rule: SamplingRule, record: Dict) -> bool:\n    """文档字符串"""\n\n        """匹配规则条件"""\n        if rule.strategy == SamplingStrategyType.FIXED_RATE:\n            return True\n\n        elif rule.strategy == SamplingStrategyType.LEVEL_BASED:\n            return record.get('level', '').upper() == rule.level\n\n        elif rule.strategy == SamplingStrategyType.BUSINESS_CRITICAL:\n            business_type = record.get('business_type')\n            if business_type and rule.business_types:\n                return business_type in rule.business_types\n            return False\n\n        elif rule.strategy == SamplingStrategyType.KEYWORD_FILTER:\n            msg = str(record.get('message', ''))\n            return any(keyword in msg for keyword in rule.keywords)\n\n        elif rule.strategy == SamplingStrategyType.COMBINED:\n            return rule.condition(record) if rule.condition else False\n\n        return False\n\n    def _apply_sampling(self, rule: SamplingRule, record: Dict) -> bool:\n    """文档字符串"""\n\n        """应用采样策略"""\n        if rule.strategy == SamplingStrategyType.DYNAMIC:\n            # 使用当前调整后的采样率\n            return random.random() < self._current_rate\n\n        return random.random() < rule.rate\n\n    def record_sampled_log(self, log_entry: LogEntry):\n    """文档字符串"""\n\n        """记录采样日志，用于关联机制"""\n        with self._lock:\n            log_id = str(uuid.uuid4())\n            self._sampled_logs[log_id] = log_entry\n\n            # 建立关联关系\n        if log_entry.trace_id:\n            self._trace_map[log_entry.trace_id].append(log_id)\n        if log_entry.correlation_id:\n            self._correlation_map[log_entry.correlation_id].append(log_id)\n\n    def get_related_logs(self, trace_id: str = None, correlation_id: str = None) -> List[LogEntry]:\n    """文档字符串"""\n\n        """获取关联的日志条目"""\n        with self._lock:\n            related_ids = set()\n\n        if trace_id and trace_id in self._trace_map:\n            related_ids.update(self._trace_map[trace_id])\n\n        if correlation_id and correlation_id in self._correlation_map:\n            related_ids.update(self._correlation_map[correlation_id])\n\n        return [self._sampled_logs[log_id] for log_id in related_ids if log_id in self._sampled_logs]\n\n    def get_critical_business_logs(self, business_type: BusinessLogType = None) -> List[LogEntry]:\n    """文档字符串"""\n\n        """获取关键业务日志"""\n        with self._lock:\n            if business_type:\n                return [\n                    entry for entry in self._sampled_logs.values()\n                    if entry.business_type == business_type\n                ]\n            else:\n                return [\n                    entry for entry in self._sampled_logs.values()\n                    if entry.business_type in self._critical_business_types\n                ]\n\n    def generate_trace_id(self) -> str:\n    """文档字符串"""\n\n        """生成跟踪ID"""\n        return str(uuid.uuid4())\n\n    def generate_correlation_id(self, base_id: str = None) -> str:\n    """文档字符串"""\n\n        """生成关联ID"""\n        if base_id:\n            return f"{base_id}_{int(time.time())}"\n        return str(uuid.uuid4())\n\n    def extract_business_type(self, message: str, logger: str) -> Optional[BusinessLogType]:\n    """文档字符串"""\n\n        """从日志消息中提取业务类型"""\n        # 订单相关关键词\n        order_keywords = ['order', '订单', '下单', '撤单', 'order_id']\n        if any(keyword in message.lower() for keyword in order_keywords):\n            return BusinessLogType.ORDER\n\n        # 交易相关关键词\n        trade_keywords = ['trade', '交易', '成交', 'trade_id']\n        if any(keyword in message.lower() for keyword in trade_keywords):\n            return BusinessLogType.TRADE\n\n        # 风控相关关键词\n        risk_keywords = ['risk', '风控', '风险', 'risk_check']\n        if any(keyword in message.lower() for keyword in risk_keywords):\n            return BusinessLogType.RISK\n\n        # 账户相关关键词\n        account_keywords = ['account', '账户', '资金', 'balance']\n        if any(keyword in message.lower() for keyword in account_keywords):\n            return BusinessLogType.ACCOUNT\n\n        # 持仓相关关键词\n        position_keywords = ['position', '持仓', '仓位', 'position_id']\n        if any(keyword in message.lower() for keyword in position_keywords):\n            return BusinessLogType.POSITION\n\n        # 调试相关关键词\n        debug_keywords = ['debug', '调试', 'cache_key', 'test']\n        if any(keyword in message.lower() for keyword in debug_keywords):\n            return BusinessLogType.DEBUG\n\n        # 系统相关关键词\n        system_keywords = ['system', '系统', 'service', 'api']\n        if any(keyword in message.lower() for keyword in system_keywords):\n            return BusinessLogType.SYSTEM\n\n        # 根据logger名称判断\n        if 'order' in logger.lower():\n            return BusinessLogType.ORDER\n        elif 'trade' in logger.lower():\n            return BusinessLogType.TRADE\n        elif 'risk' in logger.lower():\n            return BusinessLogType.RISK\n        elif 'account' in logger.lower():\n            return BusinessLogType.ACCOUNT\n        elif 'debug' in logger.lower():\n            return BusinessLogType.DEBUG\n        elif 'system' in logger.lower():\n            return BusinessLogType.SYSTEM\n\n        return None\n\n    @property\n\n    def base_rate(self) -> float:\n    """文档字符串"""\n\n        """获取当前基础采样率"""\n        with self._lock:\n            return self._base_rate\n\n    @property\n\n    def min_rate(self) -> float:\n    """文档字符串"""\n\n        """获取最小采样率"""\n        with self._lock:\n            return self._min_rate\n\n    @property\n\n    def max_rate(self) -> float:\n    """文档字符串"""\n\n        """获取最大采样率"""\n        with self._lock:\n            return self._max_rate\n\n    @property\n\n    def rules(self) -> List[SamplingRule]:\n    """文档字符串"""\n\n        """获取当前配置的采样规则列表(只读)"""\n        with self._lock:\n            return self._rules.copy()\n\n    def get_config(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取当前配置"""\n        with self._lock:\n            return {\n                'base_rate': self._base_rate,\n                'min_rate': self._min_rate,\n                'max_rate': self._max_rate,\n                'current_rate': self._current_rate,\n                'rules_count': len(self._rules),\n                'load_window': self._load_window,\n                'critical_business_types': [t.value for t in self._critical_business_types],\n                'sampled_logs_count': len(self._sampled_logs)\n            }\n\n    def get_current_strategy(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取当前采样策略配置"""\n        with self._lock:\n            return {\n                'base_rate': self._base_rate,\n                'min_rate': self._min_rate,\n                'max_rate': self._max_rate,\n                'rules': [\n                    {\n                        'strategy': rule.strategy.value,\n                        'rate': rule.rate,\n                        'level': rule.level,\n                        'business_types': [t.value for t in rule.business_types] if rule.business_types else None,\n                        'keywords': rule.keywords,\n                        'force_sample': rule.force_sample\n                    }\n                    for rule in self._rules\n                ],\n                'last_adjust_time': self._last_adjust_time,\n                'current_load': self._load_history[-1][1] if self._load_history else 0\n            }\n\n    def filter(self, record) -> bool:\n    """文档字符串"""\n\n        """\n        日志过滤器接口，适配logging.Handler的filter方法\n\n        Args:\n            record: logging.LogRecord对象\n\n        Returns:\n            bool: True表示记录日志，False表示过滤\n        """\n        # 将LogRecord转换为字典格式\n        record_dict = {\n            'level': record.levelname,\n            'message': record.getMessage(),\n            'module': record.module,\n            'funcName': record.funcName,\n            'lineno': record.lineno\n        }\n\n        return self.should_sample(record_dict)\n\n    def cleanup_old_logs(self, max_age_hours: int = 24):\n    """文档字符串"""\n\n        """清理过期的采样日志"""\n        cutoff_time = datetime.now() - timedelta(hours=max_age_hours)\n\n        with self._lock:\n            # 清理过期的日志条目\n            expired_ids = [\n                log_id for log_id, entry in self._sampled_logs.items()\n                if entry.timestamp < cutoff_time\n            ]\n\n            for log_id in expired_ids:\n                del self._sampled_logs[log_id]\n\n            # 清理过期的关联映射\n            for trace_id in list(self._trace_map.keys()):\n                self._trace_map[trace_id] = [\n                    log_id for log_id in self._trace_map[trace_id]\n                    if log_id in self._sampled_logs\n                ]\n                if not self._trace_map[trace_id]:\n                    del self._trace_map[trace_id]\n\n            for correlation_id in list(self._correlation_map.keys()):\n                self._correlation_map[correlation_id] = [\n                    log_id for log_id in self._correlation_map[correlation_id]\n                    if log_id in self._sampled_logs\n                ]\n                if not self._correlation_map[correlation_id]:\n                    del self._correlation_map[correlation_id]\n\n# Logger setup\nlogger = logging.getLogger(__name__)\n