"""\nWeb管理界面系统\n\n提供可视化的监控配置、告警规则管理和实时测试结果监控功能，包括：\n- Web管理界面\n- REST API接口\n- 实时监控仪表板\n- 配置管理界面\n"""\n\nfrom datetime import datetime, timedelta\nfrom typing import Dict, List, Optional, Any\nimport json\nimport logging\nimport os\nimport threading\nimport time\n\nfrom dataclasses import asdict\nfrom flask import Flask, render_template, request, jsonify, redirect, url_for, flash, Response\nfrom flask_socketio import SocketIO, emit\n\n# 导入监控告警系统组件\nfrom .monitoring_alert_system import (\n    MonitoringAlertSystem, AlertRule, AlertType, AlertLevel,\n    PerformanceMetrics, TestExecutionInfo\n)\n\nclass WebManagementInterface:\n\n    """Web管理界面主类"""\n\n    def __init__(self, monitoring_system: Optional[MonitoringAlertSystem] = None):\n\n        self.monitoring_system = monitoring_system or MonitoringAlertSystem()\n        self.app = Flask(__name__)\n        self.app.config['SECRET_KEY'] = os.environ.get('SECRET_KEY', 'dev - secret - key')\n\n        # 设置模板和静态文件路径\n        template_dir = os.path.join(os.path.dirname(__file__), 'templates')\n        self.app.template_folder = template_dir\n\n        # 初始化SocketIO\n        self.socketio = SocketIO(self.app, cors_allowed_origins="*")\n\n        # 设置日志\n        self.logger = logging.getLogger(__name__)\n\n        # 注册路由\n        self._register_routes()\n\n        # 启动后台更新线程\n        self._start_background_updates()\n\n    def _register_routes(self):\n    """文档字符串"""\n\n        """注册Web路由"""\n\n        # 页面路由\n        @self.app.route('/')\n        def index():\n    """文档字符串"""\n            return render_template('index.html')\n\n        @self.app.route('/dashboard')\n        def dashboard():\n    """文档字符串"""\n            return render_template('dashboard.html')\n\n        @self.app.route('/alerts')\n        def alerts():\n    """文档字符串"""\n            return render_template('alerts.html')\n\n        @self.app.route('/config')\n        def config():\n    """文档字符串"""\n            return render_template('config.html')\n\n        @self.app.route('/tests')\n        def tests():\n    """文档字符串"""\n            return render_template('tests.html')\n\n        # API路由\n        @self.app.route('/api/status')\n        def api_status():\n    """文档字符串"""\n            try:\n                status = self.monitoring_system.get_system_status()\n                return jsonify({\n                    'success': True,\n                    'data': status\n                })\n            except Exception as e:\n                self.logger.error(f"获取系统状态失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n        @self.app.route('/api / performance')\n        def api_performance():\n    """文档字符串"""\n\n            try:\n                minutes = request.args.get('minutes', 60, type=int)\n                report = self.monitoring_system.get_performance_report(minutes)\n                return jsonify({\n                    'success': True,\n                    'data': report\n                })\n\n            except Exception as e:\n                self.logger.error(f"获取性能报告失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n        @self.app.route('/api / alerts')\n        def api_alerts():\n    """文档字符串"""\n\n            try:\n                alerts = self.monitoring_system.alert_manager.get_active_alerts()\n                # 序列化告警数据\n                alerts_data = []\n                for alert in alerts:\n                    alert_dict = {\n                        'id': alert.id,\n                        'alert_type': alert.alert_type.value if hasattr(alert.alert_type, 'value') else str(alert.alert_type),\n                        'alert_level': alert.alert_level.value if hasattr(alert.alert_level, 'value') else str(alert.alert_level),\n                        'message': alert.message,\n                        'details': alert.details,\n                        'timestamp': alert.timestamp.isoformat() if alert.timestamp else None,\n                        'source': alert.source,\n                        'resolved': alert.resolved,\n                        'resolved_at': alert.resolved_at.isoformat() if alert.resolved_at else None\n                    }\n                    alerts_data.append(alert_dict)\n\n                return jsonify({\n                    'success': True,\n                    'data': alerts_data\n                })\n\n            except Exception as e:\n                self.logger.error(f"获取告警信息失败: {e}")\n                self.logger.error(f"获取告警信息失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n        @self.app.route('/api / alerts/<alert_id>/resolve', methods=['POST'])\n        def api_resolve_alert(alert_id):\n    """文档字符串"""\n\n            try:\n                self.monitoring_system.alert_manager.resolve_alert(alert_id)\n                return jsonify({\n                    'success': True,\n                    'message': f'告警 {alert_id} 已解决'\n                })\n            except Exception as e:\n                self.logger.error(f"解决告警失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n\n        @self.app.route('/api / alerts / rules', methods=['GET', 'POST'])\n        def api_alert_rules():\n    """文档字符串"""\n\n            if request.method == 'GET':\n                try:\n                    rules = self.monitoring_system.alert_manager.alert_rules\n                    # 序列化规则数据\n                    rules_data = []\n                    for rule in rules:\n                        rule_dict = {\n                            'name': rule.name,\n                            'alert_type': rule.alert_type.value if hasattr(rule.alert_type, 'value') else str(rule.alert_type),\n                            'alert_level': rule.alert_level.value if hasattr(rule.alert_level, 'value') else str(rule.alert_level),\n                            'condition': rule.condition,\n                            'threshold': rule.threshold,\n                            'enabled': rule.enabled,\n                            'cooldown': rule.cooldown\n                        }\n\n                        rules_data.append(rule_dict)\n\n                    return jsonify({\n                        'success': True,\n                        'data': rules_data\n                    })\n\n                except Exception as e:\n                    self.logger.error(f"获取告警规则失败: {e}")\n                    return jsonify({\n                        'success': False,\n                        'error': str(e)\n                    })\n            else:  # POST\n                try:\n                    data = request.get_json()\n                    if not data:\n                        return jsonify({\n                            'success': False,\n                            'error': '无效的请求数据'\n                        })\n                    # 验证必需字段\n                    required_fields = ['name', 'alert_type', 'alert_level', 'condition', 'threshold']\n                    for field in required_fields:\n                        if field not in data:\n                            return jsonify({\n                                'success': False,\n                                'error': f'缺少必需字段: {field}'\n                            })\n                    # 创建告警规则\n                    rule = AlertRule(\n                        name=data['name'],\n                        alert_type=AlertType(data['alert_type']),\n                        alert_level=AlertLevel(data['alert_level']),\n                        condition=data['condition'],\n                        threshold=data['threshold'],\n                        enabled=data.get('enabled', True),\n                        cooldown=data.get('cooldown', 300)\n                    )\n                    # 添加到监控系统\n                    self.monitoring_system.add_custom_alert_rule(rule)\n\n                    return jsonify({\n                        'success': True,\n                        'message': '告警规则添加成功'\n                    })\n                except Exception as e:\n                    self.logger.error(f"添加告警规则失败: {e}")\n                    return jsonify({\n                        'success': False,\n                        'error': str(e)\n                    })\n\n        @self.app.route('/api / tests', methods=['GET'])\n        def api_tests():\n    """文档字符串"""\n            try:\n                active_tests = self.monitoring_system.test_monitor.get_active_tests()\n                test_history = self.monitoring_system.test_monitor.get_test_history()\n\n                # 序列化测试数据\n                active_tests_data = []\n                for test in active_tests:\n                    test_dict = {\n                        'test_id': test.test_id,\n                        'test_name': test.test_name,\n                        'start_time': test.start_time.isoformat() if test.start_time else None,\n                        'status': test.status,\n                        'execution_time': test.execution_time,\n                        'error_message': test.error_message\n                    }\n                    active_tests_data.append(test_dict)\n\n                test_history_data = []\n                for test in test_history:\n                    test_dict = {\n                        'test_id': test.test_id,\n                        'test_name': test.test_name,\n                        'start_time': test.start_time.isoformat() if test.start_time else None,\n                        'end_time': test.end_time.isoformat() if test.end_time else None,\n                        'status': test.status,\n                        'execution_time': test.execution_time,\n                        'error_message': test.error_message\n                    }\n                    test_history_data.append(test_dict)\n\n                return jsonify({\n                    'success': True,\n                    'data': {\n                        'active_tests': active_tests_data,\n                        'test_history': test_history_data\n                    }\n                })\n            except Exception as e:\n                self.logger.error(f"获取测试信息失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n\n        @self.app.route('/api / tests / register', methods=['POST'])\n        def api_register_test():\n    """文档字符串"""\n            try:\n                data = request.get_json()\n                if not data:\n                    return jsonify({\n                        'success': False,\n                        'error': '无效的请求数据'\n                    })\n                test_id = data.get('test_id')\n                test_name = data.get('test_name')\n\n                if not test_id or not test_name:\n                    return jsonify({\n                        'success': False,\n                        'error': '缺少必需字段: test_id 或 test_name'\n                    })\n                # 注册测试\n                result = self.monitoring_system.register_test(test_id, test_name)\n\n                return jsonify({\n                    'success': True,\n                    'data': {\n                        'test_id': result}\n                })\n            except Exception as e:\n                self.logger.error(f"注册测试失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n\n        @self.app.route('/api / tests/<test_id>/status', methods=['PUT'])\n        def api_update_test_status(test_id):\n    """文档字符串"""\n            try:\n                data = request.get_json()\n                if not data:\n                    return jsonify({\n                        'success': False,\n                        'error': '无效的请求数据'\n                    })\n                status = data.get('status')\n                execution_time = data.get('execution_time')\n                error_message = data.get('error_message')\n\n                if not status:\n                    return jsonify({\n                        'success': False,\n                        'error': '缺少必需字段: status'\n                    })\n                # 更新测试状态\n                self.monitoring_system.update_test_status(\n                    test_id, status, execution_time, error_message)\n\n                return jsonify({\n                    'success': True,\n                    'message': f'测试 {test_id} 状态已更新'\n                })\n            except Exception as e:\n                self.logger.error(f"更新测试状态失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n\n        @self.app.route('/api / system / start', methods=['POST'])\n        def api_start_system():\n    """文档字符串"""\n            try:\n                if self.monitoring_system.running:\n                    return jsonify({\n                        'success': False,\n                        'error': '系统已在运行中'\n                    })\n                self.monitoring_system.start()\n                return jsonify({\n                    'success': True,\n                    'message': '系统已启动'\n                })\n            except Exception as e:\n                self.logger.error(f"启动系统失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n\n        @self.app.route('/api / system / stop', methods=['POST'])\n        def api_stop_system():\n    """文档字符串"""\n\n            try:\n                if not self.monitoring_system.running:\n                    return jsonify({\n                        'success': False,\n                        'error': '系统未在运行'\n                    })\n                self.monitoring_system.stop()\n                return jsonify({\n                    'success': True,\n                    'message': '系统已停止'\n                })\n            except Exception as e:\n                self.logger.error(f"停止系统失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n\n        # 配置管理API\n        @self.app.route('/api / config')\n        def api_config():\n    """文档字符串"""\n\n            try:\n                # 返回当前配置信息\n                config = {\n                    'system': {\n                        'update_interval': 5,\n                        'metrics_history_size': 1000,\n                        'network_latency_check_url': 'http://www.baidu.com',\n                        'network_latency_timeout': 5,\n                        'alert_check_interval': 10,\n                        'performance_report_interval': 60\n                    },\n                    'notifications': {\n                        'email': {\n                            'enabled': True,\n                            'smtp_server': 'smtp.gmail.com',\n                            'smtp_port': 587,\n                            'use_tls': True,\n                            'sender_email': 'admin@example.com',\n                            'recipient_emails': ['admin@example.com']\n                        },\n                        'webhook': {\n                            'enabled': False,\n                            'url': ''\n                        }\n                    },\n                    'logging': {\n                        'level': 'INFO',\n                        'file': 'logs/monitoring.log',\n                        'max_size': 100,\n                        'backup_count': 5,\n                        'format': '%(asctime)s - %(name)s - %(levelname)s - %(message)s'\n                    }\n                }\n                return jsonify({\n                    'success': True,\n                    'data': config\n                })\n            except Exception as e:\n                self.logger.error(f"获取配置失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n\n        @self.app.route('/api / config / system', methods=['POST'])\n        def api_config_system():\n    """文档字符串"""\n            try:\n                data = request.get_json()\n                if not data:\n                    return jsonify({\n                        'success': False,\n                        'error': '无效的请求数据'\n                    })\n                # 这里可以实现配置保存逻辑\n                self.logger.info(f"系统配置已更新: {data}")\n\n                return jsonify({\n                    'success': True,\n                    'message': '系统配置已保存'\n                })\n            except Exception as e:\n                self.logger.error(f"保存系统配置失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n\n        @self.app.route('/api / config / notifications', methods=['POST'])\n        def api_config_notifications():\n    """文档字符串"""\n\n            try:\n                data = request.get_json()\n                if not data:\n                    return jsonify({\n                        'success': False,\n                        'error': '无效的请求数据'\n                    })\n                # 这里可以实现通知配置保存逻辑\n                self.logger.info(f"通知配置已更新: {data}")\n\n                return jsonify({\n                    'success': True,\n                    'message': '通知配置已保存'\n                })\n            except Exception as e:\n                self.logger.error(f"保存通知配置失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n\n        @self.app.route('/api / config / logging', methods=['POST'])\n        def api_config_logging():\n    """文档字符串"""\n\n            try:\n                data = request.get_json()\n                if not data:\n                    return jsonify({\n                        'success': False,\n                        'error': '无效的请求数据'\n                    })\n                # 这里可以实现日志配置保存逻辑\n                self.logger.info(f"日志配置已更新: {data}")\n\n                return jsonify({\n                    'success': True,\n                    'message': '日志配置已保存'\n                })\n            except Exception as e:\n                self.logger.error(f"保存日志配置失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n\n        @self.app.route('/api / config / export')\n        def api_config_export():\n    """文档字符串"""\n\n            try:\n                format_type = request.args.get('format', 'json')\n\n                # 获取当前配置\n                config = {\n                    'system': {\n                        'update_interval': 5,\n                        'metrics_history_size': 1000\n                    }\n                }\n                if format_type == 'json':\n                    return Response(\n                        json.dumps(config, indent=2, ensure_ascii=False),\n                        mimetype='application / json',\n                        headers={'Content - Disposition': 'attachment; filename=monitoring_config.json'}\n                    )\n                elif format_type == 'yaml':\n                    import yaml\n                    return Response(\n                        yaml.dump(config, default_flow_style=False, allow_unicode=True),\n                        mimetype='text / yaml',\n                        headers={'Content - Disposition': 'attachment; filename=monitoring_config.yaml'}\n                    )\n                else:\n                    return jsonify({\n                        'success': False,\n                        'error': '不支持的导出格式'\n                    })\n            except Exception as e:\n                self.logger.error(f"导出配置失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n\n        @self.app.route('/api / config / import', methods=['POST'])\n        def api_config_import():\n    """文档字符串"""\n            try:\n                if 'config_file' not in request.files:\n                    return jsonify({\n                        'success': False,\n                        'error': '未找到配置文件'\n                    })\n                file = request.files['config_file']\n                if file.filename == '':\n                    return jsonify({\n                        'success': False,\n                        'error': '未选择文件'\n                    })\n                # 这里可以实现配置导入逻辑\n                self.logger.info(f"配置文件已导入: {file.filename}")\n\n                return jsonify({\n                    'success': True,\n                    'message': '配置文件导入成功'\n                })\n            except Exception as e:\n                self.logger.error(f"导入配置失败: {e}")\n                return jsonify({\n                    'success': False,\n                    'error': str(e)\n                })\n\n    def _start_background_updates(self):\n    """文档字符串"""\n\n        """启动后台更新线程"""\n\n        def background_update():\n    """文档字符串"""\n            while True:\n                try:\n                    if self.monitoring_system.running:\n                        # 获取系统状态和性能数据\n                        status = self.monitoring_system.get_system_status()\n                        performance = self.monitoring_system.get_performance_report(60)\n\n                        # 通过SocketIO发送实时更新\n                        self.socketio.emit('system_status_update', status)\n                        self.socketio.emit('performance_update', performance)\n\n                except Exception as e:\n                    self.logger.error(f"后台更新失败: {e}")\n\n                time.sleep(5)  # 每5秒更新一次\n\n        self._background_thread = threading.Thread(target=background_update, daemon=True)\n        self._background_thread.start()\n\n    def run(self, host='0.0.0.0', port=5000, debug=False):\n    """文档字符串"""\n\n        """启动Web服务器"""\n        self.logger.info(f"启动Web管理界面服务器: http://{host}:{port}")\n        self.socketio.run(self.app, host=host, port=port, debug=debug)\n\ndef create_web_interface(monitoring_system: Optional[MonitoringAlertSystem] = None) -> WebManagementInterface:\n    """文档字符串"""\n\n    """创建Web管理界面实例"""\n    return WebManagementInterface(monitoring_system)\n\ndef start_web_interface(host: str = '0.0.0.0', port: int = 5000, debug: bool = False) -> WebManagementInterface:\n    """文档字符串"""\n\n    """创建并启动Web管理界面"""\n    interface = create_web_interface()\n    interface.run(host=host, port=port, debug=debug)\n    return interface\n\nif __name__ == '__main__':\n    # 创建并启动Web管理界面\n    interface = create_web_interface()\n    interface.run(debug=True)\n\nclass IWebManagementComponent:\n\n    """Web管理接口"""\n\n    def get_status(self):\n    """文档字符串"""\n\n        """获取状态"""\n        pass\n\n    def perform_health_check(self):\n    """文档字符串"""\n\n        """执行健康检查"""\n        pass\n\n    def get_system_info(self):\n    """文档字符串"""\n\n        """获取系统信息"""\n        pass\n