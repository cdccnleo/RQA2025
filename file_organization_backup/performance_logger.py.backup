import logging\n\n#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\n引擎层性能日志记录器\n提供专门的性能监控和指标收集功能\n"""\n\nimport time\nimport threading\nfrom typing import Dict, Any, Optional, List, Callable\nfrom dataclasses import dataclass, field\nfrom enum import Enum\nfrom contextlib import contextmanager\n\nfrom .core_logger import EngineLogger, LogLevel, LogCategory\n\nclass PerformanceMetric(Enum):\n\n    """性能指标类型"""\n    LATENCY = "latency"\n    THROUGHPUT = "throughput"\n    MEMORY_USAGE = "memory_usage"\n    CPU_USAGE = "cpu_usage"\n    ERROR_RATE = "error_rate"\n    SUCCESS_RATE = "success_rate"\n\n@dataclass\n\nclass PerformanceData:\n\n    """性能数据"""\n    metric_name: str\n    value: float\n    unit: str\n    timestamp: float\n    component: str\n    operation: str\n    metadata: Dict[str, Any] = field(default_factory=dict)\n\nclass PerformanceLogger:\n\n    """性能日志记录器"""\n\n    def __init__(self, logger: EngineLogger, config: Dict[str, Any] = None):\n\n        """初始化性能日志记录器\n\n        Args:\n            logger: 引擎日志记录器\n            config: 配置字典\n        """\n        logger = logging.getLogger(__name__)\n        self.config = config or {}\n\n        # 性能数据缓存\n        self._performance_cache = {}\n        self._cache_lock = threading.RLock()\n\n        # 阈值配置\n        self._thresholds = self.config.get('thresholds', {})\n\n        # 采样率\n        self._sampling_rate = self.config.get('sampling_rate', 1.0)\n\n        # 性能统计\n        self._stats = {\n            'total_metrics': 0,\n            'threshold_violations': 0,\n            'avg_latency': 0.0,\n            'max_latency': 0.0,\n            'min_latency': float('inf')\n        }\n\n    def log_metric(self, metric_name: str, value: float, unit: str = "",\n    """文档字符串"""\n\n                   component: str = "", operation: str = "", **kwargs):\n        """记录性能指标"""\n        try:\n            # 采样检查\n            if not self._should_sample():\n                return\n\n            # 创建性能数据\n            performance_data = PerformanceData(\n                metric_name=metric_name,\n                value=value,\n                unit=unit,\n                timestamp=time.time(),\n                component=component,\n                operation=operation,\n                metadata=kwargs\n            )\n\n            # 记录性能日志\n            self.logger.performance_log(\n                f"性能指标: {metric_name} = {value} {unit}",\n                {\n                    'metric_name': metric_name,\n                    'value': value,\n                    'unit': unit,\n                    'component': component,\n                    'operation': operation,\n                    **kwargs\n                }\n            )\n\n            # 更新统计信息\n            self._update_stats(performance_data)\n\n            # 检查阈值\n            self._check_thresholds(performance_data)\n\n            # 缓存数据\n            self._cache_performance_data(performance_data)\n\n        except Exception as e:\n            self.logger.error(f"记录性能指标失败: {e}", exception=e)\n\n    def log_latency(self, operation: str, latency: float, component: str = "", **kwargs):\n    """文档字符串"""\n\n        """记录延迟指标"""\n        self.log_metric(\n            metric_name="latency",\n            value=latency,\n            unit="ms",\n            component=component,\n            operation=operation,\n            **kwargs\n        )\n\n    def log_throughput(self, operation: str, count: int, duration: float,\n    """文档字符串"""\n\n                       component: str = "", **kwargs):\n        """记录吞吐量指标"""\n        throughput = count / duration if duration > 0 else 0\n        self.log_metric(\n            metric_name="throughput",\n            value=throughput,\n            unit="ops / s",\n            component=component,\n            operation=operation,\n            count=count,\n            duration=duration,\n            **kwargs\n        )\n\n    def log_memory_usage(self, component: str, memory_mb: float, **kwargs):\n    """文档字符串"""\n\n        """记录内存使用指标"""\n        self.log_metric(\n            metric_name="memory_usage",\n            value=memory_mb,\n            unit="MB",\n            component=component,\n            operation="memory_monitoring",\n            **kwargs\n        )\n\n    def log_cpu_usage(self, component: str, cpu_percent: float, **kwargs):\n    """文档字符串"""\n\n        """记录CPU使用指标"""\n        self.log_metric(\n            metric_name="cpu_usage",\n            value=cpu_percent,\n            unit="%",\n            component=component,\n            operation="cpu_monitoring",\n            **kwargs\n        )\n\n    def log_error_rate(self, component: str, error_count: int, total_count: int, **kwargs):\n    """文档字符串"""\n\n        """记录错误率指标"""\n        error_rate = (error_count / total_count * 100) if total_count > 0 else 0\n        self.log_metric(\n            metric_name="error_rate",\n            value=error_rate,\n            unit="%",\n            component=component,\n            operation="error_monitoring",\n            error_count=error_count,\n            total_count=total_count,\n            **kwargs\n        )\n\n    @contextmanager\n\n    def measure_latency(self, operation: str, component: str = "", **kwargs):\n    """文档字符串"""\n\n        """测量延迟的上下文管理器"""\n        start_time = time.time()\n        try:\n            yield\n        finally:\n            latency = (time.time() - start_time) * 1000  # 转换为毫秒\n            self.log_latency(operation, latency, component, **kwargs)\n\n    def set_threshold(self, metric_name: str, threshold: float,\n    """文档字符串"""\n\n                      condition: str = "greater_than"):\n        """设置性能阈值\n\n        Args:\n            metric_name: 指标名称\n            threshold: 阈值\n            condition: 条件 (greater_than, less_than, equals)\n        """\n        self._thresholds[metric_name] = {\n            'value': threshold,\n            'condition': condition\n        }\n\n    def get_threshold(self, metric_name: str) -> Optional[Dict[str, Any]]:\n    """文档字符串"""\n\n        """获取性能阈值"""\n        return self._thresholds.get(metric_name)\n\n    def _should_sample(self) -> bool:\n    """文档字符串"""\n\n        """检查是否应该采样"""\n        import random\n        return random.random() <= self._sampling_rate\n\n    def _update_stats(self, performance_data: PerformanceData):\n    """文档字符串"""\n\n        """更新统计信息"""\n        with self._cache_lock:\n            self._stats['total_metrics'] += 1\n\n        if performance_data.metric_name == 'latency':\n            self._stats['avg_latency'] = (\n                (self._stats['avg_latency'] * (self._stats['total_metrics'] - 1)\n                 + performance_data.value) / self._stats['total_metrics']\n            )\n            self._stats['max_latency'] = max(self._stats['max_latency'], performance_data.value)\n            self._stats['min_latency'] = min(self._stats['min_latency'], performance_data.value)\n\n    def _check_thresholds(self, performance_data: PerformanceData):\n    """文档字符串"""\n\n        """检查阈值"""\n        threshold_config = self._thresholds.get(performance_data.metric_name)\n        if not threshold_config:\n            return\n\n        threshold_value = threshold_config['value']\n        condition = threshold_config['condition']\n        current_value = performance_data.value\n\n        violation = False\n        if condition == "greater_than" and current_value > threshold_value:\n            violation = True\n        elif condition == "less_than" and current_value < threshold_value:\n            violation = True\n        elif condition == "equals" and current_value == threshold_value:\n            violation = True\n\n        if violation:\n            with self._cache_lock:\n                self._stats['threshold_violations'] += 1\n\n            self.logger.warning(\n                f"性能阈值违反: {performance_data.metric_name} = {current_value} "\n                f"{performance_data.unit} {condition} {threshold_value}",\n                component=performance_data.component,\n                operation=performance_data.operation,\n                threshold_violation=True,\n                threshold_value=threshold_value,\n                current_value=current_value\n            )\n\n    def _cache_performance_data(self, performance_data: PerformanceData):\n    """文档字符串"""\n\n        """缓存性能数据"""\n        with self._cache_lock:\n            if performance_data.component not in self._performance_cache:\n                self._performance_cache[performance_data.component] = []\n\n            self._performance_cache[performance_data.component].append(performance_data)\n\n            # 限制缓存大小\n            max_cache_size = self.config.get('max_cache_size', 1000)\n            if len(self._performance_cache[performance_data.component]) > max_cache_size:\n                self._performance_cache[performance_data.component] = \\n                    self._performance_cache[performance_data.component][-max_cache_size:]\n\n    def get_performance_stats(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """获取性能统计信息"""\n        with self._cache_lock:\n            return self._stats.copy()\n\n    def get_cached_data(self, component: str = None,\n    """文档字符串"""\n\n                        time_range: float = None) -> List[PerformanceData]:\n        """获取缓存的性能数据"""\n        with self._cache_lock:\n            if component:\n                data = self._performance_cache.get(component, [])\n            else:\n                data = []\n                for comp_data in self._performance_cache.values():\n                    data.extend(comp_data)\n\n            if time_range:\n                current_time = time.time()\n                data = [d for d in data if current_time - d.timestamp <= time_range]\n\n            return data\n\n    def clear_cache(self, component: str = None):\n    """文档字符串"""\n\n        """清理缓存"""\n        with self._cache_lock:\n            if component:\n                self._performance_cache.pop(component, None)\n            else:\n                self._performance_cache.clear()\n\n    def health_check(self) -> Dict[str, Any]:\n    """文档字符串"""\n\n        """健康检查"""\n        try:\n            return {\n                'status': 'healthy',\n                'total_metrics': self._stats['total_metrics'],\n                'threshold_violations': self._stats['threshold_violations'],\n                'cache_size': sum(len(data) for data in self._performance_cache.values()),\n                'sampling_rate': self._sampling_rate,\n                'threshold_count': len(self._thresholds)\n            }\n        except Exception as e:\n            return {\n                'status': 'error',\n                'error': str(e)\n            }\n