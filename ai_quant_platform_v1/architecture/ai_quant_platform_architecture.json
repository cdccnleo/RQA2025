    "data_flow_design": {
      "real_time_data_flow": {
        "source": "市场数据API，交易所接口，新闻源",
        "processing": "数据清洗 → 格式化 → 验证 → 分发",
        "destination": "缓存层 → 计算引擎 → 用户界面",
        "latency_requirement": "<100ms端到端延迟"
      },
      "batch_data_flow": {
        "source": "历史数据文件，批量更新，系统日志",
        "processing": "数据提取 → 转换 → 加载 → 索引",
        "destination": "数据仓库 → 分析数据库 → 备份存储",
        "throughput_requirement": ">1GB/分钟处理能力"
