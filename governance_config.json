{
  "version": "1.0",
  "enabled_checks": [
    "import_standards",
    "naming_conventions",
    "architecture_patterns",
    "code_quality",
    "interface_implementation",
    "dependency_analysis"
  ],
  "severity_levels": {
    "high": [
      "wildcard_imports",
      "missing_interface_inheritance",
      "missing_interface_methods"
    ],
    "medium": [
      "long_imports",
      "naming_violations",
      "architecture_violations"
    ],
    "low": [
      "unordered_imports",
      "quality_violations"
    ]
  },
  "automated_fixes": {
    "import_sorting": true,
    "naming_standardization": false,
    "interface_inheritance": false
  },
  "reporting": {
    "console_output": true,
    "json_report": true,
    "html_report": false,
    "email_notifications": false
  }
}