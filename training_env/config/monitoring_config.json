{
  "performance_monitoring": {
    "enabled": true,
    "interval": 60,
    "metrics": [
      "cpu",
      "memory",
      "response_time"
    ]
  },
  "alerting": {
    "enabled": true,
    "email": "",
    "thresholds": {
      "cpu_usage": 80,
      "memory_usage": 85,
      "response_time": 5000
    }
  },
  "logging": {
    "level": "INFO",
    "rotation": "daily",
    "retention": 30
  }
}