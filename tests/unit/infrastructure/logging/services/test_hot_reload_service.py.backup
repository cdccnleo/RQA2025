"""
Hot Reload Service 单元测试

测试热重载服务功能。
"""

import pytest
from unittest.mock import Mock, MagicMock, patch, call
from datetime import datetime
import time
import threading
from pathlib import Path
import tempfile
import os

from src.infrastructure.logging.services.hot_reload_service import HotReloadService


class TestHotReloadService:
    """测试热重载服务"""

    @pytest.fixture
    def temp_config_file(self):
        """创建临时配置文件"""
        with tempfile.NamedTemporaryFile(mode='w', suffix='.json', delete=False) as f:
            f.write('{"service": "test", "version": "1.0"}')
            temp_file = f.name

        yield temp_file

        # 清理
        try:
            os.unlink(temp_file)
        except:
            pass

    @pytest.fixture
    def hot_reload_service(self):
        """创建热重载服务实例"""
        return HotReloadService()

    def test_init_default(self, hot_reload_service):
        """测试默认初始化"""
        assert hot_reload_service.watch_paths == []
        assert hot_reload_service._callbacks == {}
        assert hot_reload_service._running is False
        assert hot_reload_service._thread is None
        assert hot_reload_service._file_timestamps == {}
        assert hot_reload_service.reload_interval == 1.0

    def test_init_with_config(self):
        """测试带配置初始化"""
        watch_paths = ['/etc/config', '/var/log']
        reload_interval = 2.5

        service = HotReloadService(watch_paths, reload_interval)

        assert service.watch_paths == ['/etc/config', '/var/log']
        assert service.reload_interval == 2.5

    def test_add_watch_path(self, hot_reload_service):
        """测试添加监视路径"""
        hot_reload_service.add_watch_path('/etc/nginx/nginx.conf')
        assert '/etc/nginx/nginx.conf' in hot_reload_service.watch_paths

        # 添加重复路径
        hot_reload_service.add_watch_path('/etc/nginx/nginx.conf')
        assert hot_reload_service.watch_paths.count('/etc/nginx/nginx.conf') == 1

    def test_remove_watch_path(self, hot_reload_service):
        """测试移除监视路径"""
        hot_reload_service.add_watch_path('/etc/app/config.json')
        assert '/etc/app/config.json' in hot_reload_service.watch_paths

        hot_reload_service.remove_watch_path('/etc/app/config.json')
        assert '/etc/app/config.json' not in hot_reload_service.watch_paths

        # 移除不存在的路径
        hot_reload_service.remove_watch_path('/nonexistent/path')
        # 应该不会出错

    def test_add_callback(self, hot_reload_service):
        """测试添加回调函数"""
        def test_callback(changed_files):
            pass

        hot_reload_service.register_callback('*.json', test_callback)
        assert test_callback in hot_reload_service._callbacks['*.json']

        # 添加多个回调
        def another_callback(changed_files):
            pass

        hot_reload_service.register_callback('*.yaml', another_callback)
        assert len(hot_reload_service._callbacks) == 2

    def test_remove_callback(self, hot_reload_service):
        """测试移除回调函数"""
        def callback_to_remove(changed_files):
            pass

        hot_reload_service.register_callback('*.json', callback_to_remove)
        assert callback_to_remove in hot_reload_service._callbacks['*.json']

        hot_reload_service.unregister_callback('*.json', callback_to_remove)
        assert callback_to_remove not in hot_reload_service._callbacks['*.json']

        # 移除不存在的回调
        def nonexistent_callback(changed_files):
            pass

        hot_reload_service.unregister_callback('*.json', nonexistent_callback)
        # 应该不会出错

    def test_start_service(self, hot_reload_service):
        """测试启动服务"""
        assert not hot_reload_service._running
        assert hot_reload_service._thread is None

        hot_reload_service.start()

        assert hot_reload_service._running is True
        assert hot_reload_service._thread is not None
        assert hot_reload_service._thread.is_alive()

        # 再次启动应该没有效果
        original_thread = hot_reload_service._thread
        hot_reload_service.start()
        assert hot_reload_service._thread == original_thread

    def test_stop_service(self, hot_reload_service):
        """测试停止服务"""
        hot_reload_service.start()
        assert hot_reload_service._running is True

        hot_reload_service.stop()
        assert hot_reload_service._running is False
        assert hot_reload_service._thread is not None  # 线程对象还在，只是停止了
        assert not hot_reload_service._thread.is_alive()

        # 再次停止应该没有效果
        hot_reload_service.stop()
        assert hot_reload_service._running is False

    @patch('time.sleep')
    def test_watch_loop_file_change(self, mock_sleep, hot_reload_service, temp_config_file):
        """测试监视循环中的文件变化检测"""
        # 添加监视路径和回调
        hot_reload_service.add_watch_path(temp_config_file)

        callback_called = []
        def test_callback(file_path, event_type):
            callback_called.append((file_path, event_type))

        hot_reload_service.register_callback('*.json', test_callback)

        # 启动服务
        hot_reload_service.start()

        # 等待初始化
        time.sleep(0.1)

        # 修改文件
        with open(temp_config_file, 'w') as f:
            f.write('{"service": "test", "version": "2.0"}')

        # 等待检测
        time.sleep(1.5)

        # 停止服务
        hot_reload_service.stop()

        # 验证回调被调用
        assert len(callback_called) > 0
        assert temp_config_file in callback_called[0]

    @patch('time.sleep')
    def test_watch_loop_no_change(self, mock_sleep, hot_reload_service, temp_config_file):
        """测试监视循环中没有文件变化的情况"""
        # 添加监视路径和回调
        hot_reload_service.add_watch_path(temp_config_file)

        callback_called = []
        def test_callback(file_path, event_type):
            callback_called.append((file_path, event_type))

        hot_reload_service.register_callback('*.json', test_callback)

        # 启动服务
        hot_reload_service.start()

        # 等待几秒
        time.sleep(2.5)

        # 停止服务
        hot_reload_service.stop()

        # 验证回调没有被调用（除了初始状态）
        # 注意：第一次检测时会记录初始状态，但不应该触发回调
        initial_calls = len(callback_called)

        # 等待更多时间确认没有新调用
        time.sleep(1.0)
        assert len(callback_called) == initial_calls

    def test_get_watched_files(self, hot_reload_service):
        """测试获取被监视的文件"""
        paths = [
            '/etc/config/app.json',
            '/var/log/app.log',
            '/home/user/.config/settings.yaml'
        ]

        for path in paths:
            hot_reload_service.add_watch_path(path)

        watched = hot_reload_service.watch_paths
        assert set(watched) == set(paths)

