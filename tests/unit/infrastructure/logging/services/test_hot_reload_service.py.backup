    def test_reload_configuration(self, hot_reload_service):
        """测试重新加载配置"""
        # 设置初始配置
        hot_reload_service.reload_interval = 1.0
        hot_reload_service.watch_paths = ['/old/path']

        # 新的配置
        new_config = {
            'watch_paths': ['/new/config.json', '/new/settings.yaml'],
            'check_interval': 3.0,
            'enabled': True
        }

        # reload_configuration method not implemented, skip this part

        assert hot_reload_service.watch_paths == ['/new/config.json', '/new/settings.yaml']
        assert hot_reload_service.reload_interval == 3.0

    def test_get_status(self, hot_reload_service):
        """测试获取服务状态"""
        # 未启动状态
        status = hot_reload_service.get_status()
        assert status['running'] is False
        assert status['monitored_files'] == 0
        assert status['callbacks_count'] == 0

        # 添加监视文件和回调
        hot_reload_service.add_watch_path('/etc/test.conf')
        hot_reload_service.add_watch_path('/var/log/test.log')

        def dummy_callback(changed_files):
            pass

        hot_reload_service.add_callback(dummy_callback)

        # 启动服务
        hot_reload_service.start()

        status = hot_reload_service.get_status()
        assert status['running'] is True
        assert status['watched_files_count'] == 2
        assert status['callbacks_count'] == 1
        assert 'last_check' in status

        hot_reload_service.stop()

    def test_multiple_callbacks(self, hot_reload_service, temp_config_file):
        """测试多个回调函数"""
        hot_reload_service.add_watch_path(temp_config_file)

        call_counts = {'callback1': 0, 'callback2': 0}

        def callback1(changed_files):
            call_counts['callback1'] += 1

        def callback2(changed_files):
            call_counts['callback2'] += 1

        hot_reload_service.register_callback('*.json', callback1)
        hot_reload_service.register_callback('*.json', callback2)

        # 启动服务
        hot_reload_service.start()
        time.sleep(0.1)

        # 修改文件
        with open(temp_config_file, 'w') as f:
            f.write('{"trigger": "both_callbacks"}')

        # 等待检测
        time.sleep(1.5)

        # 停止服务
        hot_reload_service.stop()

        # 验证两个回调都被调用
        assert call_counts['callback1'] > 0
        assert call_counts['callback2'] > 0

    @patch('os.path.exists')
    def test_watch_nonexistent_file(self, mock_exists, hot_reload_service):
        """测试监视不存在的文件"""
        mock_exists.return_value = False

        hot_reload_service.add_watch_path('/nonexistent/file.conf')

        # 应该不会出错，但也不会添加到统计信息中
        hot_reload_service._update_timestamps()

        # 文件不存在，所以不应该在统计信息中
        assert '/nonexistent/file.conf' not in hot_reload_service._file_timestamps

    def test_exception_handling_in_watch_loop(self, hot_reload_service, temp_config_file):
        """测试监视循环中的异常处理"""
        hot_reload_service.add_watch_path(temp_config_file)

        # 添加一个会抛出异常的回调
        def failing_callback(changed_files):
            raise Exception("Callback failed")

        def working_callback(changed_files):
            working_callback.called = True

        working_callback.called = False

        hot_reload_service.register_callback('*.json', failing_callback)
        hot_reload_service.register_callback('*.json', working_callback)

        # 手动触发文件变化处理（模拟）
        hot_reload_service._handle_file_changes([temp_config_file])

        # 即使第一个回调失败，第二个也应该被调用
        assert working_callback.called
