    def test_model_retraining_trigger_detection(self, model_validator):
        """测试模型重训练触发检测"""
        # 模拟模型性能指标时间序列
        performance_metrics = {
            'accuracy': [0.85, 0.83, 0.81, 0.79, 0.76, 0.74],
            'precision': [0.82, 0.80, 0.78, 0.75, 0.73, 0.70],
            'data_drift_score': [0.02, 0.05, 0.08, 0.12, 0.15, 0.18]
        }

        # 重训练触发规则
        retraining_rules = {
            'accuracy_threshold': 0.80,
            'drift_threshold': 0.10,
            'consecutive_degrades': 3
        }

        retraining_decision = model_validator.detect_retraining_trigger(
            performance_metrics, retraining_rules
        )

        assert isinstance(retraining_decision, dict)
        assert 'retraining_required' in retraining_decision
        assert 'trigger_reason' in retraining_decision
        assert 'urgency_level' in retraining_decision
        assert retraining_decision['retraining_required'] is True

    def test_model_fallback_mechanism(self, model_validator):
        """测试模型降级机制"""
        # 模拟主模型失败的情况
        primary_model_status = {
            'status': 'failed',
            'error': 'Model prediction timeout',
            'last_successful_prediction': datetime.now() - timedelta(minutes=30)
        }

        # 降级选项
        fallback_options = {
            'simple_rule_based': {'available': True, 'accuracy': 0.75},
            'cached_predictions': {'available': True, 'freshness': 300},  # 5分钟
            'ensemble_fallback': {'available': False, 'reason': 'not_trained'}
        }

        fallback_decision = model_validator.select_fallback_mechanism(
            primary_model_status, fallback_options
        )

        assert isinstance(fallback_decision, dict)
        assert 'fallback_selected' in fallback_decision
        assert 'selected_mechanism' in fallback_decision
        assert 'expected_performance' in fallback_decision

