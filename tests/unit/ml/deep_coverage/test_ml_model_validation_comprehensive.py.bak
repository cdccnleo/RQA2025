    def test_walk_forward_validation(self, model_validator):
        """测试步进式验证"""
        # 创建模拟的训练数据
        dates = pd.date_range('2020-01-01', '2023-01-01', freq='D')
        np.random.seed(42)
        features = pd.DataFrame({
            'feature_1': np.random.randn(len(dates)),
            'feature_2': np.random.randn(len(dates)),
            'feature_3': np.random.randn(len(dates))
        }, index=dates)

        targets = pd.Series(
            np.random.randn(len(dates)) + 0.1 * features['feature_1'],
            index=dates
        )

        # 执行步进式验证
        validation_results = model_validator.walk_forward_validation(
            features, targets,
            train_window=252,  # 一年交易日
            test_window=21,    # 一个月的交易日
            step_size=21       # 每月步进
        )

        assert isinstance(validation_results, dict)
        assert 'fold_results' in validation_results
        assert 'overall_metrics' in validation_results
        assert len(validation_results['fold_results']) > 0

    def test_cross_validation_with_temporal_splitting(self, model_validator):
        """测试时序交叉验证"""
        # 创建时间序列数据
        dates = pd.date_range('2020-01-01', periods=1000, freq='D')
        features = pd.DataFrame({
            'x1': np.sin(np.arange(1000) * 0.1) + np.random.randn(1000) * 0.1,
            'x2': np.cos(np.arange(1000) * 0.1) + np.random.randn(1000) * 0.1,
        }, index=dates)

        targets = pd.Series(
            features['x1'] * 2 + features['x2'] * 1.5 + np.random.randn(1000) * 0.1,
            index=dates
        )

        cv_results = model_validator.temporal_cross_validation(
            features, targets, n_splits=5
        )

        assert isinstance(cv_results, dict)
        assert 'cv_scores' in cv_results
        assert 'mean_score' in cv_results
        assert 'std_score' in cv_results
        assert len(cv_results['cv_scores']) == 5

    def test_model_stability_assessment(self, model_validator):
        """测试模型稳定性评估"""
        # 创建多个模型预测结果
        np.random.seed(42)
        n_samples = 1000
        n_models = 5

        predictions = {}
        for i in range(n_models):
            predictions[f'model_{i}'] = np.random.randn(n_samples) + i * 0.1

        actuals = np.random.randn(n_samples)

        stability_results = model_validator.assess_model_stability(
            predictions, actuals
        )

        assert isinstance(stability_results, dict)
        assert 'stability_score' in stability_results
        assert 'prediction_consistency' in stability_results
        assert 'model_agreement' in stability_results

    def test_overfitting_detection(self, model_validator):
        """测试过拟合检测"""
        # 模拟训练和测试性能
        training_scores = [0.95, 0.96, 0.97, 0.98, 0.99]  # 训练分数不断提高
        validation_scores = [0.85, 0.82, 0.78, 0.75, 0.70]  # 验证分数不断下降

        overfitting_analysis = model_validator.detect_overfitting(
            training_scores, validation_scores
        )

        assert isinstance(overfitting_analysis, dict)
        assert 'is_overfitting' in overfitting_analysis
        assert 'overfitting_severity' in overfitting_analysis
        assert 'recommended_action' in overfitting_analysis
        assert overfitting_analysis['is_overfitting'] is True

    def test_feature_importance_stability(self, model_validator):
        """测试特征重要性稳定性"""
        # 模拟多次训练的特征重要性
        n_features = 10
        n_iterations = 5

        feature_importances = []
        for i in range(n_iterations):
            importance = np.random.exponential(1, n_features)
            importance = importance / importance.sum()  # 归一化
            feature_importances.append(importance)

        feature_names = [f'feature_{i}' for i in range(n_features)]

        stability_analysis = model_validator.analyze_feature_importance_stability(
            feature_importances, feature_names
        )

        assert isinstance(stability_analysis, dict)
        assert 'stable_features' in stability_analysis
        assert 'unstable_features' in stability_analysis
        assert 'importance_consistency' in stability_analysis

    def test_model_calibration_assessment(self, model_validator):
        """测试模型校准评估"""
        # 创建预测概率和实际标签
        np.random.seed(42)
        n_samples = 10000

        # 生成校准良好的预测
        true_probs = np.random.beta(2, 2, n_samples)  # Beta分布，更集中
        predictions = true_probs + np.random.normal(0, 0.1, n_samples)
        predictions = np.clip(predictions, 0, 1)  # 确保在[0,1]范围内

        actuals = np.random.binomial(1, true_probs)

        calibration_results = model_validator.assess_model_calibration(
            predictions, actuals
        )

        assert isinstance(calibration_results, dict)
        assert 'calibration_curve' in calibration_results
        assert 'brier_score' in calibration_results
        assert 'calibration_error' in calibration_results

    def test_adversarial_robustness_testing(self, model_validator):
        """测试对抗鲁棒性"""
        # 创建基础数据
        np.random.seed(42)
        n_samples = 1000
        n_features = 5

        X = np.random.randn(n_samples, n_features)
        y = (X[:, 0] + X[:, 1] > 0).astype(int)

        # 生成对抗样本
        adversarial_samples = X + np.random.normal(0, 0.1, X.shape)

        robustness_results = model_validator.test_adversarial_robustness(
            X, y, adversarial_samples
        )

        assert isinstance(robustness_results, dict)
        assert 'robustness_score' in robustness_results
        assert 'adversarial_accuracy' in robustness_results
        assert 'perturbation_sensitivity' in robustness_results

    def test_model_explainability_validation(self, model_validator):
        """测试模型可解释性验证"""
        # 创建模拟的SHAP值
        np.random.seed(42)
        n_samples = 100
        n_features = 5

        shap_values = np.random.randn(n_samples, n_features)
        feature_names = [f'feature_{i}' for i in range(n_features)]

        explainability_results = model_validator.validate_model_explainability(
            shap_values, feature_names
        )

        assert isinstance(explainability_results, dict)
        assert 'explainability_score' in explainability_results
        assert 'feature_contributions' in explainability_results
        assert 'interpretability_metrics' in explainability_results

    def test_data_drift_detection(self, model_validator):
        """测试数据漂移检测"""
        # 创建基准数据分布
        np.random.seed(42)
        n_samples = 1000
        n_features = 3

        baseline_data = np.random.normal(0, 1, (n_samples, n_features))

        # 创建有漂移的新数据
        drifted_data = np.random.normal(0.5, 1.2, (n_samples, n_features))  # 均值和方差都改变

        drift_results = model_validator.detect_data_drift(
            baseline_data, drifted_data
        )

        assert isinstance(drift_results, dict)
        assert 'drift_detected' in drift_results
        assert 'drift_severity' in drift_results
        assert 'feature_drift_scores' in drift_results
        assert drift_results['drift_detected'] is True

    def test_model_performance_decay_analysis(self, model_validator):
        """测试模型性能衰减分析"""
        # 模拟模型随时间性能衰减
        time_periods = pd.date_range('2023-01-01', periods=12, freq='M')

        # 性能随时间衰减
        base_performance = 0.85
        decay_rate = 0.02  # 每月衰减2%

        performance_history = []
        for i, period in enumerate(time_periods):
            performance = base_performance * (1 - decay_rate) ** i
            performance_history.append({
                'period': period,
                'accuracy': performance,
                'precision': performance - 0.05,
                'recall': performance - 0.03
            })

        decay_analysis = model_validator.analyze_performance_decay(
            performance_history
        )

        assert isinstance(decay_analysis, dict)
        assert 'decay_detected' in decay_analysis
        assert 'decay_rate' in decay_analysis
        assert 'retraining_trigger' in decay_analysis
        assert decay_analysis['decay_detected'] is True

