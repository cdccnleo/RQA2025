#!/usr/bin/env python3
"""
CI/CD集成工具基础测试用例

测试CICDTools类的基本功能
"""

import pytest
import tempfile
import os
from pathlib import Path
from unittest.mock import Mock, patch, MagicMock
from datetime import datetime
from src.tools.core.ci_cd_integration import (

CICDTools,
    PipelineResult,
    QualityGate
)

# 设置测试超时，避免死锁和无限等待
pytestmark = [
    pytest.mark.timeout(30),  # 30秒超时
    pytest.mark.deadlock_risk,  # 标记为可能存在死锁风险
    pytest.mark.concurrent,  # 并发测试
    pytest.mark.infinite_loop_risk  # 可能存在无限循环风险
]




class TestCICDToolsBasic:
    """CI/CD集成工具基础测试类"""

    @pytest.fixture
    def ci_cd_tools(self):
        """CI/CD工具实例"""
        return CICDTools()

    def test_initialization(self, ci_cd_tools):
        """测试初始化"""
        assert ci_cd_tools.pipeline_results is not None
        assert ci_cd_tools.quality_gates is not None
        assert isinstance(ci_cd_tools.pipeline_results, dict)
        assert isinstance(ci_cd_tools.quality_gates, dict)

        # 验证默认质量门禁已设置
        assert len(ci_cd_tools.quality_gates) > 0

    def test_pipeline_result_creation(self):
        """测试流水线结果创建"""
        pipeline_id = "test_pipeline_123"
        stage = "test_stage"
        start_time = datetime.now()

        result = PipelineResult(
            pipeline_id=pipeline_id,
            stage=stage,
            status="running",
            start_time=start_time
        )

        assert result.pipeline_id == pipeline_id
        assert result.stage == stage
        assert result.status == "running"
        assert result.start_time == start_time
        assert result.end_time is None
        assert result.duration_seconds is None
        assert isinstance(result.logs, list)
        assert isinstance(result.artifacts, dict)
        assert isinstance(result.metrics, dict)

    def test_quality_gate_creation(self):
        """测试质量门禁创建"""
        gate_id = "test_gate_123"
        name = "Test Quality Gate"
        conditions = {
            "coverage_threshold": 80.0,
            "test_pass_rate": 95.0
        }

        gate = QualityGate(
            gate_id=gate_id,
            name=name,
            conditions=conditions,
            enabled=True
        )

        assert gate.gate_id == gate_id
        assert gate.name == name
        assert gate.conditions == conditions
        assert gate.enabled is True

    @patch('subprocess.run')
    def test_run_pipeline_stage_success(self, mock_subprocess, ci_cd_tools):
        """测试运行流水线阶段成功"""
        # Mock subprocess.run
        mock_process = MagicMock()
        mock_process.returncode = 0
        mock_process.stdout = "Test output"
        mock_process.stderr = ""
        mock_subprocess.return_value = mock_process

        stage_name = "test_stage"
        commands = ["echo 'Hello World'", "python --version"]

        result = ci_cd_tools.run_pipeline_stage(stage_name, commands)

        assert result.stage == stage_name
        assert result.status == "success"
        assert result.end_time is not None
        assert result.duration_seconds is not None
        assert len(result.logs) > 0

        # 验证命令被执行
        assert mock_subprocess.call_count == len(commands)

    @patch('subprocess.run')
    def test_run_pipeline_stage_failure(self, mock_subprocess, ci_cd_tools):
        """测试运行流水线阶段失败"""
        # Mock subprocess.run to fail
        mock_process = MagicMock()
        mock_process.returncode = 1
        mock_process.stdout = ""
        mock_process.stderr = "Command failed"
        mock_subprocess.return_value = mock_process

        stage_name = "failing_stage"
        commands = ["failing_command"]

        result = ci_cd_tools.run_pipeline_stage(stage_name, commands)

        assert result.stage == stage_name
        assert result.status == "failure"
        assert result.end_time is not None
        assert result.duration_seconds is not None

    def test_get_pipeline_result(self, ci_cd_tools):
        """测试获取流水线结果"""
        # 先运行一个流水线
        stage_name = "test_stage"
        commands = ["echo 'test'"]

        # Mock the _run_command method
        with patch.object(ci_cd_tools, '_run_command') as mock_run:
            mock_run.return_value = {
                'return_code': 0,
                'logs': ['Command executed successfully']
            }

            result = ci_cd_tools.run_pipeline_stage(stage_name, commands)

            # 获取结果
            retrieved_result = ci_cd_tools.get_pipeline_result(result.pipeline_id)

            assert retrieved_result is not None
            assert retrieved_result.pipeline_id == result.pipeline_id
            assert retrieved_result.stage == stage_name

    def test_get_pipeline_result_nonexistent(self, ci_cd_tools):
        """测试获取不存在的流水线结果"""
        result = ci_cd_tools.get_pipeline_result("nonexistent_id")
        assert result is None

    def test_list_pipeline_results(self, ci_cd_tools):
        """测试列出流水线结果"""
        # 创建多个流水线结果
        initial_count = len(ci_cd_tools.list_pipeline_results())

        # Mock and run pipelines
        with patch.object(ci_cd_tools, '_run_command') as mock_run:
            mock_run.return_value = {
                'return_code': 0,
                'logs': ['Success']
            }

            ci_cd_tools.run_pipeline_stage("stage1", ["cmd1"])
            ci_cd_tools.run_pipeline_stage("stage2", ["cmd2"])

        results = ci_cd_tools.list_pipeline_results()
        assert len(results) >= initial_count + 2

