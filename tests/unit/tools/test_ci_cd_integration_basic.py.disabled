    def test_artifacts_handling(self, ci_cd_tools):
        """测试制品处理"""
        # 运行流水线
        with patch.object(ci_cd_tools, '_run_command') as mock_run:
            mock_run.return_value = {
                'return_code': 0,
                'logs': ['Build completed']
            }

            result = ci_cd_tools.run_pipeline_stage("artifacts_test", ["build_cmd"])

        # 添加制品
        result.artifacts["build_output"] = "/path/to/build"
        result.artifacts["test_reports"] = "/path/to/reports"
        result.artifacts["coverage_report"] = "/path/to/coverage"

        # 验证制品被存储
        assert result.artifacts["build_output"] == "/path/to/build"
        assert result.artifacts["test_reports"] == "/path/to/reports"
        assert result.artifacts["coverage_report"] == "/path/to/coverage"
